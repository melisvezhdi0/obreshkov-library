@model IEnumerable<ObreshkovLibrary.Models.ViewModels.StudentFavoriteBookVM>

@{
    Layout = "~/Views/Shared/_StudentLayout.cshtml";
    ViewData["Title"] = "Списък за четене";

    var returnUrl = $"{Context.Request.Path}{Context.Request.QueryString}";
    var sort = Context.Request.Query["sort"].ToString();

    var items = Model ?? Enumerable.Empty<ObreshkovLibrary.Models.ViewModels.StudentFavoriteBookVM>();

    items = sort switch
    {
        "name_desc" => items.OrderByDescending(x => x.Title),
        "date_desc" => items.OrderByDescending(x => x.CreatedOn),
        "date_asc" => items.OrderBy(x => x.CreatedOn),
        _ => items.OrderBy(x => x.Title)
    };

    var groupedItems = items
        .GroupBy(x => string.IsNullOrWhiteSpace(x.CategoryName) ? "Без категория" : x.CategoryName)
        .OrderBy(g => g.Key)
        .ToList();
}

<div style="width:min(1240px, calc(100% - 24px)); margin:28px auto 40px;">

    <section style="background:#ffffff; border:1px solid #d8e1eb; border-radius:24px; padding:26px; margin-bottom:22px;">
        <div style="display:flex; justify-content:space-between; align-items:end; gap:18px; flex-wrap:wrap;">
            <div>
                <h1 style="margin:0; color:#17325c; font-size:2rem; font-weight:900;">Списък за четене</h1>
                <div style="width:62px; height:4px; border-radius:999px; margin-top:10px; background:linear-gradient(90deg,#2563eb 0%,#60a5fa 100%);"></div>
                <div style="margin-top:12px; color:#64748b; font-size:.98rem; font-weight:700;">
                    Запази книги, които искаш да прочетеш по-късно.
                </div>
            </div>

            <form method="get" asp-action="Favorites" style="margin:0;">
                <div style="display:flex; align-items:center; gap:10px; flex-wrap:wrap;">
                    <label for="sort" style="color:#17325c; font-size:.95rem; font-weight:800;">Подреди по</label>
                    <select id="sort"
                            name="sort"
                            onchange="this.form.submit()"
                            style="min-width:220px; height:44px; border:1px solid #d5deea; border-radius:12px; padding:0 14px; background:#f8fbff; color:#17325c; font-size:.95rem; font-weight:700; outline:none;">
                        <option value="name_asc" selected="@(sort == "name_asc" || string.IsNullOrWhiteSpace(sort))">Име (А-Я)</option>
                        <option value="name_desc" selected="@(sort == "name_desc")">Име (Я-А)</option>
                        <option value="date_desc" selected="@(sort == "date_desc")">Най-ново добавени</option>
                        <option value="date_asc" selected="@(sort == "date_asc")">Най-старо добавени</option>
                    </select>
                </div>
            </form>
        </div>
    </section>

    @if (groupedItems.Any())
    {
        @foreach (var group in groupedItems)
        {
            <section style="margin-bottom:24px;">
                <div style="display:flex; align-items:center; gap:12px; margin-bottom:14px;">
                    <h2 style="margin:0; color:#17325c; font-size:1.2rem; font-weight:900;">@group.Key</h2>
                    <div style="height:1px; flex:1; background:#dbe5ef;"></div>
                </div>

                <div style="display:grid; grid-template-columns:repeat(5, minmax(0,1fr)); gap:18px;">
                    @foreach (var item in group)
                    {
                        <div style="background:#ffffff; border:1px solid #d8e1eb; border-radius:22px; overflow:hidden; box-shadow:0 8px 24px rgba(15,23,42,0.04); transition:transform .18s ease, box-shadow .18s ease;"
                             onmouseover="this.style.transform='translateY(-3px)'; this.style.boxShadow='0 14px 30px rgba(15,23,42,0.08)';"
                             onmouseout="this.style.transform='translateY(0)'; this.style.boxShadow='0 8px 24px rgba(15,23,42,0.04)';">

                            <a asp-controller="Catalog"
                               asp-action="StudentDetails"
                               asp-route-id="@item.BookId"
                               style="display:block; text-decoration:none;">
                                <div style="height:250px; border-bottom:1px solid #e7eef6; background:linear-gradient(180deg,#f8fbff 0%,#eef4fa 100%); display:flex; align-items:center; justify-content:center; padding:14px; overflow:hidden;">
                                    @if (!string.IsNullOrWhiteSpace(item.CoverPath))
                                    {
                                        <img src="@item.CoverPath"
                                             alt="@item.Title"
                                             style="max-width:100%; max-height:100%; object-fit:contain; display:block;" />
                                    }
                                    else
                                    {
                                        <div style="width:100%; height:100%; border:2px dashed #cad5e0; border-radius:14px; display:flex; align-items:center; justify-content:center; color:#94a3b8; font-size:.95rem; font-weight:800; background:#f8fbff;">
                                            Няма корица
                                        </div>
                                    }
                                </div>

                                <div style="padding:14px 14px 10px 14px;">
                                    <div style="color:#17325c; font-weight:900; font-size:1rem; line-height:1.35; min-height:44px;">
                                        @item.Title
                                    </div>

                                    <div style="margin-top:6px; color:#64748b; font-size:.93rem; font-weight:700; min-height:22px;">
                                        @item.Author
                                    </div>
                                </div>
                            </a>

                            <div style="padding:0 14px 14px 14px;">
                                <div style="display:flex; justify-content:space-between; align-items:center; gap:10px; margin-bottom:12px; flex-wrap:wrap;">
                                    <span style="display:inline-flex; align-items:center; min-height:32px; padding:0 12px; border-radius:999px; font-size:.84rem; font-weight:900; @(item.IsAvailable ? "background:#e8f7ee; color:#2f7d32; border:1px solid #cfe7d3;" : "background:#f1f5f9; color:#64748b; border:1px solid #d8e1eb;")">
                                        @(item.IsAvailable ? "Налична" : "Не е налична")
                                    </span>

                                    <span style="color:#94a3b8; font-size:.8rem; font-weight:700;">
                                        @item.CreatedOn.ToLocalTime().ToString("dd.MM.yyyy")
                                    </span>
                                </div>

                                <form asp-action="ToggleFavorite" method="post" style="margin:0;">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="bookId" value="@item.BookId" />
                                    <input type="hidden" name="returnUrl" value="@returnUrl" />

                                    <button type="submit"
                                            style="width:100%; min-height:42px; border:1px solid #f0c2c2; border-radius:12px; background:#fff5f5; color:#c81e1e; font-size:.93rem; font-weight:800; cursor:pointer; transition:all .18s ease;"
                                            onmouseover="this.style.background='#feecec'; this.style.transform='translateY(-1px)';"
                                            onmouseout="this.style.background='#fff5f5'; this.style.transform='translateY(0)';">
                                        Премахни от списъка
                                    </button>
                                </form>
                            </div>
                        </div>
                    }
                </div>
            </section>
        }
    }
    else
    {
        <section style="background:#ffffff; border:1px solid #d8e1eb; border-radius:24px; padding:26px;">
            <div style="color:#17325c; font-size:1.08rem; font-weight:900; margin-bottom:8px;">
                Списъкът за четене е празен
            </div>
            <div style="color:#64748b; font-size:.97rem; font-weight:700; line-height:1.7;">
                Когато добавиш книга от страницата с детайли, тя ще се появи тук.
            </div>
        </section>
    }
</div>