@model IEnumerable<ObreshkovLibrary.Models.ViewModels.ReaderNotificationItemVM>
@using ObreshkovLibrary.Models.Enums

@{
    ViewData["Title"] = "Съобщения";
    var returnUrl = $"{Context.Request.Path}{Context.Request.QueryString}";
    var unreadCount = ViewBag.UnreadCount as int? ?? 0;
}

<div style="width:min(1120px, calc(100% - 24px)); margin:26px auto 40px;">

    <section style="background:#ffffff; border:1px solid #dbe4ee; border-radius:24px; overflow:hidden; box-shadow:0 10px 24px rgba(15,23,42,.04);">

        <div style="display:flex; justify-content:space-between; align-items:center; gap:12px; flex-wrap:wrap; padding:18px 22px; background:linear-gradient(180deg,#2f5f93 0%,#315f8f 100%); border-bottom:1px solid #254a70;">
            <div>
                <div style="color:rgba(255,255,255,.82); font-size:.9rem; font-weight:700;">
                    @unreadCount @(unreadCount == 1 ? "непрочетено" : "непрочетени")
                </div>
                <div style="margin-top:4px; color:#ffffff; font-size:1.35rem; font-weight:900;">
                    Съобщения
                </div>
            </div>

            <a asp-controller="ReaderPortal"
               asp-action="Notifications"
               style="display:inline-flex; align-items:center; justify-content:center; height:40px; padding:0 16px; border-radius:12px; background:rgba(255,255,255,.14); color:#ffffff; font-weight:800; text-decoration:none; border:1px solid rgba(255,255,255,.18); transition:all .18s ease;"
               onmouseover="this.style.background='rgba(255,255,255,.22)';"
               onmouseout="this.style.background='rgba(255,255,255,.14)';">
                Виж всички
            </a>
        </div>

        @if (Model.Any())
        {
            <div style="padding:10px 12px 12px 12px; display:flex; flex-direction:column; gap:8px; background:#f8fbff;">
                @foreach (var item in Model)
                {
                    var accentColor = item.Type switch
                    {
                        ReaderNotificationType.OverdueReminder => "#dc2626",
                        ReaderNotificationType.Admin => "#315f8f",
                        ReaderNotificationType.NewCategory => "#2563eb",
                        _ => "#22c55e"
                    };

                    var accentBg = item.Type switch
                    {
                        ReaderNotificationType.OverdueReminder => "#fee2e2",
                        ReaderNotificationType.Admin => "#eaf2fb",
                        ReaderNotificationType.NewCategory => "#eaf2ff",
                        _ => "#ecfdf3"
                    };

                    var borderColor = item.IsRead ? "#e5e7eb" : "#cfe0fb";
                    var bgColor = item.IsRead ? "#ffffff" : "#f8fbff";

                    <div style="display:grid; grid-template-columns:46px minmax(0,1fr) auto; gap:12px; align-items:start; padding:12px 14px; background:@bgColor; border:1px solid @borderColor; border-radius:16px; transition:all .18s ease;"
                         onmouseover="this.style.boxShadow='0 10px 18px rgba(15,23,42,.05)'; this.style.transform='translateY(-1px)';"
                         onmouseout="this.style.boxShadow='none'; this.style.transform='translateY(0)';">

                        <div style="width:46px; height:46px; border-radius:12px; background:@accentBg; color:@accentColor; display:flex; align-items:center; justify-content:center; font-size:1.2rem; font-weight:900;">
                            @if (item.Type == ReaderNotificationType.OverdueReminder)
                            {
                                <span>!</span>
                            }
                            else if (item.Type == ReaderNotificationType.Admin)
                            {
                                <span>i</span>
                            }
                            else if (item.Type == ReaderNotificationType.NewCategory)
                            {
                                <span>+</span>
                            }
                            else
                            {
                                <span>•</span>
                            }
                        </div>

                        <div style="min-width:0;">
                            <div style="display:flex; align-items:center; gap:8px; flex-wrap:wrap;">
                                <div style="color:#17325c; font-size:1rem; font-weight:900; line-height:1.25;">
                                    @item.Title
                                </div>

                                @if (!item.IsRead)
                                {
                                    <span style="display:inline-flex; align-items:center; justify-content:center; height:24px; padding:0 10px; border-radius:999px; background:#eaf2ff; color:#2563eb; font-size:.74rem; font-weight:900;">
                                        НОВО
                                    </span>
                                }
                            </div>

                            <div style="margin-top:5px; color:@(item.Type == ReaderNotificationType.OverdueReminder ? "#b91c1c" : "#475569"); font-size:.96rem; line-height:1.6;">
                                @item.Message
                            </div>
                        </div>

                        <div style="display:flex; flex-direction:column; align-items:end; gap:8px;">
                            <div style="color:#94a3b8; font-size:.82rem; font-weight:800; white-space:nowrap;">
                                @item.CreatedOn.ToString("dd.MM.yyyy")
                            </div>

                            <div style="display:flex; gap:8px; flex-wrap:wrap; justify-content:end;">
                                @if (item.Type == ReaderNotificationType.NewCategory && item.CategoryId.HasValue)
                                {
                                    <a asp-controller="Catalog"
                                       asp-action="ReaderIndex"
                                       asp-route-categoryId="@item.CategoryId.Value"
                                       style="display:inline-flex; align-items:center; justify-content:center; height:36px; padding:0 12px; border-radius:10px; background:#eff6ff; color:#2563eb; border:1px solid #bfdbfe; text-decoration:none; font-size:.84rem; font-weight:800;">
                                        Към категорията
                                    </a>
                                }

                                @if (!item.IsRead)
                                {
                                    <form asp-action="MarkNotificationAsRead" method="post" style="margin:0;">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@item.NotificationId" />
                                        <input type="hidden" name="returnUrl" value="@returnUrl" />
                                        <button type="submit"
                                                style="height:36px; padding:0 12px; border:none; border-radius:10px; background:linear-gradient(180deg,#2563eb 0%,#1d4ed8 100%); color:#ffffff; font-size:.84rem; font-weight:800; box-shadow:0 8px 16px rgba(37,99,235,.16);">
                                            Прочетено
                                        </button>
                                    </form>
                                }
                            </div>
                        </div>

                    </div>
                }
            </div>
        }
        else
        {
            <div style="padding:24px 22px; background:#f8fbff; color:#64748b; font-weight:700;">
                Нямаш съобщения.
            </div>
        }
    </section>
</div>