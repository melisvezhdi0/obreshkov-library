@model ObreshkovLibrary.Models.ViewModels.SchoolNewsFormVM

@{
    ViewData["Title"] = "Добавяне на новина";
}

<div style="width:100%; padding-top:6px; padding-bottom:28px;">

    <div style="margin-bottom:16px;">
        <h2 class="section-title mb-1">Добавяне на новина</h2>
        <div class="accent-line"></div>
    </div>

    <section class="card-soft"
             style="padding:24px; border-radius:22px; background:#FFFFFF; border:1px solid #D9E2EC; box-shadow:0 14px 34px rgba(15,23,42,.06); overflow:visible;">

        <form asp-action="Create" method="post" enctype="multipart/form-data" id="schoolNewsCreateForm" style="margin:0;">
            @Html.AntiForgeryToken()

            <div asp-validation-summary="ModelOnly"
                 class="text-danger"
                 style="margin-bottom:14px; padding:10px 12px; border-radius:12px; background:#FEF2F2; border:1px solid #FECACA;"></div>

            <div style="display:flex; flex-direction:column; gap:18px;">

                <div style="background:linear-gradient(180deg,#F8FAFC 0%, #FDFEFF 100%); border:1px solid #D9E2EC; border-radius:18px; padding:18px;">
                    <div style="font-size:.82rem; text-transform:uppercase; letter-spacing:.04em; font-weight:800; color:#64748B; margin-bottom:14px;">
                        Основна информация
                    </div>

                    <div id="schoolNewsTopGrid"
                         style="display:grid; grid-template-columns:minmax(0,1fr) 320px; gap:16px; align-items:start;">

                        <div style="display:flex; flex-direction:column;">
                            <label asp-for="Title" style="font-weight:800; color:#0F172A; margin-bottom:7px;"></label>
                            <input asp-for="Title"
                                   class="form-control schoolnews-input"
                                   placeholder="Въведи заглавие на новината"
                                   style="height:50px; border-radius:14px; border:1px solid #CBD5E1; background:#FFFFFF; box-shadow:none;" />
                            <span asp-validation-for="Title" class="text-danger" style="margin-top:6px;"></span>
                        </div>

                        <div class="schoolnews-date-wrap" style="display:flex; flex-direction:column;">
                            <label asp-for="PublishedOn" style="font-weight:800; color:#0F172A; margin-bottom:7px;"></label>

                            <div style="position:relative;">
                                <input asp-for="PublishedOn"
                                       type="date"
                                       id="createPublishedOn"
                                       class="form-control schoolnews-input schoolnews-date-input"
                                       style="height:50px; border-radius:14px; border:1px solid #CBD5E1; background:#FFFFFF; box-shadow:none; padding-right:52px;" />

                                <button type="button"
                                        class="schoolnews-date-trigger"
                                        data-target="createPublishedOn"
                                        aria-label="Отвори календара"
                                        style="position:absolute; right:8px; top:50%; transform:translateY(-50%); width:36px; height:36px; border:none; border-radius:10px; background:#EFF6FF; color:#2563EB; display:flex; align-items:center; justify-content:center; transition:all .18s ease; cursor:pointer;">
                                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                                        <rect x="3" y="5" width="18" height="16" rx="2" stroke="currentColor" stroke-width="2"></rect>
                                        <path d="M16 3V7" stroke="currentColor" stroke-width="2" stroke-linecap="round"></path>
                                        <path d="M8 3V7" stroke="currentColor" stroke-width="2" stroke-linecap="round"></path>
                                        <path d="M3 10H21" stroke="currentColor" stroke-width="2" stroke-linecap="round"></path>
                                    </svg>
                                </button>
                            </div>

                            <span asp-validation-for="PublishedOn" class="text-danger" style="margin-top:6px;"></span>
                        </div>
                    </div>

                    <div style="margin-top:16px; display:flex; flex-direction:column;">
                        <label asp-for="Summary" style="font-weight:800; color:#0F172A; margin-bottom:7px;"></label>
                        <textarea asp-for="Summary"
                                  rows="6"
                                  class="form-control schoolnews-input schoolnews-textarea"
                                  placeholder="Добави кратко описание на новината..."
                                  style="border-radius:16px; border:1px solid #CBD5E1; background:#FFFFFF; box-shadow:none; resize:vertical; min-height:150px; padding-top:14px;"></textarea>
                        <span asp-validation-for="Summary" class="text-danger" style="margin-top:6px;"></span>
                    </div>

                    <div id="newsLinkActiveRow"
                         style="display:grid; grid-template-columns:minmax(0,1fr) 190px; gap:16px; align-items:start; margin-top:16px;">

                        <div style="display:flex; flex-direction:column;">
                            <label asp-for="NewsUrl" style="font-weight:800; color:#0F172A; margin-bottom:7px;"></label>
                            <input asp-for="NewsUrl"
                                   class="form-control schoolnews-input"
                                   placeholder="https://..."
                                   style="height:50px; border-radius:14px; border:1px solid #CBD5E1; background:#FFFFFF; box-shadow:none;" />
                            <span asp-validation-for="NewsUrl" class="text-danger" style="margin-top:6px;"></span>
                        </div>

                        <div style="display:flex; flex-direction:column; align-self:start;">
                            <label style="font-weight:800; color:#0F172A; margin-bottom:12px;">Статус</label>

                            <label style="display:flex; align-items:center; gap:10px; min-height:50px; padding:0 14px; border-radius:14px; border:1px solid #D9E2EC; background:#FFFFFF; margin:0; font-weight:800; color:#0F172A; cursor:pointer; transition:all .18s ease;">
                                <input asp-for="IsActive"
                                       type="checkbox"
                                       style="width:18px; height:18px; margin:0;" />
                                <span>@Html.DisplayNameFor(m => m.IsActive)</span>
                            </label>
                        </div>
                    </div>

                    <div style="margin-top:16px; display:flex; flex-direction:column;">
                        <label asp-for="ImageFile" style="font-weight:800; color:#0F172A; margin-bottom:7px;"></label>

                        <input asp-for="ImageFile"
                               type="file"
                               id="createNewsImageFile"
                               accept=".jpg,.jpeg,.png,.webp,image/*"
                               style="display:none;" />

                        <label for="createNewsImageFile"
                               class="schoolnews-file-picker"
                               style="display:flex; align-items:center; gap:12px; min-height:60px; padding:10px 14px; border-radius:16px; border:1px solid #CBD5E1; background:#FFFFFF; cursor:pointer; transition:all .18s ease;">

                            <span class="schoolnews-file-button"
                                  style="display:inline-flex; align-items:center; justify-content:center; min-width:132px; min-height:40px; padding:0 14px; border-radius:12px; background:#EFF6FF; color:#2563EB; font-weight:800; border:1px solid #BFDBFE; transition:all .18s ease;">
                                Избор на файл
                            </span>

                            <span id="createNewsImageFileName"
                                  style="color:#64748B; font-weight:600; line-height:1.4;">
                                Няма избран файл
                            </span>
                        </label>

                        <span asp-validation-for="ImageFile"
                              class="text-danger"
                              style="display:block; margin-top:6px;"></span>
                    </div>
                </div>

                <div id="schoolNewsActions"
                     style="display:flex; justify-content:flex-start; align-items:center; gap:10px; padding-top:2px; flex-wrap:wrap;">

                    <button type="submit"
                            class="schoolnews-action-btn schoolnews-save-btn"
                            style="min-width:138px; min-height:48px; border:none; border-radius:13px; background:linear-gradient(135deg,#3B82F6,#2563EB); color:#FFFFFF; font-weight:800; padding:0 20px; transition:all .18s ease; box-shadow:0 10px 22px rgba(37,99,235,.20);">
                        Запази
                    </button>

                    <a asp-action="Index"
                       class="schoolnews-action-btn schoolnews-back-btn"
                       style="display:inline-flex; align-items:center; justify-content:center; text-decoration:none; min-width:118px; min-height:48px; border-radius:13px; border:1px solid #3B82F6; background:#FFFFFF; color:#2563EB; font-weight:800; padding:0 20px; transition:all .18s ease;">
                        Назад
                    </a>
                </div>
            </div>
        </form>
    </section>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        function applySchoolNewsCreateResponsive() {
            const topGrid = document.getElementById('schoolNewsTopGrid');
            const linkActiveRow = document.getElementById('newsLinkActiveRow');
            const actions = document.getElementById('schoolNewsActions');

            if (window.innerWidth <= 700) {
                if (topGrid) topGrid.style.gridTemplateColumns = '1fr';
                if (linkActiveRow) linkActiveRow.style.gridTemplateColumns = '1fr';
                if (actions) {
                    actions.style.flexDirection = 'column';
                    actions.style.alignItems = 'stretch';
                }
            } else if (window.innerWidth <= 980) {
                if (topGrid) topGrid.style.gridTemplateColumns = '1fr';
                if (linkActiveRow) linkActiveRow.style.gridTemplateColumns = '1fr';
                if (actions) {
                    actions.style.flexDirection = 'row';
                    actions.style.alignItems = 'center';
                }
            } else {
                if (topGrid) topGrid.style.gridTemplateColumns = 'minmax(0,1fr) 320px';
                if (linkActiveRow) linkActiveRow.style.gridTemplateColumns = 'minmax(0,1fr) 190px';
                if (actions) {
                    actions.style.flexDirection = 'row';
                    actions.style.alignItems = 'center';
                }
            }
        }

        function bindDateTrigger(buttonSelector) {
            document.querySelectorAll(buttonSelector).forEach(btn => {
                btn.addEventListener('click', function () {
                    const targetId = this.getAttribute('data-target');
                    const input = document.getElementById(targetId);
                    if (!input) return;

                    if (typeof input.showPicker === 'function') {
                        input.showPicker();
                    } else {
                        input.focus();
                        input.click();
                    }
                });
            });
        }

        function bindFileName(inputId, fileNameId) {
            const input = document.getElementById(inputId);
            const fileName = document.getElementById(fileNameId);

            if (!input || !fileName) return;

            input.addEventListener('change', function () {
                if (this.files && this.files.length > 0) {
                    fileName.textContent = this.files[0].name;
                    fileName.style.color = '#0F172A';
                    fileName.style.fontWeight = '700';
                } else {
                    fileName.textContent = 'Няма избран файл';
                    fileName.style.color = '#64748B';
                    fileName.style.fontWeight = '600';
                }
            });
        }

        applySchoolNewsCreateResponsive();
        bindDateTrigger('.schoolnews-date-trigger');
        bindFileName('createNewsImageFile', 'createNewsImageFileName');

        window.addEventListener('resize', applySchoolNewsCreateResponsive);
    </script>
}