@page
@model ObreshkovLibrary.Areas.Identity.Pages.Account.ForgotPasswordModel

@{
    Layout = null;
    ViewData["Title"] = "Забравена парола";

    bool isAdmin = Model.Input.Role == "Admin";
}

<!DOCTYPE html>
<html lang="bg">
<head>
    <meta charset="utf-8" />
    <title>@ViewData["Title"]</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <partial name="_ValidationScriptsPartial" />

    <style>
        body {
            margin: 0;
            font-family: system-ui, -apple-system, Segoe UI, Roboto, sans-serif;
            background: linear-gradient(180deg, #f8fafc 0%, #eef2f7 100%);
        }

        .wrapper {
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 24px 16px;
        }

        .card {
            width: 100%;
            max-width: 520px;
            background: white;
            border: 1px solid #e2e8f0;
            border-radius: 16px;
            padding: 28px;
            box-shadow: 0 14px 34px rgba(15,23,42,.06);
        }

        .title {
            text-align: center;
            font-size: 2rem;
            font-weight: 800;
            margin: 0;
            color: #0f172a;
        }

        .accent {
            width: 58px;
            height: 3px;
            background: #3b82f6;
            margin: 12px auto 22px auto;
            border-radius: 999px;
        }

        label {
            font-weight: 700;
            display: block;
            margin-bottom: 6px;
        }

        input {
            width: 100%;
            height: 46px;
            border: 1px solid #cbd5e1;
            border-radius: 10px;
            padding: 0 12px;
            margin-bottom: 16px;
        }

        .buttons {
            display: flex;
            gap: 10px;
        }

        .btn-primary {
            flex: 1;
            height: 44px;
            border: none;
            border-radius: 10px;
            background: #2563eb;
            color: white;
            font-weight: 700;
            cursor: pointer;
            transition: .15s;
        }

            .btn-primary:hover {
                background: #1d4ed8;
            }

        .btn-secondary {
            flex: 1;
            height: 44px;
            display: flex;
            align-items: center;
            justify-content: center;
            border-radius: 10px;
            border: 1px solid #cbd5e1;
            text-decoration: none;
            color: #334155;
            font-weight: 600;
            transition: .15s;
        }

            .btn-secondary:hover {
                background: #f8fafc;
            }

        .status {
            margin-bottom: 14px;
            padding: 12px 14px;
            border-radius: 12px;
            border: 1px solid #bfdbfe;
            background: #eff6ff;
            color: #1d4ed8;
            font-weight: 600;
        }

        .subtitle {
            margin-bottom: 18px;
            color: #64748b;
        }
    </style>
</head>

<body>

    <div class="wrapper">

        <div class="card">

            <h1 class="title">Забравена парола</h1>
            <div class="accent"></div>

            @if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
            {
                <div class="status">
                    @Model.StatusMessage
                </div>
            }

            <form method="post">

                @Html.AntiForgeryToken()

                <input asp-for="Input.Role" type="hidden" />

                @if (isAdmin)
                {
                    <div class="subtitle">
                        Въведете служебния имейл за заявка за възстановяване.
                    </div>

                    <label asp-for="Input.Email">Имейл</label>

                    <input asp-for="Input.Email"
                           placeholder="admin@obreshkov.bg" />

                    <span asp-validation-for="Input.Email" class="text-danger"></span>
                }
                else
                {
                    <div class="subtitle">
                        Попълнете данните си за заявка за нова парола.
                    </div>

                    <label asp-for="Input.CardNumber">
                        Номер на читателска карта
                    </label>

                    <input asp-for="Input.CardNumber"
                           placeholder="Само цифри" />

                    <span asp-validation-for="Input.CardNumber" class="text-danger"></span>


                    <label asp-for="Input.PhoneNumber">
                        Телефонен номер
                    </label>

                    <input asp-for="Input.PhoneNumber"
                           placeholder="08XXXXXXXX" />

                    <span asp-validation-for="Input.PhoneNumber" class="text-danger"></span>
                }

                <div class="buttons">

                    <button type="submit"
                            class="btn-primary">
                        Изпрати заявка
                    </button>

                    <a asp-area="Identity"
                       asp-page="/Account/Login"
                       asp-route-role="@Model.Input.Role"
                       class="btn-secondary">
                        Назад
                    </a>

                </div>

            </form>

        </div>

    </div>

</body>
</html>