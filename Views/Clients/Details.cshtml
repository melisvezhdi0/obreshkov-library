@using ObreshkovLibrary.Models
@model ObreshkovLibrary.Models.Client

@{
    ViewData["Title"] = "Читател";
    var loans = ViewBag.ActiveLoans as List<Loan> ?? new List<Loan>();
    var successMessage = TempData["SuccessMessage"] as string;
}

<div class="client-details-page">

    <div class="client-details-header">
        <div>
            <h2 class="section-title mb-1">
                @($"{Model.FirstName} {Model.MiddleName} {Model.LastName}".Replace("  ", " ").Trim())
            </h2>
            <div class="accent-line"></div>
        </div>

        <div class="client-details-actions">
            <a class="btn btn-outline-primary"
               asp-action="Index">
                Назад
            </a>

            <a class="btn btn-accent"
               asp-controller="Loans"
               asp-action="Create"
               asp-route-clientId="@Model.Id">
                Нов заем
            </a>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-lg-4">
            <section class="details-panel card-soft">
                <div class="details-panel-head">
                    <h5 class="section-title mb-0">Данни</h5>
                </div>

                <div class="details-info-list">
                    <div class="details-info-row">
                        <span class="details-label">№ карта</span>
                        <span class="details-value">@Model.CardNumber</span>
                    </div>

                    <div class="details-info-row">
                        <span class="details-label">Име</span>
                        <span class="details-value">@Model.FirstName</span>
                    </div>

                    @if (!string.IsNullOrWhiteSpace(Model.MiddleName))
                    {
                        <div class="details-info-row">
                            <span class="details-label">Презиме</span>
                            <span class="details-value">@Model.MiddleName</span>
                        </div>
                    }

                    <div class="details-info-row">
                        <span class="details-label">Фамилия</span>
                        <span class="details-value">@Model.LastName</span>
                    </div>

                    @if (!string.IsNullOrWhiteSpace(Model.PhoneNumber))
                    {
                        <div class="details-info-row">
                            <span class="details-label">Телефон</span>
                            <span class="details-value">@Model.PhoneNumber</span>
                        </div>
                    }

                    <div class="details-info-row">
                        <span class="details-label">Създаден</span>
                        <span class="details-value">@Model.CreatedOn.ToString("dd.MM.yyyy")</span>
                    </div>

                    <div class="details-info-row">
                        <span class="details-label">Статус</span>
                        <span class="details-value">
                            @if (Model.IsActive)
                            {
                                <span class="status-badge status-active">Активен</span>
                            }
                            else
                            {
                                <span class="status-badge status-inactive">Неактивен</span>
                            }
                        </span>
                    </div>

                    <div class="details-info-row">
                        <span class="details-label">Достъп</span>
                        <span class="details-value">Ученик</span>
                    </div>

                    <div class="details-info-row">
                        <span class="details-label">Парола</span>
                        <span class="details-value">
                            @if (Model.PasswordChangedByStudent)
                            {
                                <span class="status-badge status-active">Сменена</span>
                            }
                            else if (!string.IsNullOrWhiteSpace(Model.LastTemporaryPassword))
                            {
                                <span style="display:inline-block; padding:6px 10px; background:#ffffff; border:1px solid #CBD5E1; border-radius:8px; font-weight:800; letter-spacing:.03em; color:#1F2937;">
                                    @Model.LastTemporaryPassword
                                </span>
                            }
                            else
                            {
                                <span style="color:#64748B;">Няма данни</span>
                            }
                        </span>
                    </div>

                    @if (Model.LastPasswordChangeOn != null)
                    {
                        <div class="details-info-row">
                            <span class="details-label">Последна смяна</span>
                            <span class="details-value">@Model.LastPasswordChangeOn.Value.ToString("dd.MM.yyyy HH:mm")</span>
                        </div>
                    }

                <div class="details-panel-footer">
                    <a class="btn btn-outline-primary w-100"
                       asp-action="Edit"
                       asp-route-id="@Model.Id">
                        Редактиране
                    </a>
                </div>
            </section>
        </div>

        <div class="col-lg-8">
            <section class="details-panel card-soft">
                <div class="details-panel-head details-panel-head-flex">
                    <h5 class="section-title mb-0">Активни заеми</h5>
                    <span class="count-badge">@loans.Count</span>
                </div>

                @if (!loans.Any())
                {
                    <div class="details-empty-state">
                        Няма активни заеми.
                    </div>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table details-table align-middle mb-0">
                            <thead>
                                <tr>
                                    <th>Книга</th>
                                    <th>Автор</th>
                                    <th>Заета на</th>
                                    <th>Срок</th>
                                    <th class="text-end">Действие</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var l in loans)
                                {
                                    <tr>
                                        <td class="details-book-title">@l.BookCopy?.Book?.Title</td>
                                        <td>@l.BookCopy?.Book?.Author</td>
                                        <td>@l.LoanDate.ToString("dd.MM.yyyy")</td>
                                        <td>@l.DueDate.ToString("dd.MM.yyyy")</td>
                                        <td class="text-end">
                                            <button type="button"
                                                    class="btn btn-sm btn-outline-danger"
                                                    data-bs-toggle="modal"
                                                    data-bs-target="#returnModal"
                                                    data-loan-id="@l.Id">
                                                Върни
                                            </button>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </section>
        </div>
    </div>

    <div class="modal fade" id="returnModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">

                <div class="modal-header">
                    <h5 class="modal-title">Потвърждение</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Затвори"></button>
                </div>

                <div class="modal-body">
                    Сигурни ли сте, че книгата е върната в библиотеката?
                </div>

                <div class="modal-footer">
                    <form asp-controller="Loans"
                          asp-action="Return"
                          method="post"
                          style="margin:0; display:flex; justify-content:flex-end; gap:10px; width:100%;">

                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" id="returnLoanId" />

                        <button type="button"
                                data-bs-dismiss="modal"
                                style="min-height:40px; padding:0 1.1rem; border-radius:12px; border:1px solid #CBD5E1; background:#fff; font-weight:700;">
                            Отказ
                        </button>

                        <button type="submit"
                                style="min-height:40px; padding:0 1.2rem; border-radius:12px; border:1px solid #3B82F6; background:#3B82F6; color:#fff; font-weight:800;">
                            Да
                        </button>
                    </form>
                </div>

            </div>
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(successMessage))
    {
        <div id="returnSuccessOverlay"
             style="position:fixed; inset:0; background:rgba(15,23,42,.48); z-index:1200; display:flex; align-items:center; justify-content:center; padding:20px;">
            <div style="width:min(460px, 100%); background:#FFFFFF; border-radius:20px; box-shadow:0 24px 60px rgba(15,23,42,.22); border:1px solid #E2E8F0; overflow:hidden;">

                <div style="padding:18px 20px; border-bottom:1px solid #E5EAF0; background:linear-gradient(180deg,#F8FBFF 0%,#F3F8FF 100%);">
                    <div style="font-size:.8rem; text-transform:uppercase; font-weight:800; color:#6B7280; margin-bottom:4px;">Успешно действие</div>
                    <div style="font-size:1.35rem; font-weight:800; color:#0F172A;">Връщане на книга</div>
                </div>

                <div style="padding:24px 20px; text-align:center; color:#0F172A; font-size:1.05rem; font-weight:700; line-height:1.6;">
                    @successMessage
                </div>

                <div style="padding:0 20px 20px 20px; display:flex; justify-content:center;">
                    <button type="button"
                            id="closeReturnSuccessModal"
                            onmouseover="this.style.background='#EFF6FF'; this.style.borderColor='#3B82F6'; this.style.color='#1D4ED8';"
                            onmouseout="this.style.background='#FFFFFF'; this.style.borderColor='#CBD5E1'; this.style.color='#475569';"
                            style="display:inline-flex; align-items:center; justify-content:center; min-height:46px; padding:0 1.2rem; border-radius:14px; background:#FFFFFF; color:#475569; font-weight:800; border:1px solid #CBD5E1; min-width:120px;">
                        Затвори
                    </button>
                </div>
            </div>
        </div>
    }

</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const returnButtons = document.querySelectorAll('[data-loan-id]');
            const returnLoanIdInput = document.getElementById('returnLoanId');

            returnButtons.forEach(btn => {
                btn.addEventListener('click', function () {
                    const loanId = this.getAttribute('data-loan-id');
                    if (returnLoanIdInput) {
                        returnLoanIdInput.value = loanId;
                    }
                });
            });

            const successOverlay = document.getElementById('returnSuccessOverlay');
            const closeSuccessBtn = document.getElementById('closeReturnSuccessModal');

            if (closeSuccessBtn && successOverlay) {
                closeSuccessBtn.addEventListener('click', function () {
                    successOverlay.style.display = 'none';
                });

                successOverlay.addEventListener('click', function (e) {
                    if (e.target === successOverlay) {
                        successOverlay.style.display = 'none';
                    }
                });
            }
        });
    </script>
}