<!DOCTYPE html>
<html lang="bg">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - ObreshkovLibrary</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/ObreshkovLibrary.styles.css" asp-append-version="true" />

    <style>
        html, body {
            min-height: 100%;
        }

            body.public-school-body {
                margin: 0;
                min-height: 100vh;
                display: flex;
                flex-direction: column;
                background: #eef3f8;
                color: #243247;
            }

        .public-school-body main {
            flex: 1 0 auto;
        }

        .public-school-nav {
            position: sticky;
            top: 0;
            z-index: 1000;
            background: linear-gradient(180deg, rgba(255,255,255,0.96) 0%, rgba(248,251,255,0.96) 100%);
            border-bottom: 1px solid #cfd9e5;
            box-shadow: 0 6px 18px rgba(15, 23, 42, 0.05);
        }

        .public-school-nav-container {
            width: min(1240px, calc(100% - 32px));
            min-height: 78px;
            margin: 0 auto;
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 18px;
        }

        .public-school-brand {
            display: inline-flex;
            align-items: center;
            gap: 14px;
            text-decoration: none;
            min-width: 0;
        }

        .public-school-brand-logo {
            width: 46px;
            height: 46px;
            border-radius: 14px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            background: linear-gradient(180deg, #5ea7ee 0%, #3f86e7 100%);
            color: white;
            font-size: 1.2rem;
            box-shadow: 0 10px 18px rgba(75, 149, 234, 0.18);
            flex: 0 0 auto;
        }

        .public-school-brand-text {
            display: flex;
            flex-direction: column;
            min-width: 0;
        }

        .public-school-brand-title {
            color: #23344c;
            font-size: 1.18rem;
            line-height: 1.1;
            font-weight: 900;
            white-space: nowrap;
        }

        .public-school-brand-subtitle {
            color: #70839a;
            font-size: .86rem;
            font-weight: 700;
            margin-top: 2px;
            white-space: nowrap;
        }

        .public-school-links {
            display: flex;
            align-items: center;
            gap: 8px;
            flex-wrap: wrap;
            justify-content: flex-end;
        }

        .public-school-link,
        .public-school-login {
            min-height: 44px;
            padding: 0 16px;
            border-radius: 14px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            text-decoration: none;
            font-weight: 800;
            transition: .18s ease;
        }

        .public-school-link {
            color: #334c69;
            background: transparent;
            border: 1px solid transparent;
        }

            .public-school-link:hover {
                color: #1f3550;
                background: #edf4fb;
                border-color: #d5e0ec;
                transform: translateY(-1px);
            }

        .public-school-login {
            color: #fff;
            background: linear-gradient(180deg, #5ea7ee 0%, #3f86e7 100%);
            border: 1px solid #4a8fe9;
            box-shadow: 0 10px 18px rgba(75, 149, 234, 0.18);
        }

            .public-school-login:hover {
                color: #fff;
                transform: translateY(-1px);
                background: linear-gradient(180deg, #539de8 0%, #357dde 100%);
            }

        @@media (max-width: 980px) {
            .public-school-nav-container {
                width: min(100%, calc(100% - 18px));
                min-height: auto;
                padding: 12px 0;
                flex-direction: column;
                align-items: stretch;
            }

            .public-school-brand-title,
            .public-school-brand-subtitle {
                white-space: normal;
            }

            .public-school-links {
                width: 100%;
                justify-content: stretch;
            }

            .public-school-link,
            .public-school-login {
                flex: 1 1 calc(50% - 8px);
            }
        }

        @@media (max-width: 576px) {
            .public-school-link,
            .public-school-login {
                flex: 1 1 100%;
            }
        }
    </style>
</head>
<body class="public-school-body">
    <header>
        <partial name="_PublicNavPartial" />
    </header>

    <main>
        @RenderBody()
    </main>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>