@model ObreshkovLibrary.Models.ViewModels.CatalogIndexVM
@using ObreshkovLibrary.Models
@using System.Linq
@using System.Collections.Generic

@{
    Layout = "~/Views/Shared/_StudentLayout.cshtml";
    ViewData["Title"] = "Каталог";

    var categories = Model.Categories ?? new List<Category>();
    var favoriteBookIds = ViewBag.FavoriteBookIds as List<int> ?? new List<int>();

    var rootCategories = categories
        .Where(c => c.ParentCategoryId == null)
        .OrderBy(c => c.Name)
        .ToList();

    var openIds = new HashSet<int>();

    if (Model.SelectedCategoryId.HasValue)
    {
        var current = categories.FirstOrDefault(c => c.Id == Model.SelectedCategoryId.Value);
        while (current != null)
        {
            openIds.Add(current.Id);
            current = current.ParentCategoryId.HasValue
                ? categories.FirstOrDefault(c => c.Id == current.ParentCategoryId.Value)
                : null;
        }
    }

    string GetCover(Book book)
    {
        if (string.IsNullOrWhiteSpace(book.CoverPath))
            return "";

        return book.CoverPath.StartsWith("/")
            ? Url.Content("~" + book.CoverPath)
            : Url.Content("~/" + book.CoverPath.TrimStart('/'));
    }

    List<Category> GetChildren(int parentId)
        => categories.Where(c => c.ParentCategoryId == parentId).OrderBy(c => c.Name).ToList();

    var currentReturnUrl = $"{Context.Request.Path}{Context.Request.QueryString}";
}

<div style="width:100%; margin:0; padding:0; background:
    radial-gradient(circle at 12% 16%, rgba(37,99,235,.035), transparent 24%),
    radial-gradient(circle at 88% 10%, rgba(59,130,246,.03), transparent 22%),
    linear-gradient(180deg, #f8fafc 0%, #f4f7fb 100%);">
    <div style="width:100%; margin:0; padding:0;">

        <div style="display:grid; grid-template-columns:286px minmax(0,1fr); min-height:calc(100vh - 78px); border-top:1px solid #e5e7eb;">

            <aside style="background:linear-gradient(180deg,#f8fafc 0%,#f3f6fb 100%); border-right:1px solid #e2e8f0; min-width:0;">
                <div style="position:sticky; top:0; height:calc(100vh - 78px); overflow-y:auto; overflow-x:hidden;">

                    <div style="padding:22px 18px 16px 18px; border-bottom:1px solid #e5e7eb; background:rgba(248,250,252,.97); backdrop-filter:blur(8px);">
                        <div style="color:#64748b; font-size:.76rem; font-weight:800; letter-spacing:.08em; text-transform:uppercase;">
                            Каталог
                        </div>

                        <h1 style="margin:10px 0 0 0; color:#17325c; font-size:1.92rem; font-weight:900; line-height:1.04;">
                            Книги
                        </h1>

                        <p style="margin:10px 0 0 0; color:#64748b; font-size:.94rem; font-weight:700; line-height:1.6;">
                            Разгледай по категория.
                        </p>
                    </div>

                    <div style="padding:12px;">
                        <a asp-controller="Catalog"
                           asp-action="StudentIndex"
                           asp-route-search="@Model.Search"
                           asp-route-sort="@Model.Sort"
                           style="display:flex; align-items:center; gap:10px; padding:13px 14px; border-radius:14px; text-decoration:none; font-weight:900; color:@(Model.SelectedCategoryId == null ? "#1d4ed8" : "#334155"); background:@(Model.SelectedCategoryId == null ? "#eef4ff" : "#ffffff"); border:1px solid @(Model.SelectedCategoryId == null ? "#dbe7fb" : "#e5e7eb"); margin-bottom:10px; box-shadow:@(Model.SelectedCategoryId == null ? "0 8px 18px rgba(37,99,235,.08)" : "0 2px 8px rgba(15,23,42,.025)"); transition:all .18s ease;"
                           onmouseover="this.style.background='#f3f6fa'; this.style.borderColor='#dbe7fb'; this.style.color='#1d4ed8';"
                           onmouseout="this.style.background='@(Model.SelectedCategoryId == null ? "#eef4ff" : "#ffffff")'; this.style.borderColor='@(Model.SelectedCategoryId == null ? "#dbe7fb" : "#e5e7eb")'; this.style.color='@(Model.SelectedCategoryId == null ? "#1d4ed8" : "#334155")';">
                            <span style="width:10px; height:10px; border-radius:999px; background:@(Model.SelectedCategoryId == null ? "#2563eb" : "#cbd5e1");"></span>
                            <span>Всички книги</span>
                        </a>

                        <div style="display:flex; flex-direction:column; gap:8px;">
                            @foreach (var root in rootCategories)
                            {
                                var children = GetChildren(root.Id);
                                var open = openIds.Contains(root.Id);
                                var selected = Model.SelectedCategoryId == root.Id;

                                <div style="border-radius:15px; background:#ffffff; border:1px solid #e7edf4; overflow:hidden; box-shadow:0 2px 10px rgba(15,23,42,.022); transition:border-color .18s ease, box-shadow .18s ease;"
                                     onmouseover="this.style.borderColor='#dbe4ee'; this.style.boxShadow='0 8px 18px rgba(15,23,42,.045)';"
                                     onmouseout="this.style.borderColor='#e7edf4'; this.style.boxShadow='0 2px 10px rgba(15,23,42,.022)';">

                                    <div style="display:flex; align-items:center; gap:8px; padding:8px;">
                                        @if (children.Any())
                                        {
                                            <button type="button"
                                                    class="tree-toggle-btn"
                                                    data-target="student-cat-@root.Id"
                                                    style="width:30px; height:30px; min-width:30px; border:none; border-radius:9px; background:@(open ? "#e8f0ff" : "#f1f5f9"); color:#2563eb; font-weight:900; cursor:pointer; transition:all .18s ease;"
                                                    onmouseover="this.style.background='#e8f0ff';"
                                                    onmouseout="this.style.background='@(open ? "#e8f0ff" : "#f1f5f9")';">
                                                <span class="tree-plus" style="display:@(open ? "none" : "inline")">+</span>
                                                <span class="tree-minus" style="display:@(open ? "inline" : "none")">−</span>
                                            </button>
                                        }
                                        else
                                        {
                                            <span style="width:30px; height:30px; min-width:30px; border-radius:9px; background:#f1f5f9; display:inline-flex; align-items:center; justify-content:center; color:#cbd5e1; font-weight:900;">•</span>
                                        }

                                        <a asp-controller="Catalog"
                                           asp-action="StudentIndex"
                                           asp-route-categoryId="@root.Id"
                                           asp-route-search="@Model.Search"
                                           asp-route-sort="@Model.Sort"
                                           style="flex:1; display:block; padding:9px 10px; border-radius:10px; text-decoration:none; font-size:.93rem; font-weight:900; color:@(selected ? "#1d4ed8" : "#334155"); background:@(selected ? "#eef4ff" : "transparent"); border-left:4px solid @(selected ? "#2563eb" : "transparent"); transition:all .18s ease;"
                                           onmouseover="this.style.background='#f3f6fa'; this.style.color='#1d4ed8'; this.style.borderLeftColor='#2563eb';"
                                           onmouseout="this.style.background='@(selected ? "#eef4ff" : "transparent")'; this.style.color='@(selected ? "#1d4ed8" : "#334155")'; this.style.borderLeftColor='@(selected ? "#2563eb" : "transparent")';">
                                            @root.Name
                                        </a>
                                    </div>

                                    @if (children.Any())
                                    {
                                        <div id="student-cat-@root.Id" style="display:@(open ? "block" : "none"); padding:0 8px 8px 8px;">
                                            <div style="margin-left:38px; display:flex; flex-direction:column; gap:6px;">
                                                @foreach (var child in children)
                                                {
                                                    var selectedChild = Model.SelectedCategoryId == child.Id;

                                                    <a asp-controller="Catalog"
                                                       asp-action="StudentIndex"
                                                       asp-route-categoryId="@child.Id"
                                                       asp-route-search="@Model.Search"
                                                       asp-route-sort="@Model.Sort"
                                                       style="display:block; padding:8px 10px; border-radius:10px; text-decoration:none; font-size:.82rem; font-weight:800; color:@(selectedChild ? "#1d4ed8" : "#52667d"); background:@(selectedChild ? "#eef4ff" : "#f8fafc"); transition:all .18s ease;"
                                                       onmouseover="this.style.background='#f1f5f9'; this.style.color='#1d4ed8';"
                                                       onmouseout="this.style.background='@(selectedChild ? "#eef4ff" : "#f8fafc")'; this.style.color='@(selectedChild ? "#1d4ed8" : "#52667d")';">
                                                        @child.Name
                                                    </a>
                                                }
                                            </div>
                                        </div>
                                    }
                                </div>
                            }
                        </div>
                    </div>
                </div>
            </aside>

            <section style="padding:24px 28px; min-width:0;">
                <section style="border:1px solid #e3e8ef; border-radius:18px; background:rgba(255,255,255,.95); padding:14px; margin-bottom:22px; box-shadow:0 10px 24px rgba(15,23,42,.04);">
                    <form method="get"
                          asp-action="StudentIndex"
                          style="display:grid; grid-template-columns:minmax(0,1fr) 220px 120px; gap:12px;">

                        <input type="hidden" name="categoryId" value="@Model.SelectedCategoryId" />

                        <div style="position:relative;">
                            <span style="position:absolute; left:16px; top:50%; transform:translateY(-50%); color:#94a3b8; display:flex; align-items:center; pointer-events:none;">
                                <svg xmlns="http://www.w3.org/2000/svg"
                                     width="20"
                                     height="20"
                                     fill="none"
                                     stroke="currentColor"
                                     stroke-width="2"
                                     stroke-linecap="round"
                                     stroke-linejoin="round"
                                     viewBox="0 0 24 24">
                                    <circle cx="11" cy="11" r="7"></circle>
                                    <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
                                </svg>
                            </span>

                            <input name="search"
                                   value="@Model.Search"
                                   placeholder="Търси по заглавие, автор, разказ, клас, жанр или категория..."
                                   style="width:100%; height:50px; border-radius:14px; border:1px solid #dbe4ee; padding:0 48px 0 46px; font-weight:800; color:#0f172a; background:#ffffff; outline:none;"
                                   onfocus="this.style.borderColor='#bfd4ff'; this.style.boxShadow='0 0 0 4px rgba(37,99,235,.08)';"
                                   onblur="this.style.borderColor='#dbe4ee'; this.style.boxShadow='none';" />

                            @if (!string.IsNullOrWhiteSpace(Model.Search))
                            {
                                <a asp-controller="Catalog"
                                   asp-action="StudentIndex"
                                   asp-route-categoryId="@Model.SelectedCategoryId"
                                   asp-route-sort="@Model.Sort"
                                   style="position:absolute; right:14px; top:50%; transform:translateY(-50%); width:26px; height:26px; border-radius:999px; display:flex; align-items:center; justify-content:center; color:#94a3b8; text-decoration:none; font-size:1rem; font-weight:900; transition:all .18s ease;"
                                   onmouseover="this.style.background='#f1f5f9'; this.style.color='#475569';"
                                   onmouseout="this.style.background='transparent'; this.style.color='#94a3b8';"
                                   title="Изчисти търсенето">
                                    ×
                                </a>
                            }
                        </div>

                        <select name="sort"
                                style="height:50px; border-radius:14px; border:1px solid #dbe4ee; padding:0 14px; font-weight:900; color:#0f172a; background:#ffffff; outline:none;"
                                onfocus="this.style.borderColor='#bfd4ff'; this.style.boxShadow='0 0 0 4px rgba(37,99,235,.08)';"
                                onblur="this.style.borderColor='#dbe4ee'; this.style.boxShadow='none';">
                            <option value="date_desc" selected="@(Model.Sort == "date_desc")">Най-нови първо</option>
                            <option value="date_asc" selected="@(Model.Sort == "date_asc")">Най-стари първо</option>
                            <option value="name_asc" selected="@(Model.Sort == "name_asc")">Име А-Я</option>
                            <option value="name_desc" selected="@(Model.Sort == "name_desc")">Име Я-А</option>
                        </select>

                        <button type="submit"
                                style="border:none; border-radius:14px; background:linear-gradient(180deg,#2563eb 0%,#1d4ed8 100%); color:#ffffff; font-weight:900; cursor:pointer; box-shadow:0 10px 20px rgba(37,99,235,.18); transition:all .18s ease;"
                                onmouseover="this.style.transform='translateY(-1px)'; this.style.boxShadow='0 14px 24px rgba(37,99,235,.24)';"
                                onmouseout="this.style.transform='translateY(0)'; this.style.boxShadow='0 10px 20px rgba(37,99,235,.18)';">
                            Приложи
                        </button>
                    </form>
                </section>

                <section style="border:1px solid #e3e8ef; border-radius:18px; background:rgba(255,255,255,.97); overflow:hidden; box-shadow:0 10px 24px rgba(15,23,42,.04);">
                    <div style="padding:22px 22px 18px 22px; border-bottom:1px solid #e5e7eb;">
                        <h2 style="margin:0; font-size:2rem; font-weight:900; color:#17325c; line-height:1.05;">
                            @Model.SelectedCategoryName
                        </h2>
                        <div style="width:60px; height:4px; border-radius:999px; background:linear-gradient(90deg,#2563eb 0%,#60a5fa 100%); margin-top:10px;"></div>
                        <div style="margin-top:10px; color:#64748b; font-size:.95rem; font-weight:700;">
                            Открий книги по категория, автор или ключова дума.
                        </div>
                    </div>

                    @if (Model.Books != null && Model.Books.Any())
                    {
                        <div style="padding:20px; display:grid; grid-template-columns:repeat(4, minmax(0,1fr)); gap:18px;">
                            @foreach (var book in Model.Books)
                            {
                                var cover = GetCover(book);
                                var isInReadingList = favoriteBookIds.Contains(book.Id);

                                <div style="position:relative; display:flex; flex-direction:column; border-radius:16px; padding:12px; background:#ffffff; border:1px solid #e6edf5; box-shadow:0 6px 16px rgba(15,23,42,.035); transition:all .18s ease;"
                                     onmouseover="this.style.transform='translateY(-4px)'; this.style.boxShadow='0 14px 26px rgba(15,23,42,.08)'; this.style.borderColor='#d7e4ff'; this.querySelector('.overlay').style.opacity='1';"
                                     onmouseout="this.style.transform='translateY(0)'; this.style.boxShadow='0 6px 16px rgba(15,23,42,.035)'; this.style.borderColor='#e6edf5'; this.querySelector('.overlay').style.opacity='0';">

                                    <form asp-controller="StudentPortal"
                                          asp-action="ToggleFavorite"
                                          method="post"
                                          style="position:absolute; top:10px; right:10px; z-index:3; margin:0;">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="bookId" value="@book.Id" />
                                        <input type="hidden" name="returnUrl" value="@currentReturnUrl" />

                                        <button type="submit"
                                                title="@(isInReadingList ? "Премахни от списъка за четене" : "Добави в списъка за четене")"
                                                aria-label="@(isInReadingList ? "Премахни от списъка за четене" : "Добави в списъка за четене")"
                                                style="width:38px; height:38px; border:1px solid #d7e3f4; border-radius:12px; background:@(isInReadingList ? "linear-gradient(180deg,#eef4ff 0%,#e8f1ff 100%)" : "rgba(255,255,255,.96)"); color:#2563eb; display:flex; align-items:center; justify-content:center; cursor:pointer; box-shadow:0 8px 18px rgba(15,23,42,.10); transition:all .18s ease;"
                                                onmouseover="this.style.transform='translateY(-1px) scale(1.03)';"
                                                onmouseout="this.style.transform='translateY(0) scale(1)';">
                                            @if (isInReadingList)
                                            {
                                                <svg xmlns="http://www.w3.org/2000/svg"
                                                     width="16"
                                                     height="16"
                                                     viewBox="0 0 16 16"
                                                     fill="currentColor"
                                                     style="display:block;">
                                                    <path d="M2 2a2 2 0 0 1 2-2h7a1 1 0 0 1 1 1v13l-4-2-4 2V2z" />
                                                </svg>
                                            }
                                            else
                                            {
                                                <svg xmlns="http://www.w3.org/2000/svg"
                                                     width="16"
                                                     height="16"
                                                     viewBox="0 0 16 16"
                                                     fill="currentColor"
                                                     style="display:block;">
                                                    <path d="M2 1.5A1.5 1.5 0 0 1 3.5 0h7A1.5 1.5 0 0 1 12 1.5V14l-5-2.5L2 14V1.5zM3.5 1a.5.5 0 0 0-.5.5v10.691l4-2 4 2V1.5a.5.5 0 0 0-.5-.5h-7z" />
                                                </svg>
                                            }
                                        </button>
                                    </form>

                                    <a asp-controller="Catalog"
                                       asp-action="StudentDetails"
                                       asp-route-id="@book.Id"
                                       style="text-decoration:none; color:inherit; display:flex; flex-direction:column;">

                                        <div style="height:210px; border-radius:12px; overflow:hidden; position:relative; display:flex; align-items:center; justify-content:center; background:#f7fafd; padding:8px;">
                                            @if (!string.IsNullOrEmpty(cover))
                                            {
                                                <img src="@cover"
                                                     alt="@book.Title"
                                                     style="width:100%; height:100%; object-fit:contain; display:block; transition:transform .18s ease;"
                                                     onmouseover="this.style.transform='scale(1.02)';"
                                                     onmouseout="this.style.transform='scale(1)';" />
                                            }
                                            else
                                            {
                                                <div style="width:100%; height:100%; border:2px dashed #d7dfeb; border-radius:10px; display:flex; align-items:center; justify-content:center; color:#94a3b8; font-size:.82rem; font-weight:800;">
                                                    Няма корица
                                                </div>
                                            }

                                            <div class="overlay"
                                                 style="position:absolute; inset:0; background:rgba(37,99,235,.72); display:flex; align-items:center; justify-content:center; font-weight:900; color:#ffffff; letter-spacing:.02em; font-size:.85rem; opacity:0; transition:.2s;">
                                                Виж
                                            </div>
                                        </div>

                                        <div title="@book.Title"
                                             style="margin-top:10px; font-weight:900; font-size:.95rem; color:#0f172a; line-height:1.38; min-height:2.7em; overflow:hidden; display:-webkit-box; -webkit-line-clamp:2; -webkit-box-orient:vertical; text-overflow:ellipsis;">
                                            @book.Title
                                        </div>

                                        <div title="@book.Author"
                                             style="margin-top:5px; font-size:.88rem; font-weight:700; color:#8a9ab0; white-space:nowrap; overflow:hidden; text-overflow:ellipsis;">
                                            @book.Author
                                        </div>
                                    </a>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <div style="padding:26px 22px; color:#64748b; font-size:1rem; font-weight:700;">
                            Няма намерени книги за избраните критерии.
                        </div>
                    }
                </section>
            </section>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.querySelectorAll(".tree-toggle-btn").forEach(btn => {
            btn.addEventListener("click", () => {
                const target = document.getElementById(btn.dataset.target);
                const plus = btn.querySelector(".tree-plus");
                const minus = btn.querySelector(".tree-minus");

                if (target.style.display === "none") {
                    target.style.display = "block";
                    plus.style.display = "none";
                    minus.style.display = "inline";
                } else {
                    target.style.display = "none";
                    plus.style.display = "inline";
                    minus.style.display = "none";
                }
            });
        });
    </script>
}