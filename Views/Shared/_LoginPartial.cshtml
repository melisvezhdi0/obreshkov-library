@using Microsoft.AspNetCore.Identity
@inject SignInManager<IdentityUser> SignInManager
@inject UserManager<IdentityUser> UserManager

<style>
    .admin-profile-wrap {
        margin-left: 10px;
    }

    .admin-profile-toggle {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 38px;
        height: 38px;
        border-radius: 12px;
        background: #E5E7EB;
        border: 1px solid #D1D5DB;
        padding: 0 !important;
        transition: background-color .18s ease, transform .18s ease;
    }

        .admin-profile-toggle:hover {
            background: #DDE3EA;
            transform: translateY(-1px);
        }

        .admin-profile-toggle::after {
            display: none !important;
        }

    .admin-profile-menu {
        width: max-content;
        min-width: 0;
        margin-top: 12px;
        padding: 6px;
        border-radius: 14px;
        border: 1px solid #D9E0E7;
        background: #fff;
        box-shadow: 0 14px 30px rgba(15,23,42,0.10);
    }

        .admin-profile-menu::before {
            content: "";
            position: absolute;
            top: -7px;
            right: 14px;
            width: 12px;
            height: 12px;
            background: #fff;
            border-top: 1px solid #D9E0E7;
            border-left: 1px solid #D9E0E7;
            transform: rotate(45deg);
        }

    .admin-profile-item {
        display: block;
        padding: 10px 14px;
        border-radius: 10px;
        font-weight: 700;
        color: #1F2937 !important;
        white-space: nowrap;
        transition: background-color .18s ease, color .18s ease;
        text-decoration: none;
    }

        .admin-profile-item:hover {
            background: #F3F7FC;
            color: #2563EB !important;
        }

    @@media (hover:hover) and (pointer:fine) {
        .admin-profile-wrap:hover > .dropdown-menu {
            display: block;
        }
    }
</style>

<ul class="navbar-nav">
    @if (SignInManager.IsSignedIn(User))
    {
        @if (User.IsInRole("Admin"))
        {
            <li class="nav-item dropdown admin-profile-wrap">
                <a class="nav-link dropdown-toggle admin-profile-toggle"
                   href="/Admin/Profile"
                   id="adminProfileDropdown"
                   role="button"
                   data-bs-toggle="dropdown"
                   aria-expanded="false"
                   title="Профил">

                    <svg xmlns="http://www.w3.org/2000/svg"
                         viewBox="0 0 24 24"
                         width="20"
                         height="20"
                         fill="#7a7a7a"
                         aria-hidden="true">
                        <path d="M12 12c2.761 0 5-2.462 5-5.5S14.761 1 12 1 7 3.462 7 6.5 9.239 12 12 12Zm0 2c-4.418 0-8 2.91-8 6.5 0 .828.672 1.5 1.5 1.5h13c.828 0 1.5-.672 1.5-1.5 0-3.59-3.582-6.5-8-6.5Z" />
                    </svg>
                </a>

                <ul class="dropdown-menu dropdown-menu-end admin-profile-menu">
                    <li>
                        <form asp-area="Identity"
                              asp-page="/Account/Logout"
                              asp-route-returnUrl="@Url.Action("Index", "Home", new { area = "" })"
                              style="margin:0;">
                            <button type="submit"
                                    class="dropdown-item admin-profile-item">
                                Изход
                            </button>
                        </form>
                    </li>
                </ul>
            </li>
        }
        else
        {
            <li class="nav-item">
                <form asp-area="Identity"
                      asp-page="/Account/Logout"
                      asp-route-returnUrl="@Url.Action("Index", "Home", new { area = "" })"
                      style="margin:0;">
                    <button type="submit"
                            class="nav-link btn btn-link text-dark border-0"
                            style="font-weight:700; text-decoration:none;">
                        Изход
                    </button>
                </form>
            </li>
        }
    }
    else
    {
        <li class="nav-item">
            <a class="nav-link text-dark"
               id="login"
               asp-area="Identity"
               asp-page="/Account/Login">
                Вход
            </a>
        </li>
    }
</ul>