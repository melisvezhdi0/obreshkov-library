@model ObreshkovLibrary.Models.ViewModels.RaederChangePasswordVM

@{
    ViewData["Title"] = "Смяна на парола";
}

<div style="width:100%; max-width:650px; margin:0 auto; padding-top:6px;">
    <div style="margin-bottom:16px;">
        <h2 class="section-title mb-1">Смяна на парола</h2>
        <div class="accent-line"></div>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div style="margin-bottom:16px; padding:12px 14px; border:1px solid #bbf7d0; background:#ecfdf5; color:#166534; border-radius:12px;">
            @TempData["SuccessMessage"]
        </div>
    }

    <div class="card-soft" style="padding:20px; margin-top:10px;">
        <form asp-action="ChangePassword" method="post" style="margin:0;">
            @Html.AntiForgeryToken()

            <div asp-validation-summary="ModelOnly" class="text-danger" style="margin-bottom:14px;"></div>

            <div style="display:flex; flex-direction:column; gap:14px;">
                <div>
                    <label asp-for="CurrentPassword" style="font-weight:700; margin-bottom:6px; display:block;">Текуща парола</label>
                    <input asp-for="CurrentPassword" class="form-control"
                           style="min-height:46px; border-radius:12px; border:1px solid #CBD5E1;" />
                    <span asp-validation-for="CurrentPassword" class="text-danger"></span>
                </div>

                <div>
                    <label asp-for="NewPassword" style="font-weight:700; margin-bottom:6px; display:block;">Нова парола</label>
                    <input asp-for="NewPassword" class="form-control"
                           style="min-height:46px; border-radius:12px; border:1px solid #CBD5E1;" />
                    <span asp-validation-for="NewPassword" class="text-danger"></span>
                </div>

                <div>
                    <label asp-for="ConfirmPassword" style="font-weight:700; margin-bottom:6px; display:block;">Потвърди паролата</label>
                    <input asp-for="ConfirmPassword" class="form-control"
                           style="min-height:46px; border-radius:12px; border:1px solid #CBD5E1;" />
                    <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
                </div>

                <div style="padding-top:8px;">
                    <button type="submit"
                            style="min-width:170px; height:46px; border:none; background:#2563eb; color:#ffffff; font-weight:800; border-radius:10px;">
                        Запази
                    </button>
                </div>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}