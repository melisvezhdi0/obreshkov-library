@model IEnumerable<ObreshkovLibrary.Models.PasswordResetRequest>

@{
    ViewData["Title"] = "Заявки за забравена парола";
}

<div style="width:100%; padding-top:6px;">
    <div style="margin-bottom:16px;">
        <h2 class="section-title mb-1">Заявки за забравена парола</h2>
        <div class="accent-line"></div>
    </div>

    @if (TempData["ResetError"] != null)
    {
        <div style="margin-bottom:16px; padding:12px 14px; border:1px solid #fecaca; background:#fef2f2; color:#b91c1c; border-radius:12px;">
            @TempData["ResetError"]
        </div>
    }

    <div class="card-soft" style="padding:20px; margin-top:10px;">
        <div style="overflow-x:auto;">
            <table style="width:100%; border-collapse:separate; border-spacing:0;">
                <thead>
                    <tr style="background:#f8fbff;">
                        <th style="padding:14px; text-align:left; border-bottom:1px solid #dbe5ef;">Читател</th>
                        <th style="padding:14px; text-align:left; border-bottom:1px solid #dbe5ef;">Карта</th>
                        <th style="padding:14px; text-align:left; border-bottom:1px solid #dbe5ef;">Телефон</th>
                        <th style="padding:14px; text-align:left; border-bottom:1px solid #dbe5ef;">Дата</th>
                        <th style="padding:14px; text-align:left; border-bottom:1px solid #dbe5ef;">Статус</th>
                        <th style="padding:14px; text-align:left; border-bottom:1px solid #dbe5ef;">Действие</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        var fullName = item.reader != null
                        ? $"{item.reader.FirstName} {item.reader.LastName}"
                        : "-";

                        <tr>
                            <td style="padding:14px; border-bottom:1px solid #edf2f7;">@fullName</td>
                            <td style="padding:14px; border-bottom:1px solid #edf2f7;">@item.CardNumber</td>
                            <td style="padding:14px; border-bottom:1px solid #edf2f7;">@item.PhoneNumber</td>
                            <td style="padding:14px; border-bottom:1px solid #edf2f7;">@item.RequestedOn.ToString("dd.MM.yyyy HH:mm")</td>
                            <td style="padding:14px; border-bottom:1px solid #edf2f7;">
                                @if (item.IsCompleted)
                                {
                                    <span style="display:inline-block; padding:6px 10px; background:#ecfdf5; color:#166534; border:1px solid #bbf7d0; border-radius:999px; font-weight:700;">
                                        Изпълнена
                                    </span>
                                }
                                else
                                {
                                    <span style="display:inline-block; padding:6px 10px; background:#eff6ff; color:#1d4ed8; border:1px solid #bfdbfe; border-radius:999px; font-weight:700;">
                                        Чака
                                    </span>
                                }
                            </td>
                            <td style="padding:14px; border-bottom:1px solid #edf2f7;">
                                @if (!item.IsCompleted)
                                {
                                    <form asp-action="GenerateTemporaryPassword" method="post" data-gate="1" style="margin:0;">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@item.Id" />
                                        <button type="submit"
                                                style="min-width:180px; height:40px; border:none; background:#2563eb; color:#fff; font-weight:800; border-radius:10px;">
                                            Генерирай парола
                                        </button>
                                    </form>
                                }
                                else
                                {
                                    <span style="color:#64748b;">Готово</span>
                                }
                            </td>
                        </tr>
                    }

                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="6" style="padding:18px; text-align:center; color:#64748b;">
                                Няма заявки.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@if (TempData["GeneratedPassword"] != null)
{
    <div id="passwordSuccessPayload"
         data-name="@TempData["GeneratedPasswordName"]"
         data-card="@TempData["GeneratedPasswordCard"]"
         data-password="@TempData["GeneratedPassword"]"
         style="display:none;"></div>
}

@section Scripts {
    @if (TempData["GeneratedPassword"] != null)
    {
        <script>
            window.addEventListener('load', function () {
                const payload = document.getElementById('passwordSuccessPayload');
                if (!payload || typeof window.showAdminSuccessModal !== 'function') return;

                const name = payload.dataset.name || '';
                const card = payload.dataset.card || '';
                const password = payload.dataset.password || '';

                const html =
                    '<div>Читател: <strong>' + name + '</strong></div>' +
                    '<div style="margin-top:6px;">Карта: <strong>' + card + '</strong></div>' +
                    '<div style="margin-top:14px;">Нова временна парола:</div>' +
                    '<div class="admin-modal-password-box">' + password + '</div>';

                window.showAdminSuccessModal(html);
            });
        </script>
    }
}