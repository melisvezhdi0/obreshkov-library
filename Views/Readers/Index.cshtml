@model IEnumerable<ObreshkovLibrary.Models.Reader>

@{
    ViewData["Title"] = "Читатели";

    string searchValue = (ViewBag.Search ?? "").ToString();
    string classValue = (ViewBag.ClassFilter ?? "").ToString();
    var classes = ViewBag.AvailableClasses as List<string> ?? new List<string>();

    bool hasFilters = !string.IsNullOrWhiteSpace(searchValue) || !string.IsNullOrWhiteSpace(classValue);
    bool noResults = (Model == null || !Model.Any()) && hasFilters;

    var groupedreaders = Model
        .OrderBy(c => c.Grade)
        .ThenBy(c => c.Section)
        .ThenBy(c => c.FirstName)
        .ThenBy(c => c.LastName)
        .GroupBy(c => $"{c.Grade}{c.Section}".Replace(" ", "").ToUpper())
        .ToList();
}

<div style="width:100%; padding-top:6px;">

    <div style="display:flex; align-items:end; justify-content:space-between; gap:1rem; flex-wrap:wrap; margin-bottom:1rem;">
        <div>
            <h2 class="section-title mb-1">Читатели</h2>
            <div class="accent-line"></div>
        </div>

        <a asp-action="Create"
           class="btn btn-accent"
           style="min-width:150px; justify-content:center;">
            Добави читател
        </a>
    </div>

    <section class="card-soft" style="padding:1rem; margin-bottom:1rem;">
        <form method="get"
              asp-action="Index"
              style="display:flex; align-items:center; gap:12px; width:100%; flex-wrap:nowrap;">

            <div style="position:relative; flex:1 1 auto; min-width:0;">
                <span style="position:absolute; left:15px; top:50%; transform:translateY(-50%); color:#94A3B8; font-size:1rem; pointer-events:none; z-index:2;">⌕</span>

                <input name="search"
                       value="@searchValue"
                       placeholder="Търси име, телефон или № карта..."
                       id="readersSearchInput"
                       class="form-control"
                       style="width:100%; height:50px; padding-left:40px; padding-right:42px; border-radius:16px; border:1px solid #D7DFEA; background:#fff; color:#0F172A; font-weight:600; box-shadow:none;" />

                <button type="button"
                        id="readersClearBtn"
                        aria-label="Изчисти търсенето"
                        style="position:absolute; right:12px; top:50%; transform:translateY(-50%); width:22px; height:22px; border:none; background:#E2E8F0; color:#475569; border-radius:50%; @(string.IsNullOrWhiteSpace(searchValue) ? "display:none;" : "display:inline-flex;") align-items:center; justify-content:center; font-size:15px; line-height:1; cursor:pointer; padding:0;">
                    ×
                </button>
            </div>

            <div style="flex:0 0 150px; width:150px;">
                <select name="classFilter"
                        class="form-select"
                        style="width:150px; height:50px; border-radius:16px; border:1px solid #D7DFEA; background:#fff; font-weight:700; box-shadow:none;">
                    <option value="">Клас</option>
                    @foreach (var cls in classes)
                    {
                        if (cls == classValue)
                        {
                            <option value="@cls" selected>@cls</option>
                        }
                        else
                        {
                            <option value="@cls">@cls</option>
                        }
                    }
                </select>
            </div>

            <button type="submit"
                    class="btn btn-accent"
                    style="flex:0 0 110px; width:110px; height:50px; border-radius:16px;">
                Търси
            </button>
        </form>
    </section>

    @if (noResults)
    {
        <section class="card-soft" style="padding:0; overflow:hidden;">
            <div style="padding:1.1rem 1.2rem .9rem; border-bottom:1px solid #D9E0E7; background:#FBFCFD;">
                <h5 class="section-title mb-0">Списък с читатели</h5>
            </div>

            <div style="padding:1.2rem 1.2rem .35rem; font-weight:900; color:#1F2937; font-size:1.08rem;">
                Няма намерени данни
            </div>

            <div style="padding:0 1.2rem 1.2rem; color:#6B7280; font-weight:600;">
                @if (!string.IsNullOrWhiteSpace(classValue) && !string.IsNullOrWhiteSpace(searchValue))
                {
                    <span>по клас <strong style="color:#1F2937;">@classValue</strong> и търсене <strong style="color:#1F2937;">@searchValue</strong>.</span>
                }
                else if (!string.IsNullOrWhiteSpace(classValue))
                {
                    <span>по клас <strong style="color:#1F2937;">@classValue</strong>.</span>
                }
                else if (!string.IsNullOrWhiteSpace(searchValue))
                {
                    <span>по търсене <strong style="color:#1F2937;">@searchValue</strong>.</span>
                }
            </div>
        </section>
    }
    else
    {
        <section class="card-soft" style="padding:0; overflow:hidden;">
            <div style="padding:1.1rem 1.2rem .9rem; border-bottom:1px solid #D9E0E7; background:#FBFCFD;">
                <h5 class="section-title mb-0">Списък с читатели</h5>
            </div>

            <div class="table-responsive">
                <table class="table mb-0" style="margin-bottom:0; border-collapse:separate; border-spacing:0;">
                    <thead>
                        <tr>
                            <th style="background:#F3F6F9; color:#6B7280; font-size:.82rem; text-transform:uppercase; letter-spacing:.03em; font-weight:800; padding:.95rem 1.2rem; border-bottom:1px solid #D9E0E7; white-space:nowrap; width:34%;">Име</th>
                            <th style="background:#F3F6F9; color:#6B7280; font-size:.82rem; text-transform:uppercase; letter-spacing:.03em; font-weight:800; padding:.95rem 1.2rem; border-bottom:1px solid #D9E0E7; white-space:nowrap; width:18%;">Телефон</th>
                            <th style="background:#F3F6F9; color:#6B7280; font-size:.82rem; text-transform:uppercase; letter-spacing:.03em; font-weight:800; padding:.95rem 1.2rem; border-bottom:1px solid #D9E0E7; white-space:nowrap; width:14%;">№ карта</th>
                            <th style="background:#F3F6F9; color:#6B7280; font-size:.82rem; text-transform:uppercase; letter-spacing:.03em; font-weight:800; padding:.95rem 1.2rem; border-bottom:1px solid #D9E0E7; white-space:nowrap; width:16%;">Регистриран</th>
                            <th style="background:#F3F6F9; color:#6B7280; font-size:.82rem; text-transform:uppercase; letter-spacing:.03em; font-weight:800; padding:.95rem 1.2rem; border-bottom:1px solid #D9E0E7; white-space:nowrap; width:18%; text-align:right;">Действия</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var group in groupedreaders)
                        {
                            <tr>
                                <td colspan="5"
                                    style="background:#ECEFF3; color:#6B7280; font-size:.78rem; text-transform:uppercase; letter-spacing:.06em; font-weight:900; padding:.7rem 1.2rem; border-bottom:1px solid #D9E0E7;">
                                    @group.Key
                                </td>
                            </tr>

                            @foreach (var item in group)
                            {
                                <tr role="button"
                                    tabindex="0"
                                    onclick="window.location.href='@Url.Action("Details", "readers", new { id = item.Id })';"
                                    onkeydown="if(event.key==='Enter'){ window.location.href='@Url.Action("Details", "readers", new { id = item.Id })'; }">
                                    <td style="padding:1rem 1.2rem; background:#fff; border-bottom:1px solid #E5EAF0; vertical-align:middle; font-weight:700; color:#1F2937;">
                                        @(($"{item.FirstName} {item.MiddleName} {item.LastName}").Replace("  ", " ").Trim())
                                    </td>

                                    <td style="padding:1rem 1.2rem; background:#fff; border-bottom:1px solid #E5EAF0; vertical-align:middle;">
                                        @item.PhoneNumber
                                    </td>

                                    <td style="padding:1rem 1.2rem; background:#fff; border-bottom:1px solid #E5EAF0; vertical-align:middle;">
                                        @item.CardNumber
                                    </td>

                                    <td style="padding:1rem 1.2rem; background:#fff; border-bottom:1px solid #E5EAF0; vertical-align:middle;">
                                        @item.CreatedOn.ToString("dd.MM.yyyy")
                                    </td>

                                    <td style="padding:1rem 1.2rem; background:#fff; border-bottom:1px solid #E5EAF0; vertical-align:middle; text-align:right; white-space:nowrap;">
                                        <a asp-action="Edit"
                                           asp-route-id="@item.Id"
                                           onclick="event.stopPropagation();"
                                           style="color:#3B82F6; font-weight:800; text-decoration:none;">
                                            Редакция
                                        </a>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </section>
    }
</div>

@section Scripts {
    <script>
        (() => {
            const input = document.getElementById('readersSearchInput');
            const clearBtn = document.getElementById('readersClearBtn');

            if (!input || !clearBtn) return;

            function toggleClearButton() {
                clearBtn.style.display = input.value.trim().length > 0 ? 'inline-flex' : 'none';
            }

            clearBtn.addEventListener('click', () => {
                input.value = '';
                toggleClearButton();
                input.focus();
            });

            input.addEventListener('input', toggleClearButton);
            toggleClearButton();
        })();
    </script>
}