@model ObreshkovLibrary.Models.ViewModels.StudentDashboardVM

@{
    ViewData["Title"] = "Моят профил";
    Layout = "_StudentLayout";

    var currentAction = ViewContext?.RouteData?.Values["action"]?.ToString() ?? "";

    string sideStyle(string action)
    {
        var isActive = currentAction == action;

        return isActive
            ? "display:block; padding:12px 14px; border-radius:8px; text-decoration:none; font-weight:800; color:#1d4ed8; background:#eef4ff; border:1px solid #dbe7fb;"
            : "display:block; padding:12px 14px; border-radius:8px; text-decoration:none; font-weight:800; color:#334155; background:transparent; border:1px solid transparent;";
    }
}

<div style="width:100%; margin:0; padding:0;">

    <div style="display:grid; grid-template-columns:260px minmax(0, 1fr); background:#ffffff; border-top:1px solid #e5e7eb; min-height:calc(100vh - 110px); overflow:hidden;">

        <aside style="background:#f9fafb; border-right:1px solid #e5e7eb; padding:0;">
            <div style="padding:24px 18px 18px 18px; border-bottom:1px solid #e5e7eb;">
                <div style="color:#64748b; font-size:.78rem; font-weight:800; letter-spacing:.08em; text-transform:uppercase;">
                    Student Portal
                </div>

                <h1 style="margin:12px 0 0 0; color:#17325c; font-size:1.8rem; font-weight:900; line-height:1.1;">
                    Моят профил
                </h1>
            </div>

            <nav style="display:flex; flex-direction:column; gap:4px; padding:10px;">
                <a asp-controller="StudentPortal"
                   asp-action="Index"
                   style="@sideStyle("Index")"
                   onmouseover="this.style.background='#f3f6fa'; this.style.color='#1d4ed8'; this.style.borderColor='#e2e8f0';"
                   onmouseout="this.style.background='@(currentAction == "Index" ? "#eef4ff" : "transparent")'; this.style.color='@(currentAction == "Index" ? "#1d4ed8" : "#334155")'; this.style.borderColor='@(currentAction == "Index" ? "#dbe7fb" : "transparent")';">
                    Начало
                </a>

                <a asp-controller="StudentPortal"
                   asp-action="MyBooks"
                   style="@sideStyle("MyBooks")"
                   onmouseover="this.style.background='#f3f6fa'; this.style.color='#1d4ed8'; this.style.borderColor='#e2e8f0';"
                   onmouseout="this.style.background='@(currentAction == "MyBooks" ? "#eef4ff" : "transparent")'; this.style.color='@(currentAction == "MyBooks" ? "#1d4ed8" : "#334155")'; this.style.borderColor='@(currentAction == "MyBooks" ? "#dbe7fb" : "transparent")';">
                    Текущо заети книги
                </a>

                <a asp-controller="StudentPortal"
                   asp-action="History"
                   style="@sideStyle("History")"
                   onmouseover="this.style.background='#f3f6fa'; this.style.color='#1d4ed8'; this.style.borderColor='#e2e8f0';"
                   onmouseout="this.style.background='@(currentAction == "History" ? "#eef4ff" : "transparent")'; this.style.color='@(currentAction == "History" ? "#1d4ed8" : "#334155")'; this.style.borderColor='@(currentAction == "History" ? "#dbe7fb" : "transparent")';">
                    История на заемания
                </a>

                <a asp-controller="StudentPortal"
                   asp-action="Favorites"
                   style="@sideStyle("Favorites")"
                   onmouseover="this.style.background='#f3f6fa'; this.style.color='#1d4ed8'; this.style.borderColor='#e2e8f0';"
                   onmouseout="this.style.background='@(currentAction == "Favorites" ? "#eef4ff" : "transparent")'; this.style.color='@(currentAction == "Favorites" ? "#1d4ed8" : "#334155")'; this.style.borderColor='@(currentAction == "Favorites" ? "#dbe7fb" : "transparent")';">
                    Любими книги
                </a>

                <a asp-controller="StudentPortal"
                   asp-action="Notifications"
                   style="@sideStyle("Notifications")"
                   onmouseover="this.style.background='#f3f6fa'; this.style.color='#1d4ed8'; this.style.borderColor='#e2e8f0';"
                   onmouseout="this.style.background='@(currentAction == "Notifications" ? "#eef4ff" : "transparent")'; this.style.color='@(currentAction == "Notifications" ? "#1d4ed8" : "#334155")'; this.style.borderColor='@(currentAction == "Notifications" ? "#dbe7fb" : "transparent")';">
                    Съобщения
                </a>
            </nav>
        </aside>

        <section style="padding:24px 28px; min-width:0; background:#ffffff;">
            <div style="padding-bottom:18px; border-bottom:1px solid #e5e7eb; margin-bottom:20px;">
                <div style="color:#64748b; font-size:.78rem; font-weight:800; letter-spacing:.08em; text-transform:uppercase;">
                    Добре дошъл
                </div>

                <h2 style="margin:10px 0 0 0; color:#17325c; font-size:2.2rem; font-weight:900; line-height:1.1;">
                    Здравей, @Model.StudentName
                </h2>

                <p style="margin:14px 0 0 0; color:#64748b; font-size:1rem; font-weight:700; line-height:1.6;">
                    Тук можеш бързо да виждаш най-важното за профила си.
                </p>
            </div>

            <div style="display:grid; grid-template-columns:repeat(3, minmax(0, 1fr)); gap:14px; margin-bottom:20px;">
                <div style="border:1px solid #e3e8ef; border-radius:12px; padding:18px; background:#ffffff;">
                    <div style="color:#64748b; font-size:.95rem; font-weight:800;">
                        Текущо заети книги
                    </div>
                    <div style="margin-top:10px; color:#17325c; font-size:2rem; font-weight:900;">
                        @Model.CurrentLoansCount
                    </div>
                </div>

                <div style="border:1px solid #e3e8ef; border-radius:12px; padding:18px; background:#ffffff;">
                    <div style="color:#64748b; font-size:.95rem; font-weight:800;">
                        Любими книги
                    </div>
                    <div style="margin-top:10px; color:#17325c; font-size:2rem; font-weight:900;">
                        @Model.FavoritesCount
                    </div>
                </div>

                <div style="border:1px solid #e3e8ef; border-radius:12px; padding:18px; background:#ffffff;">
                    <div style="color:#64748b; font-size:.95rem; font-weight:800;">
                        Непрочетени съобщения
                    </div>
                    <div style="margin-top:10px; color:#17325c; font-size:2rem; font-weight:900;">
                        @Model.UnreadNotificationsCount
                    </div>
                </div>
            </div>

            <section style="border:1px solid #e3e8ef; border-radius:12px; overflow:hidden; background:#ffffff;">
                <div style="padding:18px 20px; border-bottom:1px solid #e5e7eb; display:flex; justify-content:space-between; align-items:start; gap:12px; flex-wrap:wrap;">
                    <div>
                        <h3 style="margin:0; color:#17325c; font-size:1.35rem; font-weight:900;">
                            В момента заемани книги
                        </h3>
                        <p style="margin:8px 0 0 0; color:#64748b; font-size:.95rem; font-weight:700; line-height:1.6;">
                            Книгите, които са при теб сега.
                        </p>
                    </div>

                    <a asp-action="MyBooks"
                       style="text-decoration:none; color:#2563eb; font-weight:800; padding:8px 10px; border-radius:8px;"
                       onmouseover="this.style.background='#f3f6fa';"
                       onmouseout="this.style.background='transparent';">
                        Виж всички
                    </a>
                </div>

                @if (Model.CurrentLoans != null && Model.CurrentLoans.Any())
                {
                    <div style="display:flex; flex-direction:column;">
                        @foreach (var item in Model.CurrentLoans)
                        {
                            <article style="display:grid; grid-template-columns:minmax(0, 1fr) auto; gap:18px; padding:18px 20px; border-top:1px solid #eef2f6;">
                                <div style="min-width:0;">
                                    <h4 style="margin:0; color:#17325c; font-size:1.08rem; font-weight:900; line-height:1.35;">
                                        @item.Title
                                    </h4>
                                    <div style="margin-top:6px; color:#64748b; font-size:.95rem; font-weight:700;">
                                        @item.Author
                                    </div>
                                </div>

                                <div style="display:flex; align-items:center; gap:12px; flex-wrap:wrap; justify-content:flex-end;">
                                    <div style="min-width:120px;">
                                        <div style="color:#64748b; font-size:.8rem; font-weight:800; margin-bottom:4px;">Взета на</div>
                                        <div style="color:#17325c; font-size:.95rem; font-weight:900;">@item.LoanDate.ToString("dd.MM.yyyy")</div>
                                    </div>

                                    <div style="min-width:120px;">
                                        <div style="color:#64748b; font-size:.8rem; font-weight:800; margin-bottom:4px;">Връща се на</div>
                                        <div style="color:#17325c; font-size:.95rem; font-weight:900;">@item.DueDate.ToString("dd.MM.yyyy")</div>
                                    </div>

                                    <div>
                                        @if (item.IsOverdue)
                                        {
                                            <span style="display:inline-flex; align-items:center; justify-content:center; min-height:32px; padding:0 12px; border-radius:999px; font-size:.86rem; font-weight:800; background:#fef2f2; color:#dc2626;">
                                                Просрочена
                                            </span>
                                        }
                                        else if (item.IsExtended)
                                        {
                                            <span style="display:inline-flex; align-items:center; justify-content:center; min-height:32px; padding:0 12px; border-radius:999px; font-size:.86rem; font-weight:800; background:#eff6ff; color:#1d4ed8;">
                                                Удължена
                                            </span>
                                        }
                                        else
                                        {
                                            <span style="display:inline-flex; align-items:center; justify-content:center; min-height:32px; padding:0 12px; border-radius:999px; font-size:.86rem; font-weight:800; background:#ecfdf3; color:#15803d;">
                                                Активна
                                            </span>
                                        }
                                    </div>

                                    <a asp-controller="Catalog"
                                       asp-action="StudentDetails"
                                       asp-route-id="@item.BookId"
                                       style="display:inline-flex; align-items:center; justify-content:center; min-height:34px; padding:0 12px; border-radius:8px; border:1px solid #dbe4ef; background:#ffffff; color:#1d4ed8; text-decoration:none; font-weight:800;"
                                       onmouseover="this.style.background='#f3f6fa';"
                                       onmouseout="this.style.background='#ffffff';">
                                        Детайли
                                    </a>
                                </div>
                            </article>
                        }
                    </div>
                }
                else
                {
                    <div style="padding:22px 20px; color:#64748b; font-weight:700; line-height:1.6;">
                        В момента нямаш заемани книги.
                    </div>
                }
            </section>
        </section>
    </div>
</div>
@if (ViewBag.RequirePasswordChange == true)
{
    <div id="passwordOverlay"
         style="position:fixed;
                    inset:0;
                    background:rgba(15,23,42,.34);
                    backdrop-filter:blur(5px);
                    z-index:9999;
                    display:flex;
                    align-items:center;
                    justify-content:center;
                    padding:18px;">

        <div style="width:460px;
                        max-width:100%;
                        background:linear-gradient(180deg, #ffffff 0%, #f8fbff 100%);
                        border:1px solid #dbe5ef;
                        border-radius:24px;
                        padding:30px 28px 26px 28px;
                        box-shadow:0 24px 70px rgba(15,23,42,.16);">

            <div style="text-align:center; margin-bottom:20px;">
                <div style="font-size:1.65rem;
                                font-weight:900;
                                color:#0f172a;
                                line-height:1.15;
                                margin-bottom:8px;">
                    Смени паролата си
                </div>

                <div style="display:inline-flex;
                                align-items:center;
                                justify-content:center;
                                min-height:30px;
                                padding:0 12px;
                                border-radius:999px;
                                background:#eff6ff;
                                color:#2563eb;
                                font-size:.82rem;
                                font-weight:800;
                                margin-bottom:12px;">
                    Първи вход в профила
                </div>

                <div style="color:#64748b;
                                font-size:.98rem;
                                line-height:1.65;
                                max-width:340px;
                                margin:0 auto;">
                    За да продължиш към профила си, първо трябва да зададеш нова лична парола.
                </div>
            </div>

            @if (TempData["PasswordChangeError"] != null)
            {
                <div style="margin-bottom:14px;
                                    padding:11px 13px;
                                    border-radius:12px;
                                    border:1px solid #fecaca;
                                    background:#fef2f2;
                                    color:#b91c1c;
                                    font-size:.92rem;
                                    font-weight:700;">
                    @TempData["PasswordChangeError"]
                </div>
            }

            <form asp-controller="StudentAccount"
                  asp-action="ChangePassword"
                  method="post"
                  style="margin:0;">
                @Html.AntiForgeryToken()

                <div style="display:grid; gap:14px;">

                    <div>
                        <label style="display:block;
                                          margin-bottom:7px;
                                          color:#0f172a;
                                          font-size:.95rem;
                                          font-weight:800;">
                            Текуща парола
                        </label>
                        <input type="password"
                               name="CurrentPassword"
                               class="student-password-input"
                               style="width:100%;
                                          height:50px;
                                          border-radius:14px;
                                          border:1px solid #cbd5e1;
                                          background:#ffffff;
                                          box-shadow:none;
                                          font-size:.98rem;
                                          padding:0 14px;
                                          outline:none;
                                          transition:border-color .18s ease, box-shadow .18s ease, transform .18s ease;" />
                    </div>

                    <div>
                        <label style="display:block;
                                          margin-bottom:7px;
                                          color:#0f172a;
                                          font-size:.95rem;
                                          font-weight:800;">
                            Нова парола
                        </label>
                        <input type="password"
                               name="NewPassword"
                               class="student-password-input"
                               style="width:100%;
                                          height:50px;
                                          border-radius:14px;
                                          border:1px solid #cbd5e1;
                                          background:#ffffff;
                                          box-shadow:none;
                                          font-size:.98rem;
                                          padding:0 14px;
                                          outline:none;
                                          transition:border-color .18s ease, box-shadow .18s ease, transform .18s ease;" />
                    </div>

                    <div>
                        <label style="display:block;
                                          margin-bottom:7px;
                                          color:#0f172a;
                                          font-size:.95rem;
                                          font-weight:800;">
                            Потвърди новата парола
                        </label>
                        <input type="password"
                               name="ConfirmPassword"
                               class="student-password-input"
                               style="width:100%;
                                          height:50px;
                                          border-radius:14px;
                                          border:1px solid #cbd5e1;
                                          background:#ffffff;
                                          box-shadow:none;
                                          font-size:.98rem;
                                          padding:0 14px;
                                          outline:none;
                                          transition:border-color .18s ease, box-shadow .18s ease, transform .18s ease;" />
                    </div>
                </div>

                <div style="margin-top:18px;">
                    <button type="submit"
                            id="saveStudentPasswordBtn"
                            style="width:100%;
                                       height:50px;
                                       border:none;
                                       border-radius:14px;
                                       background:linear-gradient(135deg, #2563eb 0%, #3b82f6 100%);
                                       color:#ffffff;
                                       font-size:1rem;
                                       font-weight:800;
                                       box-shadow:0 14px 28px rgba(37,99,235,.18);
                                       transition:transform .18s ease, box-shadow .18s ease, filter .18s ease;">
                        Запази новата парола
                    </button>
                </div>
            </form>
        </div>
    </div>

    <script>
        document.querySelectorAll('.student-password-input').forEach(input => {
            input.addEventListener('mouseenter', function () {
                if (document.activeElement !== input) {
                    input.style.borderColor = '#93c5fd';
                    input.style.boxShadow = '0 10px 24px rgba(37,99,235,.08)';
                    input.style.transform = 'translateY(-1px)';
                }
            });

            input.addEventListener('mouseleave', function () {
                if (document.activeElement !== input) {
                    input.style.borderColor = '#cbd5e1';
                    input.style.boxShadow = 'none';
                    input.style.transform = 'translateY(0)';
                }
            });

            input.addEventListener('focus', function () {
                input.style.borderColor = '#3b82f6';
                input.style.boxShadow = '0 0 0 4px rgba(59,130,246,.12), 0 10px 24px rgba(37,99,235,.08)';
                input.style.transform = 'translateY(-1px)';
            });

            input.addEventListener('blur', function () {
                input.style.borderColor = '#cbd5e1';
                input.style.boxShadow = 'none';
                input.style.transform = 'translateY(0)';
            });
        });

        const saveStudentPasswordBtn = document.getElementById('saveStudentPasswordBtn');
        if (saveStudentPasswordBtn) {
            saveStudentPasswordBtn.addEventListener('mouseenter', function () {
                saveStudentPasswordBtn.style.transform = 'translateY(-2px)';
                saveStudentPasswordBtn.style.boxShadow = '0 18px 34px rgba(37,99,235,.24)';
                saveStudentPasswordBtn.style.filter = 'brightness(1.03)';
            });

            saveStudentPasswordBtn.addEventListener('mouseleave', function () {
                saveStudentPasswordBtn.style.transform = 'translateY(0)';
                saveStudentPasswordBtn.style.boxShadow = '0 14px 28px rgba(37,99,235,.18)';
                saveStudentPasswordBtn.style.filter = 'none';
            });
        }
    </script>
}