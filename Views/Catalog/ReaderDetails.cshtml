@model ObreshkovLibrary.Models.Book
@using System.Linq
@using ObreshkovLibrary.Models
@using ObreshkovLibrary.Models.Enums

@{
    Layout = "~/Views/Shared/_ReaderLayout.cshtml";
    ViewData["Title"] = "Детайли за книга";

    var isAvailable = (ViewBag.IsAvailable as bool?) ?? false;
    var relatedBooks = (ViewBag.RelatedBooks as List<Book>) ?? new List<Book>();
    var similarBooks = (ViewBag.SimilarBooks as List<Book>) ?? new List<Book>();
    var isInReadingList = (ViewBag.IsFavorite as bool?) ?? false;
    var currentReturnUrl = $"{Context.Request.Path}{Context.Request.QueryString}";

    string ResolveCoverUrl(string? path)
    {
        if (string.IsNullOrWhiteSpace(path))
            return "";

        return path.StartsWith("/")
            ? Url.Content("~" + path)
            : Url.Content("~/" + path.TrimStart('/'));
    }

    var coverPathProp = Model.GetType().GetProperty("CoverPath");
    var coverUrlProp = Model.GetType().GetProperty("CoverUrl");
    var coverValue = coverPathProp?.GetValue(Model)?.ToString() ?? coverUrlProp?.GetValue(Model)?.ToString();
    var coverUrl = ResolveCoverUrl(coverValue);

    string? subCategoryName = Model.Category?.Name;
    string? parentCategoryName = Model.Category?.ParentCategory?.Name;

    string genreText = "Няма";
    if (!string.IsNullOrWhiteSpace(parentCategoryName) && !string.IsNullOrWhiteSpace(subCategoryName))
    {
        genreText = $"{parentCategoryName} / {subCategoryName}";
    }
    else if (!string.IsNullOrWhiteSpace(subCategoryName))
    {
        genreText = subCategoryName!;
    }

    List<string> tagNames = new();

    if ((Model.Tags & BookTags.BulgarianLiterature) == BookTags.BulgarianLiterature) tagNames.Add("Българска литература");
    if ((Model.Tags & BookTags.WorldLiterature) == BookTags.WorldLiterature) tagNames.Add("Световна литература");
    if ((Model.Tags & BookTags.BalkanLiterature) == BookTags.BalkanLiterature) tagNames.Add("Балканска литература");
    if ((Model.Tags & BookTags.AncientLiterature) == BookTags.AncientLiterature) tagNames.Add("Антична литература");
    if ((Model.Tags & BookTags.ClassicLiterature) == BookTags.ClassicLiterature) tagNames.Add("Класика");
    if ((Model.Tags & BookTags.ContemporaryLiterature) == BookTags.ContemporaryLiterature) tagNames.Add("Съвременна литература");

    if ((Model.Tags & BookTags.Love) == BookTags.Love) tagNames.Add("Любов");
    if ((Model.Tags & BookTags.Rebellion) == BookTags.Rebellion) tagNames.Add("Бунт");
    if ((Model.Tags & BookTags.Suffering) == BookTags.Suffering) tagNames.Add("Страдание");
    if ((Model.Tags & BookTags.Romantic) == BookTags.Romantic) tagNames.Add("Романтика");

    if ((Model.Tags & BookTags.Horror) == BookTags.Horror) tagNames.Add("Хорър");
    if ((Model.Tags & BookTags.Historical) == BookTags.Historical) tagNames.Add("Исторически");
    if ((Model.Tags & BookTags.ScienceFiction) == BookTags.ScienceFiction) tagNames.Add("Фантастика");
    if ((Model.Tags & BookTags.Fantasy) == BookTags.Fantasy) tagNames.Add("Фентъзи");
    if ((Model.Tags & BookTags.Psychological) == BookTags.Psychological) tagNames.Add("Психологически");
    if ((Model.Tags & BookTags.Social) == BookTags.Social) tagNames.Add("Социален");

    if ((Model.Tags & BookTags.RequiredReading) == BookTags.RequiredReading) tagNames.Add("Задължителна литература");
    if ((Model.Tags & BookTags.RecommendedReading) == BookTags.RecommendedReading) tagNames.Add("Препоръчителна литература");
    if ((Model.Tags & BookTags.ForMatura) == BookTags.ForMatura) tagNames.Add("За матура");

    if ((Model.Tags & BookTags.BulgarianAuthor) == BookTags.BulgarianAuthor) tagNames.Add("Български автор");
    if ((Model.Tags & BookTags.ForeignAuthor) == BookTags.ForeignAuthor) tagNames.Add("Чужд автор");

    if ((Model.Tags & BookTags.EducationalContent) == BookTags.EducationalContent) tagNames.Add("Учебно съдържание");
    if ((Model.Tags & BookTags.ClassicalWork) == BookTags.ClassicalWork) tagNames.Add("Класическо произведение");

    if ((Model.Tags & BookTags.Poetry) == BookTags.Poetry) tagNames.Add("Поезия");
    if ((Model.Tags & BookTags.Prose) == BookTags.Prose) tagNames.Add("Проза");
    if ((Model.Tags & BookTags.Dramaturgy) == BookTags.Dramaturgy) tagNames.Add("Драматургия");

    if ((Model.Tags & BookTags.Mathematics) == BookTags.Mathematics) tagNames.Add("Математика");
    if ((Model.Tags & BookTags.BulgarianLanguage) == BookTags.BulgarianLanguage) tagNames.Add("Български език");
    if ((Model.Tags & BookTags.History) == BookTags.History) tagNames.Add("История");
    if ((Model.Tags & BookTags.Geography) == BookTags.Geography) tagNames.Add("География");
    if ((Model.Tags & BookTags.Biology) == BookTags.Biology) tagNames.Add("Биология");
    if ((Model.Tags & BookTags.Chemistry) == BookTags.Chemistry) tagNames.Add("Химия");
    if ((Model.Tags & BookTags.Physics) == BookTags.Physics) tagNames.Add("Физика");
    if ((Model.Tags & BookTags.Philosophy) == BookTags.Philosophy) tagNames.Add("Философия");
    if ((Model.Tags & BookTags.IT) == BookTags.IT) tagNames.Add("Информационни технологии/Информатика");
}

<form style="display:none;">
    @Html.AntiForgeryToken()
</form>

<div style="width:min(1380px, calc(100% - 40px)); margin:28px auto 46px auto;">

    <div style="margin-bottom:24px;">
        <div style="display:inline-flex; align-items:center; gap:8px; padding:6px 12px; border-radius:999px; background:#eef4ff; border:1px solid #d7e4ff; color:#2563eb; font-size:.82rem; font-weight:900;">
            Детайли за книга
        </div>

        <h1 style="margin:14px 0 0 0; color:#17325c; font-size:2.15rem; line-height:1.14; font-weight:900; letter-spacing:-0.02em;">
            @Model.Title
        </h1>

        <div style="width:68px; height:4px; border-radius:999px; background:linear-gradient(90deg,#2563eb 0%,#60a5fa 100%); margin-top:12px;"></div>
    </div>

    <section style="background:linear-gradient(180deg,#ffffff 0%,#fbfdff 100%); border:1px solid #d8e1eb; border-radius:24px; overflow:hidden; margin-bottom:24px; box-shadow:0 16px 36px rgba(15,23,42,.06);">
        <div style="display:grid; grid-template-columns:320px minmax(0,1fr); gap:0; align-items:stretch;">

            <div style="position:relative; background:linear-gradient(180deg,#f8fbff 0%,#f2f7fc 100%); border-right:1px solid #e2e8f0; padding:28px; display:flex; align-items:center; justify-content:center; min-height:460px;">
                <form asp-controller="ReaderPortal"
                      asp-action="ToggleFavorite"
                      method="post"
                      style="position:absolute; top:16px; right:16px; margin:0; z-index:2;">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="bookId" value="@Model.Id" />
                    <input type="hidden" name="returnUrl" value="@currentReturnUrl" />

                    <button type="submit"
                            title="@(isInReadingList ? "Премахни от списъка за четене" : "Добави в списъка за четене")"
                            aria-label="@(isInReadingList ? "Премахни от списъка за четене" : "Добави в списъка за четене")"
                            style="width:46px; height:46px; border:1px solid #d7e3f4; border-radius:14px; background:@(isInReadingList ? "linear-gradient(180deg,#eef4ff 0%,#e8f1ff 100%)" : "rgba(255,255,255,.95)"); color:#2563eb; display:flex; align-items:center; justify-content:center; cursor:pointer; box-shadow:0 10px 24px rgba(15,23,42,.10); transition:all .18s ease;"
                            onmouseover="this.style.transform='translateY(-2px) scale(1.03)'; this.style.boxShadow='0 16px 30px rgba(15,23,42,.14)';"
                            onmouseout="this.style.transform='translateY(0) scale(1)'; this.style.boxShadow='0 10px 24px rgba(15,23,42,.10)';">
                        @if (isInReadingList)
                        {
                            <svg xmlns="http://www.w3.org/2000/svg"
                                 width="18"
                                 height="18"
                                 viewBox="0 0 16 16"
                                 fill="currentColor"
                                 style="display:block;">
                                <path d="M2 2a2 2 0 0 1 2-2h7a1 1 0 0 1 1 1v13l-4-2-4 2V2z" />
                            </svg>
                        }
                        else
                        {
                            <svg xmlns="http://www.w3.org/2000/svg"
                                 width="18"
                                 height="18"
                                 viewBox="0 0 16 16"
                                 fill="currentColor"
                                 style="display:block;">
                                <path d="M2 1.5A1.5 1.5 0 0 1 3.5 0h7A1.5 1.5 0 0 1 12 1.5V14l-5-2.5L2 14V1.5zM3.5 1a.5.5 0 0 0-.5.5v10.691l4-2 4 2V1.5a.5.5 0 0 0-.5-.5h-7z" />
                            </svg>
                        }
                    </button>
                </form>

                @if (!string.IsNullOrWhiteSpace(coverUrl))
                {
                    <img src="@coverUrl"
                         alt="@Model.Title"
                         style="display:block; width:100%; max-width:240px; max-height:390px; object-fit:contain; filter:drop-shadow(0 18px 28px rgba(15,23,42,0.14)); transition:transform .2s ease;"
                         onmouseover="this.style.transform='translateY(-3px) scale(1.01)';"
                         onmouseout="this.style.transform='translateY(0) scale(1)';"
                         onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';" />
                    <div style="display:none; width:100%; min-height:340px; border:2px dashed #cad5e0; border-radius:18px; align-items:center; justify-content:center; color:#94a3b8; font-size:.95rem; font-weight:800; background:#f8fbff;">
                        Няма корица
                    </div>
                }
                else
                {
                    <div style="width:100%; min-height:340px; border:2px dashed #cad5e0; border-radius:18px; display:flex; align-items:center; justify-content:center; color:#94a3b8; font-size:.95rem; font-weight:800; background:#f8fbff;">
                        Няма корица
                    </div>
                }
            </div>

            <div style="min-width:0;">
                <div style="display:grid; grid-template-columns:220px minmax(0,1fr);">
                    <div style="padding:20px 18px; border-bottom:1px solid #e2e8f0; color:#64748b; font-weight:800;">Заглавие</div>
                    <div style="padding:20px 22px; border-bottom:1px solid #e2e8f0; color:#0f172a; font-weight:800; text-align:right;">
                        @(string.IsNullOrWhiteSpace(Model.Title) ? "Няма" : Model.Title)
                    </div>

                    <div style="padding:20px 18px; border-bottom:1px solid #e2e8f0; color:#64748b; font-weight:800;">Автор</div>
                    <div style="padding:20px 22px; border-bottom:1px solid #e2e8f0; color:#0f172a; font-weight:800; text-align:right;">
                        @(string.IsNullOrWhiteSpace(Model.Author) ? "Няма" : Model.Author)
                    </div>

                    <div style="padding:20px 18px; border-bottom:1px solid #e2e8f0; color:#64748b; font-weight:800;">Жанр</div>
                    <div style="padding:20px 22px; border-bottom:1px solid #e2e8f0; color:#0f172a; font-weight:800; text-align:right;">
                        @genreText
                    </div>

                    <div style="padding:20px 18px; border-bottom:1px solid #e2e8f0; color:#64748b; font-weight:800;">Година</div>
                    <div style="padding:20px 22px; border-bottom:1px solid #e2e8f0; color:#0f172a; font-weight:800; text-align:right;">
                        @(Model.Year.HasValue? Model.Year.ToString() : "Няма")
                    </div>

                    <div style="padding:20px 18px; border-bottom:1px solid #e2e8f0; color:#64748b; font-weight:800;">Класове</div>
                    <div style="padding:20px 22px; border-bottom:1px solid #e2e8f0; color:#0f172a; font-weight:800; text-align:right;">
                        @(string.IsNullOrWhiteSpace(Model.SchoolClass) ? "Не е посочен" : Model.SchoolClass)
                    </div>

                    <div style="padding:20px 18px; color:#64748b; font-weight:800;">Статус</div>
                    <div style="padding:20px 22px; text-align:right;">
                        @if (isAvailable)
                        {
                            <span style="display:inline-flex; align-items:center; justify-content:center; min-height:38px; padding:0 16px; border-radius:999px; font-size:.9rem; font-weight:900; background:linear-gradient(180deg,#e8f7ee 0%,#e0f4e9 100%); color:#2f7d32; border:1px solid #cfe7d3; box-shadow:0 6px 14px rgba(47,125,50,.08);">
                                Налична
                            </span>
                        }
                        else
                        {
                            <span style="display:inline-flex; align-items:center; justify-content:center; min-height:38px; padding:0 16px; border-radius:999px; font-size:.9rem; font-weight:900; background:linear-gradient(180deg,#fff7e8 0%,#fff2d7 100%); color:#c77a00; border:1px solid #ffe4a8; box-shadow:0 6px 14px rgba(199,122,0,.08);">
                                Заета
                            </span>
                        }
                    </div>
                </div>
            </div>
        </div>
    </section>

    <section style="background:#ffffff; border:1px solid #d8e1eb; border-radius:22px; overflow:hidden; margin-bottom:24px; box-shadow:0 12px 28px rgba(15,23,42,.05);">
        <div style="padding:16px 20px; border-bottom:1px solid #e2e8f0;">
            <h3 style="margin:0; color:#17325c; font-size:1.16rem; font-weight:900;">Ключови думи и етикети</h3>
        </div>

        <div style="display:grid; grid-template-columns:220px minmax(0,1fr); border-bottom:1px solid #e2e8f0;">
            <div style="padding:16px 18px; color:#64748b; font-weight:800; border-right:1px solid #e2e8f0;">Ключови думи</div>
            <div style="padding:16px 18px; color:#0f172a; line-height:1.8;">
                @(string.IsNullOrWhiteSpace(Model.SearchKeywords) ? "Не са добавени" : Model.SearchKeywords)
            </div>
        </div>

        <div style="display:grid; grid-template-columns:220px minmax(0,1fr);">
            <div style="padding:16px 18px; color:#64748b; font-weight:800; border-right:1px solid #e2e8f0;">Етикети</div>
            <div style="padding:16px 18px;">
                @if (tagNames.Any())
                {
                    <div style="display:flex; flex-wrap:wrap; gap:8px;">
                        @foreach (var tag in tagNames)
                        {
                            <span style="display:inline-flex; align-items:center; padding:.5rem .9rem; border-radius:999px; background:#eef4ff; color:#2563eb; font-weight:800; font-size:.9rem; border:1px solid #d7e4ff;">
                                @tag
                            </span>
                        }
                    </div>
                }
                else
                {
                    <span style="color:#0f172a;">Няма</span>
                }
            </div>
        </div>
    </section>

    <section style="background:#ffffff; border:1px solid #d8e1eb; border-radius:22px; overflow:hidden; margin-bottom:24px; box-shadow:0 12px 28px rgba(15,23,42,.05);">
        <div style="padding:16px 20px; border-bottom:1px solid #e2e8f0;">
            <h3 style="margin:0; color:#17325c; font-size:1.16rem; font-weight:900;">Описание</h3>
        </div>

        <section style="background:#ffffff; border:1px solid #d8e1eb; border-radius:22px; overflow:hidden; margin-bottom:24px; box-shadow:0 12px 28px rgba(15,23,42,.05);">
            <div style="padding:16px 20px; border-bottom:1px solid #e2e8f0; display:flex; align-items:center; justify-content:space-between; gap:14px; flex-wrap:wrap;">
                <div>
                    <h3 style="margin:0; color:#17325c; font-size:1.16rem; font-weight:900;">Моите бележки</h3>
                    <div style="margin-top:6px; color:#64748b; font-size:.94rem; font-weight:700;">
                        Лични бележки към тази книга. Видими са само за теб.
                    </div>
                </div>

                <div style="display:inline-flex; align-items:center; gap:8px; padding:8px 12px; border-radius:999px; background:#fff8cc; border:1px solid #f2e29a; color:#8a6f14; font-size:.82rem; font-weight:900;">
                    Само за reader
                </div>
            </div>

            <div style="padding:20px;">
                <div id="readerBookNotesGrid"
                     data-book-id="@Model.Id"
                     style="display:grid; grid-template-columns:repeat(auto-fit, minmax(220px, 1fr)); gap:18px;">
                </div>
            </div>
        </section>

        <div style="padding:22px;">
            @if (!string.IsNullOrWhiteSpace(Model.Description))
            {
                <div style="color:#334155; font-size:1rem; line-height:1.92; white-space:pre-line;">
                    @Model.Description
                </div>
            }
            else
            {
                <div style="color:#64748b; font-weight:700;">
                    Няма описание за тази книга.
                </div>
            }
        </div>
    </section>

    @if (relatedBooks.Any())
    {
        <section style="background:#ffffff; border:1px solid #d8e1eb; border-radius:22px; overflow:hidden; margin-bottom:24px; box-shadow:0 12px 28px rgba(15,23,42,.05);">
            <div style="padding:16px 20px; border-bottom:1px solid #e2e8f0;">
                <h3 style="margin:0; color:#17325c; font-size:1.16rem; font-weight:900;">Още книги от същия автор</h3>
            </div>

            <div style="padding:20px; display:grid; grid-template-columns:repeat(5, minmax(0,1fr)); gap:18px;">
                @foreach (var book in relatedBooks)
                {
                    var relatedCover = ResolveCoverUrl(book.CoverPath);

                    <a asp-controller="Catalog"
                       asp-action="ReaderDetails"
                       asp-route-id="@book.Id"
                       style="display:flex; flex-direction:column; text-decoration:none; border:1px solid #e6edf5; border-radius:18px; background:linear-gradient(180deg,#ffffff 0%,#fbfdff 100%); padding:12px; box-shadow:0 10px 20px rgba(15,23,42,.04); transition:all .18s ease;"
                       onmouseover="this.style.transform='translateY(-4px)'; this.style.boxShadow='0 16px 28px rgba(15,23,42,.10)'; this.style.borderColor='#d7e4ff';"
                       onmouseout="this.style.transform='translateY(0)'; this.style.boxShadow='0 10px 20px rgba(15,23,42,.04)'; this.style.borderColor='#e6edf5';">
                        <div style="height:220px; border-radius:13px; background:linear-gradient(180deg,#f8fbff 0%,#f1f6fb 100%); display:flex; align-items:center; justify-content:center; overflow:hidden; padding:10px;">
                            @if (!string.IsNullOrWhiteSpace(relatedCover))
                            {
                                <img src="@relatedCover"
                                     alt="@book.Title"
                                     style="max-width:100%; max-height:100%; object-fit:contain; transition:transform .18s ease;"
                                     onmouseover="this.style.transform='scale(1.04)';"
                                     onmouseout="this.style.transform='scale(1)';" />
                            }
                            else
                            {
                                <div style="width:100%; height:100%; border:2px dashed #cad5e0; border-radius:12px; display:flex; align-items:center; justify-content:center; color:#94a3b8; font-size:.9rem; font-weight:800;">
                                    Няма корица
                                </div>
                            }
                        </div>

                        <div style="margin-top:12px; color:#0f172a; font-size:.96rem; font-weight:900; line-height:1.38; min-height:52px; overflow:hidden; display:-webkit-box; -webkit-line-clamp:2; -webkit-box-orient:vertical;">
                            @book.Title
                        </div>

                        <div style="margin-top:6px; color:#94a3b8; font-size:.88rem; font-weight:700; min-height:20px; overflow:hidden; white-space:nowrap; text-overflow:ellipsis;">
                            @book.Author
                        </div>
                    </a>
                }
            </div>
        </section>
    }

    @if (similarBooks.Any())
    {
        <section style="background:#ffffff; border:1px solid #d8e1eb; border-radius:22px; overflow:hidden; box-shadow:0 12px 28px rgba(15,23,42,.05);">
            <div style="padding:16px 20px; border-bottom:1px solid #e2e8f0;">
                <h3 style="margin:0; color:#17325c; font-size:1.16rem; font-weight:900;">Подобни книги</h3>
            </div>

            <div style="padding:20px; display:grid; grid-template-columns:repeat(5, minmax(0,1fr)); gap:18px;">
                @foreach (var book in similarBooks)
                {
                    var similarCover = ResolveCoverUrl(book.CoverPath);

                    <a asp-controller="Catalog"
                       asp-action="ReaderDetails"
                       asp-route-id="@book.Id"
                       style="display:flex; flex-direction:column; text-decoration:none; border:1px solid #e6edf5; border-radius:18px; background:linear-gradient(180deg,#ffffff 0%,#fbfdff 100%); padding:12px; box-shadow:0 10px 20px rgba(15,23,42,.04); transition:all .18s ease;"
                       onmouseover="this.style.transform='translateY(-4px)'; this.style.boxShadow='0 16px 28px rgba(15,23,42,.10)'; this.style.borderColor='#d7e4ff';"
                       onmouseout="this.style.transform='translateY(0)'; this.style.boxShadow='0 10px 20px rgba(15,23,42,.04)'; this.style.borderColor='#e6edf5';">
                        <div style="height:220px; border-radius:13px; background:linear-gradient(180deg,#f8fbff 0%,#f1f6fb 100%); display:flex; align-items:center; justify-content:center; overflow:hidden; padding:10px;">
                            @if (!string.IsNullOrWhiteSpace(similarCover))
                            {
                                <img src="@similarCover"
                                     alt="@book.Title"
                                     style="max-width:100%; max-height:100%; object-fit:contain; transition:transform .18s ease;"
                                     onmouseover="this.style.transform='scale(1.04)';"
                                     onmouseout="this.style.transform='scale(1)';" />
                            }
                            else
                            {
                                <div style="width:100%; height:100%; border:2px dashed #cad5e0; border-radius:12px; display:flex; align-items:center; justify-content:center; color:#94a3b8; font-size:.9rem; font-weight:800;">
                                    Няма корица
                                </div>
                            }
                        </div>

                        <div style="margin-top:12px; color:#0f172a; font-size:.96rem; font-weight:900; line-height:1.38; min-height:52px; overflow:hidden; display:-webkit-box; -webkit-line-clamp:2; -webkit-box-orient:vertical;">
                            @book.Title
                        </div>

                        <div style="margin-top:6px; color:#94a3b8; font-size:.88rem; font-weight:700; min-height:20px; overflow:hidden; white-space:nowrap; text-overflow:ellipsis;">
                            @book.Author
                        </div>
                    </a>
                }
            </div>
        </section>
    }

</div>

<div id="readerBookNoteModal"
     style="display:none;
            position:fixed;
            inset:0;
            z-index:9998;
            background:rgba(15,23,42,.40);
            backdrop-filter:blur(4px);
            align-items:center;
            justify-content:center;
            padding:18px;">

    <div style="width:min(760px, 100%);
                max-height:88vh;
                overflow:auto;
                border-radius:26px;
                background:#fffef7;
                border:1px solid #eadf9f;
                box-shadow:0 30px 70px rgba(15,23,42,.20);
                padding:24px;">

        <div style="display:flex; align-items:flex-start; justify-content:space-between; gap:16px; margin-bottom:18px;">
            <div>
                <div style="color:#17325c; font-size:1.3rem; font-weight:900; line-height:1.2;">
                    @Model.Title
                </div>
                <div id="readerBookNoteModalMode"
                     style="margin-top:6px; color:#8a6f14; font-size:.85rem; font-weight:800;">
                    Нова бележка
                </div>
            </div>

            <button type="button"
                    onclick="closeReaderBookNoteModal()"
                    style="width:40px; height:40px; border:none; border-radius:12px; background:#fff3bf; color:#7c5d00; font-size:1.2rem; font-weight:900; cursor:pointer;">
                ×
            </button>
        </div>

        <input type="hidden" id="readerBookCurrentNoteId" value="" />

        <div id="readerBookNotePaper"
             contenteditable="true"
             spellcheck="true"
             style="min-height:360px;
                    padding:18px;
                    border:1px solid #e7d98c;
                    border-radius:18px;
                    outline:none;
                    background:
                        repeating-linear-gradient(
                            to bottom,
                            #fff7bf 0px,
                            #fff7bf 30px,
                            #eadf9f 31px
                        );
                    color:#5f4b00;
                    font-size:1rem;
                    line-height:31px;
                    white-space:pre-wrap;
                    overflow-wrap:anywhere;"></div>

        <div style="margin-top:18px; display:flex; align-items:center; justify-content:flex-end; gap:12px;">
            <button type="button"
                    id="readerBookDeleteBtn"
                    onclick="deleteReaderBookNote()"
                    style="display:none;
                           min-height:44px;
                           padding:0 16px;
                           border:none;
                           border-radius:12px;
                           background:#fee2e2;
                           color:#b42318;
                           font-size:.92rem;
                           font-weight:900;
                           cursor:pointer;">
                Изтрий
            </button>

            <button type="button"
                    onclick="closeReaderBookNoteModal()"
                    style="min-height:44px;
                           padding:0 18px;
                           border:1px solid #d8e1eb;
                           border-radius:12px;
                           background:#ffffff;
                           color:#334155;
                           font-size:.92rem;
                           font-weight:900;
                           cursor:pointer;">
                Затвори
            </button>

            <button type="button"
                    onclick="saveReaderBookNote()"
                    style="min-height:44px;
                           padding:0 20px;
                           border:none;
                           border-radius:12px;
                           background:linear-gradient(180deg,#facc15 0%,#eab308 100%);
                           color:#5f4b00;
                           font-size:.92rem;
                           font-weight:900;
                           cursor:pointer;
                           box-shadow:0 10px 22px rgba(234,179,8,.24);">
                Запази
            </button>
        </div>
    </div>
</div>

<script>
    const readerBookNotesGrid = document.getElementById("readerBookNotesGrid");
    const readerBookId = readerBookNotesGrid?.getAttribute("data-book-id");

    function escapeHtml(text) {
        return (text || "")
            .replaceAll("&", "&amp;")
            .replaceAll("<", "&lt;")
            .replaceAll(">", "&gt;")
            .replaceAll('"', "&quot;")
            .replaceAll("'", "&#39;");
    }

    function buildReaderBookNoteCard(note) {
        const preview = (note.text || "").length > 260
            ? note.text.substring(0, 260) + "..."
            : (note.text || "");

        const dateLabel = note.updatedOn ? "Редактирана" : "Създадена";
        const dateValue = note.updatedOn || note.createdOn || "";

        return `
            <div class="reader-book-note-card"
                 data-note-id="${note.id}"
                 data-note-text="${escapeHtml(note.text || "")}"
                 onclick="openReaderBookNoteModal(this)"
                 style="position:relative;
                        min-height:240px;
                        border:1px solid #e7d98c;
                        border-radius:18px;
                        background:
                            repeating-linear-gradient(
                                to bottom,
                                #fff7bf 0px,
                                #fff7bf 30px,
                                #eadf9f 31px
                            );
                        box-shadow:0 14px 28px rgba(148, 122, 24, .16);
                        padding:18px 18px 16px 18px;
                        cursor:pointer;
                        transition:transform .18s ease, box-shadow .18s ease;
                        overflow:hidden;"
                 onmouseover="this.style.transform='translateY(-3px) rotate(-0.5deg)'; this.style.boxShadow='0 18px 34px rgba(148,122,24,.22)';"
                 onmouseout="this.style.transform='translateY(0) rotate(0deg)'; this.style.boxShadow='0 14px 28px rgba(148,122,24,.16)';">

                <div style="display:flex; align-items:flex-start; justify-content:space-between; gap:12px; margin-bottom:10px;">
                    <div style="color:#7c5d00; font-size:.75rem; font-weight:900; text-transform:uppercase; letter-spacing:.08em;">
                        Бележка
                    </div>

                    <div style="flex:0 0 auto; color:#b08900; font-size:1.15rem;">✎</div>
                </div>

                <div style="white-space:pre-line;
                            color:#5f4b00;
                            font-size:.95rem;
                            line-height:31px;
                            min-height:124px;
                            max-height:124px;
                            overflow:hidden;
                            padding-top:2px;">
                    ${escapeHtml(preview)}
                </div>

                <div style="margin-top:14px; display:flex; align-items:center; justify-content:space-between; gap:10px;">
                    <div style="color:#8a6f14; font-size:.76rem; font-weight:800;">
                        ${dateLabel}
                    </div>

                    <div style="color:#8a6f14; font-size:.76rem; font-weight:900;">
                        ${dateValue}
                    </div>
                </div>
            </div>
        `;
    }

    function buildReaderBookAddCard() {
        return `
            <div onclick="openCreateReaderBookNoteModal()"
                 style="min-height:240px;
                        border:2px dashed #e7d98c;
                        border-radius:18px;
                        background:
                            repeating-linear-gradient(
                                to bottom,
                                #fffbe0 0px,
                                #fffbe0 30px,
                                #f2e8b5 31px
                            );
                        box-shadow:0 10px 24px rgba(148, 122, 24, .10);
                        padding:18px;
                        cursor:pointer;
                        display:flex;
                        flex-direction:column;
                        align-items:center;
                        justify-content:center;
                        text-align:center;
                        transition:transform .18s ease, box-shadow .18s ease;"
                 onmouseover="this.style.transform='translateY(-3px)'; this.style.boxShadow='0 16px 30px rgba(148,122,24,.16)';"
                 onmouseout="this.style.transform='translateY(0)'; this.style.boxShadow='0 10px 24px rgba(148,122,24,.10)';">
                <div style="width:56px; height:56px; border-radius:16px; background:#fff3bf; color:#a16207; display:flex; align-items:center; justify-content:center; font-size:2rem; font-weight:500; box-shadow:inset 0 0 0 1px #f2e29a;">
                    +
                </div>

                <div style="margin-top:14px; color:#7c5d00; font-size:1rem; font-weight:900;">
                    Нова бележка
                </div>

                <div style="margin-top:6px; color:#8a6f14; font-size:.87rem; font-weight:700; line-height:1.5;">
                    Натисни, за да запишеш мисъл, цитат или кратка идея за книгата.
                </div>
            </div>
        `;
    }

    async function loadReaderBookNotes() {
        if (!readerBookNotesGrid || !readerBookId) {
            return;
        }

        readerBookNotesGrid.innerHTML = `
            <div style="grid-column:1/-1; color:#64748b; font-weight:700; padding:8px 2px;">
                Зареждане на бележките...
            </div>
        `;

        try {
            const response = await fetch(`@Url.Action("GetNotesForBook", "ReaderPortal")?bookId=${readerBookId}`);

            if (!response.ok) {
                readerBookNotesGrid.innerHTML = `
                    <div style="grid-column:1/-1; color:#b42318; font-weight:700; padding:8px 2px;">
                        Бележките не можаха да бъдат заредени.
                    </div>
                `;
                return;
            }

            const notes = await response.json();
            let html = buildReaderBookAddCard();

            for (const note of notes) {
                html += buildReaderBookNoteCard(note);
            }

            readerBookNotesGrid.innerHTML = html;
        } catch {
            readerBookNotesGrid.innerHTML = `
                <div style="grid-column:1/-1; color:#b42318; font-weight:700; padding:8px 2px;">
                    Бележките не можаха да бъдат заредени.
                </div>
            `;
        }
    }

    function openCreateReaderBookNoteModal() {
        document.getElementById("readerBookCurrentNoteId").value = "";
        document.getElementById("readerBookNotePaper").innerText = "";
        document.getElementById("readerBookDeleteBtn").style.display = "none";
        document.getElementById("readerBookNoteModalMode").textContent = "Нова бележка";
        document.getElementById("readerBookNoteModal").style.display = "flex";
    }

    function openReaderBookNoteModal(card) {
        const noteId = card.getAttribute("data-note-id") || "";
        const text = card.getAttribute("data-note-text") || "";

        document.getElementById("readerBookCurrentNoteId").value = noteId;
        document.getElementById("readerBookNotePaper").innerText = text;
        document.getElementById("readerBookDeleteBtn").style.display = noteId ? "inline-flex" : "none";
        document.getElementById("readerBookNoteModalMode").textContent = "Редакция на бележка";
        document.getElementById("readerBookNoteModal").style.display = "flex";
    }

    function closeReaderBookNoteModal() {
        document.getElementById("readerBookNoteModal").style.display = "none";
    }

    async function saveReaderBookNote() {
        const noteId = document.getElementById("readerBookCurrentNoteId").value;
        const paper = document.getElementById("readerBookNotePaper");
        const text = (paper.innerText || "").trim();

        if (!text) {
            alert("Бележката не може да бъде празна.");
            return;
        }

        const tokenInput = document.querySelector('input[name="__RequestVerificationToken"]');
        const token = tokenInput ? tokenInput.value : "";

        const isEdit = !!noteId;
        const url = isEdit
            ? '@Url.Action("UpdateNote", "ReaderPortal")'
            : '@Url.Action("CreateNote", "ReaderPortal")';

        const formData = new URLSearchParams();

        if (isEdit) {
            formData.append("noteId", noteId);
        } else {
            formData.append("bookId", readerBookId);
        }

        formData.append("text", text);
        formData.append("__RequestVerificationToken", token);

        const response = await fetch(url, {
            method: "POST",
            headers: {
                "Content-Type": "application/x-www-form-urlencoded; charset=UTF-8"
            },
            body: formData.toString()
        });

        if (response.ok) {
            closeReaderBookNoteModal();
            await loadReaderBookNotes();
            return;
        }

        alert("Възникна проблем при запазването на бележката.");
    }

    async function deleteReaderBookNote() {
        const noteId = document.getElementById("readerBookCurrentNoteId").value;

        if (!noteId) {
            return;
        }

        if (!confirm("Сигурна ли си, че искаш да изтриеш тази бележка?")) {
            return;
        }

        const tokenInput = document.querySelector('input[name="__RequestVerificationToken"]');
        const token = tokenInput ? tokenInput.value : "";

        const formData = new URLSearchParams();
        formData.append("noteId", noteId);
        formData.append("__RequestVerificationToken", token);

        const response = await fetch('@Url.Action("DeleteNote", "ReaderPortal")', {
            method: "POST",
            headers: {
                "Content-Type": "application/x-www-form-urlencoded; charset=UTF-8"
            },
            body: formData.toString()
        });

        if (response.ok) {
            closeReaderBookNoteModal();
            await loadReaderBookNotes();
            return;
        }

        alert("Възникна проблем при изтриването на бележката.");
    }

    document.addEventListener("keydown", function (e) {
        if (e.key === "Escape") {
            closeReaderBookNoteModal();
        }
    });

    document.getElementById("readerBookNoteModal")?.addEventListener("click", function (e) {
        if (e.target === this) {
            closeReaderBookNoteModal();
        }
    });

    document.addEventListener("DOMContentLoaded", loadReaderBookNotes);
</script>