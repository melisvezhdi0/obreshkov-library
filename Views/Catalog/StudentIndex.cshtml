@model ObreshkovLibrary.Models.ViewModels.CatalogIndexVM
@using ObreshkovLibrary.Models
@using System.Linq
@using System.Collections.Generic

@{
    Layout = "~/Views/Shared/_StudentLayout.cshtml";
    ViewData["Title"] = "Каталог";

    var categories = Model.Categories ?? new List<Category>();
    var favoriteBookIds = ViewBag.FavoriteBookIds as List<int> ?? new List<int>();

    var rootCategories = categories
        .Where(c => c.ParentCategoryId == null)
        .OrderBy(c => c.Name)
        .ToList();

    var openIds = new HashSet<int>();

    if (Model.SelectedCategoryId.HasValue)
    {
        var current = categories.FirstOrDefault(c => c.Id == Model.SelectedCategoryId.Value);
        while (current != null)
        {
            openIds.Add(current.Id);
            current = current.ParentCategoryId.HasValue
                ? categories.FirstOrDefault(c => c.Id == current.ParentCategoryId.Value)
                : null;
        }
    }

    string GetCover(Book book)
    {
        if (string.IsNullOrWhiteSpace(book.CoverPath))
            return "";

        return book.CoverPath.StartsWith("/")
            ? Url.Content("~" + book.CoverPath)
            : Url.Content("~/" + book.CoverPath.TrimStart('/'));
    }

    List<Category> GetChildren(int parentId)
        => categories.Where(c => c.ParentCategoryId == parentId).OrderBy(c => c.Name).ToList();

    var currentReturnUrl = $"{Context.Request.Path}{Context.Request.QueryString}";
    var booksCount = Model.Books?.Count ?? 0;
}

<div style="width:100%; margin:0; padding:0; background:
    radial-gradient(circle at 10% 12%, rgba(37,99,235,.03), transparent 24%),
    radial-gradient(circle at 92% 8%, rgba(59,130,246,.025), transparent 20%),
    linear-gradient(180deg, #f8fafc 0%, #f4f7fb 100%);">

    <div style="display:grid; grid-template-columns:214px minmax(0,1fr); min-height:calc(100vh - 78px); border-top:1px solid #e5e7eb;">

        <aside style="background:linear-gradient(180deg,#f8fafc 0%,#f4f7fb 100%); border-right:1px solid #e2e8f0; min-width:0;">
            <div style="position:sticky; top:0; height:calc(100vh - 78px); overflow-y:auto; overflow-x:hidden;">

                <div style="padding:16px 12px 10px 12px; border-bottom:1px solid #e5e7eb; background:rgba(248,250,252,.95); backdrop-filter:blur(8px);">
                    <div style="color:#64748b; font-size:.7rem; font-weight:800; letter-spacing:.08em; text-transform:uppercase;">
                        Каталог
                    </div>

                    <h1 style="margin:7px 0 0 0; color:#17325c; font-size:1.05rem; font-weight:900; line-height:1.1;">
                        Книги
                    </h1>

                    <p style="margin:5px 0 0 0; color:#64748b; font-size:.8rem; font-weight:700; line-height:1.4;">
                        Подреди по категории.
                    </p>
                </div>

                <div style="padding:10px 9px; display:flex; flex-direction:column; gap:7px;">
                    <a asp-controller="Catalog"
                       asp-action="StudentIndex"
                       asp-route-search="@Model.Search"
                       asp-route-sort="@Model.Sort"
                       style="display:flex; align-items:center; gap:8px; padding:11px 12px; border-radius:12px; text-decoration:none; font-weight:900; font-size:.9rem; color:@(Model.SelectedCategoryId == null ? "#1d4ed8" : "#334155"); background:@(Model.SelectedCategoryId == null ? "#eef4ff" : "#ffffff"); border:1px solid @(Model.SelectedCategoryId == null ? "#dbe7fb" : "#e5e7eb"); box-shadow:@(Model.SelectedCategoryId == null ? "0 8px 16px rgba(37,99,235,.08)" : "0 2px 8px rgba(15,23,42,.025)"); transition:all .18s ease;"
                       onmouseover="this.style.background='#f3f6fa'; this.style.borderColor='#dbe7fb'; this.style.color='#1d4ed8';"
                       onmouseout="this.style.background='@(Model.SelectedCategoryId == null ? "#eef4ff" : "#ffffff")'; this.style.borderColor='@(Model.SelectedCategoryId == null ? "#dbe7fb" : "#e5e7eb")'; this.style.color='@(Model.SelectedCategoryId == null ? "#1d4ed8" : "#334155")';">
                        <span style="width:8px; height:8px; border-radius:999px; background:@(Model.SelectedCategoryId == null ? "#2563eb" : "#cbd5e1");"></span>
                        <span>Всички книги</span>
                    </a>

                    @foreach (var root in rootCategories)
                    {
                        var children = GetChildren(root.Id);
                        var open = openIds.Contains(root.Id);
                        var selected = Model.SelectedCategoryId == root.Id;

                        <div style="border-radius:13px; background:#ffffff; border:1px solid #e7edf4; overflow:hidden; box-shadow:0 2px 8px rgba(15,23,42,.02); transition:border-color .18s ease, box-shadow .18s ease;"
                             onmouseover="this.style.borderColor='#dbe4ee'; this.style.boxShadow='0 8px 18px rgba(15,23,42,.045)';"
                             onmouseout="this.style.borderColor='#e7edf4'; this.style.boxShadow='0 2px 8px rgba(15,23,42,.02)';">

                            <div style="display:flex; align-items:center; gap:7px; padding:7px;">
                                @if (children.Any())
                                {
                                    <button type="button"
                                            class="tree-toggle-btn"
                                            data-target="student-cat-@root.Id"
                                            style="width:28px; height:28px; min-width:28px; border:none; border-radius:8px; background:@(open ? "#e8f0ff" : "#f1f5f9"); color:#2563eb; font-weight:900; cursor:pointer; transition:all .18s ease;"
                                            onmouseover="this.style.background='#e8f0ff';"
                                            onmouseout="this.style.background='@(open ? "#e8f0ff" : "#f1f5f9")';">
                                        <span class="tree-plus" style="display:@(open ? "none" : "inline")">+</span>
                                        <span class="tree-minus" style="display:@(open ? "inline" : "none")">−</span>
                                    </button>
                                }
                                else
                                {
                                    <span style="width:28px; height:28px; min-width:28px; border-radius:8px; background:#f1f5f9; display:inline-flex; align-items:center; justify-content:center; color:#cbd5e1; font-weight:900;">•</span>
                                }

                                <a asp-controller="Catalog"
                                   asp-action="StudentIndex"
                                   asp-route-categoryId="@root.Id"
                                   asp-route-search="@Model.Search"
                                   asp-route-sort="@Model.Sort"
                                   style="flex:1; display:block; padding:8px 8px; border-radius:9px; text-decoration:none; font-size:.85rem; font-weight:900; line-height:1.35; color:@(selected ? "#1d4ed8" : "#334155"); background:@(selected ? "#eef4ff" : "transparent"); border-left:3px solid @(selected ? "#2563eb" : "transparent"); transition:all .18s ease;"
                                   onmouseover="this.style.background='#f3f6fa'; this.style.color='#1d4ed8'; this.style.borderLeftColor='#2563eb';"
                                   onmouseout="this.style.background='@(selected ? "#eef4ff" : "transparent")'; this.style.color='@(selected ? "#1d4ed8" : "#334155")'; this.style.borderLeftColor='@(selected ? "#2563eb" : "transparent")';">
                                    @root.Name
                                </a>
                            </div>

                            @if (children.Any())
                            {
                                <div id="student-cat-@root.Id" style="display:@(open ? "block" : "none"); padding:0 7px 7px 7px;">
                                    <div style="margin-left:35px; display:flex; flex-direction:column; gap:5px;">
                                        @foreach (var child in children)
                                        {
                                            var selectedChild = Model.SelectedCategoryId == child.Id;

                                            <a asp-controller="Catalog"
                                               asp-action="StudentIndex"
                                               asp-route-categoryId="@child.Id"
                                               asp-route-search="@Model.Search"
                                               asp-route-sort="@Model.Sort"
                                               style="display:block; padding:7px 9px; border-radius:9px; text-decoration:none; font-size:.77rem; font-weight:800; color:@(selectedChild ? "#1d4ed8" : "#52667d"); background:@(selectedChild ? "#eef4ff" : "#f8fafc"); transition:all .18s ease;"
                                               onmouseover="this.style.background='#f1f5f9'; this.style.color='#1d4ed8';"
                                               onmouseout="this.style.background='@(selectedChild ? "#eef4ff" : "#f8fafc")'; this.style.color='@(selectedChild ? "#1d4ed8" : "#52667d")';">
                                                @child.Name
                                            </a>
                                        }
                                    </div>
                                </div>
                            }
                        </div>
                    }
                </div>
            </div>
        </aside>

        <section style="padding:14px 16px 16px 16px; min-width:0;">
            <section style="border:1px solid #e3e8ef; border-radius:20px; background:rgba(255,255,255,.97); overflow:hidden; box-shadow:0 10px 24px rgba(15,23,42,.04);">

                <div style="padding:12px 14px 10px 14px; border-bottom:1px solid #e8edf4; background:linear-gradient(180deg,#ffffff 0%,#fbfdff 100%);">
                    <form method="get"
                          asp-action="StudentIndex"
                          style="display:grid; grid-template-columns:minmax(0,1fr) 220px 108px; gap:10px; align-items:center; margin:0;">

                        <input type="hidden" name="categoryId" value="@Model.SelectedCategoryId" />

                        <div style="position:relative;">
                            <span style="position:absolute; left:16px; top:50%; transform:translateY(-50%); color:#94a3b8; display:flex; align-items:center; pointer-events:none;">
                                <svg xmlns="http://www.w3.org/2000/svg"
                                     width="20"
                                     height="20"
                                     fill="none"
                                     stroke="currentColor"
                                     stroke-width="2"
                                     stroke-linecap="round"
                                     stroke-linejoin="round"
                                     viewBox="0 0 24 24">
                                    <circle cx="11" cy="11" r="7"></circle>
                                    <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
                                </svg>
                            </span>

                            <input name="search"
                                   value="@Model.Search"
                                   style="width:100%; height:44px; border-radius:14px; border:1px solid #dbe4ee; padding:0 44px 0 46px; font-weight:800; color:#0f172a; background:#ffffff; outline:none;"
                                   onfocus="this.style.borderColor='#bfd4ff'; this.style.boxShadow='0 0 0 4px rgba(37,99,235,.08)';"
                                   onblur="this.style.borderColor='#dbe4ee'; this.style.boxShadow='none';" />

                            @if (!string.IsNullOrWhiteSpace(Model.Search))
                            {
                                <a asp-controller="Catalog"
                                   asp-action="StudentIndex"
                                   asp-route-categoryId="@Model.SelectedCategoryId"
                                   asp-route-sort="@Model.Sort"
                                   style="position:absolute; right:12px; top:50%; transform:translateY(-50%); width:24px; height:24px; border-radius:999px; display:flex; align-items:center; justify-content:center; color:#94a3b8; text-decoration:none; font-size:1rem; font-weight:900; transition:all .18s ease;"
                                   onmouseover="this.style.background='#f1f5f9'; this.style.color='#475569';"
                                   onmouseout="this.style.background='transparent'; this.style.color='#94a3b8';"
                                   title="Изчисти търсенето">
                                    ×
                                </a>
                            }
                        </div>

                        <select name="sort"
                                style="height:44px; border-radius:14px; border:1px solid #dbe4ee; padding:0 14px; font-weight:900; color:#0f172a; background:#ffffff; outline:none;"
                                onfocus="this.style.borderColor='#bfd4ff'; this.style.boxShadow='0 0 0 4px rgba(37,99,235,.08)';"
                                onblur="this.style.borderColor='#dbe4ee'; this.style.boxShadow='none';">
                            <option value="date_desc" selected="@(Model.Sort == "date_desc")">Най-нови първо</option>
                            <option value="date_asc" selected="@(Model.Sort == "date_asc")">Най-стари първо</option>
                            <option value="name_asc" selected="@(Model.Sort == "name_asc")">Име А-Я</option>
                            <option value="name_desc" selected="@(Model.Sort == "name_desc")">Име Я-А</option>
                        </select>

                        <button type="submit"
                                style="height:44px; border:none; border-radius:14px; background:linear-gradient(180deg,#2563eb 0%,#1d4ed8 100%); color:#ffffff; font-weight:900; cursor:pointer; box-shadow:0 10px 20px rgba(37,99,235,.18); transition:all .18s ease;"
                                onmouseover="this.style.transform='translateY(-1px)'; this.style.boxShadow='0 14px 24px rgba(37,99,235,.24)';"
                                onmouseout="this.style.transform='translateY(0)'; this.style.boxShadow='0 10px 20px rgba(37,99,235,.18)';">
                            Търси
                        </button>
                    </form>
                </div>

                <div style="padding:14px 18px 6px 18px; display:flex; align-items:end; justify-content:space-between; gap:14px; flex-wrap:wrap;">
                    <div>
                        <h2 style="margin:0; font-size:2rem; font-weight:900; color:#17325c; line-height:1.04;">
                            @Model.SelectedCategoryName
                        </h2>
                        <div style="width:58px; height:4px; border-radius:999px; background:linear-gradient(90deg,#2563eb 0%,#60a5fa 100%); margin-top:9px;"></div>
                    </div>

                    <div style="display:inline-flex; align-items:center; gap:8px; padding:8px 12px; border-radius:999px; background:#f8fbff; border:1px solid #dbe7fb; color:#33527c; font-size:.82rem; font-weight:900;">
                        <span style="width:8px; height:8px; border-radius:999px; background:#2563eb;"></span>
                        @booksCount @(booksCount == 1 ? "книга" : "книги")
                    </div>
                </div>

                @if (Model.Books != null && Model.Books.Any())
                {
                    <div style="padding:12px 18px 18px 18px; display:grid; grid-template-columns:repeat(5, minmax(0,1fr)); gap:16px;">
                        @foreach (var book in Model.Books)
                        {
                            var cover = GetCover(book);
                            var isInReadingList = favoriteBookIds.Contains(book.Id);

                            <div style="position:relative; border-radius:20px; overflow:hidden; background:linear-gradient(180deg,#ffffff 0%,#fbfdff 100%); border:1px solid #e6edf5; box-shadow:0 6px 16px rgba(15,23,42,.035); transition:all .2s ease;"
                                 onmouseover="this.style.transform='translateY(-4px)'; this.style.boxShadow='0 16px 30px rgba(15,23,42,.09)'; this.style.borderColor='#d7e4ff'; this.querySelector('.book-overlay').style.opacity='1'; this.querySelector('.book-image').style.transform='scale(1.035)';"
                                 onmouseout="this.style.transform='translateY(0)'; this.style.boxShadow='0 6px 16px rgba(15,23,42,.035)'; this.style.borderColor='#e6edf5'; this.querySelector('.book-overlay').style.opacity='0'; this.querySelector('.book-image').style.transform='scale(1)';">

                                <form asp-controller="StudentPortal"
                                      asp-action="ToggleFavorite"
                                      method="post"
                                      style="position:absolute; top:10px; right:10px; z-index:4; margin:0;">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="bookId" value="@book.Id" />
                                    <input type="hidden" name="returnUrl" value="@currentReturnUrl" />

                                    <button type="submit"
                                            title="@(isInReadingList ? "Премахни от списъка за четене" : "Добави в списъка за четене")"
                                            aria-label="@(isInReadingList ? "Премахни от списъка за четене" : "Добави в списъка за четене")"
                                            style="width:40px; height:40px; border:1px solid @(isInReadingList ? "#2563eb" : "#d7e3f4"); border-radius:12px; background:@(isInReadingList ? "linear-gradient(180deg,#2563eb 0%,#1d4ed8 100%)" : "rgba(255,255,255,.98)"); color:@(isInReadingList ? "#ffffff" : "#2563eb"); display:flex; align-items:center; justify-content:center; cursor:pointer; box-shadow:0 10px 18px rgba(15,23,42,.12); transition:all .18s ease;"
                                            onmouseover="this.style.transform='translateY(-1px) scale(1.05)';"
                                            onmouseout="this.style.transform='translateY(0) scale(1)';">
                                        @if (isInReadingList)
                                        {
                                            <svg xmlns="http://www.w3.org/2000/svg"
                                                 width="17"
                                                 height="17"
                                                 viewBox="0 0 16 16"
                                                 fill="currentColor"
                                                 style="display:block;">
                                                <path d="M2 2a2 2 0 0 1 2-2h7a1 1 0 0 1 1 1v13l-4-2-4 2V2z" />
                                            </svg>
                                        }
                                        else
                                        {
                                            <svg xmlns="http://www.w3.org/2000/svg"
                                                 width="17"
                                                 height="17"
                                                 viewBox="0 0 16 16"
                                                 fill="currentColor"
                                                 style="display:block;">
                                                <path d="M2 1.5A1.5 1.5 0 0 1 3.5 0h7A1.5 1.5 0 0 1 12 1.5V14l-5-2.5L2 14V1.5zM3.5 1a.5.5 0 0 0-.5.5v10.691l4-2 4 2V1.5a.5.5 0 0 0-.5-.5h-7z" />
                                            </svg>
                                        }
                                    </button>
                                </form>

                                <a asp-controller="Catalog"
                                   asp-action="StudentDetails"
                                   asp-route-id="@book.Id"
                                   style="text-decoration:none; color:inherit; display:block;">

                                    <div style="position:relative; height:100%; min-height:250px; display:flex; align-items:center; justify-content:center; padding:12px; background:linear-gradient(180deg,#f8fbff 0%,#f4f7fb 100%);">
                                        @if (!string.IsNullOrEmpty(cover))
                                        {
                                            <img src="@cover"
                                                 alt="@book.Title"
                                                 class="book-image"
                                                 style="width:100%; height:226px; object-fit:contain; display:block; transition:transform .22s ease;" />
                                        }
                                        else
                                        {
                                            <div style="width:100%; height:226px; border:2px dashed #d7dfeb; border-radius:14px; display:flex; align-items:center; justify-content:center; color:#94a3b8; font-size:.82rem; font-weight:800; text-align:center; padding:8px; background:#ffffff;">
                                                Няма корица
                                            </div>
                                        }

                                        <div class="book-overlay"
                                             style="position:absolute; inset:0; border-radius:20px; background:linear-gradient(180deg, rgba(15,23,42,.04) 0%, rgba(15,23,42,.18) 35%, rgba(15,23,42,.80) 100%); display:flex; align-items:flex-end; padding:14px; opacity:0; transition:opacity .22s ease; z-index:2;">
                                            <div style="width:100%;">
                                                <div title="@book.Title"
                                                     style="color:#ffffff; font-size:.95rem; font-weight:900; line-height:1.22; overflow:hidden; display:-webkit-box; -webkit-line-clamp:2; -webkit-box-orient:vertical; text-shadow:0 2px 12px rgba(0,0,0,.25);">
                                                    @book.Title
                                                </div>

                                                <div title="@book.Author"
                                                     style="margin-top:6px; color:rgba(255,255,255,.88); font-size:.82rem; font-weight:700; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; text-shadow:0 2px 10px rgba(0,0,0,.2);">
                                                    @book.Author
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </a>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div style="padding:24px 20px 22px 20px; color:#64748b; font-size:1rem; font-weight:700;">
                        Няма намерени книги за избраните критерии.
                    </div>
                }
            </section>
        </section>
    </div>
</div>

@section Scripts {
    <script>
        document.querySelectorAll(".tree-toggle-btn").forEach(btn => {
            btn.addEventListener("click", () => {
                const target = document.getElementById(btn.dataset.target);
                const plus = btn.querySelector(".tree-plus");
                const minus = btn.querySelector(".tree-minus");

                if (target.style.display === "none") {
                    target.style.display = "block";
                    plus.style.display = "none";
                    minus.style.display = "inline";
                } else {
                    target.style.display = "none";
                    plus.style.display = "inline";
                    minus.style.display = "none";
                }
            });
        });
    </script>
}