@model IEnumerable<ObreshkovLibrary.Models.ViewModels.StudentFavoriteBookVM>

@{
    ViewData["Title"] = "Любими книги";
    var returnUrl = $"{Context.Request.Path}{Context.Request.QueryString}";
}

<div style="width:min(1240px, calc(100% - 24px)); margin:28px auto 40px;">

    <div style="background:#fff; border:1px solid #d8e1eb; border-radius:24px; padding:26px; margin-bottom:22px;">
        <h1 style="margin:0; color:#17325c; font-size:2rem; font-weight:900;">Любими книги</h1>
        <div style="width:62px; height:4px; border-radius:999px; margin-top:10px; background:linear-gradient(90deg,#2563eb 0%,#60a5fa 100%);"></div>
    </div>

    @if (Model.Any())
    {
        <div style="display:grid; grid-template-columns:repeat(4, minmax(0,1fr)); gap:18px;">
            @foreach (var item in Model)
            {
                <div style="background:#fff; border:1px solid #d8e1eb; border-radius:22px; padding:16px;">
                    <div style="height:240px; border:1px solid #e2e8f0; border-radius:16px; background:#f8fbff; display:flex; align-items:center; justify-content:center; overflow:hidden;">
                        @if (!string.IsNullOrWhiteSpace(item.CoverPath))
                        {
                            <img src="@Url.Content("~/" + item.CoverPath)" alt="@item.Title" style="max-width:100%; max-height:100%; object-fit:contain;" />
                        }
                        else
                        {
                            <span style="color:#94a3b8; font-weight:700;">Няма корица</span>
                        }
                    </div>

                    <div style="margin-top:14px; color:#17325c; font-weight:900; font-size:1.05rem;">@item.Title</div>
                    <div style="margin-top:4px; color:#64748b; font-size:.95rem;">@item.Author</div>
                    <div style="margin-top:4px; color:#64748b; font-size:.9rem;">@item.CategoryName</div>

                    <div style="margin-top:10px;">
                        @if (item.IsAvailable)
                        {
                            <span class="badge text-bg-success">Налична</span>
                        }
                        else
                        {
                            <span class="badge text-bg-secondary">Не е налична</span>
                        }
                    </div>

                    <a asp-controller="Catalog"
                       asp-action="StudentDetails"
                       asp-route-id="@item.BookId"
                       class="btn btn-outline-primary w-100 mt-3">
                        Детайли
                    </a>

                    <form asp-action="ToggleFavorite" method="post" class="mt-2">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="bookId" value="@item.BookId" />
                        <input type="hidden" name="returnUrl" value="@returnUrl" />
                        <button type="submit" class="btn btn-outline-danger w-100">
                            Премахни от любими
                        </button>
                    </form>

                    @if (!item.IsAvailable)
                    {
                        <form asp-action="RequestAvailabilityNotification" method="post" class="mt-2">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="bookId" value="@item.BookId" />
                            <input type="hidden" name="returnUrl" value="@returnUrl" />
                            <button type="submit" class="btn btn-primary w-100">
                                Уведоми ме при наличност
                            </button>
                        </form>
                    }
                </div>
            }
        </div>
    }
    else
    {
        <div style="background:#fff; border:1px solid #d8e1eb; border-radius:24px; padding:22px; color:#64748b; font-weight:700;">
            Все още нямаш добавени любими книги.
        </div>
    }
</div>