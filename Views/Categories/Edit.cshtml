@model ObreshkovLibrary.Models.Category

@{
    ViewData["Title"] = "Редактиране на категория";
}

<div style="width:100%; padding-top:6px;">

    <div style="margin-bottom:14px;">
        <h2 class="section-title mb-1">Редактиране на категория</h2>
        <div class="accent-line"></div>
    </div>

    @if (TempData["Error"] != null)
    {
        <div style="max-width:760px; margin-bottom:14px; padding:12px 14px; border-radius:12px; border:1px solid #fecaca; background:#fef2f2; color:#b91c1c; font-weight:600;">
            @TempData["Error"]
        </div>
    }

    @if (TempData["Success"] != null)
    {
        <div style="max-width:760px; margin-bottom:14px; padding:12px 14px; border-radius:12px; border:1px solid #bbf7d0; background:#f0fdf4; color:#166534; font-weight:600;">
            @TempData["Success"]
        </div>
    }

    <section style="max-width:760px; background:#ffffff; border:1px solid #dbe5ef; border-radius:18px; padding:22px; box-shadow:0 10px 24px rgba(15,23,42,.04);">

        <form asp-action="Edit" method="post" style="margin:0;">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Id" />

            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div style="display:grid; gap:16px;">

                <div>
                    <label asp-for="Name" style="display:block; font-weight:800; color:#0f172a; margin-bottom:6px;">Име</label>
                    <input asp-for="Name"
                           class="form-control"
                           style="height:48px; border-radius:12px; border:1px solid #cbd5e1; box-shadow:none;" />
                    <span asp-validation-for="Name" class="text-danger"></span>
                </div>

                <div>
                    <label asp-for="ParentCategoryId" style="display:block; font-weight:800; color:#0f172a; margin-bottom:6px;">Родителска категория</label>
                    <select asp-for="ParentCategoryId"
                            asp-items="ViewBag.ParentCategoryId"
                            class="form-select"
                            style="height:48px; border-radius:12px; border:1px solid #cbd5e1; box-shadow:none;">
                        <option value="">(Няма)</option>
                    </select>
                    <span asp-validation-for="ParentCategoryId" class="text-danger"></span>
                    <div style="margin-top:7px; color:#64748b; font-size:.95rem;">
                        Избери родител, ако това е подкатегория.
                    </div>
                </div>

            </div>

            <div style="margin-top:22px; display:flex; justify-content:space-between; align-items:center; gap:12px; flex-wrap:wrap;">
                <div style="display:flex; gap:10px; flex-wrap:wrap;">
                    <button type="submit" class="btn btn-primary">
                        Запази
                    </button>

                    <a asp-action="Index" class="btn btn-outline-primary">
                        Назад
                    </a>
                </div>

                @if (Model.IsActive)
                {
                    <form asp-action="Deactivate"
                          asp-route-id="@Model.Id"
                          method="post"
                          style="margin:0;">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-outline-danger">
                            Деактивирай
                        </button>
                    </form>
                }
                else
                {
                    <span style="font-weight:700; color:#64748b;">Категорията е деактивирана</span>
                }
            </div>
        </form>

    </section>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}