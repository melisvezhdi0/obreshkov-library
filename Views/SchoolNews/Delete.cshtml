@model ObreshkovLibrary.Models.SchoolNews

@{
    ViewData["Title"] = "Изтриване на новина";
}

<div class="page-container" style="padding-top: 110px; padding-bottom: 28px;">
    <div class="mb-4">
        <h2 class="section-title mb-1">Изтриване на новина</h2>
        <div class="accent-line"></div>
    </div>

    <section class="card-soft" style="padding: 24px; border-radius: 18px; background: #ffffff;">
        <div class="alert alert-warning" style="border-radius: 14px;">
            Сигурна ли си, че искаш да изтриеш тази новина?
        </div>

        <div class="row g-4 align-items-start">
            <div class="col-md-4">
                @if (!string.IsNullOrWhiteSpace(Model.ImagePath))
                {
                    <img src="@Url.Content(Model.ImagePath)"
                         alt="@Model.Title"
                         style="width: 100%; border-radius: 14px; border: 1px solid #dbe5ef;" />
                }
            </div>

            <div class="col-md-8">
                <h4 style="font-weight: 800;">@Model.Title</h4>
                <div style="color:#64748b; margin-bottom: 10px;">@Model.PublishedOn.ToString("dd.MM.yyyy")</div>
                <p style="line-height:1.8;">@Model.Summary</p>
                <a href="@Model.NewsUrl" target="_blank">Отвори линка</a>
            </div>
        </div>

        <form asp-action="Delete" method="post" class="mt-4">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Id" />
            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-danger">Изтрий</button>
                <a asp-action="Index" class="btn btn-outline-secondary">Отказ</a>
            </div>
        </form>
    </section>
</div>