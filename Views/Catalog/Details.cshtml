@model ObreshkovLibrary.Models.Book
@using System.Linq
@using ObreshkovLibrary.Models
@using ObreshkovLibrary.Models.Enums

@{
    Layout = "~/Views/Shared/_PublicLayout.cshtml";
    ViewData["Title"] = Model.Title;

    var isAvailable = (ViewBag.IsAvailable as bool?) ?? false;
    var relatedBooks = (ViewBag.RelatedBooks as List<Book>) ?? new List<Book>();
    var similarBooks = (ViewBag.SimilarBooks as List<Book>) ?? new List<Book>();

    string ResolveCoverUrl(string? path)
    {
        if (string.IsNullOrWhiteSpace(path))
            return "";

        return path.StartsWith("/")
            ? Url.Content("~" + path)
            : Url.Content("~/" + path.TrimStart('/'));
    }

    var coverPathProp = Model.GetType().GetProperty("CoverPath");
    var coverUrlProp = Model.GetType().GetProperty("CoverUrl");
    var coverValue = coverPathProp?.GetValue(Model)?.ToString() ?? coverUrlProp?.GetValue(Model)?.ToString();
    var coverUrl = ResolveCoverUrl(coverValue);

    string? subCategoryName = Model.Category?.Name;
    string? parentCategoryName = Model.Category?.ParentCategory?.Name;

    string genreText = "Няма";
    if (!string.IsNullOrWhiteSpace(parentCategoryName) && !string.IsNullOrWhiteSpace(subCategoryName))
    {
        genreText = $"{parentCategoryName} / {subCategoryName}";
    }
    else if (!string.IsNullOrWhiteSpace(subCategoryName))
    {
        genreText = subCategoryName!;
    }

    List<string> tagNames = new();

    if ((Model.Tags & BookTags.BulgarianLiterature) == BookTags.BulgarianLiterature) tagNames.Add("Българска литература");
    if ((Model.Tags & BookTags.WorldLiterature) == BookTags.WorldLiterature) tagNames.Add("Световна литература");
    if ((Model.Tags & BookTags.BalkanLiterature) == BookTags.BalkanLiterature) tagNames.Add("Балканска литература");
    if ((Model.Tags & BookTags.AncientLiterature) == BookTags.AncientLiterature) tagNames.Add("Антична литература");
    if ((Model.Tags & BookTags.ClassicLiterature) == BookTags.ClassicLiterature) tagNames.Add("Класика");
    if ((Model.Tags & BookTags.ContemporaryLiterature) == BookTags.ContemporaryLiterature) tagNames.Add("Съвременна литература");

    if ((Model.Tags & BookTags.Love) == BookTags.Love) tagNames.Add("Любов");
    if ((Model.Tags & BookTags.Rebellion) == BookTags.Rebellion) tagNames.Add("Бунт");
    if ((Model.Tags & BookTags.Suffering) == BookTags.Suffering) tagNames.Add("Страдание");
    if ((Model.Tags & BookTags.Romantic) == BookTags.Romantic) tagNames.Add("Романтика");

    if ((Model.Tags & BookTags.Horror) == BookTags.Horror) tagNames.Add("Хорър");
    if ((Model.Tags & BookTags.Historical) == BookTags.Historical) tagNames.Add("Исторически");
    if ((Model.Tags & BookTags.ScienceFiction) == BookTags.ScienceFiction) tagNames.Add("Фантастика");
    if ((Model.Tags & BookTags.Fantasy) == BookTags.Fantasy) tagNames.Add("Фентъзи");
    if ((Model.Tags & BookTags.Psychological) == BookTags.Psychological) tagNames.Add("Психологически");
    if ((Model.Tags & BookTags.Social) == BookTags.Social) tagNames.Add("Социален");

    if ((Model.Tags & BookTags.RequiredReading) == BookTags.RequiredReading) tagNames.Add("Задължителна литература");
    if ((Model.Tags & BookTags.RecommendedReading) == BookTags.RecommendedReading) tagNames.Add("Препоръчителна литература");
    if ((Model.Tags & BookTags.ForMatura) == BookTags.ForMatura) tagNames.Add("За матура");

    if ((Model.Tags & BookTags.BulgarianAuthor) == BookTags.BulgarianAuthor) tagNames.Add("Български автор");
    if ((Model.Tags & BookTags.ForeignAuthor) == BookTags.ForeignAuthor) tagNames.Add("Чужд автор");

    if ((Model.Tags & BookTags.EducationalContent) == BookTags.EducationalContent) tagNames.Add("Учебно съдържание");
    if ((Model.Tags & BookTags.ClassicalWork) == BookTags.ClassicalWork) tagNames.Add("Класическо произведение");

    if ((Model.Tags & BookTags.Poetry) == BookTags.Poetry) tagNames.Add("Поезия");
    if ((Model.Tags & BookTags.Prose) == BookTags.Prose) tagNames.Add("Проза");
    if ((Model.Tags & BookTags.Dramaturgy) == BookTags.Dramaturgy) tagNames.Add("Драматургия");

    if ((Model.Tags & BookTags.Mathematics) == BookTags.Mathematics) tagNames.Add("Математика");
    if ((Model.Tags & BookTags.BulgarianLanguage) == BookTags.BulgarianLanguage) tagNames.Add("Български език");
    if ((Model.Tags & BookTags.History) == BookTags.History) tagNames.Add("История");
    if ((Model.Tags & BookTags.Geography) == BookTags.Geography) tagNames.Add("География");
    if ((Model.Tags & BookTags.Biology) == BookTags.Biology) tagNames.Add("Биология");
    if ((Model.Tags & BookTags.Chemistry) == BookTags.Chemistry) tagNames.Add("Химия");
    if ((Model.Tags & BookTags.Physics) == BookTags.Physics) tagNames.Add("Физика");
    if ((Model.Tags & BookTags.Philosophy) == BookTags.Philosophy) tagNames.Add("Философия");
    if ((Model.Tags & BookTags.IT) == BookTags.IT) tagNames.Add("Информационни технологии/Информатика");
}

<div style="width:min(1380px, calc(100% - 40px)); margin:28px auto 46px auto;">

    <div style="margin-bottom:24px;">
        <h1 style="margin:0; color:#17325c; font-size:2.15rem; line-height:1.14; font-weight:900; letter-spacing:-0.02em;">
            @Model.Title
        </h1>

        <div style="width:68px; height:4px; border-radius:999px; background:linear-gradient(90deg,#2563eb 0%,#60a5fa 100%); margin-top:12px;"></div>
    </div>

    <section style="background:linear-gradient(180deg,#ffffff 0%,#fbfdff 100%); border:1px solid #d8e1eb; border-radius:24px; overflow:hidden; margin-bottom:24px; box-shadow:0 16px 36px rgba(15,23,42,.06);">
        <div class="guest-book-layout" style="display:grid; grid-template-columns:320px minmax(0,1fr); gap:0; align-items:stretch;">

            <div class="guest-book-cover-panel" style="position:relative; background:linear-gradient(180deg,#f8fbff 0%,#f2f7fc 100%); border-right:1px solid #e2e8f0; padding:28px; display:flex; align-items:center; justify-content:center; min-height:460px;">
                @if (!string.IsNullOrWhiteSpace(coverUrl))
                {
                    <img src="@coverUrl"
                         alt="@Model.Title"
                         style="display:block; width:100%; max-width:240px; max-height:390px; object-fit:contain; filter:drop-shadow(0 18px 28px rgba(15,23,42,0.14)); transition:transform .2s ease;"
                         onmouseover="this.style.transform='translateY(-3px) scale(1.01)';"
                         onmouseout="this.style.transform='translateY(0) scale(1)';"
                         onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';" />
                    <div style="display:none; width:100%; min-height:340px; border:2px dashed #cad5e0; border-radius:18px; align-items:center; justify-content:center; color:#94a3b8; font-size:.95rem; font-weight:800; background:#f8fbff;">
                        Няма корица
                    </div>
                }
                else
                {
                    <div style="width:100%; min-height:340px; border:2px dashed #cad5e0; border-radius:18px; display:flex; align-items:center; justify-content:center; color:#94a3b8; font-size:.95rem; font-weight:800; background:#f8fbff;">
                        Няма корица
                    </div>
                }
            </div>

            <div style="min-width:0;">
                <div class="guest-book-info-grid" style="display:grid; grid-template-columns:220px minmax(0,1fr);">
                    <div style="padding:20px 18px; border-bottom:1px solid #e2e8f0; color:#64748b; font-weight:800;">Заглавие</div>
                    <div style="padding:20px 22px; border-bottom:1px solid #e2e8f0; color:#0f172a; font-weight:800; text-align:right;">
                        @(string.IsNullOrWhiteSpace(Model.Title) ? "Няма" : Model.Title)
                    </div>

                    <div style="padding:20px 18px; border-bottom:1px solid #e2e8f0; color:#64748b; font-weight:800;">Автор</div>
                    <div style="padding:20px 22px; border-bottom:1px solid #e2e8f0; color:#0f172a; font-weight:800; text-align:right;">
                        @(string.IsNullOrWhiteSpace(Model.Author) ? "Няма" : Model.Author)
                    </div>

                    <div style="padding:20px 18px; border-bottom:1px solid #e2e8f0; color:#64748b; font-weight:800;">Жанр</div>
                    <div style="padding:20px 22px; border-bottom:1px solid #e2e8f0; color:#0f172a; font-weight:800; text-align:right;">
                        @genreText
                    </div>

                    <div style="padding:20px 18px; border-bottom:1px solid #e2e8f0; color:#64748b; font-weight:800;">Година</div>
                    <div style="padding:20px 22px; border-bottom:1px solid #e2e8f0; color:#0f172a; font-weight:800; text-align:right;">
                        @(Model.Year.HasValue? Model.Year.ToString() : "Няма")
                    </div>

                    <div style="padding:20px 18px; border-bottom:1px solid #e2e8f0; color:#64748b; font-weight:800;">Класове</div>
                    <div style="padding:20px 22px; border-bottom:1px solid #e2e8f0; color:#0f172a; font-weight:800; text-align:right;">
                        @(string.IsNullOrWhiteSpace(Model.SchoolClass) ? "Не е посочен" : Model.SchoolClass)
                    </div>

                    <div style="padding:20px 18px; color:#64748b; font-weight:800;">Статус</div>
                    <div style="padding:20px 22px; text-align:right;">
                        @if (isAvailable)
                        {
                            <span style="display:inline-flex; align-items:center; justify-content:center; min-height:38px; padding:0 16px; border-radius:999px; font-size:.9rem; font-weight:900; background:linear-gradient(180deg,#e8f7ee 0%,#e0f4e9 100%); color:#2f7d32; border:1px solid #cfe7d3; box-shadow:0 6px 14px rgba(47,125,50,.08);">
                                Налична
                            </span>
                        }
                        else
                        {
                            <span style="display:inline-flex; align-items:center; justify-content:center; min-height:38px; padding:0 16px; border-radius:999px; font-size:.9rem; font-weight:900; background:linear-gradient(180deg,#fff7e8 0%,#fff2d7 100%); color:#c77a00; border:1px solid #ffe4a8; box-shadow:0 6px 14px rgba(199,122,0,.08);">
                                Заета
                            </span>
                        }
                    </div>
                </div>
            </div>
        </div>
    </section>

    <section style="background:#ffffff; border:1px solid #d8e1eb; border-radius:22px; overflow:hidden; margin-bottom:24px; box-shadow:0 12px 28px rgba(15,23,42,.05);">
        <div style="padding:16px 20px; border-bottom:1px solid #e2e8f0;">
            <h3 style="margin:0; color:#17325c; font-size:1.16rem; font-weight:900;">Ключови думи / съдържание</h3>
        </div>

        <div class="guest-keywords-grid" style="display:grid; grid-template-columns:220px minmax(0,1fr); border-bottom:1px solid #e2e8f0;">
            <div style="padding:16px 18px; color:#64748b; font-weight:800; border-right:1px solid #e2e8f0;">Ключови думи</div>
            <div style="padding:16px 18px; color:#0f172a; line-height:1.8;">
                @(string.IsNullOrWhiteSpace(Model.SearchKeywords) ? "Не са добавени" : Model.SearchKeywords)
            </div>
        </div>

        <div class="guest-tags-grid" style="display:grid; grid-template-columns:220px minmax(0,1fr);">
            <div style="padding:16px 18px; color:#64748b; font-weight:800; border-right:1px solid #e2e8f0;">Етикети</div>
            <div style="padding:16px 18px;">
                @if (tagNames.Any())
                {
                    <div style="display:flex; flex-wrap:wrap; gap:8px;">
                        @foreach (var tag in tagNames)
                        {
                            <span style="display:inline-flex; align-items:center; padding:.5rem .9rem; border-radius:999px; background:#eef4ff; color:#2563eb; font-weight:800; font-size:.9rem; border:1px solid #d7e4ff;">
                                @tag
                            </span>
                        }
                    </div>
                }
                else
                {
                    <span style="color:#0f172a;">Няма</span>
                }
            </div>
        </div>
    </section>

    <section style="background:#ffffff; border:1px solid #d8e1eb; border-radius:22px; overflow:hidden; box-shadow:0 12px 28px rgba(15,23,42,.05); margin-bottom:24px;">
        <div style="padding:16px 20px; border-bottom:1px solid #e2e8f0;">
            <h3 style="margin:0; color:#17325c; font-size:1.16rem; font-weight:900;">Описание</h3>
        </div>

        <div class="guest-description-text" style="padding:18px 22px 20px 22px;">
            @(string.IsNullOrWhiteSpace(Model.Description) ? "Няма описание за тази книга." : Model.Description)
        </div>
    </section>

    @if (relatedBooks.Any())
    {
        var shownRelatedBooks = relatedBooks.Take(5).ToList();

        <section style="background:#ffffff; border:1px solid #d8e1eb; border-radius:22px; overflow:hidden; margin-bottom:24px; box-shadow:0 12px 28px rgba(15,23,42,.05);">
            <div style="padding:16px 20px; border-bottom:1px solid #e2e8f0;">
                <h3 style="margin:0; color:#17325c; font-size:1.16rem; font-weight:900;">Още книги от същия автор</h3>
            </div>

            <div class="guest-catalog-strip" style="padding:18px;">
                @foreach (var book in shownRelatedBooks)
                {
                    var relatedCover = ResolveCoverUrl(book.CoverPath);

                    <a asp-controller="Catalog"
                       asp-action="Details"
                       asp-route-id="@book.Id"
                       class="guest-catalog-mini-card">
                        <div class="guest-catalog-mini-cover">
                            @if (!string.IsNullOrWhiteSpace(relatedCover))
                            {
                                <img src="@relatedCover" alt="@book.Title" />
                            }
                            else
                            {
                                <div style="width:100%; height:100%; border:2px dashed #cad5e0; border-radius:12px; display:flex; align-items:center; justify-content:center; color:#94a3b8; font-size:.9rem; font-weight:800;">
                                    Няма корица
                                </div>
                            }

                            <div class="guest-catalog-mini-overlay">
                                <div class="guest-catalog-mini-overlay-title">@book.Title</div>
                                <div class="guest-catalog-mini-overlay-author">@book.Author</div>
                            </div>
                        </div>
                    </a>
                }
            </div>
        </section>
    }

    @if (similarBooks.Any())
    {
        var shownSimilarBooks = similarBooks.Take(5).ToList();

        <section style="background:#ffffff; border:1px solid #d8e1eb; border-radius:22px; overflow:hidden; box-shadow:0 12px 28px rgba(15,23,42,.05);">
            <div style="padding:16px 20px; border-bottom:1px solid #e2e8f0;">
                <h3 style="margin:0; color:#17325c; font-size:1.16rem; font-weight:900;">Подобни книги</h3>
            </div>

            <div class="guest-catalog-strip" style="padding:18px;">
                @foreach (var book in shownSimilarBooks)
                {
                    var similarCover = ResolveCoverUrl(book.CoverPath);

                    <a asp-controller="Catalog"
                       asp-action="Details"
                       asp-route-id="@book.Id"
                       class="guest-catalog-mini-card">
                        <div class="guest-catalog-mini-cover">
                            @if (!string.IsNullOrWhiteSpace(similarCover))
                            {
                                <img src="@similarCover" alt="@book.Title" />
                            }
                            else
                            {
                                <div style="width:100%; height:100%; border:2px dashed #cad5e0; border-radius:12px; display:flex; align-items:center; justify-content:center; color:#94a3b8; font-size:.9rem; font-weight:800;">
                                    Няма корица
                                </div>
                            }

                            <div class="guest-catalog-mini-overlay">
                                <div class="guest-catalog-mini-overlay-title">@book.Title</div>
                                <div class="guest-catalog-mini-overlay-author">@book.Author</div>
                            </div>
                        </div>
                    </a>
                }
            </div>
        </section>
    }
</div>