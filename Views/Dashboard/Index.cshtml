@model ObreshkovLibrary.Models.ViewModels.HomeDashboardVM

@{
    ViewData["Title"] = "Начало";
}

<div style="width:100%; padding-top:6px;">

    <section class="dashboard-hover-card"
             style="margin-bottom:18px; padding:22px; border-radius:18px; background:#ffffff; border:1px solid #dbe5ef; box-shadow:0 10px 24px rgba(15,23,42,.04); transition:transform .18s ease, box-shadow .18s ease, border-color .18s ease;">
        <div style="display:grid; grid-template-columns:minmax(0,1.3fr) minmax(360px,.95fr); gap:18px; align-items:start;"
             id="dashboardHeroGrid">

            <div>
                <h2 class="section-title mb-1">Начало</h2>
                <div class="accent-line"></div>
                <div style="margin-top:10px; color:#64748b; font-size:1rem;">
                    Административен преглед на библиотеката
                </div>
            </div>

            <div class="dashboard-hover-card"
                 style="background:linear-gradient(180deg, #f8fbff 0%, #f4f8fd 100%); border:1px solid #dbe5ef; border-radius:18px; padding:18px; box-shadow:0 8px 18px rgba(15,23,42,.04); transition:transform .18s ease, box-shadow .18s ease, border-color .18s ease;">
                <div style="font-size:.82rem; text-transform:uppercase; font-weight:800; letter-spacing:.05em; color:#64748b; margin-bottom:12px;">
                    Бързо търсене по номер на карта
                </div>

                <form asp-controller="Dashboard"
                      asp-action="SearchByCardNumber"
                      method="post"
                      style="margin:0;">
                    @Html.AntiForgeryToken()

                    <input type="hidden" name="cardNumber" id="cardNumberHidden" />

                    <div id="dashboardSearchRow"
                         style="display:grid; grid-template-columns:1fr auto; gap:12px; align-items:center;">
                        <div id="cardDigitsWrapper"
                             style="display:flex; align-items:center; gap:8px; flex-wrap:nowrap; min-width:0;">
                            @for (int i = 0; i < 6; i++)
                            {
                                <input type="text"
                                       class="card-digit-box"
                                       inputmode="numeric"
                                       autocomplete="off"
                                       maxlength="1"
                                       data-index="@i"
                                       aria-label="Цифра @(i + 1)"
                                       style="width:44px;
                                                  height:48px;
                                                  border:1px solid #cbd5e1;
                                                  background:#ffffff;
                                                  text-align:center;
                                                  font-size:1.05rem;
                                                  font-weight:800;
                                                  color:#0f172a;
                                                  border-radius:12px;
                                                  outline:none;
                                                  box-shadow:inset 0 1px 2px rgba(15,23,42,.03);
                                                  transition:all .18s ease;" />
                            }
                        </div>

                        
                    </div>
                </form>
            </div>
        </div>
    </section>

    @if (TempData["HomeError"] != null)
    {
        <div style="margin-bottom:18px; padding:12px 14px; border:1px solid #fecaca; background:#fef2f2; color:#b91c1c; border-radius:12px; box-shadow:0 6px 16px rgba(127,29,29,.04);">
            @TempData["HomeError"]
        </div>
    }

    <section class="dashboard-hover-card"
             style="margin-bottom:18px; padding:20px; border-radius:18px; background:#ffffff; border:1px solid #dbe5ef; box-shadow:0 10px 24px rgba(15,23,42,.04); transition:transform .18s ease, box-shadow .18s ease, border-color .18s ease;">
        <div style="display:flex; justify-content:space-between; align-items:center; gap:12px; flex-wrap:wrap; margin-bottom:14px;">
            <h5 class="section-title mb-0">Последни заемания</h5>
        </div>

        @if (Model.LatestLoans == null || !Model.LatestLoans.Any())
        {
            <div style="padding:14px 0; color:#64748b;">Няма записи.</div>
        }
        else
        {
            <div style="overflow-x:auto;">
                <table style="width:100%; border-collapse:separate; border-spacing:0;">
                    <thead>
                        <tr style="background:#f8fbff;">
                            <th style="padding:14px; text-align:left; border-bottom:1px solid #dbe5ef;">Читател</th>
                            <th style="padding:14px; text-align:left; border-bottom:1px solid #dbe5ef;">№ карта</th>
                            <th style="padding:14px; text-align:left; border-bottom:1px solid #dbe5ef;">Книга</th>
                            <th style="padding:14px; text-align:left; border-bottom:1px solid #dbe5ef;">Заета на</th>
                            <th style="padding:14px; text-align:left; border-bottom:1px solid #dbe5ef;">Срок</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var l in Model.LatestLoans)
                        {
                            <tr class="dashboard-table-row" style="transition:background .18s ease;">
                                <td style="padding:14px; border-bottom:1px solid #edf2f7;">@($"{l.Client?.FirstName} {l.Client?.LastName}".Trim())</td>
                                <td style="padding:14px; border-bottom:1px solid #edf2f7;">@l.Client?.CardNumber</td>
                                <td style="padding:14px; border-bottom:1px solid #edf2f7;">@l.BookCopy?.Book?.Title</td>
                                <td style="padding:14px; border-bottom:1px solid #edf2f7;">@l.LoanDate.ToString("dd.MM.yyyy")</td>
                                <td style="padding:14px; border-bottom:1px solid #edf2f7;">@l.DueDate.ToString("dd.MM.yyyy")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </section>

    <div style="display:grid; grid-template-columns:repeat(3, minmax(0, 1fr)); gap:18px; margin-bottom:18px;"
         id="dashboardCardsGrid">

        <section class="dashboard-hover-card"
                 style="padding:20px; border-radius:18px; background:#ffffff; border:1px solid #dbe5ef; height:100%; box-shadow:0 10px 24px rgba(15,23,42,.04); transition:transform .18s ease, box-shadow .18s ease, border-color .18s ease;">
            <div style="display:flex; justify-content:space-between; align-items:flex-start; gap:14px; margin-bottom:14px; flex-wrap:wrap;">
                <div>
                    <div style="font-size:.82rem; text-transform:uppercase; font-weight:800; letter-spacing:.04em; color:#6b7280; margin-bottom:6px;">
                        Книги за връщане днес
                    </div>
                    <div style="font-size:2rem; font-weight:800; color:#1d4f91; line-height:1;">@Model.DueTodayCount</div>
                </div>

                <button type="button"
                        data-bs-toggle="modal"
                        data-bs-target="#dueTodayModal"
                        class="dashboard-secondary-btn"
                        style="min-width:120px; height:40px; border:1px solid #93c5fd; background:#ffffff; color:#2563eb; border-radius:10px; font-weight:700; transition:all .18s ease;">
                    Виж списъка
                </button>
            </div>

            @if (Model.DueTodayLoans == null || !Model.DueTodayLoans.Any())
            {
                <div style="color:#64748b;">Няма книги за връщане днес.</div>
            }
            else
            {
                <div style="overflow-x:auto;">
                    <table style="width:100%; border-collapse:separate; border-spacing:0;">
                        <thead>
                            <tr style="background:#f8fbff;">
                                <th style="padding:12px; text-align:left; border-bottom:1px solid #dbe5ef;">Читател</th>
                                <th style="padding:12px; text-align:left; border-bottom:1px solid #dbe5ef;">Книга</th>
                                <th style="padding:12px; text-align:left; border-bottom:1px solid #dbe5ef;">Срок</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var l in Model.DueTodayLoans.Take(4))
                            {
                                <tr class="dashboard-table-row" style="transition:background .18s ease;">
                                    <td style="padding:12px; border-bottom:1px solid #edf2f7;">@($"{l.Client?.FirstName} {l.Client?.LastName}".Trim())</td>
                                    <td style="padding:12px; border-bottom:1px solid #edf2f7;">@l.BookCopy?.Book?.Title</td>
                                    <td style="padding:12px; border-bottom:1px solid #edf2f7;">@l.DueDate.ToString("dd.MM.yyyy")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </section>

        <section class="dashboard-hover-card"
                 style="padding:20px; border-radius:18px; background:#ffffff; border:1px solid #dbe5ef; height:100%; box-shadow:0 10px 24px rgba(15,23,42,.04); transition:transform .18s ease, box-shadow .18s ease, border-color .18s ease;">
            <div style="display:flex; justify-content:space-between; align-items:flex-start; gap:14px; margin-bottom:14px; flex-wrap:wrap;">
                <div>
                    <div style="font-size:.82rem; text-transform:uppercase; font-weight:800; letter-spacing:.04em; color:#6b7280; margin-bottom:6px;">
                        Просрочени книги
                    </div>
                    <div style="font-size:2rem; font-weight:800; color:#1d4f91; line-height:1;">@Model.OverdueCount</div>
                </div>

                <button type="button"
                        data-bs-toggle="modal"
                        data-bs-target="#overdueModal"
                        class="dashboard-secondary-btn"
                        style="min-width:120px; height:40px; border:1px solid #93c5fd; background:#ffffff; color:#2563eb; border-radius:10px; font-weight:700; transition:all .18s ease;">
                    Виж списъка
                </button>
            </div>

            @if (Model.OverdueLoans == null || !Model.OverdueLoans.Any())
            {
                <div style="color:#64748b;">Няма просрочени книги.</div>
            }
            else
            {
                <div style="overflow-x:auto;">
                    <table style="width:100%; border-collapse:separate; border-spacing:0;">
                        <thead>
                            <tr style="background:#f8fbff;">
                                <th style="padding:12px; text-align:left; border-bottom:1px solid #dbe5ef;">Читател</th>
                                <th style="padding:12px; text-align:left; border-bottom:1px solid #dbe5ef;">Книга</th>
                                <th style="padding:12px; text-align:left; border-bottom:1px solid #dbe5ef;">Срок</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var l in Model.OverdueLoans.Take(4))
                            {
                                <tr class="dashboard-table-row" style="transition:background .18s ease;">
                                    <td style="padding:12px; border-bottom:1px solid #edf2f7;">@($"{l.Client?.FirstName} {l.Client?.LastName}".Trim())</td>
                                    <td style="padding:12px; border-bottom:1px solid #edf2f7;">@l.BookCopy?.Book?.Title</td>
                                    <td style="padding:12px; border-bottom:1px solid #edf2f7;">@l.DueDate.ToString("dd.MM.yyyy")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </section>

        <section class="dashboard-hover-card"
                 style="padding:20px; border-radius:18px; background:#ffffff; border:1px solid #dbe5ef; height:100%; box-shadow:0 10px 24px rgba(15,23,42,.04); transition:transform .18s ease, box-shadow .18s ease, border-color .18s ease;">
            <div style="display:flex; justify-content:space-between; align-items:flex-start; gap:14px; margin-bottom:14px; flex-wrap:wrap;">
                <div>
                    <div style="font-size:.82rem; text-transform:uppercase; font-weight:800; letter-spacing:.04em; color:#6b7280; margin-bottom:6px;">
                        Заявки за смяна на парола
                    </div>
                    <div style="font-size:2rem; font-weight:800; color:#1d4f91; line-height:1;">@Model.OpenPasswordResetRequestsCount</div>
                </div>

                <button type="button"
                        data-bs-toggle="modal"
                        data-bs-target="#passwordResetModal"
                        class="dashboard-secondary-btn"
                        style="min-width:120px; height:40px; border:1px solid #93c5fd; background:#ffffff; color:#2563eb; border-radius:10px; font-weight:700; transition:all .18s ease;">
                    Виж списъка
                </button>
            </div>

            @if (Model.OpenPasswordResetRequests == null || !Model.OpenPasswordResetRequests.Any())
            {
                <div style="color:#64748b;">Няма активни заявки.</div>
            }
            else
            {
                <div style="overflow-x:auto;">
                    <table style="width:100%; border-collapse:separate; border-spacing:0;">
                        <thead>
                            <tr style="background:#f8fbff;">
                                <th style="padding:12px; text-align:left; border-bottom:1px solid #dbe5ef;">Читател</th>
                                <th style="padding:12px; text-align:left; border-bottom:1px solid #dbe5ef;">Карта</th>
                                <th style="padding:12px; text-align:left; border-bottom:1px solid #dbe5ef;">Подадена</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var r in Model.OpenPasswordResetRequests.Take(4))
                            {
                                var fullName = r.Client != null
                                ? $"{r.Client.FirstName} {r.Client.LastName}"
                                : "-";

                                <tr class="dashboard-table-row" style="transition:background .18s ease;">
                                    <td style="padding:12px; border-bottom:1px solid #edf2f7;">@fullName</td>
                                    <td style="padding:12px; border-bottom:1px solid #edf2f7;">@r.CardNumber</td>
                                    <td style="padding:12px; border-bottom:1px solid #edf2f7;">@r.RequestedOn.ToString("dd.MM.yyyy HH:mm")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </section>
    </div>

    <section class="dashboard-hover-card"
             style="background:#ffffff; border:1px solid #dbe5ef; border-radius:18px; padding:18px; margin-bottom:18px; box-shadow:0 10px 24px rgba(15,23,42,.04); transition:transform .18s ease, box-shadow .18s ease, border-color .18s ease;">

        <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:12px; gap:10px; flex-wrap:wrap;">
            <h5 style="font-weight:800; color:#0f172a; margin:0;">
                Последно добавени книги
            </h5>

            <a asp-controller="Book"
               asp-action="Recent"
               class="dashboard-link-btn"
               style="height:34px; padding:0 12px; display:flex; align-items:center;
                      border:1px solid #93c5fd; border-radius:8px;
                      text-decoration:none; color:#2563eb; font-weight:700; transition:all .18s ease;">
                Още
            </a>
        </div>

        @if (Model.LatestBookTitles == null || !Model.LatestBookTitles.Any())
        {
            <div style="color:#64748b; font-weight:600;">Няма книги.</div>
        }
        else
        {
            <div id="latestBooksGrid"
                 style="display:flex; justify-content:center; gap:18px; flex-wrap:nowrap; overflow-x:auto; padding:4px 2px 2px 2px;">

                @foreach (var b in Model.LatestBookTitles.Take(5))
                {
                    <a href="@Url.Action("Details", "Book", new { id = b.Id })"
                       class="latest-book-item dashboard-book-card"
                       style="width:146px; min-width:146px;
                                      display:flex; flex-direction:column; align-items:center;
                                      text-decoration:none; color:inherit;
                                      background:#f8fbff; border:1px solid #e2e8f0; border-radius:16px; padding:10px 8px 12px 8px;
                                      transition:transform .18s ease, box-shadow .18s ease, border-color .18s ease;">

                        <div style="width:100%; height:208px;
                                            display:flex; align-items:center; justify-content:center;
                                            background:#ffffff;
                                            border-radius:12px;
                                            overflow:hidden;
                                            margin-bottom:10px;
                                            border:1px solid #edf2f7;">

                            <img src="@b.CoverPath"
                                 alt="@b.Title"
                                 style="max-width:100%; max-height:100%; object-fit:contain;"
                                 onerror="this.style.display='none'; this.parentElement.innerHTML='<span style=&quot;color:#94a3b8;font-size:11px;font-weight:700;&quot;>Няма корица</span>';" />
                        </div>

                        <div style="text-align:center; font-weight:700; font-size:14px; line-height:1.3; color:#0f172a;">
                            @b.Title
                        </div>
                    </a>
                }
            </div>
        }
    </section>
</div>

<div class="modal fade" id="dueTodayModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-xl modal-dialog-scrollable">
        <div class="modal-content" style="border-radius:18px; border:1px solid #dbe5ef;">
            <div class="modal-header" style="border-bottom:1px solid #e2e8f0;">
                <h5 class="modal-title">Книги за връщане днес (@Model.DueTodayCount)</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Затвори"></button>
            </div>
            <div class="modal-body">
                @if (Model.DueTodayLoans == null || !Model.DueTodayLoans.Any())
                {
                    <div style="color:#64748b;">Няма книги за връщане днес.</div>
                }
                else
                {
                    <div style="overflow-x:auto;">
                        <table style="width:100%; border-collapse:separate; border-spacing:0;">
                            <thead>
                                <tr style="background:#f8fbff;">
                                    <th style="padding:14px; text-align:left; border-bottom:1px solid #dbe5ef;">Читател</th>
                                    <th style="padding:14px; text-align:left; border-bottom:1px solid #dbe5ef;">№ карта</th>
                                    <th style="padding:14px; text-align:left; border-bottom:1px solid #dbe5ef;">Книга</th>
                                    <th style="padding:14px; text-align:left; border-bottom:1px solid #dbe5ef;">Срок</th>
                                    <th style="padding:14px; text-align:right; border-bottom:1px solid #dbe5ef;">Действие</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var l in Model.DueTodayLoans)
                                {
                                    <tr class="dashboard-table-row" style="transition:background .18s ease;">
                                        <td style="padding:14px; border-bottom:1px solid #edf2f7;">@($"{l.Client?.FirstName} {l.Client?.LastName}".Trim())</td>
                                        <td style="padding:14px; border-bottom:1px solid #edf2f7;">@l.Client?.CardNumber</td>
                                        <td style="padding:14px; border-bottom:1px solid #edf2f7;">@l.BookCopy?.Book?.Title</td>
                                        <td style="padding:14px; border-bottom:1px solid #edf2f7;">@l.DueDate.ToString("dd.MM.yyyy")</td>
                                        <td style="padding:14px; text-align:right; border-bottom:1px solid #edf2f7;">
                                            <a asp-controller="Loans"
                                               asp-action="Return"
                                               asp-route-id="@l.Id"
                                               class="dashboard-action-link"
                                               style="color:#2563eb; text-decoration:none; font-weight:700; transition:all .18s ease;">
                                                Отвори
                                            </a>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

