@model IEnumerable<ObreshkovLibrary.Models.Book>

@{
    ViewData["Title"] = "Добавени през последния месец";

    string? search = Context.Request.Query["search"];
    string? sort = Context.Request.Query["sort"];
    sort ??= "date_desc";

    string GetCoverValue(ObreshkovLibrary.Models.Book book)
    {
        return book.CoverPath ?? "";
    }
}

<div style="width:100%; padding-top:6px;">

    <div style="display:flex; align-items:end; justify-content:space-between; gap:1rem; flex-wrap:wrap; margin-bottom:1rem;">
        <div>
            <h2 class="section-title mb-1">Добавени през последния месец</h2>
            <div class="accent-line"></div>
        </div>

        <div style="display:flex; gap:10px; flex-wrap:wrap;">
            <a asp-action="Index"
               style="display:inline-flex; align-items:center; justify-content:center; min-height:46px; padding:0 1.2rem; border-radius:14px; background:#fff; color:#2563eb; text-decoration:none; font-weight:800; border:1px solid #93C5FD; min-width:150px;">
                Всички книги
            </a>
        </div>
    </div>

    <section class="card-soft" style="padding:1rem; margin-bottom:1rem;">
        <form method="get"
              asp-action="Recent"
              style="display:flex; align-items:center; gap:12px; width:100%; flex-wrap:wrap;">

            <div style="position:relative; flex:1 1 320px; min-width:0;">
                <span style="position:absolute; left:15px; top:50%; transform:translateY(-50%); color:#94A3B8; font-size:1rem; pointer-events:none; z-index:2;">⌕</span>

                <input type="text"
                       name="search"
                       value="@search"
                       placeholder="Търси по заглавие, автор, жанр или категория..."
                       class="form-control"
                       style="width:100%; height:50px; border-radius:16px; border:1px solid #D7DFEA; background:#fff; color:#0F172A; padding-left:40px; padding-right:16px; font-weight:600; box-shadow:none;" />
            </div>

            <div style="flex:0 0 220px; width:220px;">
                <select name="sort"
                        class="form-select"
                        style="width:220px; height:50px; border-radius:16px; border:1px solid #D7DFEA; background:#fff; font-weight:700; box-shadow:none;">
                    <option value="date_desc" selected="@(sort == "date_desc")">Най-нови първо</option>
                    <option value="date_asc" selected="@(sort == "date_asc")">Най-стари първо</option>
                    <option value="name_asc" selected="@(sort == "name_asc")">Име А-Я</option>
                    <option value="name_desc" selected="@(sort == "name_desc")">Име Я-А</option>
                </select>
            </div>

            <button type="submit"
                    class="btn btn-accent"
                    style="flex:0 0 110px; width:110px; height:50px; border-radius:16px;">
                Приложи
            </button>
        </form>
    </section>

    <section class="card-soft" style="padding:20px; background:#fff;">
        @if (!Model.Any())
        {
            <div style="padding:1.15rem; color:#6B7280; font-weight:600;">Няма книги, добавени през последния месец.</div>
        }
        else
        {
            <div style="display:grid; grid-template-columns:repeat(4, minmax(0, 1fr)); gap:20px;" id="recentBooksGrid">
                @foreach (var book in Model)
                {
                    var coverValue = GetCoverValue(book);

                    <a asp-action="Details"
                       asp-route-id="@book.Id"
                       style="display:flex; flex-direction:column; gap:12px; text-decoration:none; color:inherit; background:transparent; border:none; border-radius:18px; padding:14px 12px; transition:transform .2s ease, box-shadow .2s ease, background .2s ease;"
                       onmouseover="this.style.transform='translateY(-6px)'; this.style.background='#FFFFFF'; this.style.boxShadow='0 14px 30px rgba(59,130,246,0.16)';"
                       onmouseout="this.style.transform='translateY(0)'; this.style.background='transparent'; this.style.boxShadow='none';">

                        <div style="height:200px; display:flex; align-items:center; justify-content:center; overflow:hidden; background:#fff; border-radius:14px;">
                            @if (!string.IsNullOrWhiteSpace(coverValue))
                            {
                                <img src="@Url.Content("~/" + book.CoverPath)"
                                     alt="@book.Title"
                                     style="max-width:100%; max-height:100%; object-fit:contain; transition:transform .2s ease;"
                                     onmouseover="this.style.transform='scale(1.05)'"
                                     onmouseout="this.style.transform='scale(1)'" />
                            }
                            else
                            {
                                <span style="color:#94A3B8; font-weight:700;">Няма корица</span>
                            }
                        </div>

                        <div style="font-weight:800; color:#111827; font-size:1.02rem; line-height:1.3;">@book.Title</div>
                        <div style="color:#475569; font-size:1rem;">@book.Author</div>
                        <div style="color:#64748B; font-size:.95rem;">Добавена: @book.CreatedOn.ToString("dd.MM.yyyy")</div>
                    </a>
                }
            </div>
        }
    </section>
</div>

@section Scripts {
    <script>
        function applyRecentBooksResponsive() {
            const grid = document.getElementById('recentBooksGrid');
            if (!grid) return;

            if (window.innerWidth <= 700) {
                grid.style.gridTemplateColumns = '1fr';
            } else if (window.innerWidth <= 1000) {
                grid.style.gridTemplateColumns = 'repeat(2, minmax(0, 1fr))';
            } else if (window.innerWidth <= 1250) {
                grid.style.gridTemplateColumns = 'repeat(3, minmax(0, 1fr))';
            } else {
                grid.style.gridTemplateColumns = 'repeat(4, minmax(0, 1fr))';
            }
        }

        applyRecentBooksResponsive();
        window.addEventListener('resize', applyRecentBooksResponsive);
    </script>
}