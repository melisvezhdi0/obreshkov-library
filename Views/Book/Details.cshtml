@model ObreshkovLibrary.Models.Book
@using ObreshkovLibrary.Models
@using System.Linq

@{
    ViewData["Title"] = "Детайли за книга";

    var activeLoanCopyIds = (ViewBag.ActiveLoanCopyIds as List<int>) ?? new List<int>();

    string categoryName = "Няма категория";
    if (Model.Category != null)
    {
        categoryName = Model.Category.ParentCategory != null
            ? $"{Model.Category.ParentCategory.Name} / {Model.Category.Name}"
            : Model.Category.Name;
    }

    List<string> tagNames = new();

    if ((Model.Tags & BookTags.Classic) == BookTags.Classic) tagNames.Add("Класика");
    if ((Model.Tags & BookTags.Romance) == BookTags.Romance) tagNames.Add("Любовен");
    if ((Model.Tags & BookTags.Drama) == BookTags.Drama) tagNames.Add("Драма");
    if ((Model.Tags & BookTags.Fantasy) == BookTags.Fantasy) tagNames.Add("Фентъзи");
    if ((Model.Tags & BookTags.Horror) == BookTags.Horror) tagNames.Add("Ужаси");
    if ((Model.Tags & BookTags.Bulgarian) == BookTags.Bulgarian) tagNames.Add("Българска литература");
    if ((Model.Tags & BookTags.Foreign) == BookTags.Foreign) tagNames.Add("Чужда литература");
    if ((Model.Tags & BookTags.SchoolLiterature) == BookTags.SchoolLiterature) tagNames.Add("Училищна литература");

    var activeCopies = Model.Copies?.Count(c => c.IsActive) ?? 0;
}

<div class="book-details-page">

    <div class="book-details-header">
        <div>
            <h2 class="section-title mb-1">@Model.Title</h2>
            <div class="accent-line"></div>
        </div>

        <div class="book-details-actions">
            <a class="btn btn-outline-primary"
               asp-action="Index">
                Назад
            </a>

            <a class="btn btn-accent"
               asp-action="Edit"
               asp-route-id="@Model.Id">
                Редактиране
            </a>
        </div>
    </div>

    <section class="details-panel card-soft">
        <div class="book-main-panel">
            <div class="book-top-layout">

                <div class="book-cover-column">
                    @if (!string.IsNullOrWhiteSpace(Model.CoverPath))
                    {
                        <div class="book-cover-box">
                            <img src="@Model.CoverPath" alt="@Model.Title" />
                        </div>
                    }
                    else
                    {
                        <div class="book-cover-box no-cover"></div>
                    }
                </div>

                <div class="book-info-column">
                    <div class="book-info-grid">

                        <div class="book-info-row">
                            <div class="book-info-label">Заглавие</div>
                            <div class="book-info-value">@Model.Title</div>
                        </div>

                        <div class="book-info-row">
                            <div class="book-info-label">Автор</div>
                            <div class="book-info-value">@Model.Author</div>
                        </div>

                        <div class="book-info-row">
                            <div class="book-info-label">Година</div>
                            <div class="book-info-value">
                                @(Model.Year.HasValue? Model.Year.ToString() : "Няма данни")
                            </div>
                        </div>

                        <div class="book-info-row">
                            <div class="book-info-label">Категория</div>
                            <div class="book-info-value">@categoryName</div>
                        </div>

                        <div class="book-info-row">
                            <div class="book-info-label">Клас</div>
                            <div class="book-info-value">
                                @(string.IsNullOrWhiteSpace(Model.SchoolClass) ? "Не е посочен" : Model.SchoolClass)
                            </div>
                        </div>

                        <div class="book-info-row">
                            <div class="book-info-label">Добавена на</div>
                            <div class="book-info-value">@Model.CreatedOn.ToString("dd.MM.yyyy")</div>
                        </div>

                        <div class="book-info-row">
                            <div class="book-info-label">Статус на книга</div>
                            <div class="book-info-value">
                                @if (Model.IsActive)
                                {
                                    <span class="status-badge status-active">Активна</span>
                                }
                                else
                                {
                                    <span class="status-badge status-inactive">Неактивна</span>
                                }
                            </div>
                        </div>

                        <div class="book-info-row">
                            <div class="book-info-label">Активни екземпляри</div>
                            <div class="book-info-value">@activeCopies</div>
                        </div>

                        <div class="book-info-row">
                            <div class="book-info-label">Тагове</div>
                            <div class="book-info-value">
                                @if (tagNames.Any())
                                {
                                    <div class="tags-inline-wrap">
                                        @foreach (var tag in tagNames)
                                        {
                                            <span class="tag-chip">@tag</span>
                                        }
                                    </div>
                                }
                                else
                                {
                                    <span class="muted-text">Няма тагове</span>
                                }
                            </div>
                        </div>

                    </div>
                </div>

            </div>
        </div>
    </section>

    <section class="details-panel card-soft book-description-panel">
        <div class="details-panel-head">
            <h5 class="section-title mb-0">Описание</h5>
        </div>

        @if (!string.IsNullOrWhiteSpace(Model.Description))
        {
            <div class="book-description-wrap">
                <div class="book-description">@Model.Description</div>
            </div>
        }
        else
        {
            <div class="details-empty-state">
                Няма добавено описание за тази книга.
            </div>
        }
    </section>

    <section class="details-panel card-soft copies-panel">
        <div class="details-panel-head details-panel-head-flex">
            <h5 class="section-title mb-0">Екземпляри</h5>
            <span class="count-badge">@(Model.Copies?.Count ?? 0)</span>
        </div>

        @if (Model.Copies == null || !Model.Copies.Any())
        {
            <div class="details-empty-state">
                Няма добавени екземпляри.
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table details-table align-middle mb-0">
                    <thead>
                        <tr>
                            <th>№ екземпляр</th>
                            <th>Състояние</th>
                            <th class="text-end">Статус</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var copy in Model.Copies.OrderBy(c => c.Id))
                        {
                            var isLoaned = copy.IsActive && activeLoanCopyIds.Contains(copy.Id);

                            <tr>
                                <td class="copy-id-cell">#@copy.Id</td>
                                <td class="copy-state-text">
                                    @(copy.IsActive ? "Активен екземпляр" : "Неактивен екземпляр")
                                </td>
                                <td class="text-end">
                                    @if (!copy.IsActive)
                                    {
                                        <span class="status-badge status-inactive">Неактивен</span>
                                    }
                                    else if (isLoaned)
                                    {
                                        <span class="status-badge status-loaned">Зает</span>
                                    }
                                    else
                                    {
                                        <span class="status-badge status-active">Наличен</span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </section>

</div>