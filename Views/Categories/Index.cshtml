@using ObreshkovLibrary.Models
@model IEnumerable<ObreshkovLibrary.Models.Category>

@{
    ViewData["Title"] = "Категории";

    var allCategories = (Model ?? Enumerable.Empty<Category>()).ToList();
    var directBookCounts = ViewBag.DirectBookCounts as Dictionary<int, int> ?? new Dictionary<int, int>();

    var byParent = allCategories
        .OrderBy(c => c.Name)
        .ToLookup(c => c.ParentCategoryId);

    var orderedRows = new List<(Category Category, int Level, int TotalBooks)>();

    int CountAllBooks(int categoryId)
    {
        var total = directBookCounts.ContainsKey(categoryId) ? directBookCounts[categoryId] : 0;

        var children = byParent[categoryId];
        foreach (var child in children)
        {
            total += CountAllBooks(child.Id);
        }

        return total;
    }

    void AddBranch(int? parentId, int level)
    {
        var children = byParent[parentId];

        foreach (var child in children)
        {
            orderedRows.Add((child, level, CountAllBooks(child.Id)));
            AddBranch(child.Id, level + 1);
        }
    }

    AddBranch(null, 0);

    var addedIds = orderedRows.Select(x => x.Category.Id).ToHashSet();
    var orphanCategories = allCategories
        .Where(c => !addedIds.Contains(c.Id))
        .OrderBy(c => c.Name)
        .ToList();

    foreach (var orphan in orphanCategories)
    {
        orderedRows.Add((orphan, 0, CountAllBooks(orphan.Id)));
    }
}

<div class="categories-page">

    <div class="categories-header">
        <div>
            <h2 class="section-title mb-1">Категории</h2>
            <div class="accent-line"></div>
        </div>

        <div class="categories-header-actions">
            <a asp-action="CreatePath"
               style="display:inline-flex; align-items:center; justify-content:center; min-height:46px; padding:0 1.2rem; border-radius:14px; background:linear-gradient(180deg,#4D8AF7 0%,#3B82F6 100%); color:#fff; text-decoration:none; font-weight:800; border:1px solid #3B82F6; box-shadow:0 8px 18px rgba(59,130,246,.18); min-width:150px;">
                Добави категория
            </a>
        </div>
    </div>

    <section class="categories-panel card-soft">
        @if (!orderedRows.Any())
        {
            <div class="categories-empty-state">
                Няма добавени категории.
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table categories-table align-middle mb-0">
                    <thead>
                        <tr>
                            <th style="width: 60%;">Категория</th>
                            <th style="width: 20%;">Бройки</th>
                            <th style="width: 20%;" class="text-end">Действия</th>
                        </tr>
                    </thead>

                    <tbody>
                        @foreach (var row in orderedRows)
                        {
                            var item = row.Category;
                            var level = row.Level;
                            var indent = level * 28;

                            <tr class="category-row @(level == 0 ? "category-root-row" : "")"
                                role="button"
                                tabindex="0"
                                onclick="window.location.href='@Url.Action("Details", "Categories", new { id = item.Id })';"
                                onkeydown="if(event.key==='Enter'){ window.location.href='@Url.Action("Details", "Categories", new { id = item.Id })'; }">

                                <td>
                                    <div class="category-tree-cell" style="padding-left:@(indent)px;">
                                        @if (level > 0)
                                        {
                                            <span class="tree-branch" aria-hidden="true"></span>
                                        }

                                        <span class="category-name-cell">@item.Name</span>
                                    </div>
                                </td>

                                <td>
                                    <span class="category-count-text">@row.TotalBooks</span>
                                </td>

                                <td class="text-end">
                                    <a asp-action="Edit"
                                       asp-route-id="@item.Id"
                                       onclick="event.stopPropagation();"
                                       style="color:#3B82F6; font-weight:800; text-decoration:none; white-space:nowrap;">
                                        Редакция
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </section>

</div>