@model ObreshkovLibrary.Models.ViewModels.ReaderNotificationDropdownVM
@using ObreshkovLibrary.Models.Enums
@using System.Linq

@{
    var unreadItems = Model.Items
        .Where(x => !x.IsRead)
        .OrderByDescending(x => x.CreatedOn)
        .ToList();

    var allItems = Model.Items
        .OrderByDescending(x => x.CreatedOn)
        .ToList();

    string GetIcon(ReaderNotificationType type)
    {
        return type switch
        {
            ReaderNotificationType.NewCategory => "+",
            ReaderNotificationType.Admin => "i",
            ReaderNotificationType.OverdueReminder => "!",
            _ => "•"
        };
    }
}

<div id="readerNotificationsDropdown"
     style="display:none;
            position:absolute;
            top:58px;
            right:0;
            width:390px;
            max-width:calc(100vw - 24px);
            background:#ffffff;
            border:1px solid #e2e8f0;
            border-radius:22px;
            overflow:hidden;
            box-shadow:0 20px 50px rgba(15,23,42,.12);
            z-index:1200;">

    <div style="padding:16px 18px 12px 18px; border-bottom:1px solid #eef2f7; background:#ffffff;">
        <div style="display:flex; align-items:flex-start; justify-content:space-between; gap:12px;">
            <div>
                <div style="color:#0f172a; font-size:1.02rem; font-weight:900; line-height:1.2;">
                    Съобщения
                </div>
                <div style="margin-top:4px; color:#64748b; font-size:.84rem; font-weight:700;">
                    @if (Model.UnreadCount > 0)
                    {
                        @Model.UnreadCount @(Model.UnreadCount == 1 ? "непрочетено съобщение" : "непрочетени съобщения")
                    }
                    else
                    {
                        <text>Няма непрочетени съобщения</text>
                    }
                </div>
            </div>

            <div style="display:inline-flex;
                        align-items:center;
                        justify-content:center;
                        min-width:34px;
                        height:34px;
                        padding:0 10px;
                        border-radius:999px;
                        border:1px solid #dbeafe;
                        background:#eff6ff;
                        color:#2563eb;
                        font-size:.86rem;
                        font-weight:900;">
                @Model.UnreadCount
            </div>
        </div>
    </div>

    @if (unreadItems.Any())
    {
        <div style="max-height:320px; overflow-y:auto; padding:10px; background:#f8fafc;">
            @foreach (var item in unreadItems.Take(5))
            {
                <div style="display:grid;
                                    grid-template-columns:38px minmax(0,1fr);
                                    gap:12px;
                                    align-items:start;
                                    padding:12px;
                                    margin-bottom:8px;
                                    border:1px solid #dbeafe;
                                    background:#ffffff;
                                    border-radius:16px;">

                    <div style="width:38px;
                                        height:38px;
                                        border-radius:12px;
                                        background:#eff6ff;
                                        color:#2563eb;
                                        display:flex;
                                        align-items:center;
                                        justify-content:center;
                                        font-size:1rem;
                                        font-weight:900;
                                        flex:0 0 auto;">
                        @GetIcon(item.Type)
                    </div>

                    <div style="min-width:0;">
                        <div style="display:flex; align-items:start; justify-content:space-between; gap:10px;">
                            <div style="min-width:0; color:#0f172a; font-size:.93rem; font-weight:800; line-height:1.35;">
                                @item.Title
                            </div>

                            <span style="flex:0 0 auto;
                                                 display:inline-flex;
                                                 align-items:center;
                                                 justify-content:center;
                                                 padding:0 8px;
                                                 height:22px;
                                                 border-radius:999px;
                                                 background:#dbeafe;
                                                 color:#2563eb;
                                                 font-size:.68rem;
                                                 font-weight:900;">
                                НОВО
                            </span>
                        </div>

                        <div style="margin-top:5px;
                                            color:#64748b;
                                            font-size:.84rem;
                                            line-height:1.45;
                                            white-space:nowrap;
                                            overflow:hidden;
                                            text-overflow:ellipsis;">
                            @item.Message
                        </div>

                        <div style="margin-top:7px; color:#94a3b8; font-size:.74rem; font-weight:800;">
                            @item.CreatedOn.ToString("dd.MM.yyyy")
                        </div>
                    </div>
                </div>
            }
        </div>

        <div style="padding:12px 14px 14px 14px; border-top:1px solid #eef2f7; background:#ffffff;">
            <button type="button"
                    id="openAllNotificationsModalBtn"
                    style="width:100%;
                               height:40px;
                               border-radius:12px;
                               border:1px solid #dbeafe;
                               background:#eff6ff;
                               color:#2563eb;
                               font-size:.85rem;
                               font-weight:800;
                               cursor:pointer;">
                Виж всички
            </button>
        </div>
    }
    else
    {
        <div style="padding:22px 18px; background:#f8fafc; color:#64748b; font-size:.92rem; font-weight:700;">
            Няма непрочетени съобщения.
        </div>

        @if (allItems.Any())
        {
            <div style="padding:12px 14px 14px 14px; border-top:1px solid #eef2f7; background:#ffffff;">
                <button type="button"
                        id="openAllNotificationsModalBtnEmpty"
                        style="width:100%;
                                       height:40px;
                                       border-radius:12px;
                                       border:1px solid #dbeafe;
                                       background:#eff6ff;
                                       color:#2563eb;
                                       font-size:.85rem;
                                       font-weight:800;
                                       cursor:pointer;">
                    Виж всички
                </button>
            </div>
        }
    }
</div>

<div id="readerNotificationsModalOverlay"
     style="display:none;
            position:fixed;
            inset:0;
            background:rgba(15,23,42,.42);
            z-index:1600;
            padding:24px;
            box-sizing:border-box;
            align-items:center;
            justify-content:center;">

    <div id="readerNotificationsModal"
         style="width:min(760px, 100%);
                max-height:min(82vh, 900px);
                background:#ffffff;
                border-radius:24px;
                border:1px solid #e2e8f0;
                box-shadow:0 30px 80px rgba(15,23,42,.22);
                overflow:hidden;
                display:flex;
                flex-direction:column;">

        <div style="padding:18px 22px;
                    border-bottom:1px solid #eef2f7;
                    background:#ffffff;
                    display:flex;
                    align-items:center;
                    justify-content:space-between;
                    gap:12px;">
            <div>
                <div style="color:#0f172a; font-size:1.18rem; font-weight:900; line-height:1.2;">
                    Всички съобщения
                </div>
                <div style="margin-top:4px; color:#64748b; font-size:.86rem; font-weight:700;">
                    @allItems.Count @(allItems.Count == 1 ? "съобщение" : "съобщения")
                </div>
            </div>

            <button type="button"
                    id="closeReaderNotificationsModalBtn"
                    style="width:38px;
                           height:38px;
                           border:none;
                           border-radius:12px;
                           background:#f1f5f9;
                           color:#475569;
                           font-size:1.1rem;
                           font-weight:900;
                           cursor:pointer;">
                ×
            </button>
        </div>

        <div style="padding:14px;
                    background:#f8fafc;
                    overflow-y:auto;
                    max-height:calc(82vh - 78px);">
            @if (allItems.Any())
            {
                @foreach (var item in allItems)
                {
                    var isUnread = !item.IsRead;

                    <div style="display:grid;
                                        grid-template-columns:42px minmax(0,1fr);
                                        gap:13px;
                                        align-items:start;
                                        padding:14px;
                                        margin-bottom:10px;
                                        border:1px solid @(isUnread ? "#dbeafe" : "#e2e8f0");
                                        background:#ffffff;
                                        border-radius:18px;
                                        box-shadow:@(isUnread ? "0 8px 18px rgba(37,99,235,.06)" : "none");">

                        <div style="width:42px;
                                            height:42px;
                                            border-radius:13px;
                                            background:@(isUnread ? "#eff6ff" : "#f1f5f9");
                                            color:@(isUnread ? "#2563eb" : "#64748b");
                                            display:flex;
                                            align-items:center;
                                            justify-content:center;
                                            font-size:1rem;
                                            font-weight:900;">
                            @GetIcon(item.Type)
                        </div>

                        <div style="min-width:0;">
                            <div style="display:flex; align-items:start; justify-content:space-between; gap:10px; flex-wrap:wrap;">
                                <div style="min-width:0; color:#0f172a; font-size:1rem; font-weight:850; line-height:1.35;">
                                    @item.Title
                                </div>

                                <div style="display:flex; align-items:center; gap:8px; flex-wrap:wrap;">
                                    @if (isUnread)
                                    {
                                        <span style="display:inline-flex;
                                                                 align-items:center;
                                                                 justify-content:center;
                                                                 padding:0 8px;
                                                                 height:22px;
                                                                 border-radius:999px;
                                                                 background:#dbeafe;
                                                                 color:#2563eb;
                                                                 font-size:.68rem;
                                                                 font-weight:900;">
                                            НОВО
                                        </span>
                                    }

                                    <span style="color:#94a3b8; font-size:.77rem; font-weight:800;">
                                        @item.CreatedOn.ToString("dd.MM.yyyy")
                                    </span>
                                </div>
                            </div>

                            <div style="margin-top:7px; color:#475569; font-size:.9rem; line-height:1.6;">
                                @item.Message
                            </div>

                            @if (item.Type == ReaderNotificationType.NewCategory && item.CategoryId.HasValue)
                            {
                                <div style="margin-top:10px;">
                                    <a asp-controller="Catalog"
                                       asp-action="ReaderIndex"
                                       asp-route-categoryId="@item.CategoryId.Value"
                                       style="display:inline-flex;
                                                          align-items:center;
                                                          justify-content:center;
                                                          height:34px;
                                                          padding:0 12px;
                                                          border-radius:10px;
                                                          border:1px solid #dbeafe;
                                                          background:#eff6ff;
                                                          color:#2563eb;
                                                          text-decoration:none;
                                                          font-size:.8rem;
                                                          font-weight:800;">
                                        Към каталога
                                    </a>
                                </div>
                            }
                        </div>
                    </div>
                }
            }
            else
            {
                <div style="padding:30px 12px; text-align:center; color:#64748b; font-size:.95rem; font-weight:700;">
                    Няма съобщения.
                </div>
            }
        </div>
    </div>
</div>

<script>
    (function () {
        if (window.readerNotificationsModalInitialized) {
            return;
        }

        window.readerNotificationsModalInitialized = true;

        function openNotificationsModal() {
            var overlay = document.getElementById('readerNotificationsModalOverlay');
            if (!overlay) return;

            overlay.style.display = 'flex';
            document.body.style.overflow = 'hidden';
        }

        function closeNotificationsModal() {
            var overlay = document.getElementById('readerNotificationsModalOverlay');
            if (!overlay) return;

            overlay.style.display = 'none';
            document.body.style.overflow = '';
        }

        document.addEventListener('click', function (e) {
            var openBtn1 = e.target.closest('#openAllNotificationsModalBtn');
            var openBtn2 = e.target.closest('#openAllNotificationsModalBtnEmpty');
            var closeBtn = e.target.closest('#closeReaderNotificationsModalBtn');
            var overlay = document.getElementById('readerNotificationsModalOverlay');
            var modal = document.getElementById('readerNotificationsModal');

            if (openBtn1 || openBtn2) {
                openNotificationsModal();
                return;
            }

            if (closeBtn) {
                closeNotificationsModal();
                return;
            }

            if (overlay && e.target === overlay) {
                closeNotificationsModal();
                return;
            }

            if (modal && modal.contains(e.target)) {
                return;
            }
        });

        document.addEventListener('keydown', function (e) {
            if (e.key === 'Escape') {
                closeNotificationsModal();
            }
        });
    })();
</script>