@model IEnumerable<ObreshkovLibrary.Models.Client>

@{
    ViewData["Title"] = "Читатели";

    string searchValue = (ViewBag.Search ?? "").ToString();
    string classValue = (ViewBag.ClassFilter ?? "").ToString();
    bool hasFilters = !string.IsNullOrWhiteSpace(searchValue) || !string.IsNullOrWhiteSpace(classValue);

    var classes = Model
        .Select(c => $"{c.Grade}{c.Section}".Replace(" ", "").ToUpper())
        .Where(x => !string.IsNullOrWhiteSpace(x))
        .Distinct()
        .OrderBy(x => x.Length)
        .ThenBy(x => x)
        .ToList();

    bool noResults = (Model == null || !Model.Any()) && hasFilters;

    var groupedClients = Model
        .OrderBy(c => c.Grade)
        .ThenBy(c => c.Section)
        .ThenBy(c => c.FirstName)
        .ThenBy(c => c.LastName)
        .GroupBy(c => $"{c.Grade}{c.Section}".Replace(" ", "").ToUpper())
        .ToList();
}

<div class="clients-page">

    <section class="hero-panel card-soft mb-4">
        <div class="clients-hero-top">
            <div>
                <h2 class="section-title mb-1">Читатели</h2>
                <div class="accent-line"></div>
            </div>

            <a asp-action="Create" class="btn btn-accent clients-add-btn">
                Добави читател
            </a>
        </div>

        <form method="get" asp-action="Index" class="dashboard-search">
            <div class="clients-filter-row">
                <select name="classFilter" class="form-select clients-class-select">
                    <option value="">Всички класове</option>
                    @foreach (var cls in classes)
                    {
                        if (cls == classValue)
                        {
                            <option value="@cls" selected>@cls</option>
                        }
                        else
                        {
                            <option value="@cls">@cls</option>
                        }
                    }
                </select>

                <input name="search"
                       value="@searchValue"
                       placeholder="Търси име, телефон или № карта..."
                       class="form-control clients-search-input" />

                <button type="submit" class="btn btn-accent">
                    Търси
                </button>

                <a asp-action="Index" class="btn btn-outline-primary">
                    Изчисти
                </a>
            </div>
        </form>

        @if (hasFilters)
        {
            <div class="clients-active-filters">
                <span class="filters-label">Активни филтри:</span>

                @if (!string.IsNullOrWhiteSpace(classValue))
                {
                    <span class="filter-chip">Клас: @classValue</span>
                }

                @if (!string.IsNullOrWhiteSpace(searchValue))
                {
                    <span class="filter-chip">Търси: @searchValue</span>
                }
            </div>
        }
    </section>

    @if (noResults)
    {
        <section class="document-panel card-soft">
            <div class="document-head">
                <h5 class="section-title mb-0">Списък с читатели</h5>
            </div>

            <div class="clients-empty-title">Няма намерени данни</div>

            <div class="clients-empty-text">
                @if (!string.IsNullOrWhiteSpace(classValue) && !string.IsNullOrWhiteSpace(searchValue))
                {
                    <span>по клас <strong>@classValue</strong> и търсене <strong>@searchValue</strong>.</span>
                }
                else if (!string.IsNullOrWhiteSpace(classValue))
                {
                    <span>по клас <strong>@classValue</strong>.</span>
                }
                else if (!string.IsNullOrWhiteSpace(searchValue))
                {
                    <span>по търсене <strong>@searchValue</strong>.</span>
                }
            </div>
        </section>
    }
    else
    {
        <section class="document-panel card-soft">
            <div class="document-head">
                <h5 class="section-title mb-0">Списък с читатели</h5>
            </div>

            <div class="table-responsive">
                <table class="table clients-doc-table mb-0">
                    <thead>
                        <tr>
                            <th style="width: 34%;">Име</th>
                            <th style="width: 18%;">Телефон</th>
                            <th style="width: 14%;">№ карта</th>
                            <th style="width: 16%;">Регистриран</th>
                            <th style="width: 18%;" class="text-end">Действия</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var group in groupedClients)
                        {
                            <tr class="class-group-row">
                                <td colspan="5">@group.Key</td>
                            </tr>

                            @foreach (var item in group)
                            {
                                <tr class="client-row"
                                    role="button"
                                    tabindex="0"
                                    onclick="window.location.href='@Url.Action("Details", "Clients", new { id = item.Id })';"
                                    onkeydown="if(event.key==='Enter'){ window.location.href='@Url.Action("Details", "Clients", new { id = item.Id })'; }">

                                    <td class="client-name-cell">
                                        @(($"{item.FirstName} {item.MiddleName} {item.LastName}")
                                                                    .Replace("  ", " ")
                                                                    .Trim())
                        </td>

                                    <td>@item.PhoneNumber</td>
                                    <td>@item.CardNumber</td>
                                    <td>@item.CreatedOn.ToString("dd.MM.yyyy")</td>

                                    <td class="text-end">
                                        <a asp-action="Edit"
                                           asp-route-id="@item.Id"
                                           onclick="event.stopPropagation();"
                                           class="link-accent">
                                            Редакция
                                        </a>
                                    </td>
                                </tr>
                                        }
                        }
                    </tbody>
                </table>
            </div>
        </section>
    }
</div>

<style>
    .clients-page {
        width: 100%;
        padding-top: 6px;
    }

    .clients-hero-top {
        margin-bottom: 1rem;
        display: flex;
        align-items: end;
        justify-content: space-between;
        gap: 1rem;
        flex-wrap: wrap;
    }

    .clients-add-btn {
        white-space: nowrap;
    }

    .clients-filter-row {
        display: grid;
        grid-template-columns: 180px minmax(220px, 1fr) auto auto;
        gap: .8rem;
        align-items: center;
    }

    .clients-class-select,
    .clients-search-input {
        min-height: 50px;
        background: #FFFFFF;
    }

    .clients-active-filters {
        display: flex;
        align-items: center;
        flex-wrap: wrap;
        gap: .5rem;
        padding-top: 1rem;
    }

    .filters-label {
        font-weight: 800;
        color: #1F2937;
    }

    .filter-chip {
        display: inline-flex;
        align-items: center;
        padding: .35rem .7rem;
        border-radius: 999px;
        background: #EEF4FF;
        border: 1px solid #D6E4FF;
        color: #2563EB;
        font-weight: 800;
        font-size: .9rem;
    }

    .document-panel {
        padding: 0;
        overflow: hidden;
    }

    .document-head {
        padding: 1.1rem 1.2rem .9rem;
        border-bottom: 1px solid #D9E0E7;
        background: #FBFCFD;
    }

    .clients-empty-title {
        padding: 1.2rem 1.2rem .35rem;
        font-weight: 900;
        color: #1F2937;
        font-size: 1.08rem;
    }

    .clients-empty-text {
        padding: 0 1.2rem 1.2rem;
        color: #6B7280;
        font-weight: 600;
    }

        .clients-empty-text strong {
            color: #1F2937;
        }

    .clients-doc-table {
        margin-bottom: 0;
        border-collapse: separate;
        border-spacing: 0;
    }

        .clients-doc-table thead th {
            background: #F3F6F9;
            color: #6B7280;
            font-size: .82rem;
            text-transform: uppercase;
            letter-spacing: .03em;
            font-weight: 800;
            padding: .95rem 1.2rem;
            border-bottom: 1px solid #D9E0E7;
            white-space: nowrap;
        }

    .class-group-row td {
        background: #ECEFF3;
        color: #6B7280;
        font-size: .78rem;
        text-transform: uppercase;
        letter-spacing: .06em;
        font-weight: 900;
        padding: .7rem 1.2rem;
        border-bottom: 1px solid #D9E0E7;
    }

    .clients-doc-table tbody td {
        padding: 1rem 1.2rem;
        background: #FFFFFF;
        border-bottom: 1px solid #E5EAF0;
        vertical-align: middle;
    }

    .clients-doc-table tbody tr:last-child td {
        border-bottom: none;
    }

    .client-row {
        transition: background-color .15s ease;
    }

        .client-row:hover td {
            background: #FAFCFF;
            cursor: pointer;
        }

    .client-name-cell {
        font-weight: 700;
        color: #1F2937;
    }

    @@media (max-width: 991.98px) {
        .clients-filter-row {
            grid-template-columns: 1fr 1fr;
        }
    }

    @@media (max-width: 767.98px) {
        .clients-hero-top {
            align-items: stretch;
        }

        .clients-add-btn {
            width: 100%;
            text-align: center;
        }

        .clients-filter-row {
            grid-template-columns: 1fr;
        }

        .clients-doc-table thead th,
        .clients-doc-table tbody td,
        .class-group-row td {
            padding-left: .9rem;
            padding-right: .9rem;
        }
    }
</style>