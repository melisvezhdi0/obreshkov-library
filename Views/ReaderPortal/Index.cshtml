@model ObreshkovLibrary.Models.ViewModels.ReaderDashboardVM

@{
    ViewData["Title"] = "Моят профил";
    Layout = "_ReaderLayout";
}

<form style="display:none;">
    @Html.AntiForgeryToken()
</form>

<div class="Reader-portal-page">

    <aside class="Reader-portal-sidebar">
        <div class="Reader-portal-sidebar-inner">
            <div class="Reader-portal-sidebar-label">Reader Portal</div>
            <h1 class="Reader-portal-sidebar-title">Моят профил</h1>

            <nav id="ReaderScrollspy" class="Reader-portal-nav">
                <a href="#current-loans" class="Reader-nav-link active">
                    <span class="Reader-nav-line"></span>
                    <span>Текущо заети книги</span>
                </a>

                <a href="#favorites" class="Reader-nav-link">
                    <span class="Reader-nav-line"></span>
                    <span>Списък за четене</span>
                </a>

                <a href="#notifications" class="Reader-nav-link">
                    <span class="Reader-nav-line"></span>
                    <span>Известия</span>
                </a>

                <a href="#history" class="Reader-nav-link">
                    <span class="Reader-nav-line"></span>
                    <span>История на заеманията</span>
                </a>

                <a href="#notes" class="Reader-nav-link">
                    <span class="Reader-nav-line"></span>
                    <span>Лична бележка към заемана книга</span>
                </a>

                <a href="#extension" class="Reader-nav-link">
                    <span class="Reader-nav-line"></span>
                    <span>Заявка за удължаване</span>
                </a>

                <a href="#profile" class="Reader-nav-link">
                    <span class="Reader-nav-line"></span>
                    <span>Лични данни</span>
                </a>
            </nav>
        </div>
    </aside>

    <main class="Reader-portal-content">

        <section id="current-loans" class="Reader-portal-section">
            <div class="Reader-section-header">
                <h2 class="Reader-section-title">Текущо заети книги</h2>
                <p class="Reader-section-subtitle">
                    Преглед на всички книги, които са заети в момента.
                </p>
            </div>

            @if (Model.CurrentLoans != null && Model.CurrentLoans.Any())
            {
                <div class="Reader-table-wrap">
                    <table class="Reader-loans-table">
                        <thead>
                            <tr>
                                <th style="width:72px;">Корица</th>
                                <th>Заглавие</th>
                                <th style="width:170px;">Дата на заемане</th>
                                <th style="width:240px;">Дата на връщане</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model.CurrentLoans)
                            {
                                var overdueDays = item.IsOverdue
                                ? (DateTime.Today - item.DueDate.Date).Days
                                : 0;

                                <tr>
                                    <td>
                                        <div class="Reader-cover-box">
                                            @if (!string.IsNullOrWhiteSpace(item.CoverPath))
                                            {
                                                <img src="@Url.Content("~/" + item.CoverPath)"
                                                     alt="@item.Title"
                                                     class="Reader-mini-cover" />
                                            }
                                            else
                                            {
                                                <div class="Reader-mini-cover Reader-cover-placeholder">
                                                    Няма
                                                </div>
                                            }
                                        </div>
                                    </td>

                                    <td>
                                        <div class="Reader-book-cell">
                                            <div class="Reader-book-title">@item.Title</div>
                                            <div class="Reader-book-author">@item.Author</div>
                                        </div>
                                    </td>

                                    <td>
                                        <div class="Reader-date-cell">
                                            @item.LoanDate.ToString("dd.MM.yyyy")
                                        </div>
                                    </td>

                                    <td>
                                        @if (item.IsOverdue)
                                        {
                                            <div class="Reader-return-status overdue">
                                                Просрочена с @overdueDays @(overdueDays == 1 ? "ден" : "дни")
                                            </div>
                                        }
                                        else if (item.IsExtended)
                                        {
                                            <div class="Reader-return-status extended">
                                                Удължена до @item.DueDate.ToString("dd.MM.yyyy")
                                            </div>
                                        }
                                        else
                                        {
                                            <div class="Reader-return-status normal">
                                                @item.DueDate.ToString("dd.MM.yyyy")
                                            </div>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="Reader-empty-state">
                    В момента нямаш заети книги.
                </div>
            }
        </section>

        <!-- 2. ЛЮБИМИ -->
        <section id="favorites" class="Reader-portal-section">
            <div class="Reader-section-header">
                <h2 class="Reader-section-title">Списък за четене</h2>
            </div>

            <div class="Reader-empty-state">
                Тази секция ще я подредим след това.
            </div>
        </section>

        <!-- 3. ИЗВЕСТИЯ -->
        <section id="notifications" class="Reader-portal-section">
            <div class="Reader-section-header">
                <h2 class="Reader-section-title">Известия</h2>
            </div>

            <div class="Reader-empty-state">
                Тази секция ще я подредим след това.
            </div>
        </section>

        <section id="history" class="Reader-portal-section">
            <div class="Reader-section-header">
                <h2 class="Reader-section-title">История на заеманията</h2>
            </div>

            <div class="Reader-empty-state">
                Тази секция ще я подредим след това.
            </div>
        </section>

        <section id="notes" class="Reader-portal-section">
            <div class="Reader-section-header">
                <h2 class="Reader-section-title">Моите бележки</h2>
                <p class="Reader-section-subtitle">
                    Всички твои лични бележки към книги са събрани тук.
                </p>
            </div>

            @if (Model.BookNotes != null && Model.BookNotes.Any())
            {
                <div style="max-height:720px; overflow:auto; padding-right:4px;">
                    <div style="display:grid; grid-template-columns:repeat(auto-fit, minmax(220px, 1fr)); gap:18px;">
                        @foreach (var note in Model.BookNotes)
                        {
                            var previewText = note.Text?.Length > 260
                            ? note.Text.Substring(0, 260) + "..."
                            : note.Text;

                            <div class="reader-note-card"
                                 data-note-id="@note.NoteId"
                                 data-book-id="@note.BookId"
                                 data-note-text="@note.Text"
                                 onclick="openReaderPortalNoteModal(this)"
                                 style="position:relative;
                                        min-height:240px;
                                        border:1px solid #e7d98c;
                                        border-radius:18px;
                                        background:
                                            repeating-linear-gradient(
                                                to bottom,
                                                #fff7bf 0px,
                                                #fff7bf 30px,
                                                #eadf9f 31px
                                            );
                                        box-shadow:0 14px 28px rgba(148, 122, 24, .16);
                                        padding:18px 18px 16px 18px;
                                        cursor:pointer;
                                        transition:transform .18s ease, box-shadow .18s ease;
                                        overflow:hidden;"
                                 onmouseover="this.style.transform='translateY(-3px) rotate(-0.5deg)'; this.style.boxShadow='0 18px 34px rgba(148,122,24,.22)';"
                                 onmouseout="this.style.transform='translateY(0) rotate(0deg)'; this.style.boxShadow='0 14px 28px rgba(148,122,24,.16)';">

                                <div style="display:flex; align-items:flex-start; justify-content:space-between; gap:12px; margin-bottom:10px;">
                                    <div style="min-width:0;">
                                        <div style="color:#7c5d00; font-size:.75rem; font-weight:900; text-transform:uppercase; letter-spacing:.08em;">
                                            Бележка
                                        </div>

                                        <a asp-controller="Catalog"
                                           asp-action="ReaderDetails"
                                           asp-route-id="@note.BookId"
                                           onclick="event.stopPropagation();"
                                           style="display:block;
                                                  margin-top:5px;
                                                  color:#17325c;
                                                  font-size:1rem;
                                                  font-weight:900;
                                                  line-height:1.2;
                                                  text-decoration:none;">
                                            @note.BookTitle
                                        </a>

                                        @if (!string.IsNullOrWhiteSpace(note.BookAuthor))
                                        {
                                            <div style="margin-top:4px; color:#7b6b2c; font-size:.84rem; font-weight:700;">
                                                @note.BookAuthor
                                            </div>
                                        }
                                    </div>

                                    <div style="flex:0 0 auto; color:#b08900; font-size:1.15rem;">✎</div>
                                </div>

                                <div style="white-space:pre-line;
                                            color:#5f4b00;
                                            font-size:.95rem;
                                            line-height:31px;
                                            min-height:124px;
                                            max-height:124px;
                                            overflow:hidden;
                                            padding-top:2px;">
                                    @previewText
                                </div>

                                <div style="margin-top:14px; display:flex; align-items:center; justify-content:space-between; gap:10px;">
                                    <div style="color:#8a6f14; font-size:.76rem; font-weight:800;">
                                        @(note.UpdatedOn.HasValue ? "Редактирана" : "Създадена")
                                    </div>

                                    <div style="color:#8a6f14; font-size:.76rem; font-weight:900;">
                                        @(note.UpdatedOn?.ToString("dd.MM.yyyy") ?? note.CreatedOn.ToString("dd.MM.yyyy"))
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            }
            else
            {
                <div class="Reader-empty-state">
                    Все още нямаш създадени бележки към книги.
                </div>
            }
        </section>


        <section id="extension" class="Reader-portal-section">
            <div class="Reader-section-header">
                <h2 class="Reader-section-title">Заявка за удължаване</h2>
            </div>

            <div class="Reader-empty-state">
                Тази секция ще я подредим след това.
            </div>
        </section>

        <!-- 7. ЛИЧНИ ДАННИ -->
        <section id="profile" class="Reader-portal-section">
            <div class="Reader-section-header">
                <h2 class="Reader-section-title">Лични данни</h2>
            </div>

            <div class="Reader-empty-state">
                Тази секция ще я подредим след това.
            </div>
        </section>

    </main>
</div>

@if (ViewBag.RequirePasswordChange == true)
{
    <div id="passwordOverlay"
         style="position:fixed;
                    inset:0;
                    background:rgba(15,23,42,.34);
                    backdrop-filter:blur(5px);
                    z-index:9999;
                    display:flex;
                    align-items:center;
                    justify-content:center;
                    padding:18px;">

        <div style="width:460px;
                        max-width:100%;
                        background:#ffffff;
                        border:1px solid #dbe5ef;
                        border-radius:24px;
                        padding:30px 28px 26px 28px;
                        box-shadow:0 24px 70px rgba(15,23,42,.16);">

            <div style="text-align:center; margin-bottom:20px;">
                <div style="font-size:1.65rem;
                                font-weight:900;
                                color:#0f172a;
                                line-height:1.15;
                                margin-bottom:8px;">
                    Смени паролата си
                </div>

                <div style="display:inline-flex;
                                align-items:center;
                                justify-content:center;
                                min-height:30px;
                                padding:0 12px;
                                border-radius:999px;
                                background:#eff6ff;
                                color:#2563eb;
                                font-size:.82rem;
                                font-weight:800;
                                margin-bottom:12px;">
                    Първи вход в профила
                </div>

                <div style="color:#64748b;
                                font-size:.98rem;
                                line-height:1.65;
                                max-width:340px;
                                margin:0 auto;">
                    За да продължиш към профила си, първо трябва да зададеш нова лична парола.
                </div>
            </div>

            @if (TempData["PasswordChangeError"] != null)
            {
                <div style="margin-bottom:14px;
                                    padding:11px 13px;
                                    border-radius:12px;
                                    border:1px solid #fecaca;
                                    background:#fef2f2;
                                    color:#b91c1c;
                                    font-size:.92rem;
                                    font-weight:700;">
                    @TempData["PasswordChangeError"]
                </div>
            }

            <form asp-controller="ReaderAccount"
                  asp-action="ChangePassword"
                  method="post"
                  style="margin:0;">
                @Html.AntiForgeryToken()

                <div style="display:grid; gap:14px;">

                    <div>
                        <label style="display:block; margin-bottom:7px; color:#0f172a; font-size:.95rem; font-weight:800;">
                            Текуща парола
                        </label>
                        <input type="password"
                               name="CurrentPassword"
                               class="Reader-password-input"
                               style="width:100%; height:50px; border-radius:14px; border:1px solid #cbd5e1; background:#ffffff; box-shadow:none; font-size:.98rem; padding:0 14px; outline:none; transition:border-color .18s ease, box-shadow .18s ease, transform .18s ease;" />
                    </div>

                    <div>
                        <label style="display:block; margin-bottom:7px; color:#0f172a; font-size:.95rem; font-weight:800;">
                            Нова парола
                        </label>
                        <input type="password"
                               name="NewPassword"
                               class="Reader-password-input"
                               style="width:100%; height:50px; border-radius:14px; border:1px solid #cbd5e1; background:#ffffff; box-shadow:none; font-size:.98rem; padding:0 14px; outline:none; transition:border-color .18s ease, box-shadow .18s ease, transform .18s ease;" />
                    </div>

                    <div>
                        <label style="display:block; margin-bottom:7px; color:#0f172a; font-size:.95rem; font-weight:800;">
                            Потвърди новата парола
                        </label>
                        <input type="password"
                               name="ConfirmPassword"
                               class="Reader-password-input"
                               style="width:100%; height:50px; border-radius:14px; border:1px solid #cbd5e1; background:#ffffff; box-shadow:none; font-size:.98rem; padding:0 14px; outline:none; transition:border-color .18s ease, box-shadow .18s ease, transform .18s ease;" />
                    </div>
                </div>

                <div style="margin-top:18px;">
                    <button type="submit"
                            id="saveReaderPasswordBtn"
                            style="width:100%; height:50px; border:none; border-radius:14px; background:linear-gradient(135deg, #2563eb 0%, #3b82f6 100%); color:#ffffff; font-size:1rem; font-weight:800; box-shadow:0 14px 28px rgba(37,99,235,.18); transition:transform .18s ease, box-shadow .18s ease, filter .18s ease;">
                        Запази новата парола
                    </button>
                </div>
                <div id="readerPortalNoteModal"
                     style="display:none;
                position:fixed;
                inset:0;
                z-index:9998;
                background:rgba(15,23,42,.40);
                backdrop-filter:blur(4px);
                align-items:center;
                justify-content:center;
                padding:18px;">

                    <div style="width:min(760px, 100%);
                    max-height:88vh;
                    overflow:auto;
                    border-radius:26px;
                    background:#fffef7;
                    border:1px solid #eadf9f;
                    box-shadow:0 30px 70px rgba(15,23,42,.20);
                    padding:24px;">

                        <div style="display:flex; align-items:flex-start; justify-content:space-between; gap:16px; margin-bottom:18px;">
                            <div>
                                <div id="readerPortalNoteBookTitle"
                                     style="color:#17325c; font-size:1.3rem; font-weight:900; line-height:1.2;">
                                    Бележка
                                </div>
                                <div style="margin-top:6px; color:#8a6f14; font-size:.85rem; font-weight:800;">
                                    Лична бележка към книга
                                </div>
                            </div>

                            <button type="button"
                                    onclick="closeReaderPortalNoteModal()"
                                    style="width:40px; height:40px; border:none; border-radius:12px; background:#fff3bf; color:#7c5d00; font-size:1.2rem; font-weight:900; cursor:pointer;">
                                ×
                            </button>
                        </div>

                        <input type="hidden" id="readerPortalCurrentNoteId" />

                        <div id="readerPortalNotePaper"
                             contenteditable="true"
                             spellcheck="true"
                             style="min-height:360px;
                        padding:18px 18px 18px 18px;
                        border:1px solid #e7d98c;
                        border-radius:18px;
                        outline:none;
                        background:
                            repeating-linear-gradient(
                                to bottom,
                                #fff7bf 0px,
                                #fff7bf 30px,
                                #eadf9f 31px
                            );
                        color:#5f4b00;
                        font-size:1rem;
                        line-height:31px;
                        white-space:pre-wrap;
                        overflow-wrap:anywhere;"></div>

                        <div style="margin-top:18px; display:flex; align-items:center; justify-content:flex-end; gap:12px;">
                            <button type="button"
                                    id="readerPortalDeleteBtn"
                                    onclick="deleteReaderPortalNote()"
                                    style="display:none;
                               min-height:44px;
                               padding:0 16px;
                               border:none;
                               border-radius:12px;
                               background:#fee2e2;
                               color:#b42318;
                               font-size:.92rem;
                               font-weight:900;
                               cursor:pointer;">
                                Изтрий
                            </button>

                            <button type="button"
                                    onclick="closeReaderPortalNoteModal()"
                                    style="min-height:44px;
                               padding:0 18px;
                               border:1px solid #d8e1eb;
                               border-radius:12px;
                               background:#ffffff;
                               color:#334155;
                               font-size:.92rem;
                               font-weight:900;
                               cursor:pointer;">
                                Затвори
                            </button>

                            <button type="button"
                                    onclick="saveReaderPortalNote()"
                                    style="min-height:44px;
                               padding:0 20px;
                               border:none;
                               border-radius:12px;
                               background:linear-gradient(180deg,#facc15 0%,#eab308 100%);
                               color:#5f4b00;
                               font-size:.92rem;
                               font-weight:900;
                               cursor:pointer;
                               box-shadow:0 10px 22px rgba(234,179,8,.24);">
                                Запази
                            </button>
                        </div>
                    </div>
                </div>
            </form>
        </div>
    </div>
}
<script>
    function openReaderPortalNoteModal(card) {
        const modal = document.getElementById("readerPortalNoteModal");
        const title = document.getElementById("readerPortalNoteBookTitle");
        const noteId = document.getElementById("readerPortalCurrentNoteId");
        const paper = document.getElementById("readerPortalNotePaper");
        const deleteBtn = document.getElementById("readerPortalDeleteBtn");

        const bookTitleLink = card.querySelector("a");
        const bookTitle = bookTitleLink ? bookTitleLink.textContent.trim() : "Бележка";

        title.textContent = bookTitle;
        noteId.value = card.getAttribute("data-note-id") || "";
        paper.innerText = card.getAttribute("data-note-text") || "";

        deleteBtn.style.display = noteId.value ? "inline-flex" : "none";
        modal.style.display = "flex";
    }

    function closeReaderPortalNoteModal() {
        document.getElementById("readerPortalNoteModal").style.display = "none";
    }

    async function saveReaderPortalNote() {
        const noteId = document.getElementById("readerPortalCurrentNoteId").value;
        const paper = document.getElementById("readerPortalNotePaper");
        const text = (paper.innerText || "").trim();

        if (!text) {
            alert("Бележката не може да бъде празна.");
            return;
        }

        const tokenInput = document.querySelector('input[name="__RequestVerificationToken"]');
        const token = tokenInput ? tokenInput.value : "";

        const formData = new URLSearchParams();
        formData.append("noteId", noteId);
        formData.append("text", text);
        formData.append("__RequestVerificationToken", token);

        const response = await fetch('@Url.Action("UpdateNote", "ReaderPortal")', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/x-www-form-urlencoded; charset=UTF-8'
            },
            body: formData.toString()
        });

        if (response.ok) {
            location.reload();
            return;
        }

        alert("Възникна проблем при запазването на бележката.");
    }

    async function deleteReaderPortalNote() {
        const noteId = document.getElementById("readerPortalCurrentNoteId").value;

        if (!noteId) {
            return;
        }

        if (!confirm("Сигурна ли си, че искаш да изтриеш тази бележка?")) {
            return;
        }

        const tokenInput = document.querySelector('input[name="__RequestVerificationToken"]');
        const token = tokenInput ? tokenInput.value : "";

        const formData = new URLSearchParams();
        formData.append("noteId", noteId);
        formData.append("__RequestVerificationToken", token);

        const response = await fetch('@Url.Action("DeleteNote", "ReaderPortal")', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/x-www-form-urlencoded; charset=UTF-8'
            },
            body: formData.toString()
        });

        if (response.ok) {
            location.reload();
            return;
        }

        alert("Възникна проблем при изтриването на бележката.");
    }

    document.addEventListener("keydown", function (e) {
        if (e.key === "Escape") {
            closeReaderPortalNoteModal();
        }
    });

    document.getElementById("readerPortalNoteModal")?.addEventListener("click", function (e) {
        if (e.target === this) {
            closeReaderPortalNoteModal();
        }
    });

    (function () {
        const links = Array.from(document.querySelectorAll('#ReaderScrollspy .Reader-nav-link'));
        const sections = Array.from(document.querySelectorAll('.Reader-portal-section'));

        function setActive(hash) {
            links.forEach(link => {
                link.classList.toggle('active', link.getAttribute('href') === hash);
            });
        }

        links.forEach(link => {
            link.addEventListener('click', function () {
                setActive(link.getAttribute('href'));
            });
        });

        const observer = new IntersectionObserver((entries) => {
            const visible = entries
                .filter(entry => entry.isIntersecting)
                .sort((a, b) => Math.abs(a.boundingreaderRect.top) - Math.abs(b.boundingreaderRect.top));

            if (visible.length > 0) {
                setActive('#' + visible[0].target.id);
            }
        }, {
            rootMargin: '-18% 0px -62% 0px',
            threshold: [0.15, 0.35, 0.55]
        });

        sections.forEach(section => observer.observe(section));

        document.querySelectorAll('.Reader-password-input').forEach(input => {
            input.addEventListener('mouseenter', function () {
                if (document.activeElement !== input) {
                    input.style.borderColor = '#93c5fd';
                    input.style.boxShadow = '0 10px 24px rgba(37,99,235,.08)';
                    input.style.transform = 'translateY(-1px)';
                }
            });

            input.addEventListener('mouseleave', function () {
                if (document.activeElement !== input) {
                    input.style.borderColor = '#cbd5e1';
                    input.style.boxShadow = 'none';
                    input.style.transform = 'translateY(0)';
                }
            });

            input.addEventListener('focus', function () {
                input.style.borderColor = '#3b82f6';
                input.style.boxShadow = '0 0 0 4px rgba(59,130,246,.12), 0 10px 24px rgba(37,99,235,.08)';
                input.style.transform = 'translateY(-1px)';
            });

            input.addEventListener('blur', function () {
                input.style.borderColor = '#cbd5e1';
                input.style.boxShadow = 'none';
                input.style.transform = 'translateY(0)';
            });
        });

        const saveReaderPasswordBtn = document.getElementById('saveReaderPasswordBtn');
        if (saveReaderPasswordBtn) {
            saveReaderPasswordBtn.addEventListener('mouseenter', function () {
                saveReaderPasswordBtn.style.transform = 'translateY(-2px)';
                saveReaderPasswordBtn.style.boxShadow = '0 18px 34px rgba(37,99,235,.24)';
                saveReaderPasswordBtn.style.filter = 'brightness(1.03)';
            });

            saveReaderPasswordBtn.addEventListener('mouseleave', function () {
                saveReaderPasswordBtn.style.transform = 'translateY(0)';
                saveReaderPasswordBtn.style.boxShadow = '0 14px 28px rgba(37,99,235,.18)';
