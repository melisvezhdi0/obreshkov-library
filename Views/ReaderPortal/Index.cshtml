@model ObreshkovLibrary.Models.ViewModels.ReaderDashboardVM

@{
    ViewData["Title"] = "Моят профил";
    Layout = "_ReaderLayout";

    string ResolveCoverUrl(string? path)
    {
        if (string.IsNullOrWhiteSpace(path))
            return "";

        return path.StartsWith("/")
            ? Url.Content("~" + path)
            : Url.Content("~/" + path.TrimStart('/'));
    }

    string fullClass = Model.Grade.HasValue
        ? $"{Model.Grade} клас{(string.IsNullOrWhiteSpace(Model.Section) ? "" : " " + Model.Section)}"
        : "Няма информация";
}

<style>
    body.reader-portal-fixed-nav {
        padding-top: 72px;
    }

        body.reader-portal-fixed-nav .reader-top-nav {
            position: fixed !important;
            top: 0;
            left: 0;
            right: 0;
            z-index: 2000 !important;
        }

    html {
        scroll-behavior: smooth;
    }
</style>

<form style="display:none;">
    @Html.AntiForgeryToken()
</form>

<div style="width:100%; margin:0; padding:0; background:
    radial-gradient(circle at 10% 12%, rgba(37,99,235,.03), transparent 24%),
    radial-gradient(circle at 92% 8%, rgba(59,130,246,.025), transparent 20%),
    linear-gradient(180deg, #f8fafc 0%, #f4f7fb 100%);
    display:grid;
    grid-template-columns:260px minmax(0,1fr);
    min-height:calc(100vh - 72px);">

    <aside style="background:linear-gradient(180deg,#f8fafc 0%,#f4f7fb 100%);
                  border-right:1px solid #e2e8f0;
                  min-width:0;
                  min-height:calc(100vh - 72px);">
        <div style="position:sticky;
                    top:72px;
                    height:calc(100vh - 72px);
                    display:flex;
                    flex-direction:column;
                    padding:18px 14px 14px 14px;
                    box-sizing:border-box;
                    overflow:hidden;">

            <div style="color:#2563eb;
                        font-size:.72rem;
                        font-weight:900;
                        letter-spacing:.12em;
                        text-transform:uppercase;
                        margin-bottom:8px;">
                Reader Portal
            </div>

            <h1 style="margin:0;
                       color:#17325c;
                       font-size:1.95rem;
                       font-weight:900;
                       line-height:1.03;
                       letter-spacing:-.03em;">
                Моят профил
            </h1>

            <nav id="ReaderScrollspy"
                 style="display:grid;
                        gap:8px;
                        margin-top:20px;
                        flex:1 1 auto;
                        align-content:start;">

                <a href="#current-loans"
                   class="reader-scroll-link active"
                   data-active="true"
                   style="display:flex; align-items:center; gap:11px; min-height:50px; padding:0 16px 0 14px; border-radius:15px; text-decoration:none; color:#1d4ed8; background:#eef4ff; border:1px solid #dbe7fb; box-shadow:0 8px 16px rgba(37,99,235,.08); font-size:.95rem; font-weight:900; transition:all .18s ease;"
                   onmouseover="if(this.dataset.active!=='true'){this.style.background='#f3f6fa';this.style.color='#1d4ed8';this.style.borderColor='#dbe7fb';this.style.boxShadow='0 8px 16px rgba(37,99,235,.08)';this.querySelector('.reader-scroll-dot').style.background='#2563eb';this.style.transform='translateY(-1px)';}"
                   onmouseout="if(this.dataset.active!=='true'){this.style.background='#ffffff';this.style.color='#334155';this.style.borderColor='#e5e7eb';this.style.boxShadow='0 2px 8px rgba(15,23,42,.025)';this.querySelector('.reader-scroll-dot').style.background='#cbd5e1';this.style.transform='translateY(0)';}">
                    <span class="reader-scroll-dot" style="width:8px; height:8px; border-radius:999px; background:#2563eb; flex:0 0 auto;"></span>
                    <span>Текущо заети книги</span>
                </a>

                <a href="#favorites"
                   class="reader-scroll-link"
                   data-active="false"
                   style="display:flex; align-items:center; gap:11px; min-height:50px; padding:0 16px 0 14px; border-radius:15px; text-decoration:none; color:#334155; background:#ffffff; border:1px solid #e5e7eb; box-shadow:0 2px 8px rgba(15,23,42,.025); font-size:.95rem; font-weight:900; transition:all .18s ease;"
                   onmouseover="if(this.dataset.active!=='true'){this.style.background='#f3f6fa';this.style.color='#1d4ed8';this.style.borderColor='#dbe7fb';this.style.boxShadow='0 8px 16px rgba(37,99,235,.08)';this.querySelector('.reader-scroll-dot').style.background='#2563eb';this.style.transform='translateY(-1px)';}"
                   onmouseout="if(this.dataset.active!=='true'){this.style.background='#ffffff';this.style.color='#334155';this.style.borderColor='#e5e7eb';this.style.boxShadow='0 2px 8px rgba(15,23,42,.025)';this.querySelector('.reader-scroll-dot').style.background='#cbd5e1';this.style.transform='translateY(0)';}">
                    <span class="reader-scroll-dot" style="width:8px; height:8px; border-radius:999px; background:#cbd5e1; flex:0 0 auto;"></span>
                    <span>Списък за четене</span>
                </a>

                <a href="#notifications"
                   class="reader-scroll-link"
                   data-active="false"
                   style="display:flex; align-items:center; gap:11px; min-height:50px; padding:0 16px 0 14px; border-radius:15px; text-decoration:none; color:#334155; background:#ffffff; border:1px solid #e5e7eb; box-shadow:0 2px 8px rgba(15,23,42,.025); font-size:.95rem; font-weight:900; transition:all .18s ease;"
                   onmouseover="if(this.dataset.active!=='true'){this.style.background='#f3f6fa';this.style.color='#1d4ed8';this.style.borderColor='#dbe7fb';this.style.boxShadow='0 8px 16px rgba(37,99,235,.08)';this.querySelector('.reader-scroll-dot').style.background='#2563eb';this.style.transform='translateY(-1px)';}"
                   onmouseout="if(this.dataset.active!=='true'){this.style.background='#ffffff';this.style.color='#334155';this.style.borderColor='#e5e7eb';this.style.boxShadow='0 2px 8px rgba(15,23,42,.025)';this.querySelector('.reader-scroll-dot').style.background='#cbd5e1';this.style.transform='translateY(0)';}">
                    <span class="reader-scroll-dot" style="width:8px; height:8px; border-radius:999px; background:#cbd5e1; flex:0 0 auto;"></span>
                    <span>Известия</span>
                </a>

                <a href="#history"
                   class="reader-scroll-link"
                   data-active="false"
                   style="display:flex; align-items:center; gap:11px; min-height:50px; padding:0 16px 0 14px; border-radius:15px; text-decoration:none; color:#334155; background:#ffffff; border:1px solid #e5e7eb; box-shadow:0 2px 8px rgba(15,23,42,.025); font-size:.95rem; font-weight:900; transition:all .18s ease;"
                   onmouseover="if(this.dataset.active!=='true'){this.style.background='#f3f6fa';this.style.color='#1d4ed8';this.style.borderColor='#dbe7fb';this.style.boxShadow='0 8px 16px rgba(37,99,235,.08)';this.querySelector('.reader-scroll-dot').style.background='#2563eb';this.style.transform='translateY(-1px)';}"
                   onmouseout="if(this.dataset.active!=='true'){this.style.background='#ffffff';this.style.color='#334155';this.style.borderColor='#e5e7eb';this.style.boxShadow='0 2px 8px rgba(15,23,42,.025)';this.querySelector('.reader-scroll-dot').style.background='#cbd5e1';this.style.transform='translateY(0)';}">
                    <span class="reader-scroll-dot" style="width:8px; height:8px; border-radius:999px; background:#cbd5e1; flex:0 0 auto;"></span>
                    <span>История на заеманията</span>
                </a>

                <a href="#notes"
                   class="reader-scroll-link"
                   data-active="false"
                   style="display:flex; align-items:center; gap:11px; min-height:50px; padding:0 16px 0 14px; border-radius:15px; text-decoration:none; color:#334155; background:#ffffff; border:1px solid #e5e7eb; box-shadow:0 2px 8px rgba(15,23,42,.025); font-size:.95rem; font-weight:900; transition:all .18s ease;"
                   onmouseover="if(this.dataset.active!=='true'){this.style.background='#f3f6fa';this.style.color='#1d4ed8';this.style.borderColor='#dbe7fb';this.style.boxShadow='0 8px 16px rgba(37,99,235,.08)';this.querySelector('.reader-scroll-dot').style.background='#2563eb';this.style.transform='translateY(-1px)';}"
                   onmouseout="if(this.dataset.active!=='true'){this.style.background='#ffffff';this.style.color='#334155';this.style.borderColor='#e5e7eb';this.style.boxShadow='0 2px 8px rgba(15,23,42,.025)';this.querySelector('.reader-scroll-dot').style.background='#cbd5e1';this.style.transform='translateY(0)';}">
                    <span class="reader-scroll-dot" style="width:8px; height:8px; border-radius:999px; background:#cbd5e1; flex:0 0 auto;"></span>
                    <span>Бележки</span>
                </a>

                <a href="#profile"
                   class="reader-scroll-link"
                   data-active="false"
                   style="display:flex; align-items:center; gap:11px; min-height:50px; padding:0 16px 0 14px; border-radius:15px; text-decoration:none; color:#334155; background:#ffffff; border:1px solid #e5e7eb; box-shadow:0 2px 8px rgba(15,23,42,.025); font-size:.95rem; font-weight:900; transition:all .18s ease;"
                   onmouseover="if(this.dataset.active!=='true'){this.style.background='#f3f6fa';this.style.color='#1d4ed8';this.style.borderColor='#dbe7fb';this.style.boxShadow='0 8px 16px rgba(37,99,235,.08)';this.querySelector('.reader-scroll-dot').style.background='#2563eb';this.style.transform='translateY(-1px)';}"
                   onmouseout="if(this.dataset.active!=='true'){this.style.background='#ffffff';this.style.color='#334155';this.style.borderColor='#e5e7eb';this.style.boxShadow='0 2px 8px rgba(15,23,42,.025)';this.querySelector('.reader-scroll-dot').style.background='#cbd5e1';this.style.transform='translateY(0)';}">
                    <span class="reader-scroll-dot" style="width:8px; height:8px; border-radius:999px; background:#cbd5e1; flex:0 0 auto;"></span>
                    <span>Лични данни</span>
                </a>
            </nav>

            <div style="margin-top:auto; padding-top:16px; border-top:1px solid #e5e7eb;">
                <form asp-area="Identity"
                      asp-page="/Account/Logout"
                      method="post"
                      style="margin:0;">
                    @Html.AntiForgeryToken()
                    <button type="submit"
                            style="width:100%;
                                   min-height:46px;
                                   border:1px solid #d7e2ef;
                                   border-radius:14px;
                                   background:#ffffff;
                                   color:#334155;
                                   font-size:.94rem;
                                   font-weight:900;
                                   cursor:pointer;
                                   box-shadow:0 2px 8px rgba(15,23,42,.025);
                                   transition:all .18s ease;"
                            onmouseover="this.style.borderColor='#fecaca';this.style.background='#fef2f2';this.style.color='#dc2626';this.style.boxShadow='0 10px 20px rgba(220,38,38,.12)';this.style.transform='translateY(-1px)';"
                            onmouseout="this.style.borderColor='#d7e2ef';this.style.background='#ffffff';this.style.color='#334155';this.style.boxShadow='0 2px 8px rgba(15,23,42,.025)';this.style.transform='translateY(0)';">
                        Изход
                    </button>
                </form>
            </div>
        </div>
    </aside>

    <main style="min-width:0; padding:16px 18px 22px 18px; display:grid; gap:18px;">

        <section id="current-loans"
                 style="scroll-margin-top:112px; border:1px solid #e3e8ef; border-radius:24px; background:rgba(255,255,255,.97); box-shadow:0 10px 24px rgba(15,23,42,.04); overflow:hidden;">
            <div style="margin:0; padding:18px 20px 14px 20px; border-bottom:1px solid #e8edf4; background:linear-gradient(180deg,#ffffff 0%,#fbfdff 100%);">
                <div style="display:flex; align-items:flex-end; justify-content:space-between; gap:14px; flex-wrap:wrap;">
                    <div>
                        <h2 style="margin:0; color:#0f172a; font-size:1.55rem; font-weight:900; line-height:1.08; letter-spacing:-.02em;">
                            Текущо заети книги
                        </h2>
                        <div style="width:58px; height:4px; margin-top:10px; border-radius:999px; background:linear-gradient(90deg,#2563eb 0%,#60a5fa 100%);"></div>
                    </div>
                </div>
            </div>

            <div style="margin:0; border:none; background:transparent; padding:18px 20px 20px 20px; overflow:hidden; max-height:280px; overflow-y:auto; padding-right:8px;">
                @if (Model.CurrentLoans != null && Model.CurrentLoans.Any())
                {
                    <div style="width:100%; overflow-x:auto; border:1px solid #e6edf5; border-radius:18px; background:#f8fbff;">
                        <table style="width:100%; min-width:760px; border-collapse:separate; border-spacing:0;">
                            <thead>
                                <tr>
                                    <th style="position:sticky; top:-18px; z-index:2; background:#eef4fb; color:#475569; font-size:.78rem; font-weight:900; text-transform:uppercase; letter-spacing:.06em; text-align:left; padding:12px 14px; border-bottom:1px solid #dbe5ef;">Заглавие</th>
                                    <th style="position:sticky; top:-18px; z-index:2; background:#eef4fb; color:#475569; font-size:.78rem; font-weight:900; text-transform:uppercase; letter-spacing:.06em; text-align:left; padding:12px 14px; border-bottom:1px solid #dbe5ef; width:190px;">Автор</th>
                                    <th style="position:sticky; top:-18px; z-index:2; background:#eef4fb; color:#475569; font-size:.78rem; font-weight:900; text-transform:uppercase; letter-spacing:.06em; text-align:left; padding:12px 14px; border-bottom:1px solid #dbe5ef; width:150px;">Заета на</th>
                                    <th style="position:sticky; top:-18px; z-index:2; background:#eef4fb; color:#475569; font-size:.78rem; font-weight:900; text-transform:uppercase; letter-spacing:.06em; text-align:left; padding:12px 14px; border-bottom:1px solid #dbe5ef; width:150px;">Връщане до</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model.CurrentLoans)
                                {
                                    <tr>
                                        <td style="padding:12px 14px; border-bottom:1px solid #e4ebf2; vertical-align:middle; background:#ffffff;">
                                            <a asp-controller="Catalog"
                                               asp-action="ReaderDetails"
                                               asp-route-id="@item.BookId"
                                               style="color:#0f172a; text-decoration:none; font-size:.95rem; font-weight:900; line-height:1.25;"
                                               onmouseover="this.style.color='#2563eb';"
                                               onmouseout="this.style.color='#0f172a';">
                                                @item.Title
                                            </a>
                                        </td>

                                        <td style="padding:12px 14px; border-bottom:1px solid #e4ebf2; vertical-align:middle; background:#ffffff; color:#334155; font-size:.9rem; font-weight:700;">
                                            @item.Author
                                        </td>

                                        <td style="padding:12px 14px; border-bottom:1px solid #e4ebf2; vertical-align:middle; background:#ffffff; color:#334155; font-size:.9rem; font-weight:700;">
                                            @item.LoanDate.ToString("dd.MM.yyyy")
                                        </td>

                                        <td style="padding:12px 14px; border-bottom:1px solid #e4ebf2; vertical-align:middle; background:#ffffff; font-size:.92rem; font-weight:900; color:@(item.IsOverdue ? "#b42318" : "#1e3a8a");">
                                            @item.DueDate.ToString("dd.MM.yyyy")
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <div style="min-height:150px; display:flex; align-items:center; justify-content:center; text-align:center; border:1px dashed #d7e0ea; border-radius:22px; background:linear-gradient(180deg,#f8fbff 0%,#f1f5f9 100%); color:#64748b; font-size:.98rem; font-weight:800; padding:24px;">
                        В момента нямаш заети книги.
                    </div>
                }
            </div>
        </section>

        <section id="favorites"
                 style="scroll-margin-top:112px; border:1px solid #e3e8ef; border-radius:24px; background:rgba(255,255,255,.97); box-shadow:0 10px 24px rgba(15,23,42,.04); overflow:hidden;">
            <div style="margin:0; padding:18px 20px 14px 20px; border-bottom:1px solid #e8edf4; background:linear-gradient(180deg,#ffffff 0%,#fbfdff 100%);">
                <div>
                    <h2 style="margin:0; color:#0f172a; font-size:1.55rem; font-weight:900; line-height:1.08; letter-spacing:-.02em;">
                        Списък за четене
                    </h2>
                    <div style="width:58px; height:4px; margin-top:10px; border-radius:999px; background:linear-gradient(90deg,#2563eb 0%,#60a5fa 100%);"></div>
                </div>
            </div>

            <div style="margin:0; border:none; background:transparent; padding:18px 20px 20px 20px; overflow:hidden; max-height:320px; overflow-y:auto; padding-right:8px;">
                @if (Model.FavoriteBooks != null && Model.FavoriteBooks.Any())
                {
                    <div style="display:grid; grid-template-columns:repeat(auto-fill, minmax(150px, 1fr)); gap:14px;">
                        @foreach (var item in Model.FavoriteBooks)
                        {
                            <div style="position:relative; border-radius:18px; overflow:hidden; border:1px solid #dfe8f2; background:#ffffff; box-shadow:0 6px 16px rgba(15,23,42,.035); transition:all .18s ease;"
                                 onmouseover="this.style.transform='translateY(-3px)';this.style.borderColor='#d7e4ff';this.style.boxShadow='0 14px 28px rgba(15,23,42,.08)'; this.querySelector('.reader-fav-overlay').style.opacity='1';"
                                 onmouseout="this.style.transform='translateY(0)';this.style.borderColor='#dfe8f2';this.style.boxShadow='0 6px 16px rgba(15,23,42,.035)'; this.querySelector('.reader-fav-overlay').style.opacity='0';">

                                <a asp-controller="Catalog"
                                   asp-action="ReaderDetails"
                                   asp-route-id="@item.BookId"
                                   style="display:block; position:relative; text-decoration:none; color:inherit; background:linear-gradient(180deg,#f8fbff 0%,#f4f7fb 100%);">
                                    @if (!string.IsNullOrWhiteSpace(item.CoverPath))
                                    {
                                        <img src="@ResolveCoverUrl(item.CoverPath)"
                                             alt="@item.Title"
                                             style="width:100%; height:230px; object-fit:contain; display:block; padding:10px; background:linear-gradient(180deg,#f8fbff 0%,#f4f7fb 100%);" />
                                    }
                                    else
                                    {
                                        <div style="width:100%; height:230px; display:flex; align-items:center; justify-content:center; color:#94a3b8; font-size:.8rem; font-weight:800; text-align:center; padding:10px; background:linear-gradient(180deg,#f8fbff 0%,#f4f7fb 100%);">
                                            Няма корица
                                        </div>
                                    }

                                    <div class="reader-fav-overlay"
                                         style="position:absolute; inset:0; background:linear-gradient(180deg, rgba(15,23,42,.04) 0%, rgba(15,23,42,.18) 35%, rgba(15,23,42,.86) 100%); display:flex; flex-direction:column; justify-content:flex-end; gap:8px; padding:14px; opacity:0; transition:opacity .2s ease;">
                                        <div style="color:#ffffff; font-size:.9rem; font-weight:900; line-height:1.3; display:-webkit-box; -webkit-line-clamp:3; -webkit-box-orient:vertical; overflow:hidden; text-shadow:0 2px 10px rgba(0,0,0,.25);">
                                            @item.Title
                                        </div>

                                        <div style="display:inline-flex; align-items:center; justify-content:center; width:fit-content; min-height:30px; padding:0 10px; border-radius:999px; font-size:.78rem; font-weight:900; background:@(item.IsAvailable ? "#ecfdf3" : "#fef3f2"); color:@(item.IsAvailable ? "#067647" : "#b42318");">
                                            @(item.IsAvailable ? "Налична" : "Неналична")
                                        </div>
                                    </div>
                                </a>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div style="min-height:150px; display:flex; align-items:center; justify-content:center; text-align:center; border:1px dashed #d7e0ea; border-radius:22px; background:linear-gradient(180deg,#f8fbff 0%,#f1f5f9 100%); color:#64748b; font-size:.98rem; font-weight:800; padding:24px;">
                        Все още нямаш книги в списъка за четене.
                    </div>
                }
            </div>
        </section>

        <section id="notifications"
                 style="scroll-margin-top:112px; border:1px solid #e3e8ef; border-radius:24px; background:rgba(255,255,255,.97); box-shadow:0 10px 24px rgba(15,23,42,.04); overflow:hidden;">
            <div style="margin:0; padding:18px 20px 14px 20px; border-bottom:1px solid #e8edf4; background:linear-gradient(180deg,#ffffff 0%,#fbfdff 100%);">
                <div style="display:flex; align-items:flex-end; justify-content:space-between; gap:14px; flex-wrap:wrap;">
                    <div>
                        <h2 style="margin:0; color:#0f172a; font-size:1.55rem; font-weight:900; line-height:1.08; letter-spacing:-.02em;">
                            Известия
                        </h2>
                        <div style="width:58px; height:4px; margin-top:10px; border-radius:999px; background:linear-gradient(90deg,#2563eb 0%,#60a5fa 100%);"></div>
                    </div>

                    @if (Model.LatestNotifications != null && Model.LatestNotifications.Any(n => !n.IsRead))
                    {
                        <button type="button"
                                id="markAllReaderNotificationsBtn"
                                style="min-height:40px; padding:0 15px; border:none; border-radius:12px; background:linear-gradient(135deg, #2563eb 0%, #3b82f6 100%); color:#ffffff; font-size:.86rem; font-weight:900; box-shadow:0 10px 20px rgba(37,99,235,.16); transition:transform .18s ease, box-shadow .18s ease; cursor:pointer;"
                                onmouseover="this.style.transform='translateY(-1px)';this.style.boxShadow='0 14px 26px rgba(37,99,235,.18)';"
                                onmouseout="this.style.transform='translateY(0)';this.style.boxShadow='0 10px 20px rgba(37,99,235,.16)';">
                            Маркирай всички като прочетени
                        </button>
                    }
                </div>
            </div>

            <div style="margin:0; border:none; background:transparent; padding:18px 20px 20px 20px; overflow:hidden; max-height:340px; overflow-y:auto; padding-right:8px;">
                @if (Model.LatestNotifications != null && Model.LatestNotifications.Any())
                {
                    <div style="display:grid; gap:10px;">
                        @foreach (var item in Model.LatestNotifications)
                        {
                            <div style="display:grid; grid-template-columns:minmax(0, 1fr) auto; gap:14px; align-items:center; padding:12px 14px; border:1px solid @(item.IsRead ? "#e6edf5" : "#bfdbfe"); border-radius:16px; background:@(item.IsRead ? "#f8fbff" : "#edf4ff");">
                                <div style="min-width:0;">
                                    <div style="display:flex; align-items:baseline; justify-content:space-between; gap:10px; margin-bottom:4px;">
                                        <div style="color:#0f172a; font-size:.98rem; font-weight:900; line-height:1.3;">@item.Title</div>
                                        <div style="color:#64748b; font-size:.8rem; font-weight:800; white-space:nowrap;">@item.CreatedOn.ToString("dd.MM.yyyy")</div>
                                    </div>

                                    <div style="color:#475569; font-size:.9rem; line-height:1.5; white-space:nowrap; overflow:hidden; text-overflow:ellipsis;">
                                        @item.Message
                                    </div>
                                </div>

                                <div style="display:flex; align-items:center; gap:8px; flex-wrap:wrap;">
                                    @if (item.BookId.HasValue)
                                    {
                                        <a asp-controller="Catalog"
                                           asp-action="ReaderDetails"
                                           asp-route-id="@item.BookId.Value"
