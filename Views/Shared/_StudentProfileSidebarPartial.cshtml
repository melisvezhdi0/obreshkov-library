@{
    var currentController = ViewContext.RouteData.Values["controller"]?.ToString();
    var currentAction = ViewContext.RouteData.Values["action"]?.ToString();

    string activeClass(string controller, string action)
        => currentController == controller && currentAction == action ? "Reader-side-link active" : "Reader-side-link";
}

<div class="Reader-profile-sidebar">
    <div class="Reader-profile-sidebar-header">
        <div class="Reader-profile-sidebar-kicker">Reader Portal</div>
        <h2 class="Reader-profile-sidebar-title">Моят профил</h2>
        <div class="Reader-profile-sidebar-line"></div>
        <p class="Reader-profile-sidebar-text">
            Бърз достъп до най-важните неща в профила ти.
        </p>
    </div>

    <nav class="Reader-profile-sidebar-nav">
        <a asp-controller="ReaderPortal"
           asp-action="Index"
           class="@activeClass("ReaderPortal", "Index")">
            <span class="Reader-side-icon">●</span>
            <span>Начало</span>
        </a>

        <a asp-controller="ReaderPortal"
           asp-action="MyBooks"
           class="@activeClass("ReaderPortal", "MyBooks")">
            <span class="Reader-side-icon">●</span>
            <span>Текущо заети книги</span>
        </a>

        <a asp-controller="ReaderPortal"
           asp-action="History"
           class="@activeClass("ReaderPortal", "History")">
            <span class="Reader-side-icon">●</span>
            <span>История на заемания</span>
        </a>

        <a asp-controller="ReaderPortal"
           asp-action="Favorites"
           class="@activeClass("ReaderPortal", "Favorites")">
            <span class="Reader-side-icon">●</span>
            <span>Списък за четене</span>
        </a>

        <a asp-controller="ReaderPortal"
           asp-action="Notifications"
           class="@activeClass("ReaderPortal", "Notifications")">
            <span class="Reader-side-icon">●</span>
            <span>Съобщения</span>
        </a>

        <a asp-controller="ReaderAccount"
           asp-action="ChangePassword"
           class="@activeClass("ReaderAccount", "ChangePassword")">
            <span class="Reader-side-icon">●</span>
            <span>Промяна на парола</span>
        </a>
    </nav>
</div>

<style>
    .Reader-profile-sidebar {
        position: sticky;
        top: 24px;
        background: linear-gradient(180deg, #eef4ff 0%, #f8fbff 100%);
        border: 1px solid #d7e3f2;
        border-radius: 24px;
        padding: 26px 20px;
        box-shadow: 0 16px 34px rgba(15, 23, 42, 0.06);
    }

    .Reader-profile-sidebar-header {
        margin-bottom: 22px;
    }

    .Reader-profile-sidebar-kicker {
        color: #64748b;
        font-size: .78rem;
        font-weight: 800;
        letter-spacing: .08em;
        text-transform: uppercase;
    }

    .Reader-profile-sidebar-title {
        margin: 8px 0 0 0;
        color: #17325c;
        font-size: 1.65rem;
        font-weight: 900;
        line-height: 1.15;
    }

    .Reader-profile-sidebar-line {
        width: 62px;
        height: 4px;
        border-radius: 999px;
        margin-top: 12px;
        background: linear-gradient(90deg, #2563eb 0%, #60a5fa 100%);
    }

    .Reader-profile-sidebar-text {
        margin: 14px 0 0 0;
        color: #64748b;
        font-size: .95rem;
        font-weight: 700;
        line-height: 1.6;
    }

    .Reader-profile-sidebar-nav {
        display: flex;
        flex-direction: column;
        gap: 10px;
    }

    .Reader-side-link {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 13px 14px;
        border-radius: 16px;
        text-decoration: none;
        color: #334155;
        font-weight: 800;
        background: rgba(255,255,255,0.7);
        border: 1px solid transparent;
        transition: .18s ease;
    }

        .Reader-side-link:hover {
            color: #1d4ed8;
            background: #ffffff;
            border-color: #cfe0f7;
            transform: translateX(2px);
        }

        .Reader-side-link.active {
            color: #0f3ea9;
            background: linear-gradient(90deg, #dbeafe 0%, #eff6ff 100%);
            border-color: #bfd7fb;
            box-shadow: 0 8px 18px rgba(37, 99, 235, 0.10);
        }

    .Reader-side-icon {
        color: #2563eb;
        font-size: .85rem;
        line-height: 1;
    }

    @@media (max-width: 991.98px) {
        .Reader-profile-sidebar {
            position: static;
        }
    }
</style>