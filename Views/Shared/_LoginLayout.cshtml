<!DOCTYPE html>
<html lang="bg">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - ObreshkovLibrary</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" />

    <style>
        html, body {
            height: 100%;
        }

        body {
            margin: 0;
            min-height: 100vh;
            position: relative;
            overflow: hidden;
            background: radial-gradient(circle at top left, rgba(96, 165, 250, 0.10), transparent 28%), radial-gradient(circle at top right, rgba(59, 130, 246, 0.08), transparent 24%), radial-gradient(circle at bottom center, rgba(37, 99, 235, 0.10), transparent 32%), linear-gradient(to bottom, #f6f9ff, #eef2f9);
        }

        .login-bg-particles {
            position: fixed;
            inset: 0;
            z-index: 1;
            overflow: hidden;
            pointer-events: none;
        }

        .login-bg-glow {
            position: absolute;
            border-radius: 999px;
            filter: blur(12px);
            opacity: 0.7;
            animation: glowFloat 12s ease-in-out infinite;
        }

        .glow-1 {
            width: 260px;
            height: 260px;
            left: -60px;
            bottom: -60px;
            background: radial-gradient(circle, rgba(59,130,246,0.18) 0%, rgba(59,130,246,0.05) 46%, transparent 74%);
        }

        .glow-2 {
            width: 200px;
            height: 200px;
            right: 4%;
            bottom: 8%;
            background: radial-gradient(circle, rgba(96,165,250,0.18) 0%, rgba(96,165,250,0.05) 46%, transparent 74%);
            animation-delay: 2s;
        }

        .glow-3 {
            width: 160px;
            height: 160px;
            left: 20%;
            bottom: 12%;
            background: radial-gradient(circle, rgba(37,99,235,0.14) 0%, rgba(37,99,235,0.04) 46%, transparent 74%);
            animation-delay: 4s;
        }

        .login-page-shell {
            position: relative;
            z-index: 2;
            min-height: 100vh;
            display: flex;
            flex-direction: column;
        }

        .login-topbar {
            width: 100%;
            background: rgba(255, 255, 255, 0.78);
            backdrop-filter: blur(10px);
            -webkit-backdrop-filter: blur(10px);
            border-bottom: 1px solid rgba(203, 213, 225, 0.85);
            box-shadow: 0 8px 24px rgba(15, 23, 42, 0.04);
        }

        .login-topbar-inner {
            max-width: 1200px;
            margin: 0 auto;
            padding: 14px 20px;
            text-align: center;
            font-size: 1.05rem;
            font-weight: 800;
            color: #0f172a;
            letter-spacing: -0.01em;
        }

        .login-main {
            flex: 1;
            position: relative;
        }

        .particle {
            position: absolute;
            fill: rgba(37, 99, 235, 0.34);
            filter: drop-shadow(0 6px 14px rgba(59, 130, 246, 0.12));
            animation: floatPremium 8.5s ease-in-out infinite;
            will-change: transform, opacity;
        }

            .particle.soft {
                fill: rgba(96, 165, 250, 0.26);
            }

            .particle.tiny {
                width: 14px;
                height: 14px;
            }

            .particle.small {
                width: 17px;
                height: 17px;
            }

            .particle.medium {
                width: 21px;
                height: 21px;
            }

            .particle.large {
                width: 25px;
                height: 25px;
            }

        .p1 {
            left: 5%;
            top: 84%;
            animation-delay: 0s;
        }

        .p2 {
            left: 11%;
            top: 89%;
            animation-delay: 1s;
        }

        .p3 {
            left: 18%;
            top: 77%;
            animation-delay: 2.1s;
        }

        .p4 {
            left: 25%;
            top: 91%;
            animation-delay: 0.7s;
        }

        .p5 {
            left: 33%;
            top: 84%;
            animation-delay: 1.7s;
        }

        .p6 {
            left: 42%;
            top: 92%;
            animation-delay: 2.8s;
        }

        .p7 {
            left: 51%;
            top: 79%;
            animation-delay: 1.3s;
        }

        .p8 {
            left: 60%;
            top: 88%;
            animation-delay: 2.2s;
        }

        .p9 {
            left: 69%;
            top: 76%;
            animation-delay: 0.5s;
        }

        .p10 {
            left: 77%;
            top: 87%;
            animation-delay: 1.4s;
        }

        .p11 {
            left: 86%;
            top: 81%;
            animation-delay: 2.6s;
        }

        .p12 {
            left: 93%;
            top: 89%;
            animation-delay: 0.9s;
        }

        .p13 {
            left: 9%;
            top: 66%;
            animation-delay: 1.1s;
        }

        .p14 {
            left: 22%;
            top: 62%;
            animation-delay: 2.3s;
        }

        .p15 {
            left: 74%;
            top: 63%;
            animation-delay: 0.8s;
        }

        .p16 {
            left: 88%;
            top: 59%;
            animation-delay: 1.9s;
        }

        @@keyframes floatPremium {
            0% {
                transform: translate3d(0, 0, 0) rotate(0deg) scale(1);
                opacity: 0.8;
            }

            25% {
                transform: translate3d(4px, -10px, 0) rotate(4deg) scale(1.03);
                opacity: 1;
            }

            50% {
                transform: translate3d(-3px, -18px, 0) rotate(-3deg) scale(0.98);
                opacity: 0.9;
            }

            75% {
                transform: translate3d(5px, -9px, 0) rotate(2deg) scale(1.02);
                opacity: 1;
            }

            100% {
                transform: translate3d(0, 0, 0) rotate(0deg) scale(1);
                opacity: 0.8;
            }
        }

        @@keyframes glowFloat {
            0% {
                transform: translateY(0) scale(1);
                opacity: 0.45;
            }

            50% {
                transform: translateY(-16px) scale(1.05);
                opacity: 0.75;
            }

            100% {
                transform: translateY(0) scale(1);
                opacity: 0.45;
            }
        }

        @@media (max-width: 768px) {
            .particle.large,
            .particle.medium {
                width: 18px !important;
                height: 18px !important;
            }

            .particle.small {
                width: 15px !important;
                height: 15px !important;
            }

            .particle.tiny {
                width: 12px !important;
                height: 12px !important;
            }

            .login-topbar-inner {
                font-size: 0.98rem;
                padding: 13px 16px;
            }
        }
    </style>
</head>
<body>
    <div class="login-bg-particles">
        <div class="login-bg-glow glow-1"></div>
        <div class="login-bg-glow glow-2"></div>
        <div class="login-bg-glow glow-3"></div>

        <svg class="particle tiny p1" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M4 19V5l8-3 8 3v14l-8 3-8-3z" />
        </svg>

        <svg class="particle small p2 soft" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M12 2a4 4 0 014 4v2h2a2 2 0 012 2v4l-2 2v4H6v-4l-2-2v-4a2 2 0 012-2h2V6a4 4 0 014-4z" />
        </svg>

        <svg class="particle medium p3" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M3 10l9-7 9 7v9a2 2 0 01-2 2h-4v-6H9v6H5a2 2 0 01-2-2v-9z" />
        </svg>

        <svg class="particle small p4 soft" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M12 12a5 5 0 100-10 5 5 0 000 10zm0 2c-4 0-8 2-8 5v3h16v-3c0-3-4-5-8-5z" />
        </svg>

        <svg class="particle medium p5" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M4 19V5l8-3 8 3v14l-8 3-8-3z" />
        </svg>

        <svg class="particle tiny p6 soft" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M12 2a4 4 0 014 4v2h2a2 2 0 012 2v4l-2 2v4H6v-4l-2-2v-4a2 2 0 012-2h2V6a4 4 0 014-4z" />
        </svg>

        <svg class="particle large p7" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M3 10l9-7 9 7v9a2 2 0 01-2 2h-4v-6H9v6H5a2 2 0 01-2-2v-9z" />
        </svg>

        <svg class="particle small p8 soft" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M12 12a5 5 0 100-10 5 5 0 000 10zm0 2c-4 0-8 2-8 5v3h16v-3c0-3-4-5-8-5z" />
        </svg>

        <svg class="particle medium p9" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M4 19V5l8-3 8 3v14l-8 3-8-3z" />
        </svg>

        <svg class="particle tiny p10 soft" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M12 2a4 4 0 014 4v2h2a2 2 0 012 2v4l-2 2v4H6v-4l-2-2v-4a2 2 0 012-2h2V6a4 4 0 014-4z" />
        </svg>

        <svg class="particle medium p11" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M3 10l9-7 9 7v9a2 2 0 01-2 2h-4v-6H9v6H5a2 2 0 01-2-2v-9z" />
        </svg>

        <svg class="particle small p12 soft" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M12 12a5 5 0 100-10 5 5 0 000 10zm0 2c-4 0-8 2-8 5v3h16v-3c0-3-4-5-8-5z" />
        </svg>

        <svg class="particle tiny p13 soft" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M4 19V5l8-3 8 3v14l-8 3-8-3z" />
        </svg>

        <svg class="particle small p14" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M12 2a4 4 0 014 4v2h2a2 2 0 012 2v4l-2 2v4H6v-4l-2-2v-4a2 2 0 012-2h2V6a4 4 0 014-4z" />
        </svg>

        <svg class="particle medium p15 soft" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M3 10l9-7 9 7v9a2 2 0 01-2 2h-4v-6H9v6H5a2 2 0 01-2-2v-9z" />
        </svg>

        <svg class="particle small p16" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M12 12a5 5 0 100-10 5 5 0 000 10zm0 2c-4 0-8 2-8 5v3h16v-3c0-3-4-5-8-5z" />
        </svg>
    </div>

    <div class="login-page-shell">
        <header class="login-topbar">
            <div class="login-topbar-inner">
                Училищна библиотека „Обрешков“
            </div>
        </header>

        <main class="login-main">
            @RenderBody()
        </main>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>