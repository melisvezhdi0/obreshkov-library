<!DOCTYPE html>
<html lang="bg">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - ObreshkovLibrary</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/ObreshkovLibrary.styles.css" asp-append-version="true" />

    <style>
        :root {
            --bg: #F5F7FA;
            --surface: #FFFFFF;
            --surface-soft: #F0F3F6;
            --surface-muted: #E8EDF2;
            --line: #D9E0E7;
            --line-strong: #C8D1DB;
            --text: #1F2937;
            --text-soft: #6B7280;
            --accent: #3B82F6;
            --accent-dark: #2563EB;
            --accent-soft: #DBEAFE;
        }

        html, body {
            height: 100%;
            margin: 0;
        }

        body {
            background: var(--bg);
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            color: var(--text);
            padding-top: 70px;
            font-family: "Segoe UI", Tahoma, Geneva, Verdana, sans-serif;
        }

        main {
            flex: 1 0 auto;
            padding-bottom: 24px;
        }

        .app-navbar {
            background: rgba(255,255,255,.96) !important;
            border-bottom: 1px solid var(--line) !important;
            backdrop-filter: blur(8px);
            min-height: 70px;
        }

            .app-navbar .navbar-brand {
                color: var(--text) !important;
                font-weight: 800;
                font-size: 1.2rem;
                letter-spacing: -.2px;
            }

            .app-navbar .navbar-collapse {
                flex-grow: 0;
            }

            .app-navbar .navbar-nav {
                gap: .15rem;
            }

            .app-navbar .nav-link {
                color: var(--text) !important;
                font-weight: 700;
                position: relative;
                padding: .65rem .8rem;
                border-radius: 8px;
                transition: background-color .18s ease, color .18s ease;
            }

                .app-navbar .nav-link:hover,
                .app-navbar .nav-link:focus {
                    background: var(--surface-soft);
                    color: var(--accent-dark) !important;
                }

            .app-navbar .dropdown-toggle::after {
                display: none !important;
            }

            .app-navbar .dropdown-menu {
                background: var(--surface);
                border: 1px solid var(--line);
                border-radius: 12px;
                padding: .35rem;
                box-shadow: 0 8px 22px rgba(17, 24, 39, 0.08);
                min-width: 220px;
            }

            .app-navbar .dropdown-item {
                color: var(--text);
                font-weight: 600;
                border-radius: 8px;
                padding: .55rem .7rem;
            }

                .app-navbar .dropdown-item:hover,
                .app-navbar .dropdown-item:focus {
                    background: var(--surface-soft);
                    color: var(--accent-dark);
                }

        .page-wrap {
            width: 100%;
            flex: 1 0 auto;
        }

        .page-container {
            max-width: 1180px;
            margin: 0 auto;
            padding: 0 18px;
        }

        .section-title {
            color: var(--text);
            font-weight: 800;
            letter-spacing: -.2px;
        }

        .accent-line {
            width: 54px;
            height: 3px;
            border-radius: 999px;
            background: var(--accent);
        }

        .card-soft {
            background: var(--surface);
            border: 1px solid var(--line);
            border-radius: 16px;
            box-shadow: 0 2px 8px rgba(17, 24, 39, 0.03);
        }

        input.form-control,
        select.form-select,
        textarea.form-control {
            background: #fff;
            border: 1px solid var(--line-strong);
            border-radius: 12px;
            color: var(--text);
            box-shadow: none;
        }

            input.form-control:focus,
            select.form-select:focus,
            textarea.form-control:focus {
                border-color: #9FC3F7;
                box-shadow: 0 0 0 .2rem rgba(59,130,246,.10);
            }

        .btn-accent {
            background: var(--accent);
            color: #fff;
            border: 1px solid var(--accent);
            font-weight: 700;
            border-radius: 12px;
        }

            .btn-accent:hover {
                background: var(--accent-dark);
                border-color: var(--accent-dark);
                color: #fff;
            }

        .btn-outline-primary {
            color: var(--accent);
            border-color: var(--accent);
            font-weight: 700;
            border-radius: 12px;
        }

            .btn-outline-primary:hover {
                background: var(--accent);
                border-color: var(--accent);
                color: #fff;
            }

        .link-accent {
            color: var(--accent);
            text-decoration: none;
            font-weight: 700;
        }

            .link-accent:hover {
                color: var(--accent-dark);
                text-decoration: underline;
            }

        .table th,
        .table td {
            border-color: var(--line);
            vertical-align: middle;
        }

        .table thead th {
            color: var(--text-soft);
        }

        .modal-content {
            border: 1px solid var(--line);
            border-radius: 16px;
        }

        .list-group-item {
            border-color: var(--line);
        }

        .footer {
            flex-shrink: 0;
            margin-top: auto;
            padding: 14px 0;
            font-size: 0.95rem;
            line-height: normal;
            background: transparent;
            border-top: 1px solid var(--line) !important;
            color: var(--text-soft) !important;
            position: static !important;
            bottom: auto !important;
            width: 100%;
        }

        @@media (hover:hover) and (pointer:fine) {
            .navbar .nav-item.dropdown:hover > .dropdown-menu {
                display: block;
                margin-top: 0;
            }
        }

        @@media (max-width: 991.98px) {
            body {
                padding-top: 64px;
            }

            .app-navbar {
                min-height: 64px;
            }

                .app-navbar .navbar-brand {
                    font-size: 1.02rem;
                }

                .app-navbar .navbar-collapse {
                    margin-top: .6rem;
                    padding-top: .6rem;
                    border-top: 1px solid var(--line);
                }

                .app-navbar .navbar-nav {
                    gap: .1rem;
                }

            .page-container {
                padding: 0 14px;
            }
        }
    </style>
</head>

<body>
    <header>
        <nav class="navbar navbar-expand-lg app-navbar fixed-top" id="topNav">
            <div class="container-fluid page-container">
                <a class="navbar-brand"
                   asp-controller="Home"
                   asp-action="Index">
                    Училищна библиотека „Обрешков“
                </a>

                <button class="navbar-toggler"
                        type="button"
                        data-bs-toggle="collapse"
                        data-bs-target="#mainNavbar"
                        aria-controls="mainNavbar"
                        aria-expanded="false"
                        aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse justify-content-end" id="mainNavbar">
                    <ul class="navbar-nav">
                        <li class="nav-item">
                            <a class="nav-link"
                               asp-controller="Home"
                               asp-action="Index">
                                Начало
                            </a>
                        </li>

                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle"
                               href="#"
                               role="button"
                               data-bs-toggle="dropdown"
                               aria-expanded="false">
                                Читатели
                            </a>
                            <ul class="dropdown-menu">
                                <li><a class="dropdown-item" asp-controller="Clients" asp-action="Index">Всички читатели</a></li>
                                <li><a class="dropdown-item" asp-controller="Clients" asp-action="Create">Регистриране</a></li>
                                <li><a class="dropdown-item" asp-controller="Clients" asp-action="Index">Редактиране</a></li>
                            </ul>
                        </li>

                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle"
                               href="#"
                               role="button"
                               data-bs-toggle="dropdown"
                               aria-expanded="false">
                                Книги
                            </a>
                            <ul class="dropdown-menu">
                                <li><a class="dropdown-item" asp-controller="Book" asp-action="Index">Всички книги</a></li>
                                <li><a class="dropdown-item" asp-controller="Book" asp-action="Create">Добавяне</a></li>
                                <li><a class="dropdown-item" asp-controller="Book" asp-action="Index">Редактиране</a></li>
                            </ul>
                        </li>

                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle"
                               href="#"
                               role="button"
                               data-bs-toggle="dropdown"
                               aria-expanded="false">
                                Категории
                            </a>
                            <ul class="dropdown-menu">
                                <li><a class="dropdown-item" asp-controller="Categories" asp-action="Index">Всички категории</a></li>
                                <li><a class="dropdown-item" asp-controller="Categories" asp-action="Create">Добавяне</a></li>
                                <li><a class="dropdown-item" asp-controller="Categories" asp-action="Index">Редактиране</a></li>
                            </ul>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Archive" asp-action="Index">Архив</a>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <div class="page-wrap mt-4">
        <div class="page-container">
            <main role="main" class="pb-3">
                @RenderBody()
            </main>
        </div>
    </div>

    <footer class="border-top footer">
        <div class="page-container">
            &copy; 2026 – ObreshkovLibrary
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)

    <script>
        (function () {
          let lastSubmitter = null;

          document.addEventListener('click', function (e) {
            const btn = e.target.closest('button[type="submit"], input[type="submit"]');
            if (btn) lastSubmitter = btn;
          }, true);

          document.addEventListener('submit', async function (e) {
            const form = e.target;
            if (!form.matches('form[data-gate="1"]')) return;

            const submitter = e.submitter || lastSubmitter;

            e.preventDefault();

            const pwd = prompt('Парола:');
            if (!pwd) return;

            const tokenInput = form.querySelector('input[name="__RequestVerificationToken"]');
            const token = tokenInput ? tokenInput.value : '';

            const body = new URLSearchParams();
            body.set('password', pwd);
            if (token) body.set('__RequestVerificationToken', token);

            const res = await fetch('/Gate/Unlock', {
              method: 'POST',
              headers: { 'Content-Type': 'application/x-www-form-urlencoded; charset=UTF-8' },
              body: body.toString()
            });

            if (!res.ok) {
              alert('Грешна парола');
              return;
            }

            if (submitter) {
              const fa = submitter.getAttribute('formaction');
              if (fa) form.setAttribute('action', fa);

              const fm = submitter.getAttribute('formmethod');
              if (fm) form.setAttribute('method', fm);
            }

            lastSubmitter = null;
            form.submit();
          }, true);
        })();
    </script>

    <script>
        (function () {
          const nav = document.getElementById("topNav");
          if (!nav) return;

          function onScroll() {
            if (window.scrollY > 10) nav.classList.add("navbar-scrolled");
            else nav.classList.remove("navbar-scrolled");
          }

          window.addEventListener("scroll", onScroll, { passive: true });
          onScroll();
        })();
    </script>
</body>
</html>