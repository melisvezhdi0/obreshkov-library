@model IEnumerable<ObreshkovLibrary.Models.LoanExtensionRequest>
@using ObreshkovLibrary.Models

@{
    ViewData["Title"] = "Заявки за удължаване";
}

<div class="container py-4">
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success">@TempData["SuccessMessage"]</div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger">@TempData["ErrorMessage"]</div>
    }

    <div class="card shadow-sm border-0">
        <div class="card-body">
            <h2 class="mb-3">Заявки за удължаване</h2>

            @if (Model.Any())
            {
                <div class="table-responsive">
                    <table class="table align-middle">
                        <thead>
                            <tr>
                                <th>Ученик</th>
                                <th>Книга</th>
                                <th>Текуща дата за връщане</th>
                                <th>Поискани дни</th>
                                <th>Подадена на</th>
                                <th>Статус</th>
                                <th>Действия</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td>@item.Loan.Client.FirstName @item.Loan.Client.LastName</td>
                                    <td>@item.Loan.BookCopy.Book.Title</td>
                                    <td>@item.Loan.DueDate.ToString("dd.MM.yyyy")</td>
                                    <td>@item.RequestedDays</td>
                                    <td>@item.RequestedOn.ToString("dd.MM.yyyy HH:mm")</td>
                                    <td>
                                        @if (item.Status == LoanExtensionRequestStatus.Pending)
                                        {
                                            <span class="badge text-bg-warning">Чакаща</span>
                                        }
                                        else if (item.Status == LoanExtensionRequestStatus.Approved)
                                        {
                                            <span class="badge text-bg-success">Одобрена</span>
                                        }
                                        else
                                        {
                                            <span class="badge text-bg-danger">Отхвърлена</span>
                                        }
                                    </td>
                                    <td>
                                        @if (item.Status == LoanExtensionRequestStatus.Pending)
                                        {
                                            <div class="d-flex flex-column gap-2">
                                                <form asp-action="Approve" method="post">
                                                    @Html.AntiForgeryToken()
                                                    <input type="hidden" name="id" value="@item.Id" />
                                                    <button type="submit" class="btn btn-success btn-sm">
                                                        Одобри
                                                    </button>
                                                </form>

                                                <form asp-action="Reject" method="post">
                                                    @Html.AntiForgeryToken()
                                                    <input type="hidden" name="id" value="@item.Id" />
                                                    <input type="text"
                                                           name="adminResponseMessage"
                                                           class="form-control form-control-sm mb-2"
                                                           placeholder="Причина (по желание)" />
                                                    <button type="submit" class="btn btn-danger btn-sm">
                                                        Отхвърли
                                                    </button>
                                                </form>
                                            </div>
                                        }
                                        else
                                        {
                                            <span class="text-muted">Обработена</span>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="text-muted">Няма подадени заявки за удължаване.</div>
            }
        </div>
    </div>
</div>