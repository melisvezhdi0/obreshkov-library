@model ObreshkovLibrary.Models.Book

@{
    ViewData["Title"] = "Детайли за книга";
    var activeLoanCopyIds = ViewBag.ActiveLoanCopyIds as List<int> ?? new List<int>();
    var copies = Model.Copies?.OrderBy(c => c.Id).ToList() ?? new List<ObreshkovLibrary.Models.BookCopy>();
}

<div class="book-details-page">

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger mb-4">@TempData["Error"]</div>
    }

    <div class="book-details-header">
        <div>
            <h2 class="section-title mb-1">@Model.Title</h2>
            <div class="accent-line"></div>
        </div>

        <div class="book-details-actions">
            <a asp-controller="Book"
               asp-action="Edit"
               asp-route-id="@Model.Id"
               class="btn btn-accent">
                Редактирай
            </a>

            <a asp-controller="Book"
               asp-action="Index"
               class="btn btn-outline-primary">
                Назад
            </a>
        </div>
    </div>

    <section class="details-panel card-soft book-main-panel">
        <div class="book-top-layout">

            <div class="book-cover-column">
                <div class="book-cover-box">
                    @if (!string.IsNullOrWhiteSpace(Model.CoverUrl))
                    {
                        <img src="@Model.CoverUrl"
                             alt="@Model.Title"
                             onerror="this.style.display='none'; this.parentElement.classList.add('no-cover');" />
                    }
                </div>
            </div>

            <div class="book-info-column">
                <div class="book-info-grid">

                    <div class="book-info-row">
                        <div class="book-info-label">Автор</div>
                        <div class="book-info-value">
                            @(string.IsNullOrWhiteSpace(Model.Author) ? "Няма" : Model.Author)
                        </div>
                    </div>

                    <div class="book-info-row">
                        <div class="book-info-label">Категория</div>
                        <div class="book-info-value">
                            @(Model.Category != null ? Model.Category.Name : "Няма")
                        </div>
                    </div>

                    <div class="book-info-row">
                        <div class="book-info-label">Година</div>
                        <div class="book-info-value">
                            @(Model.Year.HasValue? Model.Year.ToString() : "Няма")
                        </div>
                    </div>

                    <div class="book-info-row">
                        <div class="book-info-label">Копия</div>
                        <div class="book-info-value">@copies.Count</div>
                    </div>

                    <div class="book-info-row">
                        <div class="book-info-label">Статус</div>
                        <div class="book-info-value">
                            @if (Model.IsActive)
                            {
                                <span class="status-badge status-active">Активна</span>
                            }
                            else
                            {
                                <span class="status-badge status-inactive">Неактивна</span>
                            }
                        </div>
                    </div>

                </div>
            </div>

        </div>
    </section>

    <section class="details-panel card-soft book-description-panel">
        <div class="details-panel-head">
            <h5 class="section-title mb-0">Описание</h5>
        </div>

        <div class="book-description-wrap">
            @if (!string.IsNullOrWhiteSpace(Model.Description))
            {
                <div class="book-description">@Model.Description</div>
            }
            else
            {
                <div class="details-empty-state">Няма описание за тази книга.</div>
            }
        </div>
    </section>

    <section class="details-panel card-soft copies-panel">
        <div class="details-panel-head details-panel-head-flex">
            <h5 class="section-title mb-0">Копия</h5>
            <span class="count-badge">@copies.Count</span>
        </div>

        @if (!copies.Any())
        {
            <div class="details-empty-state">
                Няма добавени копия.
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table details-table align-middle mb-0">
                    <thead>
                        <tr>
                            <th>Копие</th>
                            <th>Наличност</th>
                            <th>Състояние</th>
                            <th class="text-end">Действие</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var copy in copies)
                        {
                            var isLoaned = activeLoanCopyIds.Contains(copy.Id);

                            <tr>
                                <td class="copy-id-cell">Копие #@copy.Id</td>

                                <td>
                                    @if (!copy.IsActive)
                                    {
                                        <span class="status-badge status-inactive">Недостъпно</span>
                                    }
                                    else if (isLoaned)
                                    {
                                        <span class="status-badge status-loaned">Заето</span>
                                    }
                                    else
                                    {
                                        <span class="status-badge status-active">Свободно</span>
                                    }
                                </td>

                                <td>
                                    @if (copy.IsActive)
                                    {
                                        <span class="copy-state-text">Активно</span>
                                    }
                                    else
                                    {
                                        <span class="copy-state-text muted-text">Неактивно</span>
                                    }
                                </td>

                                <td class="text-end">
                                    @if (!copy.IsActive)
                                    {
                                        <form asp-action="ReactivateCopy"
                                              asp-route-id="@copy.Id"
                                              method="post"
                                              style="display:inline;">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn btn-sm btn-outline-primary">
                                                Активирай
                                            </button>
                                        </form>
                                    }
                                    else if (!isLoaned)
                                    {
                                        <form asp-action="DeactivateCopy"
                                              asp-route-id="@copy.Id"
                                              method="post"
                                              data-gate="1"
                                              style="display:inline;">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn btn-sm btn-outline-danger">
                                                Деактивирай
                                            </button>
                                        </form>
                                    }
                                    else
                                    {
                                        <span class="muted-text small">Няма действие</span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </section>

</div>

<style>
    .book-details-page {
        width: 100%;
        padding-top: 6px;
    }

    .book-details-header {
        display: flex;
        align-items: end;
        justify-content: space-between;
        gap: 1rem;
        flex-wrap: wrap;
        margin-bottom: 1rem;
    }

    .book-details-actions {
        display: flex;
        gap: .75rem;
        flex-wrap: wrap;
    }

    .details-panel {
        padding: 0;
        overflow: hidden;
        background: #FFFFFF;
    }

    .book-main-panel {
        padding: 1.25rem;
        margin-bottom: 1.25rem;
    }

    .book-top-layout {
        display: grid;
        grid-template-columns: 280px 1fr;
        gap: 1.5rem;
        align-items: start;
    }

    .book-cover-column {
        display: flex;
        justify-content: flex-start;
    }

    .book-cover-box {
        width: 100%;
        max-width: 260px;
        height: 360px;
        border-radius: 16px;
        background: #F3F6F9;
        border: 1px solid #D9E0E7;
        overflow: hidden;
        display: flex;
        align-items: center;
        justify-content: center;
    }

        .book-cover-box img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            display: block;
        }

        .book-cover-box.no-cover::after {
            content: "Няма корица";
            color: #6B7280;
            font-size: .95rem;
            font-weight: 600;
        }

    .book-info-grid {
        display: grid;
        border: 1px solid #E5EAF0;
        border-radius: 16px;
        overflow: hidden;
        background: #FFFFFF;
    }

    .book-info-row {
        display: grid;
        grid-template-columns: 160px 1fr;
        gap: 1rem;
        align-items: center;
        padding: 1rem 1.1rem;
        border-bottom: 1px solid #E5EAF0;
    }

        .book-info-row:last-child {
            border-bottom: none;
        }

    .book-info-label {
        color: #6B7280;
        font-weight: 800;
    }

    .book-info-value {
        color: #1F2937;
        font-weight: 700;
        text-align: right;
        justify-self: end;
    }

    .book-description-panel,
    .copies-panel {
        margin-bottom: 1.25rem;
    }

    .details-panel-head {
        padding: 1.05rem 1.15rem .9rem;
        border-bottom: 1px solid #D9E0E7;
        background: #FBFCFD;
    }

    .details-panel-head-flex {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
    }

    .book-description-wrap {
        padding: 1.15rem;
    }

    .book-description {
        color: #4B5563;
        line-height: 1.75;
        font-size: 1rem;
    }

    .details-empty-state {
        padding: 1.15rem;
        color: #6B7280;
        font-weight: 600;
    }

    .count-badge {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-width: 34px;
        height: 34px;
        padding: 0 .7rem;
        border-radius: 999px;
        background: #EEF4FF;
        color: #2563EB;
        border: 1px solid #D6E4FF;
        font-weight: 800;
    }

    .details-table thead th {
        background: #F3F6F9;
        color: #6B7280;
        font-size: .82rem;
        text-transform: uppercase;
        letter-spacing: .03em;
        font-weight: 800;
        padding: .95rem 1rem;
        border-bottom: 1px solid #D9E0E7;
        white-space: nowrap;
    }

    .details-table tbody td {
        padding: 1rem;
        background: #FFFFFF;
        border-bottom: 1px solid #E5EAF0;
        vertical-align: middle;
    }

    .details-table tbody tr:last-child td {
        border-bottom: none;
    }

    .copy-id-cell {
        font-weight: 700;
        color: #1F2937;
    }

    .copy-state-text {
        color: #1F2937;
        font-weight: 600;
    }

    .muted-text {
        color: #6B7280;
    }

    .status-badge {
        display: inline-flex;
        align-items: center;
        padding: .35rem .7rem;
        border-radius: 999px;
        font-size: .88rem;
        font-weight: 800;
    }

    .status-active {
        background: #EEF4FF;
        color: #2563EB;
        border: 1px solid #D6E4FF;
    }

    .status-loaned {
        background: #EFF6FF;
        color: #1D4ED8;
        border: 1px solid #BFDBFE;
    }

    .status-inactive {
        background: #F3F4F6;
        color: #6B7280;
        border: 1px solid #D1D5DB;
    }

    @@media (max-width: 991.98px) {
        .book-top-layout {
            grid-template-columns: 220px 1fr;
        }

        .book-cover-box {
            max-width: 220px;
            height: 310px;
        }
    }

    @@media (max-width: 767.98px) {
        .book-details-header {
            align-items: stretch;
        }

        .book-details-actions {
            width: 100%;
        }

            .book-details-actions .btn {
                flex: 1 1 auto;
                text-align: center;
            }

        .book-top-layout {
            grid-template-columns: 1fr;
        }

        .book-cover-column {
            justify-content: center;
        }

        .book-cover-box {
            max-width: 220px;
            height: 310px;
        }

        .book-info-row {
            grid-template-columns: 1fr;
            gap: .35rem;
        }

        .book-info-value {
            text-align: left;
            justify-self: start;
        }
    }
</style>