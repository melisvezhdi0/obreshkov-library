@model IEnumerable<ObreshkovLibrary.Models.Book>

@{
    ViewData["Title"] = "Книги";

    string? search = Context.Request.Query["search"];
    string? selectedClass = Context.Request.Query["schoolClass"];

    string GetCoverValue(ObreshkovLibrary.Models.Book book)
    {
        var coverPathProp = book.GetType().GetProperty("CoverPath");
        var coverUrlProp = book.GetType().GetProperty("CoverUrl");

        return coverPathProp?.GetValue(book)?.ToString()
               ?? coverUrlProp?.GetValue(book)?.ToString()
               ?? "";
    }

    string GetGenre(ObreshkovLibrary.Models.Book book)
    {
        return book.Category?.ParentCategory?.Name ?? "Без жанр";
    }

    string GetCategory(ObreshkovLibrary.Models.Book book)
    {
        return book.Category?.Name ?? "Без категория";
    }

    var groupedBooks = Model
        .GroupBy(b => new
        {
            Genre = GetGenre(b),
            Category = GetCategory(b)
        })
        .OrderBy(g => g.Key.Genre)
        .ThenBy(g => g.Key.Category)
        .ToList();

    var groupedByGenre = groupedBooks
        .GroupBy(g => g.Key.Genre)
        .OrderBy(g => g.Key)
        .ToList();
}

<div class="books-page">

    <div style="display:flex; align-items:end; justify-content:space-between; gap:1rem; flex-wrap:wrap; margin-bottom:1rem;">
        <div>
            <h2 class="section-title mb-1">Книги</h2>
            <div class="accent-line"></div>
        </div>

        <a asp-action="Create"
           class="btn btn-accent"
           style="min-width:150px; min-height:46px; display:inline-flex; align-items:center; justify-content:center; border-radius:14px; font-weight:800; text-decoration:none;">
            Добави книга
        </a>
    </div>

    <section class="card-soft books-toolbar">
        <form method="get"
              asp-action="Index"
              style="display:flex; align-items:center; gap:12px; width:100%; flex-wrap:nowrap;">

            <div style="position:relative; flex:1 1 auto; min-width:0;">
                <span style="position:absolute; left:15px; top:50%; transform:translateY(-50%); color:#94A3B8; pointer-events:none; z-index:2;">⌕</span>

                <input type="text"
                       name="search"
                       value="@search"
                       id="searchInput"
                       placeholder="Търси по заглавие, автор, жанр, категория, клас или ключова дума..."
                       class="form-control"
                       style="width:100%; height:50px; border-radius:16px; border:1px solid #D7DFEA; background:#fff; color:#0F172A; padding-left:40px; padding-right:42px; font-weight:600; box-shadow:none;" />

                <button type="button"
                        id="clearSearchBtn"
                        aria-label="Изчисти търсенето"
                        class="search-clear-btn @(string.IsNullOrWhiteSpace(search) ? "" : "visible")"
                        style="position:absolute; right:12px; top:50%; transform:translateY(-50%); width:24px; height:24px; border:none; background:#E2E8F0; color:#475569; border-radius:50%; align-items:center; justify-content:center; font-size:15px; line-height:1; cursor:pointer; padding:0;">
                    ×
                </button>
            </div>

            <div style="flex:0 0 150px;">
                <select name="schoolClass"
                        class="form-select"
                        style="width:150px; height:50px; border-radius:16px; border:1px solid #D7DFEA; background:#fff; font-weight:700; box-shadow:none;">
                    <option value="">Клас</option>
                    @for (int i = 5; i <= 12; i++)
                    {
                        if (selectedClass == i.ToString())
                        {
                            <option value="@i" selected>@i клас</option>
                        }
                        else
                        {
                            <option value="@i">@i клас</option>
                        }
                    }
                </select>
            </div>

            <button type="submit"
                    class="btn btn-accent"
                    style="width:110px; height:50px; border-radius:16px; font-weight:800;">
                Търси
            </button>
        </form>
    </section>

    <section class="card-soft books-tree-panel" style="padding:0; overflow:hidden; background:#fff;">
        @if (!groupedByGenre.Any())
        {
            <div class="books-empty-state">Няма намерени книги.</div>
        }
        else
        {
            @foreach (var genreGroup in groupedByGenre)
            {
                <div>
                    <div style="height:1px; background:linear-gradient(90deg, rgba(203,213,225,.08) 0%, rgba(203,213,225,.95) 18%, rgba(203,213,225,.95) 82%, rgba(203,213,225,.08) 100%);"></div>

                    <div style="border-top:1px solid #E5EAF0; background:linear-gradient(180deg, #FFFFFF 0%, #FCFDFE 100%);">
                        <div style="padding:1rem 1rem; min-height:72px; display:flex; align-items:center;">
                            <span style="font-size:1.06rem; font-weight:800; color:#1F2937; letter-spacing:-0.01em;">
                                @genreGroup.Key
                            </span>
                        </div>
                    </div>

                    @foreach (var categoryGroup in genreGroup)
                    {
                        <div style="border-top:1px solid #E5EAF0; background:#fff;">
                            <div style="min-height:70px; display:flex; align-items:center; gap:.8rem; padding:0 1rem 0 1.8rem;">
                                <span style="width:18px; height:18px; border-left:1.5px solid #CBD5E1; border-bottom:1.5px solid #CBD5E1; margin-top:-8px; flex:0 0 18px;"></span>
                                <span style="font-weight:700; color:#475569; font-size:.98rem; letter-spacing:-0.01em;">
                                    @categoryGroup.Key.Category
                                </span>
                            </div>
                        </div>

                        @foreach (var book in categoryGroup.OrderBy(b => b.Title).ThenBy(b => b.Author))
                        {
                            var coverValue = GetCoverValue(book);

                            <div style="display:flex; align-items:center; justify-content:space-between; gap:1rem; min-height:106px; padding:12px 16px 12px 50px; border-top:1px solid #E5EAF0; background:#fff;">
                                <div class="book-main-row"
                                     style="display:flex; align-items:center; gap:14px; flex:1 1 auto; min-width:0;">

                                    <span style="width:18px; height:18px; border-left:1.5px solid #CBD5E1; border-bottom:1.5px solid #CBD5E1; margin-top:-8px; flex:0 0 18px;"></span>

                                    <div class="book-thumb-hover"
                                         style="width:60px; height:84px; border-radius:14px; overflow:hidden; border:1px solid #D7DFEA; background:linear-gradient(180deg, #F8FAFD 0%, #F1F5F9 100%); display:flex; align-items:center; justify-content:center; flex:0 0 60px; box-shadow:0 5px 14px rgba(15, 23, 42, .05); transition:transform .2s ease, box-shadow .2s ease, border-color .2s ease;">
                                        @if (!string.IsNullOrWhiteSpace(coverValue))
                                        {
                                            <img src="@Url.Content("~/" + book.CoverPath)"
                                                 alt="@book.Title"
                                                 style="width:100%; height:100%; object-fit:cover; display:block;" />
                                        }
                                        else
                                        {
                                            <span style="color:#94A3B8; font-weight:800; font-size:1rem;">—</span>
                                        }
                                    </div>

                                    <div style="min-width:0; display:flex; flex-direction:column; justify-content:center; gap:7px;">
                                        <a asp-action="Details"
                                           asp-route-id="@book.Id"
                                           class="book-title-modern"
                                           style="display:inline-block; width:fit-content; max-width:100%; color:#0F172A; font-weight:800; font-size:1.02rem; line-height:1.35; text-decoration:none; word-break:break-word; overflow-wrap:anywhere; transition:color .18s ease, transform .18s ease;">
                                            @book.Title
                                        </a>

                                        <div style="display:flex; align-items:center; gap:.45rem; flex-wrap:wrap; min-width:0;">
                                            <span style="color:#475569; font-size:.96rem; font-weight:600; line-height:1.35; word-break:break-word; overflow-wrap:anywhere;">
                                                @book.Author
                                            </span>

                                            @if (book.Year.HasValue)
                                            {
                                                <span style="color:#94A3B8; font-size:.92rem; font-weight:700;">•</span>
                                                <span style="color:#64748B; font-size:.94rem; font-weight:700; white-space:nowrap;">
                                                    @book.Year
                                                </span>
                                            }
                                        </div>
                                    </div>
                                </div>

                                <div style="flex:0 0 auto; white-space:nowrap;">
                                    <a asp-action="Edit"
                                       asp-route-id="@book.Id"
                                       class="book-edit-modern"
                                       style="min-height:40px; padding:0 .98rem; border-radius:12px; font-weight:800; display:inline-flex; align-items:center; justify-content:center; text-decoration:none; color:#2563EB; background:linear-gradient(180deg, rgba(59,130,246,.08) 0%, rgba(59,130,246,.11) 100%); border:1px solid rgba(59,130,246,.16); box-shadow:0 4px 10px rgba(59,130,246,.08); transition:transform .18s ease, background .18s ease, color .18s ease, border-color .18s ease, box-shadow .18s ease;">
                                        Редакция
                                    </a>
                                </div>
                            </div>
                        }
                    }
                </div>
            }
        }
    </section>
</div>

@section Scripts {
    <script>
        (() => {
            const input = document.getElementById('searchInput');
            const clearBtn = document.getElementById('clearSearchBtn');

            if (!input || !clearBtn) return;

            function toggleClearButton() {
                if (input.value.trim().length > 0) {
                    clearBtn.classList.add('visible');
                    clearBtn.style.display = 'inline-flex';
                } else {
                    clearBtn.classList.remove('visible');
                    clearBtn.style.display = 'none';
                }
            }

            clearBtn.addEventListener('click', () => {
                input.value = '';
                toggleClearButton();
                input.focus();
            });

            input.addEventListener('input', toggleClearButton);
            toggleClearButton();

            const titleLinks = document.querySelectorAll('.book-title-modern');
            titleLinks.forEach(link => {
                link.addEventListener('mouseenter', () => {
                    link.style.color = '#1D4ED8';
                    link.style.transform = 'translateX(1px)';
                });
                link.addEventListener('mouseleave', () => {
                    link.style.color = '#0F172A';
                    link.style.transform = 'translateX(0)';
                });
            });

            const editLinks = document.querySelectorAll('.book-edit-modern');
            editLinks.forEach(link => {
                link.addEventListener('mouseenter', () => {
                    link.style.color = '#1D4ED8';
                    link.style.background = 'linear-gradient(180deg, rgba(59,130,246,.13) 0%, rgba(59,130,246,.18) 100%)';
                    link.style.borderColor = 'rgba(59,130,246,.24)';
                    link.style.boxShadow = '0 10px 18px rgba(59,130,246,.14)';
                    link.style.transform = 'translateY(-2px)';
                });
                link.addEventListener('mouseleave', () => {
                    link.style.color = '#2563EB';
                    link.style.background = 'linear-gradient(180deg, rgba(59,130,246,.08) 0%, rgba(59,130,246,.11) 100%)';
                    link.style.borderColor = 'rgba(59,130,246,.16)';
                    link.style.boxShadow = '0 4px 10px rgba(59,130,246,.08)';
                    link.style.transform = 'translateY(0)';
                });
            });

            const hoverRows = document.querySelectorAll('.book-main-row');
            hoverRows.forEach(row => {
                const thumb = row.querySelector('.book-thumb-hover');
                if (!thumb) return;

                row.addEventListener('mouseenter', () => {
                    thumb.style.transform = 'translateY(-3px) scale(1.02)';
                    thumb.style.boxShadow = '0 12px 24px rgba(15, 23, 42, .12)';
                    thumb.style.borderColor = '#BDD2F8';
                });

                row.addEventListener('mouseleave', () => {
                    thumb.style.transform = 'translateY(0) scale(1)';
                    thumb.style.boxShadow = '0 5px 14px rgba(15, 23, 42, .05)';
                    thumb.style.borderColor = '#D7DFEA';
                });
            });

            function applyMobileLayout() {
                const rows = document.querySelectorAll('[data-book-row-mobile]');
                rows.forEach(r => {
                    if (window.innerWidth <= 767.98) {
                        r.style.flexDirection = 'column';
                        r.style.alignItems = 'flex-start';
                    } else {
                        r.style.flexDirection = 'row';
                        r.style.alignItems = 'center';
                    }
                });
            }

            const bookRows = document.querySelectorAll('.books-tree-panel > div div[style*="justify-content:space-between"]');
            bookRows.forEach(row => row.setAttribute('data-book-row-mobile', 'true'));

            applyMobileLayout();
            window.addEventListener('resize', applyMobileLayout);
        })();
    </script>
}