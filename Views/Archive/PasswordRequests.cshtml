@model IEnumerable<ObreshkovLibrary.Models.PasswordResetRequest>

@{
    ViewData["Title"] = "Архив заявки за парола";
    string search = (ViewBag.Search ?? "").ToString();
}

<div style="width:100%; padding-top:6px; padding-bottom:28px;">

    <div style="display:flex; align-items:end; justify-content:space-between; gap:1rem; flex-wrap:wrap; margin-bottom:1rem;">
        <div>
            <h2 class="section-title mb-1">Архив — заявки за парола</h2>
            <div class="accent-line"></div>
        </div>
    </div>

    <section style="background:#ffffff; border:1px solid #D9E0E7; border-radius:18px; overflow:hidden; margin-bottom:1rem; box-shadow:0 10px 30px rgba(15,23,42,.05);">
        <div id="archivePasswordTabsGrid" style="display:grid; grid-template-columns:repeat(8,1fr);">
            <a asp-action="Index" style="padding:14px 8px; text-align:center; text-decoration:none; border-right:1px solid #E5EAF0; background:#F8FBFF; color:#64748B; font-weight:700;">Скоро архивирани</a>
            <a asp-action="Books" style="padding:14px 8px; text-align:center; text-decoration:none; border-right:1px solid #E5EAF0; background:#F8FBFF; color:#64748B; font-weight:700;">Книги</a>
            <a asp-action="Readers" style="padding:14px 8px; text-align:center; text-decoration:none; border-right:1px solid #E5EAF0; background:#F8FBFF; color:#64748B; font-weight:700;">Читатели</a>
            <a asp-action="Categories" style="padding:14px 8px; text-align:center; text-decoration:none; border-right:1px solid #E5EAF0; background:#F8FBFF; color:#64748B; font-weight:700;">Категории</a>
            <a asp-action="Copies" style="padding:14px 8px; text-align:center; text-decoration:none; border-right:1px solid #E5EAF0; background:#F8FBFF; color:#64748B; font-weight:700;">Копия</a>
            <a asp-action="Loans" style="padding:14px 8px; text-align:center; text-decoration:none; border-right:1px solid #E5EAF0; background:#F8FBFF; color:#64748B; font-weight:700;">Заеми</a>
            <a asp-action="SchoolNews" style="padding:14px 8px; text-align:center; text-decoration:none; border-right:1px solid #E5EAF0; background:#F8FBFF; color:#64748B; font-weight:700;">Актуално в ППМГ</a>
            <a asp-action="PasswordRequests" style="padding:14px 8px; text-align:center; text-decoration:none; background:#FFFFFF; color:#1F2937; font-weight:800;">Пароли</a>
        </div>
    </section>

    <section class="card-soft" style="padding:1rem; margin-bottom:1rem; background:#FFFFFF; border:1px solid #D9E0E7; border-radius:18px; box-shadow:0 10px 30px rgba(15,23,42,.05);">
        <form method="get" asp-action="PasswordRequests" style="display:flex; align-items:center; gap:12px; width:100%; flex-wrap:nowrap;">

            <div style="position:relative; flex:1 1 auto; min-width:0;">
                <span style="position:absolute; left:15px; top:50%; transform:translateY(-50%); color:#94A3B8; font-size:1rem; pointer-events:none; z-index:2;">⌕</span>

                <input type="text"
                       name="search"
                       value="@search"
                       id="archivePasswordSearch"
                       placeholder="Търси читател, карта, телефон..."
                       class="form-control archive-search-input"
                       style="width:100%; height:50px; border-radius:16px; border:1px solid #D7DFEA; background:#fff; color:#0F172A; padding-left:40px; padding-right:42px; font-weight:600; box-shadow:none;" />

                <button type="button"
                        id="archivePasswordClearBtn"
                        aria-label="Изчисти търсенето"
                        style="position:absolute; right:12px; top:50%; transform:translateY(-50%); width:22px; height:22px; border:none; background:#E2E8F0; color:#475569; border-radius:50%; @(string.IsNullOrWhiteSpace(search) ? "display:none;" : "display:inline-flex;") align-items:center; justify-content:center; font-size:15px; line-height:1; cursor:pointer; padding:0;">
                    ×
                </button>
            </div>

            <button type="submit"
                    class="archive-main-btn archive-search-btn"
                    style="flex:0 0 116px; width:116px; height:50px; border:none; border-radius:16px; background:linear-gradient(135deg,#3B82F6,#2563EB); color:#FFFFFF; font-weight:800; box-shadow:0 10px 22px rgba(37,99,235,.18); transition:all .18s ease;">
                Търси
            </button>
        </form>
    </section>

    <section class="card-soft" style="padding:0; overflow:hidden; background:#FFFFFF; border:1px solid #D9E0E7; border-radius:18px; box-shadow:0 10px 30px rgba(15,23,42,.05);">
        @if (!Model.Any())
        {
            <div style="padding:1.15rem; color:#6B7280; font-weight:600;">Няма архивирани заявки за парола.</div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table mb-0" style="margin-bottom:0;">
                    <thead>
                        <tr>
                            <th style="padding:.95rem 1.2rem;">Читател</th>
                            <th style="padding:.95rem 1.2rem;">№ карта</th>
                            <th style="padding:.95rem 1.2rem;">Телефон</th>
                            <th style="padding:.95rem 1.2rem;">Подадена на</th>
                            <th style="padding:.95rem 1.2rem;">Статус</th>
                            <th style="padding:.95rem 1.2rem;">Бележка</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            var fullName = item.Reader != null
                            ? $"{item.Reader.FirstName} {item.Reader.MiddleName} {item.Reader.LastName}".Replace("  ", " ").Trim()
                            : "Неизвестен читател";

                            <tr class="archive-password-row">
                                <td style="padding:1rem 1.2rem; font-weight:700; color:#0F172A;">
                                    @fullName
                                </td>

                                <td style="padding:1rem 1.2rem; color:#334155;">
                                    @(string.IsNullOrWhiteSpace(item.CardNumber) ? "—" : item.CardNumber)
                                </td>

                                <td style="padding:1rem 1.2rem; color:#334155;">
                                    @(string.IsNullOrWhiteSpace(item.PhoneNumber) ? "—" : item.PhoneNumber)
                                </td>

                                <td style="padding:1rem 1.2rem; color:#334155;">
                                    @item.RequestedOn.ToString("dd.MM.yyyy HH:mm")
                                </td>

                                <td style="padding:1rem 1.2rem;">
                                    <span style="display:inline-flex; align-items:center; min-height:30px; padding:0 10px; border-radius:999px; background:#ECFDF5; color:#166534; border:1px solid #BBF7D0; font-weight:700;">
                                        Изпълнена
                                    </span>
                                </td>

                                <td style="padding:1rem 1.2rem; color:#334155;">
                                    @(string.IsNullOrWhiteSpace(item.Notes) ? "—" : item.Notes)
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </section>
</div>

@section Scripts {
    <script>
        (() => {
            const input = document.getElementById('archivePasswordSearch');
            const clearBtn = document.getElementById('archivePasswordClearBtn');
            const tabsGrid = document.getElementById('archivePasswordTabsGrid');

            function applyArchivePasswordResponsive() {
                if (!tabsGrid) return;

                if (window.innerWidth <= 820) {
                    tabsGrid.style.gridTemplateColumns = 'repeat(2, 1fr)';
                } else {
                    tabsGrid.style.gridTemplateColumns = 'repeat(8, 1fr)';
                }
            }

            if (input && clearBtn) {
                function toggleClearButton() {
                    clearBtn.style.display = input.value.trim().length > 0 ? 'inline-flex' : 'none';
                }

                clearBtn.addEventListener('click', () => {
                    input.value = '';
                    toggleClearButton();
                    input.focus();
                });

                input.addEventListener('input', toggleClearButton);
                toggleClearButton();
            }

            applyArchivePasswordResponsive();
            window.addEventListener('resize', applyArchivePasswordResponsive);
        })();
    </script>
}