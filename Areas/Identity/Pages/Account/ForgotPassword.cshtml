@page
@model ObreshkovLibrary.Areas.Identity.Pages.Account.ForgotPasswordModel

@{
    ViewData["Title"] = "Забравена парола";
}

<div style="min-height:100vh; background:#eef3f8; display:flex; align-items:center; justify-content:center; padding:30px 16px;">
    <div style="width:100%; max-width:540px; background:#ffffff; border:1px solid #d8e1ea; box-shadow:0 10px 24px rgba(15, 23, 42, 0.08); overflow:hidden;">

        <div style="padding:24px 28px; border-bottom:1px solid #d8e1ea; background:#f8fbff;">
            <div style="font-size:1.35rem; font-weight:800; color:#1d4f91;">Забравена парола</div>
            <div style="margin-top:6px; color:#64748b;">
                При ученик заявката се записва за обработка от администратор.
            </div>
        </div>

        <div style="padding:28px;">
            <form method="post" style="margin:0;">
                <div asp-validation-summary="ModelOnly" class="text-danger" style="margin-bottom:14px;"></div>

                <input asp-for="Input.Role" type="hidden" />

                @if (Model.Input.Role == "Admin")
                {
                    <div style="margin-bottom:16px; color:#475569;">
                        За администраторски профил възстановяването на парола става чрез системен администратор.
                    </div>
                }
                else
                {
                    <div style="margin-bottom:14px;">
                        <label style="display:block; margin-bottom:6px; font-weight:700; color:#334155;">
                            Номер на читателска карта
                        </label>
                        <input asp-for="Input.CardNumber"
                               style="width:100%; height:46px; border:1px solid #cbd5e1; outline:none; padding:0 14px; background:#ffffff; color:#1f2937; box-sizing:border-box;" />
                    </div>

                    <div style="margin-bottom:16px;">
                        <label style="display:block; margin-bottom:6px; font-weight:700; color:#334155;">
                            Телефонен номер
                        </label>
                        <input asp-for="Input.PhoneNumber"
                               style="width:100%; height:46px; border:1px solid #cbd5e1; outline:none; padding:0 14px; background:#ffffff; color:#1f2937; box-sizing:border-box;" />
                    </div>

                    <div style="display:flex; gap:10px; flex-wrap:wrap;">
                        <button type="submit"
                                style="min-width:170px; height:46px; border:none; background:#2563eb; color:#ffffff; font-weight:800;">
                            Изпрати заявка
                        </button>

                        <a asp-area="Identity"
                           asp-page="/Account/Login"
                           style="min-width:140px; height:46px; display:inline-flex; align-items:center; justify-content:center; text-decoration:none; border:1px solid #cbd5e1; color:#334155; background:#ffffff; font-weight:700;">
                            Назад
                        </a>
                    </div>
                }
            </form>
        </div>
    </div>
</div>

@if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
{
    <div id="statusModalBackdrop"
         style="position:fixed; inset:0; background:rgba(15,23,42,0.24); display:flex; align-items:center; justify-content:center; padding:20px; z-index:2000;">
        <div style="width:100%; max-width:460px; background:#ffffff; border:1px solid #d8e1ea; box-shadow:0 18px 45px rgba(15,23,42,0.14); overflow:hidden;">
            <div style="padding:24px 28px; border-bottom:1px solid #d8e1ea; background:#f8fbff;">
                <div style="font-size:1.35rem; font-weight:800; color:#1d4f91;">Съобщение</div>
                <div style="margin-top:10px; width:54px; height:3px; background:#3b82f6;"></div>
            </div>

            <div style="padding:24px 28px 10px 28px; color:#334155; font-size:1.04rem; line-height:1.7;">
                @Model.StatusMessage
            </div>

            <div style="display:flex; justify-content:flex-end; padding:18px 28px 24px 28px;">
                <button type="button"
                        id="closeStatusModalBtn"
                        style="min-width:120px; height:42px; border:none; background:#2563eb; color:#ffffff; font-weight:800;">
                    Затвори
                </button>
            </div>
        </div>
    </div>
}

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    @if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
    {
        <script>
            (function () {
                const backdrop = document.getElementById('statusModalBackdrop');
                const closeBtn = document.getElementById('closeStatusModalBtn');

                if (!backdrop || !closeBtn) return;

                function closeModal() {
                    backdrop.style.display = 'none';
                }

                closeBtn.addEventListener('click', closeModal);

                backdrop.addEventListener('click', function (e) {
                    if (e.target === backdrop) {
                        closeModal();
                    }
                });

                document.addEventListener('keydown', function (e) {
                    if (e.key === 'Escape') {
                        closeModal();
                    }
                });
            })();
        </script>
    }
}