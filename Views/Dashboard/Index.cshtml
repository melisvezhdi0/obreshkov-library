@model ObreshkovLibrary.Models.ViewModels.HomeDashboardVM

@{
    ViewData["Title"] = "Начало";
}

<div style="width:100%; padding-top:6px;">

    <section style="margin-bottom:18px; padding:22px; border-radius:18px; background:#ffffff; border:1px solid #dbe5ef; box-shadow:0 10px 24px rgba(15,23,42,.04);">
        <div style="display:grid; grid-template-columns:minmax(0,1.3fr) minmax(360px,.95fr); gap:18px; align-items:start;"
             id="dashboardHeroGrid">

            <div>
                <h2 class="section-title mb-1">Начало</h2>
                <div class="accent-line"></div>
                <div style="margin-top:10px; color:#64748b; font-size:1rem;">
                    Административен преглед на библиотеката
                </div>
            </div>

            <div style="background:linear-gradient(180deg, #f8fbff 0%, #f4f8fd 100%); border:1px solid #dbe5ef; border-radius:18px; padding:18px; box-shadow:0 8px 18px rgba(15,23,42,.04);">
                <div style="font-size:.82rem; text-transform:uppercase; font-weight:800; letter-spacing:.05em; color:#64748b; margin-bottom:12px;">
                    Бързо търсене по номер на карта
                </div>

                <form asp-controller="Dashboard"
                      asp-action="SearchByCardNumber"
                      method="post"
                      style="margin:0;">
                    @Html.AntiForgeryToken()

                    <input type="hidden" name="cardNumber" id="cardNumberHidden" />

                    <div id="dashboardSearchRow"
                         style="display:flex; align-items:center; gap:4px; flex-wrap:nowrap;">
                        <div id="cardDigitsWrapper"
                             style="display:flex; align-items:center; gap:6px; flex-wrap:nowrap; min-width:0;">
                            @for (int i = 0; i < 6; i++)
                            {
                                <input type="text"
                                       class="card-digit-box"
                                       inputmode="numeric"
                                       autocomplete="off"
                                       maxlength="1"
                                       data-index="@i"
                                       aria-label="Цифра @(i + 1)"
                                       style="width:44px;
                                                  height:48px;
                                                  border:1px solid #cbd5e1;
                                                  background:#ffffff;
                                                  text-align:center;
                                                  font-size:1.05rem;
                                                  font-weight:800;
                                                  color:#0f172a;
                                                  border-radius:12px;
                                                  outline:none;
                                                  box-shadow:inset 0 1px 2px rgba(15,23,42,.03);
                                                  transition:border-color .18s ease, box-shadow .18s ease;" />
                            }
                        </div>

                        <button type="submit"
                                class="dashboard-search-btn"
                                aria-label="Търси"
                                title="Търси"
                                style="width:48px;
                                       height:48px;
                                       min-width:48px;
                                       padding:0;
                                       margin-left:2px;
                                       display:flex;
                                       align-items:center;
                                       justify-content:center;
                                       border:1px solid #93c5fd;
                                       background:#ffffff;
                                       color:#2563eb;
                                       border-radius:12px;
                                       cursor:pointer;
                                       line-height:1;
                                       flex:0 0 auto;
                                       transition:background .18s ease, border-color .18s ease, box-shadow .18s ease, transform .18s ease;">
                            <svg xmlns="http://www.w3.org/2000/svg"
                                 width="18"
                                 height="18"
                                 viewBox="0 0 24 24"
                                 fill="none"
                                 stroke="currentColor"
                                 stroke-width="2.2"
                                 stroke-linecap="round"
                                 stroke-linejoin="round"
                                 aria-hidden="true"
                                 style="display:block;">
                                <circle cx="11" cy="11" r="7"></circle>
                                <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
                            </svg>
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </section>

    @if (TempData["HomeError"] != null)
    {
        <div style="margin-bottom:18px; padding:12px 14px; border:1px solid #fecaca; background:#fef2f2; color:#b91c1c; border-radius:12px; box-shadow:0 6px 16px rgba(127,29,29,.04);">
            @TempData["HomeError"]
        </div>
    }

    <section style="margin-bottom:18px; padding:20px; border-radius:18px; background:#ffffff; border:1px solid #dbe5ef; box-shadow:0 10px 24px rgba(15,23,42,.04);">
        <div style="display:flex; justify-content:space-between; align-items:center; gap:12px; flex-wrap:wrap; margin-bottom:14px;">
            <h5 class="section-title mb-0">Последни заемания</h5>
        </div>

        @if (Model.LatestLoans == null || !Model.LatestLoans.Any())
        {
            <div style="padding:14px 0; color:#64748b;">Няма записи.</div>
        }
        else
        {
            <div style="overflow-x:auto;">
                <table style="width:100%; border-collapse:separate; border-spacing:0;">
                    <thead>
                        <tr style="background:#f8fbff;">
                            <th style="padding:14px; text-align:left; border-bottom:1px solid #dbe5ef;">Читател</th>
                            <th style="padding:14px; text-align:left; border-bottom:1px solid #dbe5ef;">№ карта</th>
                            <th style="padding:14px; text-align:left; border-bottom:1px solid #dbe5ef;">Книга</th>
                            <th style="padding:14px; text-align:left; border-bottom:1px solid #dbe5ef;">Заета на</th>
                            <th style="padding:14px; text-align:left; border-bottom:1px solid #dbe5ef;">Срок</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var l in Model.LatestLoans)
                        {
                            <tr>
                                <td style="padding:14px; border-bottom:1px solid #edf2f7;">@($"{l.Reader?.FirstName} {l.Reader?.LastName}".Trim())</td>
                                <td style="padding:14px; border-bottom:1px solid #edf2f7;">@l.Reader?.CardNumber</td>
                                <td style="padding:14px; border-bottom:1px solid #edf2f7;">@l.BookCopy?.Book?.Title</td>
                                <td style="padding:14px; border-bottom:1px solid #edf2f7;">@l.LoanDate.ToString("dd.MM.yyyy")</td>
                                <td style="padding:14px; border-bottom:1px solid #edf2f7;">@l.DueDate.ToString("dd.MM.yyyy")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </section>

    <div style="display:grid; grid-template-columns:repeat(3, minmax(0, 1fr)); gap:18px; margin-bottom:18px;"
         id="dashboardCardsGrid">

        <section class="dashboard-summary-card"
                 style="padding:20px; border-radius:18px; background:#ffffff; border:1px solid #dbe5ef; min-height:190px; box-shadow:0 10px 24px rgba(15,23,42,.04); transition:transform .18s ease, box-shadow .18s ease, border-color .18s ease;">
            <div style="height:100%; display:flex; flex-direction:column; justify-content:space-between;">
                <div>
                    <div style="font-size:.82rem; text-transform:uppercase; font-weight:800; letter-spacing:.04em; color:#6b7280; margin-bottom:10px;">
                        Книги за връщане днес
                    </div>
                    <div style="font-size:2.2rem; font-weight:800; color:#1d4f91; line-height:1;">@Model.DueTodayCount</div>
                </div>

                <button type="button"
                        data-bs-toggle="modal"
                        data-bs-target="#dueTodayModal"
                        class="dashboard-secondary-btn"
                        style="width:max-content; min-width:120px; height:40px; border:1px solid #93c5fd; background:#ffffff; color:#2563eb; border-radius:10px; font-weight:700; transition:background .18s ease, border-color .18s ease, box-shadow .18s ease, transform .18s ease;">
                    Виж списъка
                </button>
            </div>
        </section>

        <section class="dashboard-summary-card"
                 style="padding:20px; border-radius:18px; background:#ffffff; border:1px solid #dbe5ef; min-height:190px; box-shadow:0 10px 24px rgba(15,23,42,.04); transition:transform .18s ease, box-shadow .18s ease, border-color .18s ease;">
            <div style="height:100%; display:flex; flex-direction:column; justify-content:space-between;">
                <div>
                    <div style="font-size:.82rem; text-transform:uppercase; font-weight:800; letter-spacing:.04em; color:#6b7280; margin-bottom:10px;">
                        Просрочени книги
                    </div>
                    <div style="font-size:2.2rem; font-weight:800; color:#1d4f91; line-height:1;">@Model.OverdueCount</div>
                </div>

                <button type="button"
                        data-bs-toggle="modal"
                        data-bs-target="#overdueModal"
                        class="dashboard-secondary-btn"
                        style="width:max-content; min-width:120px; height:40px; border:1px solid #93c5fd; background:#ffffff; color:#2563eb; border-radius:10px; font-weight:700; transition:background .18s ease, border-color .18s ease, box-shadow .18s ease, transform .18s ease;">
                    Виж списъка
                </button>
            </div>
        </section>

        <section class="dashboard-summary-card"
                 style="padding:20px; border-radius:18px; background:#ffffff; border:1px solid #dbe5ef; min-height:190px; box-shadow:0 10px 24px rgba(15,23,42,.04); transition:transform .18s ease, box-shadow .18s ease, border-color .18s ease;">
            <div style="height:100%; display:flex; flex-direction:column; justify-content:space-between;">
                <div>
                    <div style="font-size:.82rem; text-transform:uppercase; font-weight:800; letter-spacing:.04em; color:#6b7280; margin-bottom:10px;">
                        Заявки за смяна на парола
                    </div>
                    <div style="font-size:2.2rem; font-weight:800; color:#1d4f91; line-height:1;">@Model.OpenPasswordResetRequestsCount</div>
                </div>

                <button type="button"
                        data-bs-toggle="modal"
                        data-bs-target="#passwordResetModal"
                        class="dashboard-secondary-btn"
                        style="width:max-content; min-width:120px; height:40px; border:1px solid #93c5fd; background:#ffffff; color:#2563eb; border-radius:10px; font-weight:700; transition:background .18s ease, border-color .18s ease, box-shadow .18s ease, transform .18s ease;">
                    Виж списъка
                </button>
            </div>
        </section>
    </div>

    <section style="background:#ffffff; border:1px solid #dbe5ef; border-radius:18px; padding:18px; margin-bottom:18px; box-shadow:0 10px 24px rgba(15,23,42,.04);">

        <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:12px; gap:10px; flex-wrap:wrap;">
            <h5 style="font-weight:800; color:#0f172a; margin:0;">
                Последно добавени книги
            </h5>

            <a asp-controller="Book"
               asp-action="Recent"
               class="dashboard-link-btn"
               style="height:34px; padding:0 12px; display:flex; align-items:center;
                      border:1px solid #93c5fd; border-radius:8px;
                      text-decoration:none; color:#2563eb; font-weight:700; background:#ffffff;
                      transition:background .18s ease, border-color .18s ease, box-shadow .18s ease, transform .18s ease;">
                Още
            </a>
        </div>

        @if (Model.LatestBookTitles == null || !Model.LatestBookTitles.Any())
        {
            <div style="color:#64748b; font-weight:600;">Няма книги.</div>
        }
        else
        {
            <div id="latestBooksGrid"
                 style="display:flex; justify-content:center; gap:26px; flex-wrap:nowrap; overflow-x:auto; padding:6px 2px 2px 2px;">

                @foreach (var b in Model.LatestBookTitles.Take(5))
                {
                    <div style="width:136px; min-width:136px; display:flex; flex-direction:column; align-items:center;">
                        <a href="@Url.Action("Details", "Book", new { id = b.Id })"
                           class="dashboard-book-cover-link"
                           style="width:100%;
                                          height:208px;
                                          display:flex;
                                          align-items:center;
                                          justify-content:center;
                                          text-decoration:none;
                                          background:#ffffff;
                                          border-radius:12px;
                                          overflow:hidden;
                                          margin-bottom:10px;">

                            <div class="dashboard-book-cover-frame"
                                 style="width:100%;
                                                height:100%;
                                                display:flex;
                                                align-items:center;
                                                justify-content:center;
                                                border-radius:12px;
                                                overflow:hidden;
                                                transition:transform .18s ease, box-shadow .18s ease;">

                                <img src="@b.CoverPath"
                                     alt="@b.Title"
                                     class="dashboard-book-cover-image"
                                     style="max-width:100%; max-height:100%; object-fit:contain; transition:transform .22s ease;"
                                     onerror="this.style.display='none'; this.parentElement.innerHTML='<span style=&quot;color:#94a3b8;font-size:11px;font-weight:700;&quot;>Няма корица</span>';" />
                            </div>
                        </a>

                        <div style="text-align:center; font-weight:700; font-size:14px; line-height:1.3; color:#0f172a;">
                            @b.Title
                        </div>
                    </div>
                }
            </div>
        }
    </section>
</div>

<div class="modal fade" id="dueTodayModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-xl modal-dialog-scrollable">
        <div class="modal-content" style="border-radius:18px; border:1px solid #dbe5ef;">
            <div class="modal-header" style="border-bottom:1px solid #e2e8f0;">
                <h5 class="modal-title">Книги за връщане днес (@Model.DueTodayCount)</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Затвори"></button>
            </div>
            <div class="modal-body">
                @if (Model.DueTodayLoans == null || !Model.DueTodayLoans.Any())
                {
                    <div style="color:#64748b;">Няма книги за връщане днес.</div>
                }
                else
                {
                    <div style="overflow-x:auto;">
                        <table style="width:100%; border-collapse:separate; border-spacing:0;">
                            <thead>
                                <tr style="background:#f8fbff;">
                                    <th style="padding:14px; text-align:left; border-bottom:1px solid #dbe5ef;">Читател</th>
                                    <th style="padding:14px; text-align:left; border-bottom:1px solid #dbe5ef;">№ карта</th>
                                    <th style="padding:14px; text-align:left; border-bottom:1px solid #dbe5ef;">Книга</th>
                                    <th style="padding:14px; text-align:left; border-bottom:1px solid #dbe5ef;">Срок</th>
                                    <th style="padding:14px; text-align:right; border-bottom:1px solid #dbe5ef;">Действие</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var l in Model.DueTodayLoans)
                                {
                                    <tr>
                                        <td style="padding:14px; border-bottom:1px solid #edf2f7;">@($"{l.Reader?.FirstName} {l.Reader?.LastName}".Trim())</td>
                                        <td style="padding:14px; border-bottom:1px solid #edf2f7;">@l.Reader?.CardNumber</td>
                                        <td style="padding:14px; border-bottom:1px solid #edf2f7;">@l.BookCopy?.Book?.Title</td>
                                        <td style="padding:14px; border-bottom:1px solid #edf2f7;">@l.DueDate.ToString("dd.MM.yyyy")</td>
                                        <td style="padding:14px; text-align:right; border-bottom:1px solid #edf2f7;">
                                            <a asp-controller="Loans"
                                               asp-action="Return"
                                               asp-route-id="@l.Id"
                                               class="dashboard-action-link"
                                               style="color:#2563eb; text-decoration:none; font-weight:700; transition:color .18s ease, text-decoration .18s ease;">
                                                Отвори
                                            </a>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="overdueModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-xl modal-dialog-scrollable">
        <div class="modal-content" style="border-radius:18px; border:1px solid #dbe5ef;">
            <div class="modal-header" style="border-bottom:1px solid #e2e8f0;">
                <h5 class="modal-title">Просрочени книги (@Model.OverdueCount)</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Затвори"></button>
            </div>
            <div class="modal-body">
                @if (Model.OverdueLoans == null || !Model.OverdueLoans.Any())
                {
                    <div style="color:#64748b;">Няма просрочени книги.</div>
                }
                else
                {
                    <div style="overflow-x:auto;">
                        <table style="width:100%; border-collapse:separate; border-spacing:0;">
                            <thead>
                                <tr style="background:#f8fbff;">
                                    <th style="padding:14px; text-align:left; border-bottom:1px solid #dbe5ef;">Читател</th>
                                    <th style="padding:14px; text-align:left; border-bottom:1px solid #dbe5ef;">№ карта</th>
                                    <th style="padding:14px; text-align:left; border-bottom:1px solid #dbe5ef;">Книга</th>
                                    <th style="padding:14px; text-align:left; border-bottom:1px solid #dbe5ef;">Срок</th>
                                    <th style="padding:14px; text-align:right; border-bottom:1px solid #dbe5ef;">Действие</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var l in Model.OverdueLoans)
                                {
                                    <tr>
                                        <td style="padding:14px; border-bottom:1px solid #edf2f7;">@($"{l.Reader?.FirstName} {l.Reader?.LastName}".Trim())</td>
                                        <td style="padding:14px; border-bottom:1px solid #edf2f7;">@l.Reader?.CardNumber</td>
                                        <td style="padding:14px; border-bottom:1px solid #edf2f7;">@l.BookCopy?.Book?.Title</td>
                                        <td style="padding:14px; border-bottom:1px solid #edf2f7;">@l.DueDate.ToString("dd.MM.yyyy")</td>
                                        <td style="padding:14px; text-align:right; border-bottom:1px solid #edf2f7;">
                                            <a asp-controller="Loans"
                                               asp-action="Return"
                                               asp-route-id="@l.Id"
                                               class="dashboard-action-link"
                                               style="color:#2563eb; text-decoration:none; font-weight:700; transition:color .18s ease, text-decoration .18s ease;">
                                                Отвори
                                            </a>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="passwordResetModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-xl modal-dialog-scrollable">
        <div class="modal-content" style="border-radius:18px; border:1px solid #dbe5ef;">
            <div class="modal-header" style="border-bottom:1px solid #e2e8f0;">
                <h5 class="modal-title">Заявки за смяна на парола (@Model.OpenPasswordResetRequestsCount)</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Затвори"></button>
            </div>
            <div class="modal-body">
                @if (Model.OpenPasswordResetRequests == null || !Model.OpenPasswordResetRequests.Any())
                {
                    <div style="color:#64748b;">Няма активни заявки.</div>
                }
                else
                {
                    <div style="overflow-x:auto;">
                        <table style="width:100%; border-collapse:separate; border-spacing:0;">
                            <thead>
                                <tr style="background:#f8fbff;">
                                    <th style="padding:14px; text-align:left; border-bottom:1px solid #dbe5ef;">Читател</th>
                                    <th style="padding:14px; text-align:left; border-bottom:1px solid #dbe5ef;">Карта</th>
                                    <th style="padding:14px; text-align:left; border-bottom:1px solid #dbe5ef;">Телефон</th>
                                    <th style="padding:14px; text-align:left; border-bottom:1px solid #dbe5ef;">Подадена</th>
                                    <th style="padding:14px; text-align:right; border-bottom:1px solid #dbe5ef;">Действие</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var r in Model.OpenPasswordResetRequests)
                                {
                                    var fullName = r.Reader != null
                                    ? $"{r.Reader.FirstName} {r.Reader.LastName}"
                                    : "-";

                                    <tr>
                                        <td style="padding:14px; border-bottom:1px solid #edf2f7;">@fullName</td>
                                        <td style="padding:14px; border-bottom:1px solid #edf2f7;">@r.CardNumber</td>
                                        <td style="padding:14px; border-bottom:1px solid #edf2f7;">@r.PhoneNumber</td>
                                        <td style="padding:14px; border-bottom:1px solid #edf2f7;">@r.RequestedOn.ToString("dd.MM.yyyy HH:mm")</td>
                                        <td style="padding:14px; text-align:right; border-bottom:1px solid #edf2f7;">
                                            <a asp-controller="Readers"
                                               asp-action="PasswordResetRequests"
                                               class="dashboard-action-link"
                                               style="color:#2563eb; text-decoration:none; font-weight:700; transition:color .18s ease, text-decoration .18s ease;">
                                                Отвори
                                            </a>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function applyDashboardResponsive() {
            const heroGrid = document.getElementById('dashboardHeroGrid');
            const cardsGrid = document.getElementById('dashboardCardsGrid');
            const latestBooksGrid = document.getElementById('latestBooksGrid');
            const searchRow = document.getElementById('dashboardSearchRow');
            const digitsWrapper = document.getElementById('cardDigitsWrapper');

            if (window.innerWidth <= 1200) {
                if (cardsGrid) cardsGrid.style.gridTemplateColumns = '1fr 1fr';
            } else {
                if (cardsGrid) cardsGrid.style.gridTemplateColumns = 'repeat(3, minmax(0, 1fr))';
            }

            if (window.innerWidth <= 900) {
                if (heroGrid) heroGrid.style.gridTemplateColumns = '1fr';
                if (cardsGrid) cardsGrid.style.gridTemplateColumns = '1fr';
            } else {
                if (heroGrid) heroGrid.style.gridTemplateColumns = 'minmax(0,1.3fr) minmax(360px,.95fr)';
            }

            if (window.innerWidth <= 640) {
                if (searchRow) {
                    searchRow.style.justifyContent = 'flex-start';
                    searchRow.style.gap = '4px';
                }

                if (digitsWrapper) {
                    digitsWrapper.style.justifyContent = 'flex-start';
                    digitsWrapper.style.gap = '6px';
                }

                if (latestBooksGrid) {
                    latestBooksGrid.style.justifyContent = 'flex-start';
                    latestBooksGrid.style.paddingBottom = '4px';
                }
            } else {
                if (searchRow) {
                    searchRow.style.justifyContent = 'flex-start';
                    searchRow.style.gap = '4px';
                }

                if (digitsWrapper) {
                    digitsWrapper.style.justifyContent = 'flex-start';
                    digitsWrapper.style.gap = '6px';
                }

                if (latestBooksGrid) latestBooksGrid.style.justifyContent = 'center';
            }
        }

        function initializeCardNumberBoxes() {
            const inputs = Array.from(document.querySelectorAll('.card-digit-box'));
            const hiddenInput = document.getElementById('cardNumberHidden');
            const form = hiddenInput ? hiddenInput.closest('form') : null;

            if (!inputs.length || !hiddenInput || !form) {
                return;
            }

            function syncHiddenInput() {
                hiddenInput.value = inputs.map(x => x.value).join('');
            }

            inputs.forEach((input, index) => {
                input.addEventListener('input', function (e) {
                    let value = e.target.value.replace(/\D/g, '');

                    if (value.length > 1) {
                        const chars = value.split('');
                        for (let i = 0; i < chars.length && index + i < inputs.length; i++) {
                            inputs[index + i].value = chars[i];
                        }

                        const nextIndex = Math.min(index + value.length, inputs.length - 1);
                        inputs[nextIndex].focus();
                        inputs[nextIndex].select();
                    } else {
                        e.target.value = value;

                        if (value && index < inputs.length - 1) {
                            inputs[index + 1].focus();
                            inputs[index + 1].select();
                        }
                    }

                    syncHiddenInput();
                });

                input.addEventListener('keydown', function (e) {
                    if (e.key === 'Backspace') {
                        if (e.target.value === '' && index > 0) {
                            inputs[index - 1].focus();
                            inputs[index - 1].value = '';
                            syncHiddenInput();
                            e.preventDefault();
                        }
                    }

                    if (e.key === 'ArrowLeft' && index > 0) {
                        inputs[index - 1].focus();
                        e.preventDefault();
                    }

                    if (e.key === 'ArrowRight' && index < inputs.length - 1) {
                        inputs[index + 1].focus();
                        e.preventDefault();
                    }
                });

                input.addEventListener('paste', function (e) {
                    e.preventDefault();

                    const pasted = (e.clipboardData || window.clipboardData)
                        .getData('text')
                        .replace(/\D/g, '')
                        .slice(0, 6);

                    if (!pasted) {
                        return;
                    }

                    for (let i = 0; i < inputs.length; i++) {
                        inputs[i].value = pasted[i] || '';
                    }

                    syncHiddenInput();

                    const focusIndex = Math.min(pasted.length, 5);
                    inputs[focusIndex].focus();
                    inputs[focusIndex].select();
                });

                input.addEventListener('focus', function () {
                    input.style.borderColor = '#3b82f6';
                    input.style.boxShadow = '0 0 0 3px rgba(59,130,246,.12)';
                    input.select();
                });

                input.addEventListener('blur', function () {
                    input.style.borderColor = '#cbd5e1';
                    input.style.boxShadow = 'inset 0 1px 2px rgba(15,23,42,.03)';
                });
            });

            form.addEventListener('submit', function () {
                syncHiddenInput();
            });
        }

        function initializeDashboardEffects() {
                    document.querySelectorAll('.dashboard-secondary-btn, .dashboard-link-btn, .dashboard-search-btn, .card-digit-box').forEach(el => {
            el.addEventListener('mouseenter', function () {
                if (el.classList.contains('card-digit-box')) {
                    el.style.borderColor = '#60a5fa';
                    el.style.boxShadow = '0 8px 18px rgba(37,99,235,.08)';
                    el.style.transform = 'translateY(-1px)';
                } else {
                    el.style.background = '#eff6ff';
                    el.style.borderColor = '#60a5fa';
                    el.style.transform = 'translateY(-1px)';
                    el.style.boxShadow = '0 8px 18px rgba(37,99,235,.10)';
                }
            });

            el.addEventListener('mouseleave', function () {
                if (el.classList.contains('card-digit-box')) {
                    el.style.borderColor = '#cbd5e1';
                    el.style.boxShadow = 'inset 0 1px 2px rgba(15,23,42,.03)';
                    el.style.transform = 'translateY(0)';
                } else {
                    el.style.background = '#ffffff';
                    el.style.borderColor = '#93c5fd';
                    el.style.transform = 'translateY(0)';
                    el.style.boxShadow = 'none';
                }
            });
        });

            document.querySelectorAll('.dashboard-secondary-btn, .dashboard-link-btn, .dashboard-search-btn').forEach(btn => {
                btn.addEventListener('mouseenter', function () {
                    btn.style.background = '#eff6ff';
                    btn.style.borderColor = '#60a5fa';
                    btn.style.transform = 'translateY(-1px)';
                    btn.style.boxShadow = '0 8px 18px rgba(37,99,235,.10)';
                });

                btn.addEventListener('mouseleave', function () {
                    btn.style.background = '#ffffff';
                    btn.style.borderColor = '#93c5fd';
                    btn.style.transform = 'translateY(0)';
                    btn.style.boxShadow = 'none';
                });
            });

            document.querySelectorAll('.dashboard-book-cover-frame').forEach(frame => {
                frame.addEventListener('mouseenter', function () {
                    frame.style.transform = 'translateY(-3px)';
                    frame.style.boxShadow = '0 14px 26px rgba(15,23,42,.12)';

                    const image = frame.querySelector('.dashboard-book-cover-image');
                    if (image) {
                        image.style.transform = 'scale(1.05)';
                    }
                });

                frame.addEventListener('mouseleave', function () {
                    frame.style.transform = 'translateY(0)';
                    frame.style.boxShadow = 'none';

                    const image = frame.querySelector('.dashboard-book-cover-image');
                    if (image) {
                        image.style.transform = 'scale(1)';
                    }
                });
            });

            document.querySelectorAll('.dashboard-action-link').forEach(link => {
                link.addEventListener('mouseenter', function () {
                    link.style.color = '#1d4ed8';
                    link.style.textDecoration = 'underline';
                    link.style.textUnderlineOffset = '3px';
                });

                link.addEventListener('mouseleave', function () {
                    link.style.color = '#2563eb';
                    link.style.textDecoration = 'none';
                });
            });
        }

        applyDashboardResponsive();
        initializeCardNumberBoxes();
        initializeDashboardEffects();
        window.addEventListener('resize', applyDashboardResponsive);
    </script>
}