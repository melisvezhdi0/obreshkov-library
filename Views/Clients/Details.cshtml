@using ObreshkovLibrary.Models
@model ObreshkovLibrary.Models.Client

@{
    ViewData["Title"] = "Читател";
    var loans = ViewBag.ActiveLoans as List<Loan> ?? new List<Loan>();
}

<div class="client-details-page">

    <div class="client-details-header">
        <div>
            <h2 class="section-title mb-1">
                @($"{Model.FirstName} {Model.MiddleName} {Model.LastName}".Replace("  ", " ").Trim())
            </h2>
            <div class="accent-line"></div>
            @if (TempData["CreatedStudentPassword"] != null)
            {
                <div style="margin-bottom:16px; padding:14px; border:1px solid #bfdbfe; background:#eff6ff; color:#1e3a8a; border-radius:12px;">
                    <div style="font-weight:800; margin-bottom:6px;">Създаден е ученически профил</div>
                    <div><strong>Читател:</strong> @TempData["CreatedStudentName"]</div>
                    <div><strong>Номер на карта:</strong> @TempData["CreatedStudentCard"]</div>
                    <div style="margin-top:8px;">
                        <strong>Временна парола:</strong>
                        <span style="display:inline-block; padding:6px 10px; background:#ffffff; border:1px solid #cbd5e1; border-radius:8px; font-weight:800; letter-spacing:.03em;">
                            @TempData["CreatedStudentPassword"]
                        </span>
                    </div>
                </div>
            }
        </div>

        <div class="client-details-actions">
            <a class="btn btn-outline-primary"
               asp-action="Index">
                Назад
            </a>

            <a class="btn btn-accent"
               asp-controller="Loans"
               asp-action="Create"
               asp-route-clientId="@Model.Id">
                Нов заем
            </a>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-lg-4">
            <section class="details-panel card-soft">
                <div class="details-panel-head">
                    <h5 class="section-title mb-0">Данни</h5>
                </div>

                <div class="details-info-list">
                    <div class="details-info-row">
                        <span class="details-label">№ карта</span>
                        <span class="details-value">@Model.CardNumber</span>
                    </div>

                    <div class="details-info-row">
                        <span class="details-label">Име</span>
                        <span class="details-value">@Model.FirstName</span>
                    </div>

                    @if (!string.IsNullOrWhiteSpace(Model.MiddleName))
                    {
                        <div class="details-info-row">
                            <span class="details-label">Презиме</span>
                            <span class="details-value">@Model.MiddleName</span>
                        </div>
                    }

                    <div class="details-info-row">
                        <span class="details-label">Фамилия</span>
                        <span class="details-value">@Model.LastName</span>
                    </div>

                    @if (!string.IsNullOrWhiteSpace(Model.PhoneNumber))
                    {
                        <div class="details-info-row">
                            <span class="details-label">Телефон</span>
                            <span class="details-value">@Model.PhoneNumber</span>
                        </div>
                    }

                    <div class="details-info-row">
                        <span class="details-label">Създаден</span>
                        <span class="details-value">@Model.CreatedOn.ToString("dd.MM.yyyy")</span>
                    </div>

                    <div class="details-info-row">
                        <span class="details-label">Статус</span>
                        <span class="details-value">
                            @if (Model.IsActive)
                            {
                                <span class="status-badge status-active">Активен</span>
                            }
                            else
                            {
                                <span class="status-badge status-inactive">Неактивен</span>
                            }
                        </span>
                    </div>
                </div>

                <div class="details-panel-footer">
                    <a class="btn btn-outline-primary w-100"
                       asp-action="Edit"
                       asp-route-id="@Model.Id">
                        Редактиране
                    </a>
                </div>
            </section>
        </div>

        <div class="col-lg-8">
            <section class="details-panel card-soft">
                <div class="details-panel-head details-panel-head-flex">
                    <h5 class="section-title mb-0">Активни заеми</h5>
                    <span class="count-badge">@loans.Count</span>
                </div>

                @if (!loans.Any())
                {
                    <div class="details-empty-state">
                        Няма активни заеми.
                    </div>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table details-table align-middle mb-0">
                            <thead>
                                <tr>
                                    <th>Книга</th>
                                    <th>Автор</th>
                                    <th>Заета на</th>
                                    <th>Срок</th>
                                    <th class="text-end">Действие</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var l in loans)
                                {
                                    <tr>
                                        <td class="details-book-title">@l.BookCopy?.Book?.Title</td>
                                        <td>@l.BookCopy?.Book?.Author</td>
                                        <td>@l.LoanDate.ToString("dd.MM.yyyy")</td>
                                        <td>@l.DueDate.ToString("dd.MM.yyyy")</td>
                                        <td class="text-end">
                                            <form asp-controller="Loans"
                                                  asp-action="Return"
                                                  method="post"
                                                  style="display:inline;">

                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="id" value="@l.Id" />
                                                <button type="button"
                                                        class="btn btn-sm btn-outline-danger"
                                                        data-bs-toggle="modal"
                                                        data-bs-target="#returnModal"
                                                        data-loan-id="@l.Id">
                                                    Върни
                                                </button>

                                            </form>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </section>
        </div>
    </div>
    <div class="modal fade" id="returnModal" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">

                <div class="modal-header">
                    <h5 class="modal-title">Потвърждение</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>

                <div class="modal-body">
                    Сигурни ли сте, че книгата е върната в библиотеката?
                </div>
                <div class="modal-footer">

                    <button type="button"
                            class="btn btn-outline-secondary"
                            data-bs-dismiss="modal">
                        Отказ
                    </button>

                    <form id="returnForm"
                          asp-controller="Loans"
                          asp-action="Return"
                          method="post">

                        @Html.AntiForgeryToken()

                        <input type="hidden" name="id" id="returnLoanId" />

                        <button type="submit" class="btn btn-accent">
                            Да
                        </button>

                    </form>

                </div>
            </div>
        </div>
    </div>
</div>
