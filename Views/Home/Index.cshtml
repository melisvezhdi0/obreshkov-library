@using ObreshkovLibrary.Models
@{
    var homeNews = ViewBag.HomeNews as List<SchoolNews> ?? new List<SchoolNews>();
}
@{
    Layout = "~/Views/Shared/_PublicLayout.cshtml";
    ViewData["Title"] = "Начало";
}

<div class="home-page">
    <div class="home-shell">

        <div class="hero-wrap">
            <section class="hero-card">

                <div class="hero-images">
                    <img src="~/images/school1.png" class="hero-img active" />
                    <img src="~/images/school2.png" class="hero-img" />
                    <img src="~/images/school3.png" class="hero-img" />
                    <img src="~/images/school4.png" class="hero-img" />
                    <img src="~/images/school5.png" class="hero-img" />
                    <img src="~/images/school6.png" class="hero-img" />
                    <img src="~/images/school7.png" class="hero-img" />                  
                </div>

                <div class="hero-fade-left"></div>
                <div class="hero-fade-right"></div>

                <div class="hero-nav">
                    <div class="hero-nav-inner">
                        <a asp-controller="Catalog" asp-action="Index">Каталог</a>
                        <a href="#school-info">За училището</a>
                        <a href="#library-info">За библиотеката</a>
                    </div>
                </div>

                <div class="hero-search-wrap">
                    <div class="hero-search-panel">
                        <form method="get" asp-controller="Catalog" asp-action="Index" class="hero-search-form">
                            <input type="text"
                                   name="searchTerm"
                                   class="hero-search-input"
                                   placeholder="Търсене по книга, автор, категория или клас..." />
                            <button type="submit" class="hero-search-button">Търси</button>
                        </form>
                    </div>
                </div>
            </section>
            }

        <section class="guest-section-grid">
            <article id="about-school" class="guest-section-card">
                <div class="guest-section-label">За училището</div>
                <h2 class="guest-section-title">Училищна среда с място за знание и четене</h2>
                <p class="guest-section-text">
                    ППМГ „Акад. Никола Обрешков“ – Разград е училище с традиции, академична насоченост
                    и активен училищен живот. Библиотеката е естествена част от тази среда – пространство,
                    което подпомага подготовката, любознателността и интереса към литературата.
                </p>

                <ul class="guest-list">
                    <li><span class="guest-list-dot"></span><span>По-ясна ориентация за ученици, учители и гости.</span></li>
                    <li><span class="guest-list-dot"></span><span>Лесен достъп до каталога и основната информация.</span></li>
                    <li><span class="guest-list-dot"></span><span>Визия, близка до училищен уебсайт, а не до тъмен промоционален landing page.</span></li>
                </ul>
            </article>

            <article id="about-library" class="guest-section-card">
                <div class="guest-section-label">За библиотеката</div>
                <h2 class="guest-section-title">Достъпна и подредена библиотечна система</h2>
                <p class="guest-section-text">
                    Библиотечната система е създадена, за да представя по ясен и подреден начин
                    наличните книги и основната информация за библиотеката. Началната страница
                    насочва гостите към най-важното, без излишно повторение и без претрупани елементи.
                </p>

                <ul class="guest-list">
                    <li><span class="guest-list-dot"></span><span>Прегледно представяне на библиотечния каталог.</span></li>
                    <li><span class="guest-list-dot"></span><span>По-лесна ориентация за гости и потребители.</span></li>
                    <li><span class="guest-list-dot"></span><span>Визия, съобразена с училищната среда и останалата част от проекта.</span></li>
                </ul>
            </article>
        </section>

        <section class="guest-stats">
            <article class="guest-stat-card">
                <h3 class="guest-stat-title">Местоположение</h3>
                <p class="guest-stat-number">01</p>
                <p class="guest-stat-text">
                    гр. Разград, ППМГ „Акад. Никола Обрешков“
                </p>
                <a href="https://www.google.com/maps?q=ППМГ+Акад.+Никола+Обрешков+Разград"
                   target="_blank"
                   class="guest-stat-link">
                    Отвори в Google Maps
                </a>
            </article>

            <article class="guest-stat-card">
                <h3 class="guest-stat-title">Връзка с нас</h3>
                <p class="guest-stat-number">02</p>
                <p class="guest-stat-text">
                    Телефон: 08XXXXXXXX
                </p>
                <a href="tel:08XXXXXXXX" class="guest-stat-link">
                    Обади се
                </a>
            </article>

            <article class="guest-stat-card">
                <h3 class="guest-stat-title">Последвайте училището</h3>
                <p class="guest-stat-number">03</p>
                <div class="guest-social-links">
                    <a href="https://www.facebook.com/" target="_blank" class="guest-stat-link">Facebook</a>
                    <a href="https://www.instagram.com/" target="_blank" class="guest-stat-link">Instagram</a>
                    <a href="https://www.pmgrz.net/" target="_blank" class="guest-stat-link">Уебсайт</a>
                </div>
            </article>
            <script>
                const slides = document.querySelectorAll(".hero-slide");
                let index = 0;

                setInterval(() => {
                    slides[index].classList.remove("active");
                    index = (index + 1) % slides.length;
                    slides[index].classList.add("active");
                }, 6000);
            </script>
        </section>

    </div>
</div>
<script>
    document.addEventListener("DOMContentLoaded", function () {
        const images = document.querySelectorAll('.hero-img');
        let current = 0;

        if (images.length > 1) {
            setInterval(() => {
                images[current].classList.remove('active');
                current = (current + 1) % images.length;
                images[current].classList.add('active');
            }, 4000);
        }
    });
</script>