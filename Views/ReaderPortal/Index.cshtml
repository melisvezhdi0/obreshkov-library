@model ObreshkovLibrary.Models.ViewModels.ReaderDashboardVM

@{
    ViewData["Title"] = "Моят профил";
    Layout = "_ReaderLayout";

    string ResolveCoverUrl(string? path)
    {
        if (string.IsNullOrWhiteSpace(path))
            return "";

        return path.StartsWith("/")
            ? Url.Content("~" + path)
            : Url.Content("~/" + path.TrimStart('/'));
    }

    string fullClass = Model.Grade.HasValue
        ? $"{Model.Grade} клас{(string.IsNullOrWhiteSpace(Model.Section) ? "" : " " + Model.Section)}"
        : "Няма информация";
}

<form style="display:none;">
    @Html.AntiForgeryToken()
</form>

<div class="Reader-portal-page">
    <aside class="Reader-portal-sidebar">
        <div class="Reader-portal-sidebar-inner">
            <div class="Reader-portal-sidebar-label">Reader Portal</div>
            <h1 class="Reader-portal-sidebar-title">Моят профил</h1>

            <nav id="ReaderScrollspy" class="Reader-portal-nav">
                <a href="#current-loans" class="Reader-nav-link active">
                    <span class="Reader-nav-line"></span>
                    <span>Текущо заети книги</span>
                </a>

                <a href="#favorites" class="Reader-nav-link">
                    <span class="Reader-nav-line"></span>
                    <span>Списък за четене</span>
                </a>

                <a href="#notifications" class="Reader-nav-link">
                    <span class="Reader-nav-line"></span>
                    <span>Известия</span>
                </a>

                <a href="#history" class="Reader-nav-link">
                    <span class="Reader-nav-line"></span>
                    <span>История на заеманията</span>
                </a>

                <a href="#notes" class="Reader-nav-link">
                    <span class="Reader-nav-line"></span>
                    <span>Бележки</span>
                </a>

                <a href="#profile" class="Reader-nav-link">
                    <span class="Reader-nav-line"></span>
                    <span>Лични данни</span>
                </a>
            </nav>

            <div class="Reader-portal-sidebar-footer">
                <form asp-area="Identity"
                      asp-page="/Account/Logout"
                      method="post"
                      style="margin:0;">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="Reader-logout-btn">
                        Изход
                    </button>
                </form>
            </div>
        </div>
    </aside>

    <main class="Reader-portal-content">

        <section id="current-loans" class="Reader-portal-section">
            <div class="Reader-section-header">
                <h2 class="Reader-section-title">Текущо заети книги</h2>
                <p class="Reader-section-subtitle">
                    Тук можеш да видиш всички книги, които държиш в момента.
                </p>
            </div>

            <div class="Reader-panel Reader-panel-scroll Reader-panel-lg">
                @if (Model.CurrentLoans != null && Model.CurrentLoans.Any())
                {
                    <div class="Reader-table-wrap">
                        <table class="Reader-loans-table">
                            <thead>
                                <tr>
                                    <th style="width:88px;">Корица</th>
                                    <th>Заглавие</th>
                                    <th style="width:180px;">Автор</th>
                                    <th style="width:160px;">Заета на</th>
                                    <th style="width:170px;">Връщане до</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model.CurrentLoans)
                                {
                                    <tr>
                                        <td>
                                            <a asp-controller="Catalog"
                                               asp-action="ReaderDetails"
                                               asp-route-id="@item.BookId"
                                               class="Reader-cover-link">
                                                @if (!string.IsNullOrWhiteSpace(item.CoverPath))
                                                {
                                                    <img src="@ResolveCoverUrl(item.CoverPath)"
                                                         alt="@item.Title"
                                                         class="Reader-mini-cover" />
                                                }
                                                else
                                                {
                                                    <div class="Reader-mini-cover Reader-cover-placeholder">
                                                        Няма
                                                    </div>
                                                }
                                            </a>
                                        </td>

                                        <td>
                                            <a asp-controller="Catalog"
                                               asp-action="ReaderDetails"
                                               asp-route-id="@item.BookId"
                                               class="Reader-book-title-link">
                                                @item.Title
                                            </a>
                                        </td>

                                        <td>
                                            <div class="Reader-date-cell">@item.Author</div>
                                        </td>

                                        <td>
                                            <div class="Reader-date-cell">@item.LoanDate.ToString("dd.MM.yyyy")</div>
                                        </td>

                                        <td>
                                            <div class="Reader-return-status @(item.IsOverdue ? "overdue" : "normal")">
                                                @item.DueDate.ToString("dd.MM.yyyy")
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <div class="Reader-empty-state">
                        В момента нямаш заети книги.
                    </div>
                }
            </div>
        </section>

        <section id="favorites" class="Reader-portal-section">
            <div class="Reader-section-header">
                <h2 class="Reader-section-title">Списък за четене</h2>
                <p class="Reader-section-subtitle">
                    Книгите, които си запазила за следващо разглеждане.
                </p>
            </div>

            <div class="Reader-panel Reader-panel-scroll Reader-panel-md">
                @if (Model.FavoriteBooks != null && Model.FavoriteBooks.Any())
                {
                    <div class="Reader-favorites-grid">
                        @foreach (var item in Model.FavoriteBooks)
                        {
                            <div class="Reader-favorite-card">
                                <a asp-controller="Catalog"
                                   asp-action="ReaderDetails"
                                   asp-route-id="@item.BookId"
                                   class="Reader-favorite-cover-link">
                                    @if (!string.IsNullOrWhiteSpace(item.CoverPath))
                                    {
                                        <img src="@ResolveCoverUrl(item.CoverPath)"
                                             alt="@item.Title"
                                             class="Reader-favorite-cover" />
                                    }
                                    else
                                    {
                                        <div class="Reader-favorite-cover Reader-cover-placeholder">
                                            Няма
                                        </div>
                                    }
                                </a>

                                <div class="Reader-favorite-body">
                                    <a asp-controller="Catalog"
                                       asp-action="ReaderDetails"
                                       asp-route-id="@item.BookId"
                                       class="Reader-favorite-title">
                                        @item.Title
                                    </a>

                                    <div class="Reader-favorite-author">@item.Author</div>

                                    <div class="Reader-favorite-meta">
                                        <span class="Reader-favorite-category">@item.CategoryName</span>
                                        <span class="Reader-favorite-availability @(item.IsAvailable ? "available" : "unavailable")">
                                            @(item.IsAvailable ? "Налична" : "Неналична")
                                        </span>
                                    </div>

                                    <form asp-action="ToggleFavorite"
                                          asp-controller="ReaderPortal"
                                          method="post"
                                          class="Reader-favorite-form">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="bookId" value="@item.BookId" />
                                        <input type="hidden" name="returnUrl" value="@Url.Action("Index", "ReaderPortal")#favorites" />
                                        <button type="submit" class="Reader-favorite-remove-btn">
                                            Премахни
                                        </button>
                                    </form>
                                </div>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div class="Reader-empty-state">
                        Все още нямаш книги в списъка за четене.
                    </div>
                }
            </div>
        </section>

        <section id="notifications" class="Reader-portal-section">
            <div class="Reader-section-header Reader-section-header-row">
                <div>
                    <h2 class="Reader-section-title">Известия</h2>
                    <p class="Reader-section-subtitle">
                        Всички твои автоматични съобщения на едно място.
                    </p>
                </div>

                @if (Model.LatestNotifications != null && Model.LatestNotifications.Any(n => !n.IsRead))
                {
                    <button type="button" id="markAllReaderNotificationsBtn" class="Reader-inline-btn">
                        Маркирай всички като прочетени
                    </button>
                }
            </div>

            <div class="Reader-panel Reader-panel-scroll Reader-panel-sm">
                @if (Model.LatestNotifications != null && Model.LatestNotifications.Any())
                {
                    <div class="Reader-notification-list compact">
                        @foreach (var item in Model.LatestNotifications)
                        {
                            <div class="Reader-notification-row @(item.IsRead ? "read" : "unread")">
                                <div class="Reader-notification-row-main">
                                    <div class="Reader-notification-row-top">
                                        <div class="Reader-notification-row-title">@item.Title</div>
                                        <div class="Reader-notification-row-date">@item.CreatedOn.ToString("dd.MM.yyyy")</div>
                                    </div>

                                    <div class="Reader-notification-row-message">
                                        @item.Message
                                    </div>
                                </div>

                                <div class="Reader-notification-row-actions">
                                    @if (item.BookId.HasValue)
                                    {
                                        <a asp-controller="Catalog"
                                           asp-action="ReaderDetails"
                                           asp-route-id="@item.BookId.Value"
                                           class="Reader-notification-mini-link">
                                            Към книгата
                                        </a>
                                    }

                                    @if (!item.IsRead)
                                    {
                                        <form asp-action="MarkNotificationAsRead"
                                              asp-controller="ReaderPortal"
                                              method="post"
                                              class="Reader-notification-form">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@item.NotificationId" />
                                            <input type="hidden" name="returnUrl" value="@Url.Action("Index", "ReaderPortal")#notifications" />
                                            <button type="submit" class="Reader-notification-mini-btn">
                                                Прочетено
                                            </button>
                                        </form>
                                    }
                                </div>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div class="Reader-empty-state">
                        Все още нямаш известия.
                    </div>
                }
            </div>
        </section>

        <section id="history" class="Reader-portal-section">
            <div class="Reader-section-header">
                <h2 class="Reader-section-title">История на заеманията</h2>
                <p class="Reader-section-subtitle">
                    Всички книги, които си заемала досега.
                </p>
            </div>

            <div class="Reader-panel Reader-panel-scroll Reader-panel-lg">
                @if (Model.LoanHistory != null && Model.LoanHistory.Any())
                {
                    <div class="Reader-table-wrap">
                        <table class="Reader-history-table">
                            <thead>
                                <tr>
                                    <th style="width:88px;">Корица</th>
                                    <th>Заглавие</th>
                                    <th style="width:180px;">Автор</th>
                                    <th style="width:150px;">Заемане</th>
                                    <th style="width:150px;">Срок</th>
                                    <th style="width:150px;">Върната на</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model.LoanHistory)
                                {
                                    <tr>
                                        <td>
                                            <a asp-controller="Catalog"
                                               asp-action="ReaderDetails"
                                               asp-route-id="@item.BookId"
                                               class="Reader-cover-link">
                                                @if (!string.IsNullOrWhiteSpace(item.CoverPath))
                                                {
                                                    <img src="@ResolveCoverUrl(item.CoverPath)"
                                                         alt="@item.Title"
                                                         class="Reader-mini-cover" />
                                                }
                                                else
                                                {
                                                    <div class="Reader-mini-cover Reader-cover-placeholder">
                                                        Няма
                                                    </div>
                                                }
                                            </a>
                                        </td>

                                        <td>
                                            <a asp-controller="Catalog"
                                               asp-action="ReaderDetails"
                                               asp-route-id="@item.BookId"
                                               class="Reader-book-title-link">
                                                @item.Title
                                            </a>
                                        </td>

                                        <td>
                                            <div class="Reader-date-cell">@item.Author</div>
                                        </td>

                                        <td>
                                            <div class="Reader-date-cell">@item.LoanDate.ToString("dd.MM.yyyy")</div>
                                        </td>

                                        <td>
                                            <div class="Reader-date-cell">@item.DueDate.ToString("dd.MM.yyyy")</div>
                                        </td>

                                        <td>
                                            <div class="Reader-date-cell">
                                                @(item.ReturnDate.HasValue? item.ReturnDate.Value.ToString("dd.MM.yyyy") : "Все още е заета")
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <div class="Reader-empty-state">
                        Все още нямаш история на заеманията.
                    </div>
                }
            </div>
        </section>

        <section id="notes" class="Reader-portal-section">
            <div class="Reader-section-header">
                <h2 class="Reader-section-title">Бележки</h2>
                <p class="Reader-section-subtitle">
                    Кратък преглед на личните ти бележки към книги.
                </p>
            </div>

            <div class="Reader-panel Reader-panel-scroll Reader-panel-md Reader-notes-panel">
                @if (Model.BookNotes != null && Model.BookNotes.Any())
                {
                    <div class="Reader-notes-grid">
                        @foreach (var note in Model.BookNotes)
                        {
                            var previewText = note.Text?.Length > 70
                            ? note.Text.Substring(0, 70) + "..."
                            : note.Text;

                            <div class="Reader-note-tile"
                                 data-note-id="@note.NoteId"
                                 data-book-id="@note.BookId"
                                 data-note-text="@note.Text"
                                 onclick="openReaderPortalNoteModal(this)">
                                <div class="Reader-note-book">@note.BookTitle</div>

                                <div class="Reader-note-preview">
                                    @previewText
                                </div>

                                <div class="Reader-note-date">
                                    @(note.UpdatedOn?.ToString("dd.MM.yyyy") ?? note.CreatedOn.ToString("dd.MM.yyyy"))
                                </div>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div class="Reader-empty-state">
                        Все още нямаш създадени бележки към книги.
                    </div>
                }
            </div>
        </section>

        <section id="profile" class="Reader-portal-section">
            <div class="Reader-section-header">
                <h2 class="Reader-section-title">Лични данни</h2>
                <p class="Reader-section-subtitle">
                    Основна информация за твоя читателски профил.
                </p>
            </div>

            <div class="Reader-profile-clean">
                <div class="Reader-profile-clean-row">
                    <div class="Reader-profile-clean-label">Име</div>
                    <div class="Reader-profile-clean-value">@Model.FirstName</div>
                </div>

                <div class="Reader-profile-clean-row">
                    <div class="Reader-profile-clean-label">Презиме</div>
                    <div class="Reader-profile-clean-value">
                        @(string.IsNullOrWhiteSpace(Model.MiddleName) ? "Няма информация" : Model.MiddleName)
                    </div>
                </div>

                <div class="Reader-profile-clean-row">
                    <div class="Reader-profile-clean-label">Фамилия</div>
                    <div class="Reader-profile-clean-value">@Model.LastName</div>
                </div>

                <div class="Reader-profile-clean-row">
                    <div class="Reader-profile-clean-label">Телефонен номер</div>
                    <div class="Reader-profile-clean-value">@Model.PhoneNumber</div>
                </div>

                <div class="Reader-profile-clean-row">
                    <div class="Reader-profile-clean-label">Номер на карта</div>
                    <div class="Reader-profile-clean-value">
                        @(string.IsNullOrWhiteSpace(Model.CardNumber) ? "Няма информация" : Model.CardNumber)
                    </div>
                </div>

                <div class="Reader-profile-clean-row">
                    <div class="Reader-profile-clean-label">Клас</div>
                    <div class="Reader-profile-clean-value">@fullClass</div>
                </div>

                <div class="Reader-profile-clean-row">
                    <div class="Reader-profile-clean-label">Статус</div>
                    <div class="Reader-profile-clean-value">
                        @(Model.IsActive ? "Активен профил" : "Неактивен профил")
                    </div>
                </div>

                <div class="Reader-profile-clean-row">
                    <div class="Reader-profile-clean-label">Създаден на</div>
                    <div class="Reader-profile-clean-value">@Model.CreatedOn.ToString("dd.MM.yyyy")</div>
                </div>
            </div>
        </section>

    </main>
</div>

<div id="readerPortalNoteModal"
     class="Reader-note-modal-overlay"
     style="display:none;">
    <div class="Reader-note-modal">
        <div class="Reader-note-modal-header">
            <div>
                <div id="readerPortalNoteBookTitle" class="Reader-note-modal-title">Бележка</div>
                <div class="Reader-note-modal-subtitle">Лична бележка към книга</div>
            </div>

            <button type="button"
                    onclick="closeReaderPortalNoteModal()"
                    class="Reader-note-close-btn">
                ×
            </button>
        </div>

        <input type="hidden" id="readerPortalCurrentNoteId" />

        <div id="readerPortalNotePaper"
             contenteditable="true"
             spellcheck="true"
             class="Reader-note-modal-paper"></div>

        <div class="Reader-note-modal-actions">
            <button type="button"
                    id="readerPortalDeleteBtn"
                    onclick="deleteReaderPortalNote()"
                    class="Reader-note-delete-btn"
                    style="display:none;">
                Изтрий
            </button>

            <button type="button"
                    onclick="closeReaderPortalNoteModal()"
                    class="Reader-note-cancel-btn">
                Затвори
            </button>

            <button type="button"
                    onclick="saveReaderPortalNote()"
                    class="Reader-note-save-btn">
                Запази
            </button>
        </div>
    </div>
</div>

@if (ViewBag.RequirePasswordChange == true)
{
    <div id="passwordOverlay"
         style="position:fixed; inset:0; background:rgba(15,23,42,.34); backdrop-filter:blur(5px); z-index:9999; display:flex; align-items:center; justify-content:center; padding:18px;">

        <div style="width:460px; max-width:100%; background:#ffffff; border:1px solid #dbe5ef; border-radius:24px; padding:30px 28px 26px 28px; box-shadow:0 24px 70px rgba(15,23,42,.16);">
            <div style="text-align:center; margin-bottom:20px;">
                <div style="font-size:1.65rem; font-weight:900; color:#0f172a; line-height:1.15; margin-bottom:8px;">
                    Смени паролата си
                </div>

                <div style="display:inline-flex; align-items:center; justify-content:center; min-height:30px; padding:0 12px; border-radius:999px; background:#eff6ff; color:#2563eb; font-size:.82rem; font-weight:800; margin-bottom:12px;">
                    Първи вход в профила
                </div>

                <div style="color:#64748b; font-size:.98rem; line-height:1.65; max-width:340px; margin:0 auto;">
                    За да продължиш към профила си, първо трябва да зададеш нова лична парола.
                </div>
            </div>

            @if (TempData["PasswordChangeError"] != null)
            {
                <div style="margin-bottom:14px; padding:11px 13px; border-radius:12px; border:1px solid #fecaca; background:#fef2f2; color:#b91c1c; font-size:.92rem; font-weight:700;">
                    @TempData["PasswordChangeError"]
                </div>
            }

            <form asp-controller="ReaderAccount"
                  asp-action="ChangePassword"
                  method="post"
                  style="margin:0;">
                @Html.AntiForgeryToken()

                <div style="display:grid; gap:14px;">
                    <div>
                        <label style="display:block; margin-bottom:7px; color:#0f172a; font-size:.95rem; font-weight:800;">
                            Текуща парола
                        </label>
                        <input type="password"
                               name="CurrentPassword"
                               class="Reader-password-input"
                               style="width:100%; height:50px; border-radius:14px; border:1px solid #cbd5e1; background:#ffffff; box-shadow:none; font-size:.98rem; padding:0 14px; outline:none; transition:border-color .18s ease, box-shadow .18s ease, transform .18s ease;" />
                    </div>

                    <div>
                        <label style="display:block; margin-bottom:7px; color:#0f172a; font-size:.95rem; font-weight:800;">
                            Нова парола
                        </label>
                        <input type="password"
                               name="NewPassword"
                               class="Reader-password-input"
                               style="width:100%; height:50px; border-radius:14px; border:1px solid #cbd5e1; background:#ffffff; box-shadow:none; font-size:.98rem; padding:0 14px; outline:none; transition:border-color .18s ease, box-shadow .18s ease, transform .18s ease;" />
                    </div>

                    <div>
                        <label style="display:block; margin-bottom:7px; color:#0f172a; font-size:.95rem; font-weight:800;">
                            Потвърди новата парола
                        </label>
                        <input type="password"
                               name="ConfirmPassword"
                               class="Reader-password-input"
                               style="width:100%; height:50px; border-radius:14px; border:1px solid #cbd5e1; background:#ffffff; box-shadow:none; font-size:.98rem; padding:0 14px; outline:none; transition:border-color .18s ease, box-shadow .18s ease, transform .18s ease;" />
                    </div>
                </div>

                <div style="margin-top:18px;">
                    <button type="submit"
                            id="saveReaderPasswordBtn"
                            style="width:100%; height:50px; border:none; border-radius:14px; background:linear-gradient(135deg, #2563eb 0%, #3b82f6 100%); color:#ffffff; font-size:1rem; font-weight:800; box-shadow:0 14px 28px rgba(37,99,235,.18); transition:transform .18s ease, box-shadow .18s ease, filter .18s ease;">
                        Запази новата парола
                    </button>
                </div>
            </form>
        </div>
    </div>
}

<script>
    function openReaderPortalNoteModal(card) {
        const modal = document.getElementById("readerPortalNoteModal");
        const title = document.getElementById("readerPortalNoteBookTitle");
        const noteId = document.getElementById("readerPortalCurrentNoteId");
        const paper = document.getElementById("readerPortalNotePaper");
        const deleteBtn = document.getElementById("readerPortalDeleteBtn");

        const bookTitle = card.querySelector(".Reader-note-book")
            ? card.querySelector(".Reader-note-book").textContent.trim()
            : "Бележка";

        title.textContent = bookTitle;
        noteId.value = card.getAttribute("data-note-id") || "";
        paper.innerText = card.getAttribute("data-note-text") || "";

        deleteBtn.style.display = noteId.value ? "inline-flex" : "none";
        modal.style.display = "flex";
    }

    function closeReaderPortalNoteModal() {
        document.getElementById("readerPortalNoteModal").style.display = "none";
    }

    async function saveReaderPortalNote() {
        const noteId = document.getElementById("readerPortalCurrentNoteId").value;
        const paper = document.getElementById("readerPortalNotePaper");
        const text = (paper.innerText || "").trim();

        if (!text) {
            alert("Бележката не може да бъде празна.");
            return;
        }

        const tokenInput = document.querySelector('input[name="__RequestVerificationToken"]');
        const token = tokenInput ? tokenInput.value : "";

        const formData = new URLSearchParams();
        formData.append("noteId", noteId);
        formData.append("text", text);
        formData.append("__RequestVerificationToken", token);

        const response = await fetch('@Url.Action("UpdateNote", "ReaderPortal")', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/x-www-form-urlencoded; charset=UTF-8'
            },
            body: formData.toString()
        });

        if (response.ok) {
            location.reload();
            return;
        }

        alert("Възникна проблем при запазването на бележката.");
    }

    async function deleteReaderPortalNote() {
        const noteId = document.getElementById("readerPortalCurrentNoteId").value;

        if (!noteId) {
            return;
        }

        if (!confirm("Сигурна ли си, че искаш да изтриеш тази бележка?")) {
            return;
        }

        const tokenInput = document.querySelector('input[name="__RequestVerificationToken"]');
        const token = tokenInput ? tokenInput.value : "";

        const formData = new URLSearchParams();
        formData.append("noteId", noteId);
        formData.append("__RequestVerificationToken", token);

        const response = await fetch('@Url.Action("DeleteNote", "ReaderPortal")', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/x-www-form-urlencoded; charset=UTF-8'
            },
            body: formData.toString()
        });

        if (response.ok) {
            location.reload();
            return;
        }

        alert("Възникна проблем при изтриването на бележката.");
    }

    async function markAllReaderNotificationsAsRead() {
        const tokenInput = document.querySelector('input[name="__RequestVerificationToken"]');
        const token = tokenInput ? tokenInput.value : "";

        const formData = new URLSearchParams();
        formData.append("__RequestVerificationToken", token);

        const response = await fetch('@Url.Action("MarkAllNotificationsAsRead", "ReaderPortal")', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/x-www-form-urlencoded; charset=UTF-8'
            },
            body: formData.toString()
        });

        if (response.ok) {
            location.reload();
            return;
        }

        alert("Възникна проблем при маркирането на известията.");
    }

    document.addEventListener("keydown", function (e) {
        if (e.key === "Escape") {
            closeReaderPortalNoteModal();
        }
    });

    document.getElementById("readerPortalNoteModal")?.addEventListener("click", function (e) {
        if (e.target === this) {
            closeReaderPortalNoteModal();
        }
    });

    document.getElementById("markAllReaderNotificationsBtn")?.addEventListener("click", markAllReaderNotificationsAsRead);

    (function () {
        const links = Array.from(document.querySelectorAll('#ReaderScrollspy .Reader-nav-link'));
        const sections = Array.from(document.querySelectorAll('.Reader-portal-section'));

        function setActive(hash) {
            links.forEach(link => {
                link.classList.toggle('active', link.getAttribute('href') === hash);
            });
        }

        links.forEach(link => {
            link.addEventListener('click', function () {
                setActive(link.getAttribute('href'));
            });
        });

        function handleLastSection() {
            const scrollBottom = window.innerHeight + window.scrollY;
            const documentHeight = document.documentElement.scrollHeight;

            if (documentHeight - scrollBottom < 120) {
                setActive('#profile');
            }
        }

        const observer = new IntersectionObserver((entries) => {
            const visible = entries
                .filter(entry => entry.isIntersecting)
                .sort((a, b) => Math.abs(a.boundingClientRect.top) - Math.abs(b.boundingClientRect.top));

            if (visible.length > 0) {
                setActive('#' + visible[0].target.id);
            }

            handleLastSection();
        }, {
            rootMargin: '-20% 0px -55% 0px',
            threshold: [0.12, 0.25, 0.4, 0.6]
        });

        sections.forEach(section => observer.observe(section));
        window.addEventListener('scroll', handleLastSection);

        document.querySelectorAll('.Reader-password-input').forEach(input => {
            input.addEventListener('mouseenter', function () {
                if (document.activeElement !== input) {
                    input.style.borderColor = '#93c5fd';
                    input.style.boxShadow = '0 10px 24px rgba(37,99,235,.08)';
                    input.style.transform = 'translateY(-1px)';
                }
            });

            input.addEventListener('mouseleave', function () {
                if (document.activeElement !== input) {
                    input.style.borderColor = '#cbd5e1';
                    input.style.boxShadow = 'none';
                    input.style.transform = 'translateY(0)';
                }
            });

            input.addEventListener('focus', function () {
                input.style.borderColor = '#3b82f6';
                input.style.boxShadow = '0 0 0 4px rgba(59,130,246,.12), 0 10px 24px rgba(37,99,235,.08)';
                input.style.transform = 'translateY(-1px)';
            });

            input.addEventListener('blur', function () {
                input.style.borderColor = '#cbd5e1';
                input.style.boxShadow = 'none';
                input.style.transform = 'translateY(0)';
            });
        });

        const saveReaderPasswordBtn = document.getElementById('saveReaderPasswordBtn');
        if (saveReaderPasswordBtn) {
            saveReaderPasswordBtn.addEventListener('mouseenter', function () {
                saveReaderPasswordBtn.style.transform = 'translateY(-2px)';
                saveReaderPasswordBtn.style.boxShadow = '0 18px 34px rgba(37,99,235,.24)';
                saveReaderPasswordBtn.style.filter = 'brightness(1.03)';
            });

            saveReaderPasswordBtn.addEventListener('mouseleave', function () {
                saveReaderPasswordBtn.style.transform = 'translateY(0)';
                saveReaderPasswordBtn.style.boxShadow = '0 14px 28px rgba(37,99,235,.18)';
                saveReaderPasswordBtn.style.filter = 'none';
            });
        }
    })();
</script>