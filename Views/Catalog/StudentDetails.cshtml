@model ObreshkovLibrary.Models.Book
@using ObreshkovLibrary.Models
@using System.Linq

@{
    Layout = "~/Views/Shared/_StudentLayout.cshtml";
    ViewData["Title"] = "Детайли за книга";

    var isAvailable = (ViewBag.IsAvailable as bool?) ?? false;
    var relatedBooks = (ViewBag.RelatedBooks as List<Book>) ?? new List<Book>();
    var similarBooks = (ViewBag.SimilarBooks as List<Book>) ?? new List<Book>();
    var isInReadingList = (ViewBag.IsFavorite as bool?) ?? false;
    var currentReturnUrl = $"{Context.Request.Path}{Context.Request.QueryString}";

    var coverPathProp = Model.GetType().GetProperty("CoverPath");
    var coverUrlProp = Model.GetType().GetProperty("CoverUrl");
    var coverValue = coverPathProp?.GetValue(Model)?.ToString() ?? coverUrlProp?.GetValue(Model)?.ToString();

    string ResolveCoverUrl(string? path)
    {
        if (string.IsNullOrWhiteSpace(path))
            return "";

        return path.StartsWith("/")
            ? Url.Content("~" + path)
            : Url.Content("~/" + path.TrimStart('/'));
    }

    string coverUrl = ResolveCoverUrl(coverValue);

    string? subCategoryName = Model.Category?.Name;
    string? parentCategoryName = Model.Category?.ParentCategory?.Name;

    string genreText = "Няма";

    if (!string.IsNullOrWhiteSpace(parentCategoryName) && !string.IsNullOrWhiteSpace(subCategoryName))
    {
        genreText = $"{parentCategoryName} / {subCategoryName}";
    }
    else if (!string.IsNullOrWhiteSpace(subCategoryName))
    {
        genreText = subCategoryName!;
    }

    List<string> tagNames = new();

    if ((Model.Tags & BookTags.BulgarianLiterature) == BookTags.BulgarianLiterature) tagNames.Add("Българска литература");
    if ((Model.Tags & BookTags.WorldLiterature) == BookTags.WorldLiterature) tagNames.Add("Световна литература");
    if ((Model.Tags & BookTags.BalkanLiterature) == BookTags.BalkanLiterature) tagNames.Add("Балканска литература");
    if ((Model.Tags & BookTags.AncientLiterature) == BookTags.AncientLiterature) tagNames.Add("Антична литература");
    if ((Model.Tags & BookTags.ClassicLiterature) == BookTags.ClassicLiterature) tagNames.Add("Класика");
    if ((Model.Tags & BookTags.ContemporaryLiterature) == BookTags.ContemporaryLiterature) tagNames.Add("Съвременна литература");

    if ((Model.Tags & BookTags.Love) == BookTags.Love) tagNames.Add("Любов");
    if ((Model.Tags & BookTags.Rebellion) == BookTags.Rebellion) tagNames.Add("Бунт");
    if ((Model.Tags & BookTags.Suffering) == BookTags.Suffering) tagNames.Add("Страдание");
    if ((Model.Tags & BookTags.Romantic) == BookTags.Romantic) tagNames.Add("Романтика");

    if ((Model.Tags & BookTags.Horror) == BookTags.Horror) tagNames.Add("Хорър");
    if ((Model.Tags & BookTags.Historical) == BookTags.Historical) tagNames.Add("Исторически");
    if ((Model.Tags & BookTags.ScienceFiction) == BookTags.ScienceFiction) tagNames.Add("Фантастика");
    if ((Model.Tags & BookTags.Fantasy) == BookTags.Fantasy) tagNames.Add("Фентъзи");
    if ((Model.Tags & BookTags.Psychological) == BookTags.Psychological) tagNames.Add("Психологически");
    if ((Model.Tags & BookTags.Social) == BookTags.Social) tagNames.Add("Социален");

    if ((Model.Tags & BookTags.RequiredReading) == BookTags.RequiredReading) tagNames.Add("Задължителна литература");
    if ((Model.Tags & BookTags.RecommendedReading) == BookTags.RecommendedReading) tagNames.Add("Препоръчителна литература");
    if ((Model.Tags & BookTags.ForMatura) == BookTags.ForMatura) tagNames.Add("За матура");

    if ((Model.Tags & BookTags.BulgarianAuthor) == BookTags.BulgarianAuthor) tagNames.Add("Български автор");
    if ((Model.Tags & BookTags.ForeignAuthor) == BookTags.ForeignAuthor) tagNames.Add("Чужд автор");

    if ((Model.Tags & BookTags.EducationalContent) == BookTags.EducationalContent) tagNames.Add("Учебно съдържание");
    if ((Model.Tags & BookTags.ClassicalWork) == BookTags.ClassicalWork) tagNames.Add("Класическо произведение");

    if ((Model.Tags & BookTags.Poetry) == BookTags.Poetry) tagNames.Add("Поезия");
    if ((Model.Tags & BookTags.Prose) == BookTags.Prose) tagNames.Add("Проза");
    if ((Model.Tags & BookTags.Dramaturgy) == BookTags.Dramaturgy) tagNames.Add("Драматургия");

    if ((Model.Tags & BookTags.Mathematics) == BookTags.Mathematics) tagNames.Add("Математика");
    if ((Model.Tags & BookTags.BulgarianLanguage) == BookTags.BulgarianLanguage) tagNames.Add("Български език");
    if ((Model.Tags & BookTags.History) == BookTags.History) tagNames.Add("История");
    if ((Model.Tags & BookTags.Geography) == BookTags.Geography) tagNames.Add("География");
    if ((Model.Tags & BookTags.Biology) == BookTags.Biology) tagNames.Add("Биология");
    if ((Model.Tags & BookTags.Chemistry) == BookTags.Chemistry) tagNames.Add("Химия");
    if ((Model.Tags & BookTags.Physics) == BookTags.Physics) tagNames.Add("Физика");
    if ((Model.Tags & BookTags.Philosophy) == BookTags.Philosophy) tagNames.Add("Философия");
    if ((Model.Tags & BookTags.IT) == BookTags.IT) tagNames.Add("Информационни технологии/Информатика");
}

<div class="book-details-page">

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger mb-4">@TempData["Error"]</div>
    }

    <div class="book-details-header">
        <div>
            <h2 class="section-title mb-1">@Model.Title</h2>
            <div class="accent-line"></div>
        </div>

        <div class="book-details-actions">
            <form asp-controller="StudentPortal"
                  asp-action="ToggleFavorite"
                  method="post"
                  style="display:inline;">
                @Html.AntiForgeryToken()
                <input type="hidden" name="bookId" value="@Model.Id" />
                <input type="hidden" name="returnUrl" value="@currentReturnUrl" />

                <button type="submit"
                        title="@(isInReadingList ? "Премахни от списъка за четене" : "Добави в списъка за четене")"
                        aria-label="@(isInReadingList ? "Премахни от списъка за четене" : "Добави в списъка за четене")"
                        class="btn btn-outline-primary"
                        style="width:44px; height:44px; padding:0; display:inline-flex; align-items:center; justify-content:center;">
                    @if (isInReadingList)
                    {
                        <svg xmlns="http://www.w3.org/2000/svg"
                             width="18"
                             height="18"
                             viewBox="0 0 16 16"
                             fill="currentColor"
                             style="display:block;">
                            <path d="M2 2a2 2 0 0 1 2-2h7a1 1 0 0 1 1 1v13l-4-2-4 2V2z" />
                        </svg>
                    }
                    else
                    {
                        <svg xmlns="http://www.w3.org/2000/svg"
                             width="18"
                             height="18"
                             viewBox="0 0 16 16"
                             fill="currentColor"
                             style="display:block;">
                            <path d="M2 1.5A1.5 1.5 0 0 1 3.5 0h7A1.5 1.5 0 0 1 12 1.5V14l-5-2.5L2 14V1.5zM3.5 1a.5.5 0 0 0-.5.5v10.691l4-2 4 2V1.5a.5.5 0 0 0-.5-.5h-7z" />
                        </svg>
                    }
                </button>
            </form>

            <a asp-controller="Catalog"
               asp-action="StudentIndex"
               class="btn btn-outline-primary">
                Назад
            </a>
        </div>
    </div>

    <section class="details-panel card-soft book-main-panel">
        <div class="book-top-layout"
             style="display:grid; grid-template-columns:240px minmax(0, 1fr); gap:28px; align-items:start;">

            <div class="book-cover-column"
                 style="width:240px; min-width:240px; max-width:240px; display:flex; flex-direction:column; align-self:start;">
                <div class="book-cover-box @(string.IsNullOrWhiteSpace(coverValue) ? "no-cover" : "")"
                     style="width:240px; min-height:340px; padding:14px; display:flex; align-items:center; justify-content:center; overflow:hidden;">
                    @if (!string.IsNullOrWhiteSpace(coverUrl))
                    {
                        <img src="@coverUrl"
                             alt="@Model.Title"
                             style="display:block; width:100%; max-width:100%; height:310px; object-fit:contain;"
                             onerror="this.style.display='none'; this.parentElement.classList.add('no-cover');" />
                    }
                </div>
            </div>

            <div class="book-info-column">
                <div class="book-info-grid">

                    <div class="book-info-row">
                        <div class="book-info-label">Заглавие</div>
                        <div class="book-info-value">
                            @(string.IsNullOrWhiteSpace(Model.Title) ? "Няма" : Model.Title)
                        </div>
                    </div>

                    <div class="book-info-row">
                        <div class="book-info-label">Автор</div>
                        <div class="book-info-value">
                            @(string.IsNullOrWhiteSpace(Model.Author) ? "Няма" : Model.Author)
                        </div>
                    </div>

                    <div class="book-info-row">
                        <div class="book-info-label">Жанр</div>
                        <div class="book-info-value">@genreText</div>
                    </div>

                    <div class="book-info-row">
                        <div class="book-info-label">Година</div>
                        <div class="book-info-value">
                            @(Model.Year.HasValue? Model.Year.ToString() : "Няма")
                        </div>
                    </div>

                    <div class="book-info-row">
                        <div class="book-info-label">Класове</div>
                        <div class="book-info-value">
                            @(string.IsNullOrWhiteSpace(Model.SchoolClass) ? "Не е посочен" : Model.SchoolClass)
                        </div>
                    </div>

                    <div class="book-info-row">
                        <div class="book-info-label">Статус</div>
                        <div class="book-info-value">
                            @if (isAvailable)
                            {
                                <span class="status-badge status-active">Налична</span>
                            }
                            else
                            {
                                <span class="status-badge status-loaned">Заета</span>
                            }
                        </div>
                    </div>

                </div>
            </div>

        </div>
    </section>

    <section class="details-panel card-soft" style="margin-top:22px;">

        <div class="details-panel-head">
            <h5 class="section-title mb-0">Ключови думи и етикети</h5>
        </div>

        <div style="display:grid; grid-template-columns:220px minmax(0,1fr); border-top:1px solid #E2E8F0;">

            <div style="padding:16px 18px; font-weight:700; color:#64748B; border-right:1px solid #E2E8F0;">
                Ключови думи
            </div>

            <div style="padding:16px 18px; color:#0F172A; line-height:1.75;">
                @(string.IsNullOrWhiteSpace(Model.SearchKeywords) ? "Не са добавени" : Model.SearchKeywords)
            </div>

        </div>

        <div style="display:grid; grid-template-columns:220px minmax(0,1fr); border-top:1px solid #E2E8F0;">

            <div style="padding:16px 18px; font-weight:700; color:#64748B; border-right:1px solid #E2E8F0;">
                Етикети
            </div>

            <div style="padding:16px 18px;">
                @if (tagNames.Any())
                {
                    <div style="display:flex; flex-wrap:wrap; gap:8px;">
                        @foreach (var tag in tagNames)
                        {
                            <span class="tag-chip">@tag</span>
                        }
                    </div>
                }
                else
                {
                    <span style="color:#0F172A;">Няма</span>
                }
            </div>

        </div>

    </section>

    <section class="details-panel card-soft book-description-panel" style="margin-top:22px;">
        <div class="details-panel-head">
            <h5 class="section-title mb-0">Описание</h5>
        </div>

        <div class="book-description-wrap">
            @if (!string.IsNullOrWhiteSpace(Model.Description))
            {
                <div class="book-description">@Model.Description</div>
            }
            else
            {
                <div class="details-empty-state">Няма описание за тази книга.</div>
            }
        </div>
    </section>

    @if (relatedBooks.Any())
    {
        <section class="details-panel card-soft" style="margin-top:22px;">
            <div class="details-panel-head">
                <h5 class="section-title mb-0">Още книги от същия автор</h5>
            </div>

            <div style="padding:20px; display:grid; grid-template-columns:repeat(5, minmax(0,1fr)); gap:18px;">
                @foreach (var book in relatedBooks)
                {
                    var relatedCover = ResolveCoverUrl(book.CoverPath);

                    <a asp-controller="Catalog"
                       asp-action="StudentDetails"
                       asp-route-id="@book.Id"
                       style="display:flex; flex-direction:column; text-decoration:none; border:1px solid #e6edf5; border-radius:16px; background:#ffffff; padding:12px;"
                       onmouseover="this.style.transform='translateY(-4px)';"
                       onmouseout="this.style.transform='translateY(0)'">
                        <div style="height:210px; border-radius:12px; background:#f4f7fb; display:flex; align-items:center; justify-content:center; overflow:hidden;">
                            @if (!string.IsNullOrWhiteSpace(relatedCover))
                            {
                                <img src="@relatedCover" alt="@book.Title" style="max-width:100%; max-height:100%; object-fit:contain;" />
                            }
                            else
                            {
                                <div style="width:100%; height:100%; border:2px dashed #cad5e0; border-radius:12px; display:flex; align-items:center; justify-content:center; color:#94a3b8; font-size:.9rem; font-weight:800;">
                                    Няма корица
                                </div>
                            }
                        </div>
                        <div style="margin-top:10px; color:#0f172a; font-size:.95rem; font-weight:900; line-height:1.35;">
                            @book.Title
                        </div>
                    </a>
                }
            </div>
        </section>
    }

    @if (similarBooks.Any())
    {
        <section class="details-panel card-soft" style="margin-top:22px;">
            <div class="details-panel-head">
                <h5 class="section-title mb-0">Подобни книги</h5>
            </div>

            <div style="padding:20px; display:grid; grid-template-columns:repeat(5, minmax(0,1fr)); gap:18px;">
                @foreach (var book in similarBooks)
                {
                    var similarCover = ResolveCoverUrl(book.CoverPath);

                    <a asp-controller="Catalog"
                       asp-action="StudentDetails"
                       asp-route-id="@book.Id"
                       style="display:flex; flex-direction:column; text-decoration:none; border:1px solid #e6edf5; border-radius:16px; background:#ffffff; padding:12px;"
                       onmouseover="this.style.transform='translateY(-4px)';"
                       onmouseout="this.style.transform='translateY(0)'">
                        <div style="height:210px; border-radius:12px; background:#f4f7fb; display:flex; align-items:center; justify-content:center; overflow:hidden;">
                            @if (!string.IsNullOrWhiteSpace(similarCover))
                            {
                                <img src="@similarCover" alt="@book.Title" style="max-width:100%; max-height:100%; object-fit:contain;" />
                            }
                            else
                            {
                                <div style="width:100%; height:100%; border:2px dashed #cad5e0; border-radius:12px; display:flex; align-items:center; justify-content:center; color:#94a3b8; font-size:.9rem; font-weight:800;">
                                    Няма корица
                                </div>
                            }
                        </div>
                        <div style="margin-top:10px; color:#0f172a; font-size:.95rem; font-weight:900; line-height:1.35;">
                            @book.Title
                        </div>
                    </a>
                }
            </div>
        </section>
    }

</div>