@model ObreshkovLibrary.Models.ViewModels.BookCreateVM

@{
    ViewData["Title"] = "Редактиране на книга";
}

<div class="book-edit-page">
    <div class="book-edit-header">
        <div>
            <h2 class="section-title mb-1">Редактиране на книга</h2>
            <div class="accent-line"></div>
        </div>
    </div>

    <section class="book-edit-panel card-soft">
        <form id="bookEditForm"
              asp-action="Edit"
              asp-route-id="@ViewBag.BookId"
              method="post"
              enctype="multipart/form-data"
              class="book-edit-form">
            @Html.AntiForgeryToken()

            <div asp-validation-summary="ModelOnly" class="text-danger validation-summary"></div>

            <input type="hidden" name="Id" value="@ViewBag.BookId" />
            <input asp-for="CurrentCoverPath" type="hidden" />

            <div class="form-section">
                <div class="form-section-title">Основна информация</div>

                <div class="form-grid form-grid-2">
                    <div class="form-field">
                        <label asp-for="Title" class="form-label-strong">Заглавие</label>
                        <input asp-for="Title" class="form-control" />
                        <span asp-validation-for="Title" class="text-danger"></span>
                    </div>

                    <div class="form-field">
                        <label asp-for="Author" class="form-label-strong">Автор</label>
                        <input asp-for="Author" class="form-control" />
                        <span asp-validation-for="Author" class="text-danger"></span>
                    </div>

                    <div class="form-field">
                        <label asp-for="Year" class="form-label-strong">Година</label>
                        <input asp-for="Year" type="number" class="form-control" />
                        <span asp-validation-for="Year" class="text-danger"></span>
                    </div>

                    <div class="form-field">
                        <label asp-for="CopiesCount" class="form-label-strong">Брой копия</label>
                        <input asp-for="CopiesCount" type="number" min="1" class="form-control" />
                        <span asp-validation-for="CopiesCount" class="text-danger"></span>
                    </div>
                </div>

                <div class="form-field mt-3">
                    <label asp-for="CoverFile" class="form-label-strong">Корица</label>
                    <input asp-for="CoverFile" type="file" accept=".jpg,.jpeg,.png,.webp,image/*" class="form-control" id="coverFileInput" />
                    <span asp-validation-for="CoverFile" class="text-danger"></span>

                    <div class="mt-3" id="coverPreviewBox" style="@(string.IsNullOrWhiteSpace(Model.CurrentCoverPath) ? "display:none;" : "display:block;")">
                        <div class="picker-help-text mb-2">Текуща / нова корица</div>
                        <img id="coverPreviewImage"
                             src="@(!string.IsNullOrWhiteSpace(Model.CurrentCoverPath) ? Url.Content(Model.CurrentCoverPath) : "")"
                             alt="Корица"
                             style="max-width:180px;max-height:240px;border-radius:14px;border:1px solid #E2E8F0;object-fit:cover;" />
                    </div>
                </div>

                <div class="form-field mt-3">
                    <label asp-for="Description" class="form-label-strong">Описание</label>
                    <textarea asp-for="Description" rows="5" class="form-control form-textarea"></textarea>
                    <span asp-validation-for="Description" class="text-danger"></span>
                </div>
            </div>

            <div class="form-section">
                <div class="form-section-title">Категория</div>

                <div class="picker-head">
                    <div id="categoryPreview" class="picker-preview"></div>

                    <button type="button"
                            class="btn btn-outline-primary"
                            data-bs-toggle="modal"
                            data-bs-target="#categoryPickerModal">
                        Избери категория
                    </button>
                </div>

                <input asp-for="Level1Id" type="hidden" id="Level1Hidden" />
                <input asp-for="Level2Id" type="hidden" id="Level2Hidden" />
            </div>

            <div class="form-section">
                <div class="form-section-title">Етикети</div>

                <div class="picker-head">
                    <div>
                        <div id="selectedTagsPreview" class="tags-preview"></div>
                        <div class="picker-help-text">
                            Избрани: <span id="selectedTagsCount">0</span>
                        </div>
                    </div>

                    <button type="button"
                            class="btn btn-outline-primary"
                            data-bs-toggle="modal"
                            data-bs-target="#tagsPickerModal">
                        Избери етикети
                    </button>
                </div>
            </div>

            <div class="form-actions-bar">
                <div class="left-actions">
                    <button type="submit" class="btn btn-accent">
                        Запази
                    </button>

                    <a asp-action="Details"
                       asp-route-id="@ViewBag.BookId"
                       class="btn btn-outline-primary">
                        Назад
                    </a>
                </div>
            </div>

            <div class="modal fade" id="categoryPickerModal" tabindex="-1" aria-hidden="true">
                <div class="modal-dialog modal-lg modal-dialog-scrollable">
                    <div class="modal-content picker-modal-content">
                        <div class="modal-header picker-modal-header">
                            <h5 class="modal-title">Категории</h5>
                            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Затвори"></button>
                        </div>

                        <div class="modal-body">
                            <div class="mb-3">
                                <input id="catSearch"
                                       type="text"
                                       class="form-control"
                                       placeholder="Търси категория..." />
                            </div>

                            <div class="picker-columns">
                                <div class="picker-column">
                                    <div class="picker-column-title">Главни категории</div>

                                    <div id="level1List" class="picker-list">
                                        @foreach (var c in (Model.Level1Options ?? new List<ObreshkovLibrary.Models.Category>()).OrderBy(x => x.Name))
                                        {
                                            <button type="button"
                                                    class="btn picker-item-btn level1-item"
                                                    data-id="@c.Id"
                                                    data-name="@c.Name">
                                                @c.Name
                                            </button>
                                        }
                                    </div>
                                </div>

                                <div class="picker-column">
                                    <div class="picker-column-title">Подкатегории</div>
                                    <div id="level2List" class="picker-list"></div>
                                </div>
                            </div>

                            <div class="picker-footer-actions mt-3">
                                <button type="button" id="btnClearCategory" class="btn btn-outline-secondary">
                                    Изчисти
                                </button>

                                <button type="button" class="btn btn-accent" data-bs-dismiss="modal">
                                    Готово
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="modal fade" id="tagsPickerModal" tabindex="-1" aria-hidden="true">
                <div class="modal-dialog modal-lg modal-dialog-scrollable">
                    <div class="modal-content picker-modal-content">
                        <div class="modal-header picker-modal-header">
                            <h5 class="modal-title">Етикети</h5>
                            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Затвори"></button>
                        </div>

                        <div class="modal-body">
                            <div class="mb-3">
                                <input id="tagsSearch"
                                       type="text"
                                       class="form-control"
                                       placeholder="Търси етикет..." />
                            </div>

                            <div id="tagsList" class="tags-list">
                                @{
                                    var ordered = (Model.TagOptions ?? new List<Microsoft.AspNetCore.Mvc.Rendering.SelectListItem>())
                                    .OrderBy(x => x.Text)
                                    .ToList();
                                }

                                @for (int i = 0; i < ordered.Count; i++)
                                {
                                    var opt = ordered[i];
                                    var isChecked = Model.SelectedTagValues != null && Model.SelectedTagValues.Contains(int.Parse(opt.Value));

                                    <label class="form-check tag-item" data-tag-text="@opt.Text.ToLowerInvariant()">
                                        <input class="form-check-input tag-checkbox"
                                               type="checkbox"
                                               name="SelectedTagValues"
                                               value="@opt.Value"
                                               id="tagopt_@i"
                                               data-name="@opt.Text"
                                               @(isChecked ? "checked" : "") />
                                        <span class="form-check-label ms-2" for="tagopt_@i">@opt.Text</span>
                                    </label>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </form>

        @if (ViewBag.IsBookActive == true)
        {
            <div class="danger-actions-row">
                <form asp-action="Deactivate"
                      asp-route-id="@ViewBag.BookId"
                      method="post"
                      data-gate="1"
                      class="m-0">
                    @Html.AntiForgeryToken()

                    <button type="submit" class="btn btn-outline-danger">
                        Деактивирай заглавието
                    </button>
                </form>
            </div>
        }
    </section>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        const level1Hidden = document.getElementById('Level1Hidden');
        const level2Hidden = document.getElementById('Level2Hidden');
        const categoryPreview = document.getElementById('categoryPreview');
        const level1Buttons = document.querySelectorAll('.level1-item');
        const level2List = document.getElementById('level2List');
        const catSearch = document.getElementById('catSearch');
        const clearCategoryBtn = document.getElementById('btnClearCategory');

        function renderCategoryPreview(level1Name, level2Name) {
            if (!level1Name) {
                categoryPreview.innerHTML = '';
                return;
            }

            const text = level2Name ? `${level1Name} → ${level2Name}` : level1Name;
            categoryPreview.innerHTML = `<span style="display:inline-block;padding:6px 10px;background:#EEF2FF;border-radius:999px;">${text}</span>`;
        }

        async function loadChildren(id) {
            const r = await fetch(`/Categories/GetChildren?parentId=${id}`);
            return await r.json();
        }

        async function selectLevel1(btn, preserveLevel2 = false) {
            level1Hidden.value = btn.dataset.id;

            if (!preserveLevel2) {
                level2Hidden.value = '';
                renderCategoryPreview(btn.dataset.name, '');
            }

            const children = await loadChildren(btn.dataset.id);
            level2List.innerHTML = '';

            children.forEach(c => {
                const childBtn = document.createElement('button');
                childBtn.type = 'button';
                childBtn.textContent = c.name;
                childBtn.className = 'btn picker-item-btn w-100 text-start mb-1';

                if (String(level2Hidden.value) === String(c.id)) {
                    renderCategoryPreview(btn.dataset.name, c.name);
                }

                childBtn.onclick = () => {
                    level2Hidden.value = c.id;
                    renderCategoryPreview(btn.dataset.name, c.name);
                };

                level2List.appendChild(childBtn);
            });
        }

        level1Buttons.forEach(btn => {
            btn.addEventListener('click', () => selectLevel1(btn));
        });

        if (catSearch) {
            catSearch.addEventListener('input', () => {
                const q = catSearch.value.trim().toLowerCase();
                level1Buttons.forEach(btn => {
                    btn.style.display = btn.dataset.name.toLowerCase().includes(q) ? 'block' : 'none';
                });
            });
        }

        if (clearCategoryBtn) {
            clearCategoryBtn.addEventListener('click', () => {
                level1Hidden.value = '';
                level2Hidden.value = '';
                level2List.innerHTML = '';
                renderCategoryPreview('', '');
            });
        }

        const selectedLevel1Btn = [...level1Buttons].find(b => String(b.dataset.id) === String(level1Hidden.value));
        if (selectedLevel1Btn) {
            selectLevel1(selectedLevel1Btn, true);
            if (!level2Hidden.value) {
                renderCategoryPreview(selectedLevel1Btn.dataset.name, '');
            }
        }

        const tagCheckboxes = document.querySelectorAll('.tag-checkbox');
        const tagsPreview = document.getElementById('selectedTagsPreview');
        const tagsCount = document.getElementById('selectedTagsCount');
        const tagsSearch = document.getElementById('tagsSearch');
        const tagItems = document.querySelectorAll('.tag-item');

        function renderTags() {
            tagsPreview.innerHTML = '';
            const selected = [...tagCheckboxes].filter(x => x.checked);
            tagsCount.textContent = selected.length;

            selected.forEach(item => {
                const chip = document.createElement('span');
                chip.textContent = item.dataset.name;
                chip.style.cssText = 'display:inline-block;margin:0 6px 6px 0;padding:4px 10px;background:#E6FFFA;border-radius:999px;';
                tagsPreview.appendChild(chip);
            });
        }

        tagCheckboxes.forEach(cb => cb.addEventListener('change', renderTags));
        renderTags();

        if (tagsSearch) {
            tagsSearch.addEventListener('input', () => {
                const q = tagsSearch.value.trim().toLowerCase();
                tagItems.forEach(item => {
                    item.style.display = item.dataset.tagText.includes(q) ? 'block' : 'none';
                });
            });
        }

        const coverInput = document.getElementById('coverFileInput');
        const coverPreviewBox = document.getElementById('coverPreviewBox');
        const coverPreviewImage = document.getElementById('coverPreviewImage');

        if (coverInput) {
            coverInput.addEventListener('change', () => {
                const file = coverInput.files && coverInput.files[0];
                if (!file) {
                    const currentSrc = '@(!string.IsNullOrWhiteSpace(Model.CurrentCoverPath) ? Url.Content(Model.CurrentCoverPath) : "")';
                    if (currentSrc) {
                        coverPreviewImage.src = currentSrc;
                        coverPreviewBox.style.display = 'block';
                    } else {
                        coverPreviewImage.src = '';
                        coverPreviewBox.style.display = 'none';
                    }
                    return;
                }

                const reader = new FileReader();
                reader.onload = e => {
                    coverPreviewImage.src = e.target.result;
                    coverPreviewBox.style.display = 'block';
                };
                reader.readAsDataURL(file);
            });
        }
    </script>
}