<!DOCTYPE html>
<html lang="bg">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - ObreshkovLibrary</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/ObreshkovLibrary.styles.css" asp-append-version="true" />

    <style>
        :root {
            --bg: #F5F7FA;
            --surface: #FFFFFF;
            --surface-soft: #F0F3F6;
            --surface-muted: #E8EDF2;
            --line: #D9E0E7;
            --line-strong: #C8D1DB;
            --text: #1F2937;
            --text-soft: #6B7280;
            --accent: #3B82F6;
            --accent-dark: #2563EB;
            --accent-soft: #DBEAFE;
        }

        html, body {
            height: 100%;
            margin: 0;
        }

        body {
            background: var(--bg);
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            color: var(--text);
            padding-top: 70px;
            font-family: "Segoe UI", Tahoma, Geneva, Verdana, sans-serif;
        }

        main {
            flex: 1 0 auto;
            padding-bottom: 24px;
        }

        .app-navbar {
            background: rgba(255,255,255,.96) !important;
            border-bottom: 1px solid var(--line) !important;
            backdrop-filter: blur(8px);
            min-height: 70px;
        }

            .app-navbar .navbar-brand {
                color: var(--text) !important;
                font-weight: 800;
                font-size: 1.2rem;
                letter-spacing: -.2px;
            }

            .app-navbar .navbar-collapse {
                flex-grow: 0;
            }

            .app-navbar .navbar-nav {
                gap: .15rem;
            }

            .app-navbar .nav-link {
                color: var(--text) !important;
                font-weight: 700;
                position: relative;
                padding: .65rem .8rem;
                border-radius: 8px;
                transition: background-color .18s ease, color .18s ease;
            }

                .app-navbar .nav-link:hover,
                .app-navbar .nav-link:focus {
                    background: var(--surface-soft);
                    color: var(--accent-dark) !important;
                }

            .app-navbar .dropdown-toggle::after {
                display: none !important;
            }

            .app-navbar .dropdown-menu {
                background: var(--surface);
                border: 1px solid var(--line);
                border-radius: 12px;
                padding: .35rem;
                box-shadow: 0 8px 22px rgba(17, 24, 39, 0.08);
                min-width: 220px;
            }

            .app-navbar .dropdown-item {
                color: var(--text);
                font-weight: 600;
                border-radius: 8px;
                padding: .55rem .7rem;
            }

                .app-navbar .dropdown-item:hover,
                .app-navbar .dropdown-item:focus {
                    background: var(--surface-soft);
                    color: var(--accent-dark);
                }

        .page-wrap {
            width: 100%;
            flex: 1 0 auto;
        }

        .page-container {
            max-width: 1180px;
            margin: 0 auto;
            padding: 0 18px;
        }

        .section-title {
            color: var(--text);
            font-weight: 800;
            letter-spacing: -.2px;
        }

        .accent-line {
            width: 54px;
            height: 3px;
            border-radius: 999px;
            background: var(--accent);
        }

        .card-soft {
            background: var(--surface);
            border: 1px solid var(--line);
            border-radius: 16px;
            box-shadow: 0 2px 8px rgba(17, 24, 39, 0.03);
        }

        input.form-control,
        select.form-select,
        textarea.form-control {
            background: #fff;
            border: 1px solid var(--line-strong);
            border-radius: 12px;
            color: var(--text);
            box-shadow: none;
        }

            input.form-control:focus,
            select.form-select:focus,
            textarea.form-control:focus {
                border-color: #9FC3F7;
                box-shadow: 0 0 0 .2rem rgba(59,130,246,.10);
            }

        .btn-accent {
            background: var(--accent);
            color: #fff;
            border: 1px solid var(--accent);
            font-weight: 700;
            border-radius: 12px;
        }

            .btn-accent:hover {
                background: var(--accent-dark);
                border-color: var(--accent-dark);
                color: #fff;
            }

        .btn-outline-primary {
            color: var(--accent);
            border-color: var(--accent);
            font-weight: 700;
            border-radius: 12px;
        }

            .btn-outline-primary:hover {
                background: var(--accent);
                border-color: var(--accent);
                color: #fff;
            }

        .link-accent {
            color: var(--accent);
            text-decoration: none;
            font-weight: 700;
        }

            .link-accent:hover {
                color: var(--accent-dark);
                text-decoration: underline;
            }

        .table th,
        .table td {
            border-color: var(--line);
            vertical-align: middle;
        }

        .table thead th {
            color: var(--text-soft);
        }

        .modal-content {
            border: 1px solid var(--line);
            border-radius: 16px;
        }

        .list-group-item {
            border-color: var(--line);
        }

        .footer {
            flex-shrink: 0;
            margin-top: auto;
            padding: 14px 0;
            font-size: 0.95rem;
            line-height: normal;
            background: transparent;
            border-top: 1px solid var(--line) !important;
            color: var(--text-soft) !important;
            position: static !important;
            bottom: auto !important;
            width: 100%;
        }

        .admin-modal-backdrop {
            position: fixed;
            inset: 0;
            background: rgba(15, 23, 42, 0.24);
            display: none;
            align-items: center;
            justify-content: center;
            padding: 20px;
            z-index: 2000;
        }

            .admin-modal-backdrop.is-open {
                display: flex;
            }

        .admin-modal {
            width: 100%;
            max-width: 430px;
            background: #fff;
            border: 1px solid var(--line);
            border-radius: 12px;
            box-shadow: 0 18px 45px rgba(15, 23, 42, 0.14);
            overflow: hidden;
        }

        .admin-modal-header {
            padding: 18px 20px 10px 20px;
        }

        .admin-modal-title {
            margin: 0;
            font-size: 1.35rem;
            font-weight: 800;
            color: var(--text);
            letter-spacing: -.2px;
        }

        .admin-modal-accent {
            width: 54px;
            height: 3px;
            border-radius: 999px;
            background: var(--accent);
            margin-top: 10px;
        }

        .admin-modal-body {
            padding: 12px 20px 0 20px;
            color: var(--text-soft);
            font-weight: 600;
            line-height: 1.6;
        }

        .admin-modal-field {
            margin-top: 14px;
        }

        .admin-modal-input {
            width: 100%;
            height: 44px;
            padding: 0 12px;
            border: 1px solid var(--line-strong);
            border-radius: 10px;
            outline: none;
            color: var(--text);
            background: #fff;
            box-shadow: none;
        }

            .admin-modal-input:focus {
                border-color: #9FC3F7;
                box-shadow: 0 0 0 .2rem rgba(59,130,246,.10);
            }

        .admin-modal-error {
            display: none;
            margin-top: 12px;
            padding: 10px 12px;
            border: 1px solid #fecaca;
            background: #fef2f2;
            color: #b91c1c;
            border-radius: 10px;
            font-weight: 700;
        }

            .admin-modal-error.is-visible {
                display: block;
            }

        .admin-modal-footer {
            display: flex;
            justify-content: flex-end;
            gap: 10px;
            padding: 18px 20px 20px 20px;
        }

        .admin-modal-btn {
            min-width: 110px;
            height: 40px;
            padding: 0 16px;
            border-radius: 10px;
            font-weight: 800;
            border: 1px solid transparent;
            transition: .18s ease;
        }

        .admin-modal-btn-cancel {
            background: #fff;
            color: var(--text);
            border-color: var(--line-strong);
        }

            .admin-modal-btn-cancel:hover {
                background: var(--surface-soft);
            }

        .admin-modal-btn-confirm {
            background: var(--accent);
            color: #fff;
            border-color: var(--accent);
        }

            .admin-modal-btn-confirm:hover {
                background: var(--accent-dark);
                border-color: var(--accent-dark);
            }

        .admin-modal-btn-close {
            background: var(--accent);
            color: #fff;
            border-color: var(--accent);
        }

            .admin-modal-btn-close:hover {
                background: var(--accent-dark);
                border-color: var(--accent-dark);
            }

        .admin-modal-success-text {
            color: var(--text);
            font-weight: 700;
            white-space: normal;
        }

        .admin-modal-password-box {
            margin-top: 12px;
            display: inline-block;
            padding: 7px 12px;
            background: #fff;
            border: 1px solid var(--line-strong);
            border-radius: 10px;
            color: #1e3a8a;
            font-weight: 800;
            letter-spacing: .03em;
        }

        @@media (hover:hover) and (pointer:fine) {
            .navbar .nav-item.dropdown:hover > .dropdown-menu {
                display: block;
                margin-top: 0;
            }
        }

        @@media (max-width: 991.98px) {
            body {
                padding-top: 64px;
            }

            .app-navbar {
                min-height: 64px;
            }

                .app-navbar .navbar-brand {
                    font-size: 1.02rem;
                }

                .app-navbar .navbar-collapse {
                    margin-top: .6rem;
                    padding-top: .6rem;
                    border-top: 1px solid var(--line);
                }

                .app-navbar .navbar-nav {
                    gap: .1rem;
                }

            .page-container {
                padding: 0 14px;
            }
        }
    </style>
</head>

<body>
    <partial name="_HeaderPartial" />

    <div class="page-wrap mt-4">
        <div class="page-container">
            <main role="main" class="pb-3">
                @RenderBody()
            </main>
        </div>
    </div>

    <footer class="border-top footer">
        <div class="page-container">
            &copy; 2026 – ObreshkovLibrary
        </div>
    </footer>

    <div id="gateModalBackdrop" class="admin-modal-backdrop" aria-hidden="true">
        <div class="admin-modal" role="dialog" aria-modal="true" aria-labelledby="gateModalTitle">
            <div class="admin-modal-header">
                <h3 id="gateModalTitle" class="admin-modal-title">Потвърждение</h3>
                <div class="admin-modal-accent"></div>
            </div>
            <div class="admin-modal-body">
                За да продължиш, въведи администраторската парола.
                <div class="admin-modal-field">
                    <input id="gatePasswordInput" class="admin-modal-input" type="password" placeholder="Парола" />
                </div>
                <div id="gateModalError" class="admin-modal-error">Грешна парола.</div>
            </div>
            <div class="admin-modal-footer">
                <button type="button" id="gateCancelBtn" class="admin-modal-btn admin-modal-btn-cancel">Отказ</button>
                <button type="button" id="gateConfirmBtn" class="admin-modal-btn admin-modal-btn-confirm">Потвърди</button>
            </div>
        </div>
    </div>

    <div id="successModalBackdrop" class="admin-modal-backdrop" aria-hidden="true">
        <div class="admin-modal" role="dialog" aria-modal="true" aria-labelledby="successModalTitle">
            <div class="admin-modal-header">
                <h3 id="successModalTitle" class="admin-modal-title">Успешно сменена парола</h3>
                <div class="admin-modal-accent"></div>
            </div>
            <div class="admin-modal-body">
                <div id="successModalContent" class="admin-modal-success-text"></div>
            </div>
            <div class="admin-modal-footer">
                <button type="button" id="successModalCloseBtn" class="admin-modal-btn admin-modal-btn-close">Затвори</button>
            </div>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)

    <script>
        (function () {
            let lastSubmitter = null;
            let pendingForm = null;
            let pendingSubmitter = null;

            const gateBackdrop = document.getElementById('gateModalBackdrop');
            const gatePasswordInput = document.getElementById('gatePasswordInput');
            const gateError = document.getElementById('gateModalError');
            const gateConfirmBtn = document.getElementById('gateConfirmBtn');
            const gateCancelBtn = document.getElementById('gateCancelBtn');

            const successBackdrop = document.getElementById('successModalBackdrop');
            const successContent = document.getElementById('successModalContent');
            const successCloseBtn = document.getElementById('successModalCloseBtn');

            function openGateModal(form, submitter) {
                pendingForm = form;
                pendingSubmitter = submitter;
                gatePasswordInput.value = '';
                gateError.classList.remove('is-visible');
                gateBackdrop.classList.add('is-open');
                document.body.style.overflow = 'hidden';
                setTimeout(() => gatePasswordInput.focus(), 30);
            }

            function closeGateModal() {
                gateBackdrop.classList.remove('is-open');
                document.body.style.overflow = '';
                pendingForm = null;
                pendingSubmitter = null;
                gatePasswordInput.value = '';
                gateError.classList.remove('is-visible');
            }

            function openSuccessModal(html) {
                successContent.innerHTML = html;
                successBackdrop.classList.add('is-open');
                document.body.style.overflow = 'hidden';
            }

            function closeSuccessModal() {
                successBackdrop.classList.remove('is-open');
                document.body.style.overflow = '';
            }

            document.addEventListener('click', function (e) {
                const btn = e.target.closest('button[type="submit"], input[type="submit"]');
                if (btn) lastSubmitter = btn;
            }, true);

            document.addEventListener('submit', function (e) {
                const form = e.target;
                if (!form.matches('form[data-gate="1"]')) return;

                const submitter = e.submitter || lastSubmitter;
                e.preventDefault();
                openGateModal(form, submitter);
            }, true);

            gateConfirmBtn.addEventListener('click', async function () {
                if (!pendingForm) return;

                const pwd = gatePasswordInput.value.trim();
                if (!pwd) {
                    gateError.textContent = 'Моля, въведи парола.';
                    gateError.classList.add('is-visible');
                    gatePasswordInput.focus();
                    return;
                }

                const tokenInput = pendingForm.querySelector('input[name="__RequestVerificationToken"]');
                const token = tokenInput ? tokenInput.value : '';

                const body = new URLSearchParams();
                body.set('password', pwd);
                if (token) body.set('__RequestVerificationToken', token);

                const res = await fetch('/Gate/Unlock', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/x-www-form-urlencoded; charset=UTF-8' },
                    body: body.toString()
                });

                if (!res.ok) {
                    gateError.textContent = 'Грешна парола.';
                    gateError.classList.add('is-visible');
                    gatePasswordInput.focus();
                    gatePasswordInput.select();
                    return;
                }

                if (pendingSubmitter) {
                    const fa = pendingSubmitter.getAttribute('formaction');
                    if (fa) pendingForm.setAttribute('action', fa);

                    const fm = pendingSubmitter.getAttribute('formmethod');
                    if (fm) pendingForm.setAttribute('method', fm);
                }

                const formToSubmit = pendingForm;
                lastSubmitter = null;
                closeGateModal();
                formToSubmit.submit();
            });

            gateCancelBtn.addEventListener('click', closeGateModal);
            successCloseBtn.addEventListener('click', closeSuccessModal);

            gateBackdrop.addEventListener('click', function (e) {
                if (e.target === gateBackdrop) closeGateModal();
            });

            successBackdrop.addEventListener('click', function (e) {
                if (e.target === successBackdrop) closeSuccessModal();
            });

            document.addEventListener('keydown', function (e) {
                if (e.key === 'Escape') {
                    if (gateBackdrop.classList.contains('is-open')) closeGateModal();
                    if (successBackdrop.classList.contains('is-open')) closeSuccessModal();
                }

                if (e.key === 'Enter' && gateBackdrop.classList.contains('is-open')) {
                    const active = document.activeElement;
                    if (active && active.id === 'gatePasswordInput') {
                        e.preventDefault();
                        gateConfirmBtn.click();
                    }
                }
            });

            window.showAdminSuccessModal = openSuccessModal;
        })();
    </script>

    <script>
        (function () {
          const nav = document.getElementById("topNav");
          if (!nav) return;

          function onScroll() {
            if (window.scrollY > 10) nav.classList.add("navbar-scrolled");
            else nav.classList.remove("navbar-scrolled");
          }

          window.addEventListener("scroll", onScroll, { passive: true });
          onScroll();
        })();
    </script>
</body>
</html>