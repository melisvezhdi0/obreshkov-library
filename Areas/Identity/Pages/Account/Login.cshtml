@page
@model ObreshkovLibrary.Areas.Identity.Pages.Account.LoginModel

@{
    Layout = "~/Views/Shared/_LoginLayout.cshtml";
    ViewData["Title"] = "Вход в системата";
    var selectedRole = Model.Input?.SelectedRole ?? "Student";
}

<div style="min-height:calc(100vh - 64px); display:flex; align-items:center; justify-content:center; padding:24px 16px 40px 16px; box-sizing:border-box;">
    <div style="width:100%; max-width:640px;">

        <div style="text-align:center; margin-bottom:18px;">
            <h1 style="margin:0; font-size:2rem; font-weight:800; color:#0f172a; line-height:1.1; letter-spacing:-0.02em;">
                Вход в системата
            </h1>

            <div style="width:58px; height:3px; background:#3b82f6; margin:12px auto 0 auto; border-radius:999px;"></div>
        </div>

        <div style="
            background:#ffffff;
            border:1px solid #d9e2ec;
            border-radius:18px;
            box-shadow:0 18px 48px rgba(15, 23, 42, 0.08);
            overflow:hidden;">

            <div style="display:grid; grid-template-columns:1fr 1fr; background:#f8fbff; border-bottom:1px solid #d9e2ec;">
                <button type="button"
                        id="studentRoleBtn"
                        style="height:60px; border:none; border-right:1px solid #d9e2ec; border-bottom:3px solid #2563eb; background:#ffffff; color:#1f2937; font-size:1rem; font-weight:800; transition:all .18s ease;">
                    Ученик
                </button>

                <button type="button"
                        id="adminRoleBtn"
                        style="height:60px; border:none; border-bottom:3px solid transparent; background:#f8fbff; color:#64748b; font-size:1rem; font-weight:700; transition:all .18s ease;">
                    Админ
                </button>
            </div>

            <div style="padding:26px 28px 22px 28px;">
                <form id="account" method="post" style="margin:0;">
                    <div asp-validation-summary="ModelOnly" class="text-danger" style="margin-bottom:10px; font-weight:600;"></div>

                    <input asp-for="Input.SelectedRole" type="hidden" id="selectedRoleInput" />

                    <div id="studentFields">
                        <div style="margin-bottom:16px;">
                            <label style="display:block; margin-bottom:7px; font-weight:800; color:#334155; font-size:0.98rem;">
                                Номер на читателска карта
                            </label>

                            <input asp-for="Input.CardNumber"
                                   id="studentCardNumberInput"
                                   placeholder="Номер на читателска карта"
                                   autocomplete="username"
                                   style="width:100%; height:46px; border:1px solid #cbd5e1; border-radius:12px; padding:0 14px; background:#ffffff; box-sizing:border-box; outline:none; transition:border .18s ease, box-shadow .18s ease;" />

                            <span asp-validation-for="Input.CardNumber" class="text-danger" style="font-size:.92rem;"></span>
                        </div>
                    </div>

                    <div id="adminFields" style="display:none;">
                        <div style="margin-bottom:16px;">
                            <label style="display:block; margin-bottom:7px; font-weight:800; color:#334155; font-size:0.98rem;">
                                Имейл
                            </label>

                            <input asp-for="Input.Email"
                                   id="adminEmailInput"
                                   placeholder="Имейл"
                                   autocomplete="username"
                                   style="width:100%; height:46px; border:1px solid #cbd5e1; border-radius:12px; padding:0 14px; background:#ffffff; box-sizing:border-box; outline:none; transition:border .18s ease, box-shadow .18s ease;" />

                            <span asp-validation-for="Input.Email" class="text-danger" style="font-size:.92rem;"></span>
                        </div>
                    </div>

                    <div style="margin-bottom:14px;">
                        <label style="display:block; margin-bottom:7px; font-weight:800; color:#334155; font-size:0.98rem;">
                            Парола
                        </label>

                        <input asp-for="Input.Password"
                               id="passwordInput"
                               autocomplete="current-password"
                               placeholder="Парола"
                               style="width:100%; height:46px; border:1px solid #cbd5e1; border-radius:12px; padding:0 14px; background:#ffffff; box-sizing:border-box; outline:none; transition:border .18s ease, box-shadow .18s ease;" />

                        <span asp-validation-for="Input.Password" class="text-danger" style="font-size:.92rem;"></span>
                    </div>

                    <div style="display:flex; justify-content:space-between; align-items:center; gap:12px; margin-bottom:18px; flex-wrap:wrap;">
                        <label asp-for="Input.RememberMe"
                               style="display:flex; align-items:center; gap:8px; color:#475569; font-weight:600; margin:0;">
                            <input asp-for="Input.RememberMe" id="rememberMeInput" style="accent-color:#2563eb;" />
                            <span>Запомни ме</span>
                        </label>

                        <a id="forgotPasswordLink"
                           asp-area="Identity"
                           asp-page="/Account/ForgotPassword"
                           style="color:#2563eb; text-decoration:none; font-weight:800;">
                            Забравена парола
                        </a>
                    </div>

                    <div style="display:flex; justify-content:flex-end;">
                        <button id="login-submit"
                                type="submit"
                                style="min-width:210px; height:48px; border:none; border-radius:12px; background:linear-gradient(135deg,#2563eb,#1d4ed8); color:#ffffff; font-weight:800; font-size:1rem; box-shadow:0 6px 16px rgba(37,99,235,.25); transition:transform .15s ease, box-shadow .15s ease;">
                            Вход
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        const selectedRoleInput = document.getElementById('selectedRoleInput');
        const studentRoleBtn = document.getElementById('studentRoleBtn');
        const adminRoleBtn = document.getElementById('adminRoleBtn');
        const studentFields = document.getElementById('studentFields');
        const adminFields = document.getElementById('adminFields');
        const forgotPasswordLink = document.getElementById('forgotPasswordLink');
        const studentCardNumberInput = document.getElementById('studentCardNumberInput');
        const adminEmailInput = document.getElementById('adminEmailInput');
        const rememberMeInput = document.getElementById('rememberMeInput');

        function setRole(role) {
            selectedRoleInput.value = role;

            if (role === 'Student') {
                studentFields.style.display = 'block';
                adminFields.style.display = 'none';

                studentRoleBtn.style.background = '#ffffff';
                studentRoleBtn.style.color = '#1f2937';
                studentRoleBtn.style.fontWeight = '800';
                studentRoleBtn.style.borderBottom = '3px solid #2563eb';

                adminRoleBtn.style.background = '#f8fbff';
                adminRoleBtn.style.color = '#64748b';
                adminRoleBtn.style.fontWeight = '700';
                adminRoleBtn.style.borderBottom = '3px solid transparent';

                if (studentCardNumberInput) {
                    studentCardNumberInput.placeholder = 'Номер на читателска карта';
                }

                forgotPasswordLink.href = '/Identity/Account/ForgotPassword?role=Student';
            } else {
                studentFields.style.display = 'none';
                adminFields.style.display = 'block';

                adminRoleBtn.style.background = '#ffffff';
                adminRoleBtn.style.color = '#1f2937';
                adminRoleBtn.style.fontWeight = '800';
                adminRoleBtn.style.borderBottom = '3px solid #2563eb';

                studentRoleBtn.style.background = '#f8fbff';
                studentRoleBtn.style.color = '#64748b';
                studentRoleBtn.style.fontWeight = '700';
                studentRoleBtn.style.borderBottom = '3px solid transparent';

                if (adminEmailInput) {
                    adminEmailInput.placeholder = 'Имейл';
                }

                forgotPasswordLink.href = '/Identity/Account/ForgotPassword?role=Admin';
            }
        }

        studentRoleBtn.addEventListener('click', () => setRole('Student'));
        adminRoleBtn.addEventListener('click', () => setRole('Admin'));
    </script>

    <script>
        (function () {
            const html = document.documentElement;
            const body = document.body;

            const oldHtmlOverflow = html.style.overflow;
            const oldBodyOverflow = body.style.overflow;

            html.style.overflow = 'hidden';
            body.style.overflow = 'hidden';

            window.addEventListener('beforeunload', function () {
                html.style.overflow = oldHtmlOverflow;
                body.style.overflow = oldBodyOverflow;
            });
        })();
    </script>

    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const inputs = document.querySelectorAll('#account input[type="text"], #account input[type="email"], #account input[type="password"]');
            const loginButton = document.getElementById('login-submit');

            inputs.forEach(input => {
                input.addEventListener('focus', function () {
                    this.style.border = '1px solid #2563eb';
                    this.style.boxShadow = '0 0 0 3px rgba(37,99,235,.12)';
                });

                input.addEventListener('blur', function () {
                    this.style.border = '1px solid #cbd5e1';
                    this.style.boxShadow = 'none';
                });
            });

            if (loginButton) {
                loginButton.addEventListener('mouseover', function () {
                    this.style.transform = 'translateY(-1px)';
                    this.style.boxShadow = '0 10px 22px rgba(37,99,235,.28)';
                });

                loginButton.addEventListener('mouseout', function () {
                    this.style.transform = 'translateY(0)';
                    this.style.boxShadow = '0 6px 16px rgba(37,99,235,.25)';
                });
            }
        });
    </script>

    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const form = document.getElementById('account');

            const rememberSaved = localStorage.getItem('loginRememberMe') === 'true';
            const savedRole = localStorage.getItem('loginRole');
            const savedStudentCard = localStorage.getItem('savedStudentCard');
            const savedAdminEmail = localStorage.getItem('savedAdminEmail');

            if (rememberMeInput) {
                rememberMeInput.checked = rememberSaved;
            }

            const initialRole =
                rememberSaved && (savedRole === 'Admin' || savedRole === 'Student')
                    ? savedRole
                    : '@selectedRole';

            setRole(initialRole);

            if (rememberSaved) {
                if (initialRole === 'Student') {
                    if (studentCardNumberInput && savedStudentCard) {
                        studentCardNumberInput.value = savedStudentCard;
                    }
                    if (adminEmailInput) {
                        adminEmailInput.value = '';
                    }
                } else {
                    if (adminEmailInput && savedAdminEmail) {
                        adminEmailInput.value = savedAdminEmail;
                    }
                    if (studentCardNumberInput) {
                        studentCardNumberInput.value = '';
                    }
                }
            } else {
                if (studentCardNumberInput) studentCardNumberInput.value = '';
                if (adminEmailInput) adminEmailInput.value = '';
            }

            if (form) {
                form.addEventListener('submit', function () {
                    const currentRole = selectedRoleInput ? selectedRoleInput.value : 'Student';
                    const remember = rememberMeInput ? rememberMeInput.checked : false;

                    if (remember) {
                        localStorage.setItem('loginRememberMe', 'true');
                        localStorage.setItem('loginRole', currentRole);

                        if (currentRole === 'Student' && studentCardNumberInput) {
                            localStorage.setItem('savedStudentCard', studentCardNumberInput.value.trim());
                            localStorage.removeItem('savedAdminEmail');
                        }

                        if (currentRole === 'Admin' && adminEmailInput) {
                            localStorage.setItem('savedAdminEmail', adminEmailInput.value.trim());
                            localStorage.removeItem('savedStudentCard');
                        }
                    } else {
                        localStorage.removeItem('loginRememberMe');
                        localStorage.removeItem('loginRole');
                        localStorage.removeItem('savedStudentCard');
                        localStorage.removeItem('savedAdminEmail');
                    }
                });
            }
        });
    </script>
}