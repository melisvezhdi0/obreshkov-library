@model ObreshkovLibrary.Models.ViewModels.StudentDashboardVM

@{
    ViewData["Title"] = "Моят профил";
}

<div style="width:min(1240px, calc(100% - 24px)); margin:28px auto 40px;">
    <partial name="_StudentAlertsPartial" />

    <div style="background:#fff; border:1px solid #d8e1eb; border-radius:24px; padding:26px; box-shadow:0 10px 28px rgba(15,23,42,0.05); margin-bottom:22px;">
        <h1 style="margin:0; color:#17325c; font-size:2.2rem; font-weight:900;">Здравей, @Model.StudentName</h1>
        <div style="width:62px; height:4px; border-radius:999px; margin-top:10px; background:linear-gradient(90deg,#2563eb 0%,#60a5fa 100%);"></div>
        <p style="margin:16px 0 0 0; color:#64748b; font-size:1rem; font-weight:700;">
            Тук виждаш текущите си книги, любимите книги и последните съобщения.
        </p>
    </div>

    <div style="display:grid; grid-template-columns:repeat(3, minmax(0,1fr)); gap:16px; margin-bottom:22px;">
        <div style="background:#fff; border:1px solid #d8e1eb; border-radius:20px; padding:20px;">
            <div style="color:#64748b; font-weight:800;">Текущо заети книги</div>
            <div style="margin-top:8px; color:#17325c; font-size:2rem; font-weight:900;">@Model.CurrentLoansCount</div>
        </div>

        <div style="background:#fff; border:1px solid #d8e1eb; border-radius:20px; padding:20px;">
            <div style="color:#64748b; font-weight:800;">Любими книги</div>
            <div style="margin-top:8px; color:#17325c; font-size:2rem; font-weight:900;">@Model.FavoritesCount</div>
        </div>

        <div style="background:#fff; border:1px solid #d8e1eb; border-radius:20px; padding:20px;">
            <div style="color:#64748b; font-weight:800;">Непрочетени съобщения</div>
            <div style="margin-top:8px; color:#17325c; font-size:2rem; font-weight:900;">@Model.UnreadNotificationsCount</div>
        </div>
    </div>

    <div style="display:grid; grid-template-columns:minmax(0,1.2fr) minmax(0,0.8fr); gap:20px;">
        <div style="display:flex; flex-direction:column; gap:20px;">
            <section style="background:#fff; border:1px solid #d8e1eb; border-radius:24px; overflow:hidden;">
                <div style="padding:18px 22px; border-bottom:1px solid #e2e8f0; display:flex; justify-content:space-between; align-items:center;">
                    <h2 style="margin:0; color:#17325c; font-size:1.2rem; font-weight:900;">Текущи книги</h2>
                    <a asp-action="MyBooks" style="text-decoration:none; font-weight:800;">Виж всички</a>
                </div>

                @if (Model.CurrentLoans.Any())
                {
                    <div style="padding:16px 18px;">
                        <div class="table-responsive">
                            <table class="table align-middle mb-0">
                                <thead>
                                    <tr>
                                        <th>Книга</th>
                                        <th>Взета на</th>
                                        <th>Връща се на</th>
                                        <th>Статус</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var item in Model.CurrentLoans)
                                    {
                                        <tr>
                                            <td>
                                                <a asp-controller="Catalog" asp-action="Details" asp-route-id="@item.BookId" style="font-weight:800; text-decoration:none;">
                                                    @item.Title
                                                </a>
                                                <div style="color:#64748b; font-size:.94rem;">@item.Author</div>
                                            </td>
                                            <td>@item.LoanDate.ToString("dd.MM.yyyy")</td>
                                            <td>@item.DueDate.ToString("dd.MM.yyyy")</td>
                                            <td>
                                                @if (item.IsOverdue)
                                                {
                                                    <span class="badge text-bg-danger">Просрочена</span>
                                                }
                                                else if (item.IsExtended)
                                                {
                                                    <span class="badge text-bg-primary">Удължена</span>
                                                }
                                                else
                                                {
                                                    <span class="badge text-bg-success">Активна</span>
                                                }
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                }
                else
                {
                    <div style="padding:22px; color:#64748b; font-weight:700;">Нямаш текущо заети книги.</div>
                }
            </section>

            <section style="background:#fff; border:1px solid #d8e1eb; border-radius:24px; overflow:hidden;">
                <div style="padding:18px 22px; border-bottom:1px solid #e2e8f0; display:flex; justify-content:space-between; align-items:center;">
                    <h2 style="margin:0; color:#17325c; font-size:1.2rem; font-weight:900;">Любими книги</h2>
                    <a asp-action="Favorites" style="text-decoration:none; font-weight:800;">Виж всички</a>
                </div>

                @if (Model.FavoriteBooks.Any())
                {
                    <div style="padding:18px; display:grid; grid-template-columns:repeat(3, minmax(0,1fr)); gap:16px;">
                        @foreach (var item in Model.FavoriteBooks)
                        {
                            <div style="background:#f8fbff; border:1px solid #dbe7f3; border-radius:18px; padding:14px;">
                                <div style="height:190px; border-radius:14px; background:#fff; border:1px solid #e5edf5; display:flex; align-items:center; justify-content:center; overflow:hidden; margin-bottom:12px;">
                                    @if (!string.IsNullOrWhiteSpace(item.CoverPath))
                                    {
                                        <img src="@item.CoverPath" alt="@item.Title" style="max-width:100%; max-height:100%; object-fit:contain;" />
                                    }
                                    else
                                    {
                                        <span style="color:#94a3b8; font-weight:700;">Няма корица</span>
                                    }
                                </div>

                                <div style="font-weight:900; color:#17325c;">@item.Title</div>
                                <div style="color:#64748b; font-size:.95rem; margin-top:4px;">@item.Author</div>

                                <div style="margin-top:10px;">
                                    @if (item.IsAvailable)
                                    {
                                        <span class="badge text-bg-success">Налична</span>
                                    }
                                    else
                                    {
                                        <span class="badge text-bg-secondary">Не е налична</span>
                                    }
                                </div>

                                <a asp-controller="Catalog"
                                   asp-action="Details"
                                   asp-route-id="@item.BookId"
                                   class="btn btn-outline-primary w-100 mt-3">
                                    Детайли
                                </a>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div style="padding:22px; color:#64748b; font-weight:700;">Нямаш добавени любими книги.</div>
                }
            </section>
        </div>

        <section style="background:#fff; border:1px solid #d8e1eb; border-radius:24px; overflow:hidden; height:max-content;">
            <div style="padding:18px 22px; border-bottom:1px solid #e2e8f0; display:flex; justify-content:space-between; align-items:center;">
                <h2 style="margin:0; color:#17325c; font-size:1.2rem; font-weight:900;">Последни съобщения</h2>
                <a asp-action="Notifications" style="text-decoration:none; font-weight:800;">Всички</a>
            </div>

            @if (Model.LatestNotifications.Any())
            {
                <div style="padding:16px; display:flex; flex-direction:column; gap:12px;">
                    @foreach (var item in Model.LatestNotifications)
                    {
                        <div style="border:1px solid @(item.IsRead ? "#e2e8f0" : "#bfdbfe"); background:@(item.IsRead ? "#ffffff" : "#eff6ff"); border-radius:16px; padding:14px;">
                            <div style="display:flex; justify-content:space-between; gap:10px; align-items:flex-start;">
                                <div style="font-weight:900; color:#17325c;">@item.Title</div>
                                <div style="color:#64748b; font-size:.85rem; white-space:nowrap;">@item.CreatedOn.ToString("dd.MM.yyyy")</div>
                            </div>

                            <div style="margin-top:8px; color:#475569; line-height:1.6;">
                                @item.Message
                            </div>

                            @if (item.BookId.HasValue)
                            {
                                <a asp-controller="Catalog"
                                   asp-action="Details"
                                   asp-route-id="@item.BookId.Value"
                                   style="display:inline-block; margin-top:10px; text-decoration:none; font-weight:800;">
                                    Към книгата
                                </a>
                            }
                        </div>
                    }
                </div>
            }
            else
            {
                <div style="padding:22px; color:#64748b; font-weight:700;">Нямаш съобщения.</div>
            }
        </section>
    </div>
</div>