@model ObreshkovLibrary.Models.ViewModels.StudentDashboardVM

@{
    ViewData["Title"] = "Моят профил";
    Layout = "_StudentLayout";
}

<div class="student-portal-page">

    <aside class="student-portal-sidebar">
        <div class="student-portal-sidebar-inner">
            <div class="student-portal-sidebar-label">Student Portal</div>
            <h1 class="student-portal-sidebar-title">Моят профил</h1>

            <nav id="studentScrollspy" class="student-portal-nav">
                <a href="#current-loans" class="student-nav-link active">
                    <span class="student-nav-line"></span>
                    <span>Текущо заети книги</span>
                </a>

                <a href="#favorites" class="student-nav-link">
                    <span class="student-nav-line"></span>
                    <span>Списък за четене</span>
                </a>

                <a href="#notifications" class="student-nav-link">
                    <span class="student-nav-line"></span>
                    <span>Известия</span>
                </a>

                <a href="#history" class="student-nav-link">
                    <span class="student-nav-line"></span>
                    <span>История на заеманията</span>
                </a>

                <a href="#notes" class="student-nav-link">
                    <span class="student-nav-line"></span>
                    <span>Лична бележка към заемана книга</span>
                </a>

                <a href="#extension" class="student-nav-link">
                    <span class="student-nav-line"></span>
                    <span>Заявка за удължаване</span>
                </a>

                <a href="#profile" class="student-nav-link">
                    <span class="student-nav-line"></span>
                    <span>Лични данни</span>
                </a>
            </nav>
        </div>
    </aside>

    <main class="student-portal-content">

        <!-- 1. ТЕКУЩО ЗАЕТИ КНИГИ -->
        <section id="current-loans" class="student-portal-section">
            <div class="student-section-header">
                <h2 class="student-section-title">Текущо заети книги</h2>
                <p class="student-section-subtitle">
                    Преглед на всички книги, които са заети в момента.
                </p>
            </div>

            @if (Model.CurrentLoans != null && Model.CurrentLoans.Any())
            {
                <div class="student-table-wrap">
                    <table class="student-loans-table">
                        <thead>
                            <tr>
                                <th style="width:72px;">Корица</th>
                                <th>Заглавие</th>
                                <th style="width:170px;">Дата на заемане</th>
                                <th style="width:240px;">Дата на връщане</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model.CurrentLoans)
                            {
                                var overdueDays = item.IsOverdue
                                ? (DateTime.Today - item.DueDate.Date).Days
                                : 0;

                                <tr>
                                    <td>
                                        <div class="student-cover-box">
                                            @if (!string.IsNullOrWhiteSpace(item.CoverPath))
                                            {
                                                <img src="@Url.Content("~/" + item.CoverPath)"
                                                     alt="@item.Title"
                                                     class="student-mini-cover" />
                                            }
                                            else
                                            {
                                                <div class="student-mini-cover student-cover-placeholder">
                                                    Няма
                                                </div>
                                            }
                                        </div>
                                    </td>

                                    <td>
                                        <div class="student-book-cell">
                                            <div class="student-book-title">@item.Title</div>
                                            <div class="student-book-author">@item.Author</div>
                                        </div>
                                    </td>

                                    <td>
                                        <div class="student-date-cell">
                                            @item.LoanDate.ToString("dd.MM.yyyy")
                                        </div>
                                    </td>

                                    <td>
                                        @if (item.IsOverdue)
                                        {
                                            <div class="student-return-status overdue">
                                                Просрочена с @overdueDays @(overdueDays == 1 ? "ден" : "дни")
                                            </div>
                                        }
                                        else if (item.IsExtended)
                                        {
                                            <div class="student-return-status extended">
                                                Удължена до @item.DueDate.ToString("dd.MM.yyyy")
                                            </div>
                                        }
                                        else
                                        {
                                            <div class="student-return-status normal">
                                                @item.DueDate.ToString("dd.MM.yyyy")
                                            </div>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="student-empty-state">
                    В момента нямаш заети книги.
                </div>
            }
        </section>

        <!-- 2. ЛЮБИМИ -->
        <section id="favorites" class="student-portal-section">
            <div class="student-section-header">
                <h2 class="student-section-title">Списък за четене</h2>
            </div>

            <div class="student-empty-state">
                Тази секция ще я подредим след това.
            </div>
        </section>

        <!-- 3. ИЗВЕСТИЯ -->
        <section id="notifications" class="student-portal-section">
            <div class="student-section-header">
                <h2 class="student-section-title">Известия</h2>
            </div>

            <div class="student-empty-state">
                Тази секция ще я подредим след това.
            </div>
        </section>

        <!-- 4. ИСТОРИЯ -->
        <section id="history" class="student-portal-section">
            <div class="student-section-header">
                <h2 class="student-section-title">История на заеманията</h2>
            </div>

            <div class="student-empty-state">
                Тази секция ще я подредим след това.
            </div>
        </section>

        <!-- 5. ЛИЧНА БЕЛЕЖКА -->
        <section id="notes" class="student-portal-section">
            <div class="student-section-header">
                <h2 class="student-section-title">Лична бележка към заемана книга</h2>
            </div>

            <div class="student-empty-state">
                Тази секция ще я подредим след това.
            </div>
        </section>

        <!-- 6. УДЪЛЖАВАНЕ -->
        <section id="extension" class="student-portal-section">
            <div class="student-section-header">
                <h2 class="student-section-title">Заявка за удължаване</h2>
            </div>

            <div class="student-empty-state">
                Тази секция ще я подредим след това.
            </div>
        </section>

        <!-- 7. ЛИЧНИ ДАННИ -->
        <section id="profile" class="student-portal-section">
            <div class="student-section-header">
                <h2 class="student-section-title">Лични данни</h2>
            </div>

            <div class="student-empty-state">
                Тази секция ще я подредим след това.
            </div>
        </section>

    </main>
</div>

@if (ViewBag.RequirePasswordChange == true)
{
    <div id="passwordOverlay"
         style="position:fixed;
                    inset:0;
                    background:rgba(15,23,42,.34);
                    backdrop-filter:blur(5px);
                    z-index:9999;
                    display:flex;
                    align-items:center;
                    justify-content:center;
                    padding:18px;">

        <div style="width:460px;
                        max-width:100%;
                        background:#ffffff;
                        border:1px solid #dbe5ef;
                        border-radius:24px;
                        padding:30px 28px 26px 28px;
                        box-shadow:0 24px 70px rgba(15,23,42,.16);">

            <div style="text-align:center; margin-bottom:20px;">
                <div style="font-size:1.65rem;
                                font-weight:900;
                                color:#0f172a;
                                line-height:1.15;
                                margin-bottom:8px;">
                    Смени паролата си
                </div>

                <div style="display:inline-flex;
                                align-items:center;
                                justify-content:center;
                                min-height:30px;
                                padding:0 12px;
                                border-radius:999px;
                                background:#eff6ff;
                                color:#2563eb;
                                font-size:.82rem;
                                font-weight:800;
                                margin-bottom:12px;">
                    Първи вход в профила
                </div>

                <div style="color:#64748b;
                                font-size:.98rem;
                                line-height:1.65;
                                max-width:340px;
                                margin:0 auto;">
                    За да продължиш към профила си, първо трябва да зададеш нова лична парола.
                </div>
            </div>

            @if (TempData["PasswordChangeError"] != null)
            {
                <div style="margin-bottom:14px;
                                    padding:11px 13px;
                                    border-radius:12px;
                                    border:1px solid #fecaca;
                                    background:#fef2f2;
                                    color:#b91c1c;
                                    font-size:.92rem;
                                    font-weight:700;">
                    @TempData["PasswordChangeError"]
                </div>
            }

            <form asp-controller="StudentAccount"
                  asp-action="ChangePassword"
                  method="post"
                  style="margin:0;">
                @Html.AntiForgeryToken()

                <div style="display:grid; gap:14px;">

                    <div>
                        <label style="display:block; margin-bottom:7px; color:#0f172a; font-size:.95rem; font-weight:800;">
                            Текуща парола
                        </label>
                        <input type="password"
                               name="CurrentPassword"
                               class="student-password-input"
                               style="width:100%; height:50px; border-radius:14px; border:1px solid #cbd5e1; background:#ffffff; box-shadow:none; font-size:.98rem; padding:0 14px; outline:none; transition:border-color .18s ease, box-shadow .18s ease, transform .18s ease;" />
                    </div>

                    <div>
                        <label style="display:block; margin-bottom:7px; color:#0f172a; font-size:.95rem; font-weight:800;">
                            Нова парола
                        </label>
                        <input type="password"
                               name="NewPassword"
                               class="student-password-input"
                               style="width:100%; height:50px; border-radius:14px; border:1px solid #cbd5e1; background:#ffffff; box-shadow:none; font-size:.98rem; padding:0 14px; outline:none; transition:border-color .18s ease, box-shadow .18s ease, transform .18s ease;" />
                    </div>

                    <div>
                        <label style="display:block; margin-bottom:7px; color:#0f172a; font-size:.95rem; font-weight:800;">
                            Потвърди новата парола
                        </label>
                        <input type="password"
                               name="ConfirmPassword"
                               class="student-password-input"
                               style="width:100%; height:50px; border-radius:14px; border:1px solid #cbd5e1; background:#ffffff; box-shadow:none; font-size:.98rem; padding:0 14px; outline:none; transition:border-color .18s ease, box-shadow .18s ease, transform .18s ease;" />
                    </div>
                </div>

                <div style="margin-top:18px;">
                    <button type="submit"
                            id="saveStudentPasswordBtn"
                            style="width:100%; height:50px; border:none; border-radius:14px; background:linear-gradient(135deg, #2563eb 0%, #3b82f6 100%); color:#ffffff; font-size:1rem; font-weight:800; box-shadow:0 14px 28px rgba(37,99,235,.18); transition:transform .18s ease, box-shadow .18s ease, filter .18s ease;">
                        Запази новата парола
                    </button>
                </div>
            </form>
        </div>
    </div>
}

<style>
    html {
        scroll-behavior: smooth;
    }

    .student-portal-page {
        width: 100%;
        display: grid;
        grid-template-columns: 270px minmax(0, 1fr);
        gap: 42px;
        align-items: start;
        padding-top: 8px;
    }

    .student-portal-sidebar {
        position: sticky;
        top: 92px;
        align-self: start;
    }

    .student-portal-sidebar-inner {
        padding-top: 4px;
    }

    .student-portal-sidebar-label {
        margin-bottom: 10px;
        color: #94a3b8;
        font-size: .75rem;
        font-weight: 800;
        letter-spacing: .11em;
        text-transform: uppercase;
    }

    .student-portal-sidebar-title {
        margin: 0 0 24px 0;
        color: #0f172a;
        font-size: 1.9rem;
        line-height: 1.08;
        font-weight: 900;
    }

    .student-portal-nav {
        display: flex;
        flex-direction: column;
        gap: 8px;
    }

    .student-nav-link {
        display: flex;
        align-items: center;
        gap: 12px;
        min-height: 42px;
        text-decoration: none;
        color: #475569;
        font-size: .97rem;
        font-weight: 700;
        line-height: 1.4;
        transition: .18s ease;
    }

        .student-nav-link:hover {
            color: #2563eb;
        }

        .student-nav-link.active {
            color: #2563eb;
            font-weight: 900;
        }

    .student-nav-line {
        width: 3px;
        height: 24px;
        border-radius: 999px;
        background: transparent;
        transition: .18s ease;
        flex: 0 0 3px;
    }

    .student-nav-link.active .student-nav-line {
        background: #2563eb;
    }

    .student-portal-content {
        min-width: 0;
        padding-right: 6px;
    }

    .student-portal-section {
        scroll-margin-top: 110px;
        margin-bottom: 60px;
    }

    .student-section-header {
        margin-bottom: 18px;
    }

    .student-section-title {
        margin: 0;
        color: #0f172a;
        font-size: 1.95rem;
        line-height: 1.08;
        font-weight: 900;
        letter-spacing: -.02em;
    }

    .student-section-subtitle {
        margin: 8px 0 0 0;
        color: #64748b;
        font-size: .98rem;
        font-weight: 700;
        line-height: 1.65;
    }

    .student-table-wrap {
        border: 1px solid #e2e8f0;
        border-radius: 18px;
        overflow: hidden;
        background: #ffffff;
        box-shadow: 0 12px 32px rgba(15, 23, 42, .04);
    }

    .student-loans-table {
        width: 100%;
        border-collapse: collapse;
    }

        .student-loans-table thead th {
            background: #f8fafc;
            color: #475569;
            font-size: .82rem;
            font-weight: 800;
            letter-spacing: .04em;
            text-transform: uppercase;
            padding: 15px 16px;
            border-bottom: 1px solid #e5e7eb;
            text-align: left;
        }

        .student-loans-table tbody td {
            padding: 14px 16px;
            vertical-align: middle;
            border-bottom: 1px solid #eef2f7;
        }

        .student-loans-table tbody tr:last-child td {
            border-bottom: none;
        }

        .student-loans-table tbody tr:hover {
            background: #fbfdff;
        }

    .student-cover-box {
        display: flex;
        align-items: center;
    }

    .student-mini-cover {
        width: 42px;
        height: 58px;
        object-fit: cover;
        border-radius: 10px;
        border: 1px solid #dbe4ef;
        background: #f8fafc;
        display: block;
    }

    .student-cover-placeholder {
        align-items: center;
        justify-content: center;
        color: #94a3b8;
        font-size: .68rem;
        font-weight: 800;
        text-transform: uppercase;
        display: flex;
    }

    .student-book-cell {
        min-width: 0;
    }

    .student-book-title {
        color: #0f172a;
        font-size: 1rem;
        font-weight: 800;
        line-height: 1.45;
    }

    .student-book-author {
        margin-top: 5px;
        color: #64748b;
        font-size: .92rem;
        font-weight: 700;
        line-height: 1.5;
    }

    .student-date-cell {
        color: #0f172a;
        font-size: .94rem;
        font-weight: 800;
    }

    .student-return-status {
        font-size: .94rem;
        font-weight: 800;
        line-height: 1.45;
    }

        .student-return-status.normal {
            color: #0f172a;
        }

        .student-return-status.overdue {
            color: #dc2626;
        }

        .student-return-status.extended {
            color: #ca8a04;
        }

    .student-empty-state {
        color: #64748b;
        font-size: .98rem;
        font-weight: 700;
        line-height: 1.7;
        padding-top: 4px;
    }

    @@media (max-width: 1100px) {
        .student-portal-page {
            grid-template-columns: 230px minmax(0, 1fr);
            gap: 28px;
        }
    }

    @@media (max-width: 900px) {
        .student-portal-page {
            grid-template-columns: 1fr;
            gap: 24px;
        }

        .student-portal-sidebar {
            position: relative;
            top: auto;
        }

        .student-portal-sidebar-title {
            margin-bottom: 16px;
        }

        .student-portal-nav {
            gap: 4px;
        }

        .student-loans-table {
            min-width: 720px;
        }

        .student-table-wrap {
            overflow-x: auto;
        }
    }
</style>

<script>
    (function () {
        const links = Array.from(document.querySelectorAll('#studentScrollspy .student-nav-link'));
        const sections = Array.from(document.querySelectorAll('.student-portal-section'));

        function setActive(hash) {
            links.forEach(link => {
                link.classList.toggle('active', link.getAttribute('href') === hash);
            });
        }

        links.forEach(link => {
            link.addEventListener('click', function () {
                setActive(link.getAttribute('href'));
            });
        });

        const observer = new IntersectionObserver((entries) => {
            const visible = entries
                .filter(entry => entry.isIntersecting)
                .sort((a, b) => Math.abs(a.boundingClientRect.top) - Math.abs(b.boundingClientRect.top));

            if (visible.length > 0) {
                setActive('#' + visible[0].target.id);
            }
        }, {
            rootMargin: '-18% 0px -62% 0px',
            threshold: [0.15, 0.35, 0.55]
        });

        sections.forEach(section => observer.observe(section));

        document.querySelectorAll('.student-password-input').forEach(input => {
            input.addEventListener('mouseenter', function () {
                if (document.activeElement !== input) {
                    input.style.borderColor = '#93c5fd';
                    input.style.boxShadow = '0 10px 24px rgba(37,99,235,.08)';
                    input.style.transform = 'translateY(-1px)';
                }
            });

            input.addEventListener('mouseleave', function () {
                if (document.activeElement !== input) {
                    input.style.borderColor = '#cbd5e1';
                    input.style.boxShadow = 'none';
                    input.style.transform = 'translateY(0)';
                }
            });

            input.addEventListener('focus', function () {
                input.style.borderColor = '#3b82f6';
                input.style.boxShadow = '0 0 0 4px rgba(59,130,246,.12), 0 10px 24px rgba(37,99,235,.08)';
                input.style.transform = 'translateY(-1px)';
            });

            input.addEventListener('blur', function () {
                input.style.borderColor = '#cbd5e1';
                input.style.boxShadow = 'none';
                input.style.transform = 'translateY(0)';
            });
        });

        const saveStudentPasswordBtn = document.getElementById('saveStudentPasswordBtn');
        if (saveStudentPasswordBtn) {
            saveStudentPasswordBtn.addEventListener('mouseenter', function () {
                saveStudentPasswordBtn.style.transform = 'translateY(-2px)';
                saveStudentPasswordBtn.style.boxShadow = '0 18px 34px rgba(37,99,235,.24)';
                saveStudentPasswordBtn.style.filter = 'brightness(1.03)';
            });

            saveStudentPasswordBtn.addEventListener('mouseleave', function () {
                saveStudentPasswordBtn.style.transform = 'translateY(0)';
                saveStudentPasswordBtn.style.boxShadow = '0 14px 28px rgba(37,99,235,.18)';
                saveStudentPasswordBtn.style.filter = 'none';
            });
        }
    })();
</script>