@model ObreshkovLibrary.Models.ViewModels.CatalogIndexVM
@using ObreshkovLibrary.Models
@using System.Linq

@{
    Layout = "~/Views/Shared/_PublicLayout.cshtml";
    ViewData["Title"] = "Каталог";

    var categories = Model.Categories ?? new List<Category>();

    var rootCategories = categories
        .Where(c => c.ParentCategoryId == null)
        .OrderBy(c => c.Name)
        .ToList();

    var openIds = new HashSet<int>();

    if (Model.SelectedCategoryId.HasValue)
    {
        var current = categories.FirstOrDefault(c => c.Id == Model.SelectedCategoryId.Value);
        while (current != null)
        {
            openIds.Add(current.Id);
            current = current.ParentCategoryId.HasValue
                ? categories.FirstOrDefault(c => c.Id == current.ParentCategoryId.Value)
                : null;
        }
    }

    string GetCover(Book book) => book.CoverPath ?? "";
    List<Category> GetChildren(int parentId)
        => categories.Where(c => c.ParentCategoryId == parentId).OrderBy(c => c.Name).ToList();
}

<div style="width:100%;min-height:calc(100vh - 78px);padding:28px 0 40px;background:linear-gradient(180deg,#f5f8fc 0%,#eef3f8 100%);">

    <div style="width:min(1360px,calc(100% - 28px));margin:0 auto;">

        <div class="catalog-grid"
             style="display:grid;grid-template-columns:270px 1fr;gap:24px;align-items:start;">


            <!-- SIDEBAR -->

            <aside style="
position:sticky;
top:94px;
border-radius:28px;
background:linear-gradient(180deg,#ffffffcc,#f3f7fc);
border:1px solid #dde6f1;
box-shadow:0 20px 50px rgba(15,23,42,.05);
overflow:hidden;
">

                <div style="padding:18px 18px 12px;border-bottom:1px solid #e6edf4;">
                    <div style="font-size:.72rem;font-weight:900;letter-spacing:.14em;color:#6b7f95;text-transform:uppercase;">
                        Категории
                    </div>
                    <div style="margin-top:6px;font-size:1.08rem;font-weight:900;color:#17325c;">
                        Разгледай по жанр
                    </div>
                </div>


                <div style="padding:12px;max-height:calc(100vh - 220px);overflow:auto;">

                    <a asp-controller="Catalog"
                       asp-action="Index"
                       asp-route-search="@Model.Search"
                       asp-route-sort="@Model.Sort"
                       style="
display:flex;
align-items:center;
min-height:44px;
padding:0 14px;
border-radius:14px;
font-size:.9rem;
font-weight:900;
text-decoration:none;
color:@(Model.SelectedCategoryId == null ? "#2563eb" : "#1f3555");
background:@(Model.SelectedCategoryId == null ? "#eef4ff" : "#fff");
border:1px solid #e2eaf2;
margin-bottom:8px;
">
                        Всички книги
                    </a>


                    @foreach (var root in rootCategories)
                    {
                        var children = GetChildren(root.Id);
                        var open = openIds.Contains(root.Id);
                        var selected = Model.SelectedCategoryId == root.Id;

                        <div style="margin-bottom:6px;border-radius:14px;border:1px solid #e5edf4;background:#fff;overflow:hidden;">

                            <div style="display:flex;align-items:center;padding:8px 8px;gap:6px;">

                                @if (children.Any())
                                {
                                    <button type="button"
                                            class="tree-toggle-btn"
                                            data-target="cat-@root.Id"
                                            style="
        width:28px;height:28px;
        border:none;
        border-radius:8px;
        background:#eef4ff;
        font-weight:900;
        cursor:pointer;
        ">
                                        <span class="tree-plus" style="display:@(open ? "none" : "inline")">+</span>
                                        <span class="tree-minus" style="display:@(open ? "inline" : "none")">−</span>
                                    </button>
                                }
                                else
                                {
                                    <span style="width:28px;height:28px;"></span>
                                }

                                <a asp-controller="Catalog"
                                   asp-action="Index"
                                   asp-route-categoryId="@root.Id"
                                   asp-route-search="@Model.Search"
                                   asp-route-sort="@Model.Sort"
                                   style="
    flex:1;
    font-size:.85rem;
    font-weight:800;
    text-decoration:none;
    padding:6px 8px;
    border-radius:10px;
    color:@(selected?"#2563eb":"#304c6a");
    background:@(selected?"#eef4ff":"transparent");
    ">
                                    @root.Name
                                </a>

                            </div>


                            @if (children.Any())
                            {
                                <div id="cat-@root.Id" style="display:@(open ? "block" : "none");padding:0 8px 8px 8px;">
                                    @foreach (var child in children)
                                    {
                                        var selectedChild = Model.SelectedCategoryId == child.Id;

                                        <a asp-controller="Catalog"
                                           asp-action="Index"
                                           asp-route-categoryId="@child.Id"
                                           asp-route-search="@Model.Search"
                                           asp-route-sort="@Model.Sort"
                                           style="
            display:block;
            font-size:.8rem;
            font-weight:800;
            padding:6px 10px 6px 36px;
            border-radius:9px;
            text-decoration:none;
            color:@(selectedChild?"#2563eb":"#4c647f");
            background:@(selectedChild?"#eef4ff":"transparent");
            ">
                                            @child.Name
                                        </a>
                                    }
                                </div>
                            }

                        </div>
                    }

                </div>
            </aside>



            <!-- MAIN -->

            <section>

                <!-- FILTER BAR -->

                <section style="
border-radius:26px;
background:#ffffffcc;
border:1px solid #dde6f1;
padding:14px;
margin-bottom:20px;
box-shadow:0 18px 40px rgba(15,23,42,.05);
">

                    <form method="get"
                          asp-action="Index"
                          style="
display:grid;
grid-template-columns:1fr 220px 120px;
gap:12px;
">

                        <input type="hidden" name="categoryId" value="@Model.SelectedCategoryId" />

                        <input name="search"
                               value="@Model.Search"
                               placeholder="Търси по заглавие, автор, жанр или категория..."
                               style="
height:50px;
border-radius:16px;
border:1px solid #dbe4ee;
padding:0 18px;
font-weight:700;
" />

                        <select name="sort"
                                style="
height:50px;
border-radius:16px;
border:1px solid #dbe4ee;
padding:0 14px;
font-weight:800;
">

                            <option value="date_desc">Най-нови първо</option>
                            <option value="date_asc">Най-стари първо</option>
                            <option value="name_asc">Име А-Я</option>
                            <option value="name_desc">Име Я-А</option>

                        </select>

                        <button type="submit"
                                style="
border:none;
border-radius:16px;
background:linear-gradient(180deg,#67abef,#3f86e7);
color:white;
font-weight:900;
cursor:pointer;
transition:.2s;
">
                            Приложи
                        </button>

                    </form>

                </section>



                <!-- BOOK GRID -->

                <section style="
border-radius:28px;
background:#ffffffcc;
border:1px solid #dde6f1;
padding:26px;
box-shadow:0 18px 40px rgba(15,23,42,.05);
">

                    <h2 style="
margin:0;
font-size:2.1rem;
font-weight:900;
color:#17325c;
letter-spacing:-.02em;
">
                        @Model.SelectedCategoryName
                    </h2>

                    <div style="
margin-top:20px;
display:grid;
grid-template-columns:repeat(4,1fr);
gap:24px;
">

                        @foreach (var book in Model.Books)
                        {
                            var cover = GetCover(book);

                            <a asp-controller="Catalog"
                               asp-action="Details"
                               asp-route-id="@book.Id"
                               style="
    position:relative;
    display:flex;
    flex-direction:column;
    border-radius:20px;
    padding:12px;
    background:white;
    border:1px solid #e6edf5;
    text-decoration:none;
    transition:.25s;
    box-shadow:0 10px 25px rgba(15,23,42,.03);
    "
                               onmouseover="
    this.style.transform='translateY(-6px)';
    this.querySelector('.overlay').style.opacity='1';
    "
                               onmouseout="
    this.style.transform='translateY(0)';
    this.querySelector('.overlay').style.opacity='0';
    ">

                                <div style="
    height:210px;
    border-radius:14px;
    overflow:hidden;
    position:relative;
    display:flex;
    align-items:center;
    justify-content:center;
    background:#f4f7fb;
    ">

                                    @if (!string.IsNullOrEmpty(cover))
                                    {
                                        <img src="@cover"
                                             style="max-width:100%;max-height:100%;object-fit:contain;">
                                    }

                                    <div class="overlay"
                                         style="
    position:absolute;
    inset:0;
    background:rgba(37,99,235,.78);
    display:flex;
    align-items:center;
    justify-content:center;
    font-weight:900;
    color:white;
    letter-spacing:.05em;
    font-size:.9rem;
    opacity:0;
    transition:.25s;
    ">
                                        Виж детайли
                                    </div>

                                </div>

                                <div style="margin-top:10px;font-weight:900;font-size:.95rem;color:#0f172a;">
                                    @book.Title
                                </div>

                                <div style="font-size:.9rem;font-weight:700;color:#6b7f95;">
                                    @book.Author
                                </div>

                            </a>
                        }

                    </div>

                </section>

            </section>

        </div>
    </div>
</div>


@section Scripts {
    <script>
        document.querySelectorAll(".tree-toggle-btn").forEach(btn=>{
        btn.addEventListener("click",()=>{
        const target=document.getElementById(btn.dataset.target)
        const plus=btn.querySelector(".tree-plus")
        const minus=btn.querySelector(".tree-minus")

        if(target.style.display==="none"){
        target.style.display="block"
        plus.style.display="none"
        minus.style.display="inline"
        }else{
        target.style.display="none"
        plus.style.display="inline"
        minus.style.display="none"
        }
        })
        })
    </script>
}