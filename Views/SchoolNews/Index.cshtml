@model IEnumerable<ObreshkovLibrary.Models.SchoolNews>

@{
    ViewData["Title"] = "Актуално в ППМГ";
}

<div class="page-container" style="padding-top: 110px; padding-bottom: 28px;">
    <div class="d-flex justify-content-between align-items-center flex-wrap gap-3 mb-4">
        <div>
            <h2 class="section-title mb-1">Актуално в ППМГ</h2>
            <div class="accent-line"></div>
        </div>

        <a asp-controller="SchoolNews" asp-action="Create" class="btn btn-primary" style="border-radius:12px; font-weight:700;">
            Добави новина
        </a>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success" style="border-radius:14px;">
            @TempData["SuccessMessage"]
        </div>
    }

    <section class="card-soft" style="padding: 18px; border-radius: 18px; background: #ffffff;">
        @if (!Model.Any())
        {
            <div style="padding: 24px 10px; color: #64748b;">Все още няма добавени новини.</div>
        }
        else
        {
            <div style="overflow-x:auto;">
                <table class="table align-middle mb-0">
                    <thead>
                        <tr>
                            <th>Снимка</th>
                            <th>Заглавие</th>
                            <th>Дата</th>
                            <th>Ред</th>
                            <th>Статус</th>
                            <th>Линк</th>
                            <th class="text-end">Действия</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td style="width:110px;">
                                    @if (!string.IsNullOrWhiteSpace(item.ImagePath))
                                    {
                                        <img src="@Url.Content(item.ImagePath)"
                                             alt="@item.Title"
                                             style="width:80px;height:56px;object-fit:cover;border-radius:10px;border:1px solid #dbe5ef;" />
                                    }
                                </td>
                                <td>
                                    <div style="font-weight:800; color:#1f2937;">@item.Title</div>
                                    <div style="font-size:.92rem; color:#64748b; max-width:420px;">
                                        @item.Summary
                                    </div>
                                </td>
                                <td>@item.PublishedOn.ToString("dd.MM.yyyy")</td>
                                <td>@item.DisplayOrder</td>
                                <td>
                                    @if (item.IsActive)
                                    {
                                        <span class="badge bg-success">Активна</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">Скрита</span>
                                    }
                                </td>
                                <td>
                                    <a href="@item.NewsUrl" target="_blank" style="font-weight:700;">Отвори</a>
                                </td>
                                <td class="text-end">
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary me-2">Редактирай</a>
                                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger">Изтрий</a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </section>
</div>