<!DOCTYPE html>
<html lang="bg">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - ObreshkovLibrary</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/ObreshkovLibrary.styles.css" asp-append-version="true" />
</head>
<body style="margin:0; min-height:100vh; background:#ffffff; color:#243247; font-family:'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;">
    <header style="margin:0; padding:0; background:#ffffff;">
        <partial name="_StudentNavPartial" />
    </header>

    <partial name="_StudentAlertsPartial" />

    <main style="margin:0; padding:0; width:100%; background:#ffffff;">
        @RenderBody()
    </main>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>