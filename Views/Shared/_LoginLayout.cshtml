<!DOCTYPE html>
<html lang="bg">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - ObreshkovLibrary</title>

    <link rel="stylesheet" href="~/css/site.css" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
</head>
<body style="margin:0; background:linear-gradient(to bottom,#f6f9ff,#eef2f9);">

    <div style="
        height:64px;
        display:flex;
        align-items:center;
        justify-content:center;
        font-weight:800;
        font-size:1.1rem;
        color:#1f2937;
        border-bottom:1px solid #e2e8f0;
        background:#ffffff;
        box-shadow:0 1px 0 rgba(15,23,42,.02);">
        Училищна библиотека „Обрешков“
    </div>

    @RenderBody()

    <div style="
        position:fixed;
        bottom:12px;
        left:0;
        right:0;
        text-align:center;
        font-size:.8rem;
        color:#94a3b8;
        pointer-events:none;">
        © ППМГ „Никола Обрешков“
    </div>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>