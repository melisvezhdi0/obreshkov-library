@{
    var currentController = ViewContext.RouteData.Values["controller"]?.ToString();
    var currentAction = ViewContext.RouteData.Values["action"]?.ToString();

    bool isHomeActive = currentController == "Home" && currentAction == "ReaderIndex";
    bool isCatalogActive = currentController == "Catalog";
    bool isNotificationsActive = currentController == "ReaderPortal" && currentAction == "Notifications";
    bool isFavoritesActive = currentController == "ReaderPortal" && currentAction == "Favorites";
    bool isProfileActive = currentController == "ReaderPortal" && currentAction == "Index";

    bool hasUnread = ViewBag.HasUnreadNotifications == true;

    string textStyle(bool active)
    {
        return active
            ? "display:inline-flex; align-items:center; justify-content:center; height:44px; padding:0 18px; border-radius:12px; background:linear-gradient(180deg,#eef4ff 0%,#e9f1ff 100%); color:#2563eb; font-weight:800; border:1px solid #dbe7fb; text-decoration:none; box-shadow:0 8px 18px rgba(37,99,235,.08); transition:background .18s ease, color .18s ease, border-color .18s ease, box-shadow .18s ease, transform .18s ease;"
            : "display:inline-flex; align-items:center; justify-content:center; height:44px; padding:0 18px; border-radius:12px; background:transparent; color:#475569; font-weight:800; border:1px solid transparent; text-decoration:none; transition:background .18s ease, color .18s ease, border-color .18s ease, box-shadow .18s ease, transform .18s ease;";
    }

    string iconStyle(bool active)
    {
        return active
            ? "width:44px; height:44px; border-radius:12px; background:linear-gradient(180deg,#eef4ff 0%,#e9f1ff 100%); color:#2563eb; display:inline-flex; align-items:center; justify-content:center; border:1px solid #dbe7fb; text-decoration:none; position:relative; box-shadow:0 8px 18px rgba(37,99,235,.08); transition:background .18s ease, color .18s ease, border-color .18s ease, box-shadow .18s ease, transform .18s ease;"
            : "width:44px; height:44px; border-radius:12px; background:transparent; color:#475569; display:inline-flex; align-items:center; justify-content:center; border:1px solid transparent; text-decoration:none; position:relative; transition:background .18s ease, color .18s ease, border-color .18s ease, box-shadow .18s ease, transform .18s ease;";
    }
}

<nav class="reader-top-nav"
     style="width:100%;
            position:sticky;
            top:0;
            z-index:1200;
            background:rgba(255,255,255,.96);
            backdrop-filter:blur(10px);
            border-bottom:1px solid #e5e7eb;
            box-shadow:0 1px 0 rgba(15,23,42,.02);">

    <div style="width:100%;
                min-height:72px;
                padding:0 26px;
                display:flex;
                align-items:center;
                justify-content:space-between;
                gap:18px;
                box-sizing:border-box;">

        <a asp-controller="Home"
           asp-action="ReaderIndex"
           style="text-decoration:none; color:#17325c; font-size:1.08rem; font-weight:900; letter-spacing:.01em; white-space:nowrap;">
            Училищна библиотека „Обрешков“
        </a>

        <div style="display:flex;
                    align-items:center;
                    justify-content:flex-end;
                    gap:8px;
                    flex-wrap:wrap;">

            <a asp-controller="Home"
               asp-action="ReaderIndex"
               style="@textStyle(isHomeActive)"
               onmouseover="this.style.background='#f8fbff'; this.style.color='#1d4ed8'; this.style.borderColor='#e2e8f0'; this.style.boxShadow='0 10px 20px rgba(15,23,42,.06)'; this.style.transform='translateY(-1px)';"
               onmouseout="this.style.background='@(isHomeActive ? "linear-gradient(180deg,#eef4ff 0%,#e9f1ff 100%)" : "transparent")'; this.style.color='@(isHomeActive ? "#2563eb" : "#475569")'; this.style.borderColor='@(isHomeActive ? "#dbe7fb" : "transparent")'; this.style.boxShadow='@(isHomeActive ? "0 8px 18px rgba(37,99,235,.08)" : "none")'; this.style.transform='translateY(0)';">
                Начало
            </a>

            <a asp-controller="Catalog"
               asp-action="ReaderIndex"
               style="@textStyle(isCatalogActive)"
               onmouseover="this.style.background='#f8fbff'; this.style.color='#1d4ed8'; this.style.borderColor='#e2e8f0'; this.style.boxShadow='0 10px 20px rgba(15,23,42,.06)'; this.style.transform='translateY(-1px)';"
               onmouseout="this.style.background='@(isCatalogActive ? "linear-gradient(180deg,#eef4ff 0%,#e9f1ff 100%)" : "transparent")'; this.style.color='@(isCatalogActive ? "#2563eb" : "#475569")'; this.style.borderColor='@(isCatalogActive ? "#dbe7fb" : "transparent")'; this.style.boxShadow='@(isCatalogActive ? "0 8px 18px rgba(37,99,235,.08)" : "none")'; this.style.transform='translateY(0)';">
                Каталог
            </a>

            <div style="position:relative;">
                <button type="button"
                        id="readerNotificationsToggle"
                        style="@iconStyle(isNotificationsActive); cursor:pointer;"
                        onmouseover="this.style.background='#f8fbff'; this.style.color='#1d4ed8'; this.style.borderColor='#e2e8f0'; this.style.boxShadow='0 10px 20px rgba(15,23,42,.06)'; this.style.transform='translateY(-1px)';"
                        onmouseout="this.style.background='@(isNotificationsActive ? "linear-gradient(180deg,#eef4ff 0%,#e9f1ff 100%)" : "transparent")'; this.style.color='@(isNotificationsActive ? "#2563eb" : "#475569")'; this.style.borderColor='@(isNotificationsActive ? "#dbe7fb" : "transparent")'; this.style.boxShadow='@(isNotificationsActive ? "0 8px 18px rgba(37,99,235,.08)" : "none")'; this.style.transform='translateY(0)';"
                        title="Съобщения"
                        aria-label="Съобщения">

                    <svg xmlns="http://www.w3.org/2000/svg"
                         width="19"
                         height="19"
                         viewBox="0 0 16 16"
                         fill="currentColor"
                         style="display:block;">
                        <path d="M8 16a2 2 0 0 0 2-2H6a2 2 0 0 0 2 2m.995-14.901a1 1 0 1 0-1.99 0A5 5 0 0 0 3 6c0 1.098-.5 6-2 7h14c-1.5-1-2-5.902-2-7 0-2.42-1.72-4.44-4.005-4.901" />
                    </svg>

                    @if (hasUnread)
                    {
                        <span style="position:absolute;
                                         top:8px;
                                         right:8px;
                                         width:8px;
                                         height:8px;
                                         border-radius:50%;
                                         background:#2563eb;
                                         box-shadow:0 0 0 3px #ffffff;">
                        </span>
                    }
                </button>

                @await Component.InvokeAsync("ReaderNotifications")
            </div>

            <a asp-controller="ReaderPortal"
               asp-action="Favorites"
               style="@iconStyle(isFavoritesActive)"
               onmouseover="this.style.background='#f8fbff'; this.style.color='#1d4ed8'; this.style.borderColor='#e2e8f0'; this.style.boxShadow='0 10px 20px rgba(15,23,42,.06)'; this.style.transform='translateY(-1px)';"
               onmouseout="this.style.background='@(isFavoritesActive ? "linear-gradient(180deg,#eef4ff 0%,#e9f1ff 100%)" : "transparent")'; this.style.color='@(isFavoritesActive ? "#2563eb" : "#475569")'; this.style.borderColor='@(isFavoritesActive ? "#dbe7fb" : "transparent")'; this.style.boxShadow='@(isFavoritesActive ? "0 8px 18px rgba(37,99,235,.08)" : "none")'; this.style.transform='translateY(0)';"
               title="Списък за четене"
               aria-label="Списък за четене">

                <svg xmlns="http://www.w3.org/2000/svg"
                     width="19"
                     height="19"
                     viewBox="0 0 16 16"
                     fill="currentColor"
                     style="display:block;">
                    <path d="M2 2a2 2 0 0 1 2-2h7a1 1 0 0 1 1 1v13l-4-2-4 2V2z" />
                </svg>
            </a>

            <a asp-controller="ReaderPortal"
               asp-action="Index"
               style="@textStyle(isProfileActive)"
               onmouseover="this.style.background='#f8fbff'; this.style.color='#1d4ed8'; this.style.borderColor='#e2e8f0'; this.style.boxShadow='0 10px 20px rgba(15,23,42,.06)'; this.style.transform='translateY(-1px)';"
               onmouseout="this.style.background='@(isProfileActive ? "linear-gradient(180deg,#eef4ff 0%,#e9f1ff 100%)" : "transparent")'; this.style.color='@(isProfileActive ? "#2563eb" : "#475569")'; this.style.borderColor='@(isProfileActive ? "#dbe7fb" : "transparent")'; this.style.boxShadow='@(isProfileActive ? "0 8px 18px rgba(37,99,235,.08)" : "none")'; this.style.transform='translateY(0)';">
                Моят профил
            </a>

        </div>
    </div>
</nav>

<script>
    document.addEventListener("DOMContentLoaded", function () {
        const toggle = document.getElementById("readerNotificationsToggle");
        const dropdown = document.getElementById("readerNotificationsDropdown");

        if (!toggle || !dropdown) return;

        toggle.addEventListener("click", function (e) {
            e.preventDefault();
            e.stopPropagation();

            dropdown.style.display = dropdown.style.display === "block" ? "none" : "block";
        });

        document.addEventListener("click", function (e) {
            if (!dropdown.contains(e.target) && !toggle.contains(e.target)) {
                dropdown.style.display = "none";
            }
        });
    });
</script>