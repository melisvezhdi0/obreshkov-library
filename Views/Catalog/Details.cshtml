@model ObreshkovLibrary.Models.Book
@using ObreshkovLibrary.Models
@using System.Linq

@{
    Layout = "~/Views/Shared/_PublicLayout.cshtml";
    ViewData["Title"] = Model.Title;

    var isAvailable = (ViewBag.IsAvailable as bool?) ?? false;
    var relatedBooks = (ViewBag.RelatedBooks as List<Book>) ?? new List<Book>();
    var similarBooks = (ViewBag.SimilarBooks as List<Book>) ?? new List<Book>();

    var isStudent = (ViewBag.IsStudent as bool?) ?? false;
    var isFavorite = (ViewBag.IsFavorite as bool?) ?? false;
    var hasAvailabilityRequest = (ViewBag.HasAvailabilityRequest as bool?) ?? false;
    var currentReturnUrl = $"{Context.Request.Path}{Context.Request.QueryString}";

    string categoryName = "Няма категория";
    if (Model.Category != null)
    {
        categoryName = Model.Category.ParentCategory != null
            ? $"{Model.Category.ParentCategory.Name} / {Model.Category.Name}"
            : Model.Category.Name;
    }

    List<string> tagNames = new();

    if ((Model.Tags & BookTags.Classic) == BookTags.Classic) tagNames.Add("Класика");
    if ((Model.Tags & BookTags.Romance) == BookTags.Romance) tagNames.Add("Любовен");
    if ((Model.Tags & BookTags.Drama) == BookTags.Drama) tagNames.Add("Драма");
    if ((Model.Tags & BookTags.Fantasy) == BookTags.Fantasy) tagNames.Add("Фентъзи");
    if ((Model.Tags & BookTags.Horror) == BookTags.Horror) tagNames.Add("Ужаси");
    if ((Model.Tags & BookTags.Bulgarian) == BookTags.Bulgarian) tagNames.Add("Българска литература");
    if ((Model.Tags & BookTags.Foreign) == BookTags.Foreign) tagNames.Add("Чужда литература");
    if ((Model.Tags & BookTags.SchoolLiterature) == BookTags.SchoolLiterature) tagNames.Add("Училищна литература");

    var authorSliderId = $"authorSlider_{Model.Id}";
    var authorTrackId = $"authorTrack_{Model.Id}";
    var similarSliderId = $"similarSlider_{Model.Id}";
    var similarTrackId = $"similarTrack_{Model.Id}";
}

<div style="width:100%; min-height:calc(100vh - 80px); background:#f3f6fa; padding:28px 0 42px;">
    <div style="width:min(1220px, calc(100% - 24px)); margin:0 auto;">

        <div style="display:flex; justify-content:space-between; align-items:flex-start; gap:16px; flex-wrap:wrap; margin-bottom:20px;">
            <div>
                <h1 style="margin:0; color:#17325c; font-size:2.65rem; line-height:1.05; font-weight:900; letter-spacing:-0.03em;">
                    @Model.Title
                </h1>
                <div style="width:60px; height:4px; border-radius:999px; margin-top:10px; background:linear-gradient(90deg,#2563eb 0%,#4f8cff 100%);"></div>
            </div>

            <a asp-controller="Catalog"
               asp-action="Index"
               style="display:inline-flex; align-items:center; justify-content:center; min-height:44px; padding:0 17px; border-radius:12px; border:1px solid #cfd8e3; background:#ffffff; color:#2563eb; text-decoration:none; font-size:0.95rem; font-weight:800; white-space:nowrap; box-shadow:0 8px 20px rgba(37,99,235,0.06); transition:all .18s ease;"
               onmouseover="this.style.transform='translateY(-2px)'; this.style.background='#f8fbff'; this.style.borderColor='#bdd0ea'; this.style.boxShadow='0 12px 26px rgba(37,99,235,0.10)'"
               onmouseout="this.style.transform='translateY(0)'; this.style.background='#ffffff'; this.style.borderColor='#cfd8e3'; this.style.boxShadow='0 8px 20px rgba(37,99,235,0.06)'">
                Назад към каталога
            </a>
        </div>

        <section style="border:1px solid #d8e1eb; border-radius:24px; background:#ffffff; box-shadow:0 10px 28px rgba(15,23,42,0.05); overflow:hidden; margin-bottom:20px; transition:box-shadow .22s ease, transform .22s ease;"
                 onmouseover="this.style.boxShadow='0 18px 42px rgba(37,99,235,0.08)'; this.style.transform='translateY(-2px)'"
                 onmouseout="this.style.boxShadow='0 10px 28px rgba(15,23,42,0.05)'; this.style.transform='translateY(0)'">
            <div class="catalog-main-grid"
                 style="display:grid; grid-template-columns:360px minmax(0,1fr); gap:26px; padding:24px; align-items:stretch;">

                <div style="display:flex;">
                    <div style="width:100%; min-height:540px; border:1px solid #dbe3ec; border-radius:24px; background:linear-gradient(180deg,#f8fafc 0%,#eef3f8 100%); padding:16px; display:flex; align-items:center; justify-content:center; transition:all .22s ease;"
                         onmouseover="this.style.borderColor='#c7d5e5'; this.style.boxShadow='inset 0 1px 0 rgba(255,255,255,0.9), 0 16px 32px rgba(15,23,42,0.06)'"
                         onmouseout="this.style.borderColor='#dbe3ec'; this.style.boxShadow='none'">
                        @if (!string.IsNullOrWhiteSpace(Model.CoverPath))
                        {
                            <img src="@Model.CoverPath"
                                 alt="@Model.Title"
                                 style="width:100%; height:100%; max-height:640px; object-fit:contain; display:block; border-radius:16px; background:#ffffff; box-shadow:0 16px 34px rgba(15,23,42,0.13); transition:transform .22s ease, box-shadow .22s ease;"
                                 onmouseover="this.style.transform='scale(1.02)'; this.style.boxShadow='0 22px 42px rgba(15,23,42,0.18)'"
                                 onmouseout="this.style.transform='scale(1)'; this.style.boxShadow='0 16px 34px rgba(15,23,42,0.13)'" />
                        }
                        else
                        {
                            <div style="width:100%; min-height:500px; border:2px dashed #cad5e0; border-radius:18px; background:#f8fbff; display:flex; align-items:center; justify-content:center; text-align:center; padding:18px; color:#6b7c8e; font-size:1rem; font-weight:800;">
                                Няма корица
                            </div>
                        }
                    </div>
                </div>

                <div style="display:flex; flex-direction:column; gap:18px; min-width:0; height:100%;">

                    <div style="padding:4px 2px 0 2px;">
                        <div style="color:#64748b; font-size:1rem; font-weight:800; margin-bottom:6px;">
                            Автор
                        </div>
                        <div style="color:#17325c; font-size:1.45rem; line-height:1.25; font-weight:900;">
                            @Model.Author
                        </div>
                    </div>

                    <div style="border:1px solid #d9e1ea; border-radius:22px; overflow:hidden; background:#ffffff; flex:1; display:flex; flex-direction:column; box-shadow:0 8px 22px rgba(15,23,42,0.03);">

                        <div class="catalog-info-row" style="display:grid; grid-template-columns:210px minmax(0,1fr); min-height:68px; border-bottom:1px solid #e4ebf2;">
                            <div style="display:flex; align-items:center; padding:1rem 1.15rem; background:#fbfcfe; color:#64748b; font-size:0.97rem; font-weight:900;">Статус</div>
                            <div style="display:flex; align-items:center; justify-content:flex-end; text-align:right; padding:1rem 1.15rem;">
                                <span style="display:inline-flex; align-items:center; justify-content:center; min-height:36px; padding:0 15px; border-radius:999px; font-size:0.92rem; font-weight:900; white-space:nowrap; @(isAvailable ? "background:#e8f7ee; color:#2f7d32; border:1px solid #cfe7d3;" : "background:#fff1ee; color:#c2410c; border:1px solid #ffd6c8;")">
                                    @(isAvailable ? "Налична" : "Не е налична")
                                </span>
                            </div>
                        </div>

                        <div class="catalog-info-row" style="display:grid; grid-template-columns:210px minmax(0,1fr); min-height:68px; border-bottom:1px solid #e4ebf2;">
                            <div style="display:flex; align-items:center; padding:1rem 1.15rem; background:#fbfcfe; color:#64748b; font-size:0.97rem; font-weight:900;">Година</div>
                            <div style="display:flex; align-items:center; justify-content:flex-end; text-align:right; padding:1rem 1.15rem; color:#0f172a; font-size:1rem; font-weight:800;">
                                @(Model.Year.HasValue? Model.Year.ToString() : "Няма данни")
                            </div>
                        </div>

                        <div class="catalog-info-row" style="display:grid; grid-template-columns:210px minmax(0,1fr); min-height:68px; border-bottom:1px solid #e4ebf2;">
                            <div style="display:flex; align-items:center; padding:1rem 1.15rem; background:#fbfcfe; color:#64748b; font-size:0.97rem; font-weight:900;">Категория</div>
                            <div style="display:flex; align-items:center; justify-content:flex-end; text-align:right; padding:1rem 1.15rem; color:#0f172a; font-size:1rem; font-weight:800;">
                                @categoryName
                            </div>
                        </div>

                        <div class="catalog-info-row" style="display:grid; grid-template-columns:210px minmax(0,1fr); min-height:68px; border-bottom:1px solid #e4ebf2;">
                            <div style="display:flex; align-items:center; padding:1rem 1.15rem; background:#fbfcfe; color:#64748b; font-size:0.97rem; font-weight:900;">Клас</div>
                            <div style="display:flex; align-items:center; justify-content:flex-end; text-align:right; padding:1rem 1.15rem; color:#0f172a; font-size:1rem; font-weight:800;">
                                @(string.IsNullOrWhiteSpace(Model.SchoolClass) ? "Не е посочен" : Model.SchoolClass)
                            </div>
                        </div>

                        <div class="catalog-info-row" style="display:grid; grid-template-columns:210px minmax(0,1fr); min-height:78px;">
                            <div style="display:flex; align-items:center; padding:1rem 1.15rem; background:#fbfcfe; color:#64748b; font-size:0.97rem; font-weight:900;">Тагове</div>
                            <div style="display:flex; align-items:center; justify-content:flex-end; text-align:right; padding:1rem 1.15rem;">
                                @if (tagNames.Any())
                                {
                                    <div style="display:flex; justify-content:flex-end; flex-wrap:wrap; gap:8px; width:100%;">
                                        @foreach (var tag in tagNames)
                                        {
                                            <span style="display:inline-flex; align-items:center; padding:0.5rem 0.92rem; border-radius:999px; border:1px solid #d8e6ff; background:#eef4ff; color:#2563eb; font-size:0.89rem; font-weight:800; line-height:1; transition:all .18s ease;"
                                                  onmouseover="this.style.transform='translateY(-1px)'; this.style.background='#e7f0ff'; this.style.boxShadow='0 8px 18px rgba(37,99,235,0.12)'"
                                                  onmouseout="this.style.transform='translateY(0)'; this.style.background='#eef4ff'; this.style.boxShadow='none'">
                                                @tag
                                            </span>
                                        }
                                    </div>
                                }
                                else
                                {
                                    <span style="color:#6b7c8e; font-size:0.97rem; font-weight:700;">Няма тагове</span>
                                }
                                @if (isStudent)
                                {
                                    <section style="border:1px solid #d8e1eb; border-radius:22px; background:#ffffff; box-shadow:0 8px 22px rgba(15,23,42,0.03); padding:18px; margin-top:18px;">
                                        <h3 style="margin:0 0 14px 0; color:#17325c; font-size:1.1rem; font-weight:900;">
                                            Опции за ученик
                                        </h3>

                                        <div style="display:flex; gap:12px; flex-wrap:wrap;">
                                            <form asp-controller="StudentPortal" asp-action="ToggleFavorite" method="post" style="margin:0;">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="bookId" value="@Model.Id" />
                                                <input type="hidden" name="returnUrl" value="@currentReturnUrl" />

                                                @if (isFavorite)
                                                {
                                                    <button type="submit" class="btn btn-outline-danger">
                                                        Премахни от любими
                                                    </button>
                                                }
                                                else
                                                {
                                                    <button type="submit" class="btn btn-primary">
                                                        Добави в любими
                                                    </button>
                                                }
                                            </form>

                                            @if (!isAvailable)
                                            {
                                                @if (hasAvailabilityRequest)
                                                {
                                                    <div class="alert alert-info mb-0" style="display:flex; align-items:center;">
                                                        Вече имаш активна заявка да бъдеш уведомен, когато книгата стане налична.
                                                    </div>
                                                }
                                                else
                                                {
                                                    <form asp-controller="StudentPortal" asp-action="RequestAvailabilityNotification" method="post" style="margin:0;">
                                                        @Html.AntiForgeryToken()
                                                        <input type="hidden" name="bookId" value="@Model.Id" />
                                                        <input type="hidden" name="returnUrl" value="@currentReturnUrl" />
                                                        <button type="submit" class="btn btn-outline-primary">
                                                            Уведоми ме, когато е налична
                                                        </button>
                                                    </form>
                                                }
                                            }
                                        </div>
                                    </section>
                                }
                            </div>
                        </div>

                    </div>
                </div>

            </div>
        </section>

        <section style="border:1px solid #d8e1eb; border-radius:24px; background:#ffffff; box-shadow:0 10px 28px rgba(15,23,42,0.05); overflow:hidden; margin-bottom:20px; transition:box-shadow .22s ease, transform .22s ease;"
                 onmouseover="this.style.boxShadow='0 18px 42px rgba(37,99,235,0.08)'; this.style.transform='translateY(-2px)'"
                 onmouseout="this.style.boxShadow='0 10px 28px rgba(15,23,42,0.05)'; this.style.transform='translateY(0)'">
            <div style="padding:16px 20px; border-bottom:1px solid #e2e8f0;">
                <h3 style="margin:0; color:#17325c; font-size:1.18rem; font-weight:900; letter-spacing:-0.02em;">
                    Описание
                </h3>
            </div>

            @if (!string.IsNullOrWhiteSpace(Model.Description))
            {
                <div style="padding:20px;">
                    <p style="margin:0; color:#334155; font-size:1rem; line-height:1.85; white-space:pre-line;">
                        @Model.Description
                    </p>
                </div>
            }
            else
            {
                <div style="padding:20px; color:#6b7c8e; font-weight:700;">
                    Няма добавено описание за тази книга.
                </div>
            }
        </section>

        @if (relatedBooks.Any())
        {
            <section style="border:1px solid #d8e1eb; border-radius:24px; background:#ffffff; box-shadow:0 10px 28px rgba(15,23,42,0.05); overflow:hidden; margin-bottom:20px; transition:box-shadow .22s ease, transform .22s ease;"
                     onmouseover="this.style.boxShadow='0 18px 42px rgba(37,99,235,0.08)'; this.style.transform='translateY(-2px)'"
                     onmouseout="this.style.boxShadow='0 10px 28px rgba(15,23,42,0.05)'; this.style.transform='translateY(0)'">
                <div style="padding:16px 20px; border-bottom:1px solid #e2e8f0;">
                    <h3 style="margin:0; color:#17325c; font-size:1.18rem; font-weight:900; letter-spacing:-0.02em;">
                        Още от автора
                    </h3>
                </div>

                <div style="position:relative; padding:18px 22px 30px;">
                    <button type="button"
                            onclick="scrollBooks('@authorSliderId', '@authorTrackId', -1)"
                            class="slider-arrow left"
                            style="position:absolute; left:10px; top:42%; transform:translateY(-50%); width:46px; height:46px; border:none; border-radius:999px; background:rgba(255,255,255,0.94); color:#2563eb; font-size:1.45rem; font-weight:900; cursor:pointer; z-index:3; box-shadow:0 10px 24px rgba(15,23,42,0.16); transition:all .18s ease;"
                            onmouseover="this.style.transform='translateY(-50%) scale(1.08)'; this.style.background='#eef4ff'; this.style.boxShadow='0 14px 28px rgba(37,99,235,0.18)'"
                            onmouseout="this.style.transform='translateY(-50%) scale(1)'; this.style.background='rgba(255,255,255,0.94)'; this.style.boxShadow='0 10px 24px rgba(15,23,42,0.16)'">
                        ‹
                    </button>

                    <button type="button"
                            onclick="scrollBooks('@authorSliderId', '@authorTrackId', 1)"
                            class="slider-arrow right"
                            style="position:absolute; right:10px; top:42%; transform:translateY(-50%); width:46px; height:46px; border:none; border-radius:999px; background:rgba(255,255,255,0.94); color:#2563eb; font-size:1.45rem; font-weight:900; cursor:pointer; z-index:3; box-shadow:0 10px 24px rgba(15,23,42,0.16); transition:all .18s ease;"
                            onmouseover="this.style.transform='translateY(-50%) scale(1.08)'; this.style.background='#eef4ff'; this.style.boxShadow='0 14px 28px rgba(37,99,235,0.18)'"
                            onmouseout="this.style.transform='translateY(-50%) scale(1)'; this.style.background='rgba(255,255,255,0.94)'; this.style.boxShadow='0 10px 24px rgba(15,23,42,0.16)'">
                        ›
                    </button>

                    <div id="@authorSliderId"
                         onscroll="updateDots('@authorSliderId', '@authorTrackId')"
                         style="display:flex; gap:16px; overflow-x:auto; scroll-behavior:smooth; padding:8px 34px 6px; scrollbar-width:none; -ms-overflow-style:none;">
                        @foreach (var book in relatedBooks)
                        {
                            <a asp-controller="Catalog"
                               asp-action="Details"
                               asp-route-id="@book.Id"
                               style="flex:0 0 152px; width:152px; display:flex; flex-direction:column; align-items:center; text-decoration:none; color:inherit; background:transparent; padding:4px 2px; transition:transform .2s ease;"
                               onmouseover="this.style.transform='translateY(-6px) scale(1.03)'"
                               onmouseout="this.style.transform='translateY(0) scale(1)'">
                                <div style="width:100%; height:215px; display:flex; align-items:center; justify-content:center; background:#ffffff; border-radius:16px; overflow:hidden; margin-bottom:10px; border:1px solid #e8eef5; box-shadow:0 12px 22px rgba(15,23,42,0.08); transition:all .22s ease;"
                                     onmouseover="this.style.boxShadow='0 20px 34px rgba(37,99,235,0.16)'; this.style.borderColor='#c9d9ee'"
                                     onmouseout="this.style.boxShadow='0 12px 22px rgba(15,23,42,0.08)'; this.style.borderColor='#e8eef5'">
                                    @if (!string.IsNullOrWhiteSpace(book.CoverPath))
                                    {
                                        <img src="@book.CoverPath"
                                             alt="@book.Title"
                                             style="max-width:100%; max-height:100%; object-fit:contain; display:block; transition:transform .22s ease;"
                                             onmouseover="this.style.transform='scale(1.04)'"
                                             onmouseout="this.style.transform='scale(1)'" />
                                    }
                                    else
                                    {
                                        <span style="color:#94a3b8; font-size:11px; font-weight:700;">Няма корица</span>
                                    }
                                </div>

                                <div style="text-align:center; font-weight:800; font-size:14px; line-height:1.3; color:#0f172a; transition:color .18s ease;"
                                     onmouseover="this.style.color='#2563eb'"
                                     onmouseout="this.style.color='#0f172a'">
                                    @book.Title
                                </div>
                            </a>
                        }
                    </div>

                    <div id="@authorTrackId"
                         style="display:flex; justify-content:center; gap:7px; margin-top:14px;"></div>
                </div>
            </section>
        }

        @if (similarBooks.Any())
        {
            <section style="border:1px solid #d8e1eb; border-radius:24px; background:#ffffff; box-shadow:0 10px 28px rgba(15,23,42,0.05); overflow:hidden; transition:box-shadow .22s ease, transform .22s ease;"
                     onmouseover="this.style.boxShadow='0 18px 42px rgba(37,99,235,0.08)'; this.style.transform='translateY(-2px)'"
                     onmouseout="this.style.boxShadow='0 10px 28px rgba(15,23,42,0.05)'; this.style.transform='translateY(0)'">
                <div style="padding:16px 20px; border-bottom:1px solid #e2e8f0;">
                    <h3 style="margin:0; color:#17325c; font-size:1.18rem; font-weight:900; letter-spacing:-0.02em;">
                        Подобни книги
                    </h3>
                </div>

                <div style="position:relative; padding:18px 22px 30px;">
                    <button type="button"
                            onclick="scrollBooks('@similarSliderId', '@similarTrackId', -1)"
                            class="slider-arrow left"
                            style="position:absolute; left:10px; top:42%; transform:translateY(-50%); width:46px; height:46px; border:none; border-radius:999px; background:rgba(255,255,255,0.94); color:#2563eb; font-size:1.45rem; font-weight:900; cursor:pointer; z-index:3; box-shadow:0 10px 24px rgba(15,23,42,0.16); transition:all .18s ease;"
                            onmouseover="this.style.transform='translateY(-50%) scale(1.08)'; this.style.background='#eef4ff'; this.style.boxShadow='0 14px 28px rgba(37,99,235,0.18)'"
                            onmouseout="this.style.transform='translateY(-50%) scale(1)'; this.style.background='rgba(255,255,255,0.94)'; this.style.boxShadow='0 10px 24px rgba(15,23,42,0.16)'">
                        ‹
                    </button>

                    <button type="button"
                            onclick="scrollBooks('@similarSliderId', '@similarTrackId', 1)"
                            class="slider-arrow right"
                            style="position:absolute; right:10px; top:42%; transform:translateY(-50%); width:46px; height:46px; border:none; border-radius:999px; background:rgba(255,255,255,0.94); color:#2563eb; font-size:1.45rem; font-weight:900; cursor:pointer; z-index:3; box-shadow:0 10px 24px rgba(15,23,42,0.16); transition:all .18s ease;"
                            onmouseover="this.style.transform='translateY(-50%) scale(1.08)'; this.style.background='#eef4ff'; this.style.boxShadow='0 14px 28px rgba(37,99,235,0.18)'"
                            onmouseout="this.style.transform='translateY(-50%) scale(1)'; this.style.background='rgba(255,255,255,0.94)'; this.style.boxShadow='0 10px 24px rgba(15,23,42,0.16)'">
                        ›
                    </button>

                    <div id="@similarSliderId"
                         onscroll="updateDots('@similarSliderId', '@similarTrackId')"
                         style="display:flex; gap:16px; overflow-x:auto; scroll-behavior:smooth; padding:8px 34px 6px; scrollbar-width:none; -ms-overflow-style:none;">
                        @foreach (var book in similarBooks)
                        {
                            <a asp-controller="Catalog"
                               asp-action="Details"
                               asp-route-id="@book.Id"
                               style="flex:0 0 152px; width:152px; display:flex; flex-direction:column; align-items:center; text-decoration:none; color:inherit; background:transparent; padding:4px 2px; transition:transform .2s ease;"
                               onmouseover="this.style.transform='translateY(-6px) scale(1.03)'"
                               onmouseout="this.style.transform='translateY(0) scale(1)'">
                                <div style="width:100%; height:215px; display:flex; align-items:center; justify-content:center; background:#ffffff; border-radius:16px; overflow:hidden; margin-bottom:10px; border:1px solid #e8eef5; box-shadow:0 12px 22px rgba(15,23,42,0.08); transition:all .22s ease;"
                                     onmouseover="this.style.boxShadow='0 20px 34px rgba(37,99,235,0.16)'; this.style.borderColor='#c9d9ee'"
                                     onmouseout="this.style.boxShadow='0 12px 22px rgba(15,23,42,0.08)'; this.style.borderColor='#e8eef5'">
                                    @if (!string.IsNullOrWhiteSpace(book.CoverPath))
                                    {
                                        <img src="@book.CoverPath"
                                             alt="@book.Title"
                                             style="max-width:100%; max-height:100%; object-fit:contain; display:block; transition:transform .22s ease;"
                                             onmouseover="this.style.transform='scale(1.04)'"
                                             onmouseout="this.style.transform='scale(1)'" />
                                    }
                                    else
                                    {
                                        <span style="color:#94a3b8; font-size:11px; font-weight:700;">Няма корица</span>
                                    }
                                </div>

                                <div style="text-align:center; font-weight:800; font-size:14px; line-height:1.3; color:#0f172a; transition:color .18s ease;"
                                     onmouseover="this.style.color='#2563eb'"
                                     onmouseout="this.style.color='#0f172a'">
                                    @book.Title
                                </div>
                            </a>
                        }
                    </div>

                    <div id="@similarTrackId"
                         style="display:flex; justify-content:center; gap:7px; margin-top:14px;"></div>
                </div>
            </section>
        }

    </div>
</div>

<script>
    function getSliderMetrics(container) {
        const card = container.querySelector('a');
        const step = card ? card.offsetWidth + 16 : 168;
        const visibleWidth = container.clientWidth;
        const totalWidth = container.scrollWidth;
        const pages = Math.max(1, Math.ceil(totalWidth / visibleWidth));
        return { step, visibleWidth, totalWidth, pages };
    }

    function renderDots(containerId, trackId) {
        const container = document.getElementById(containerId);
        const track = document.getElementById(trackId);
        if (!container || !track) return;

        const metrics = getSliderMetrics(container);
        track.innerHTML = '';

        if (metrics.pages <= 1) return;

        for (let i = 0; i < metrics.pages; i++) {
            const dot = document.createElement('button');
            dot.type = 'button';
            dot.setAttribute('aria-label', 'Слайд ' + (i + 1));
            dot.style.width = i === 0 ? '24px' : '16px';
            dot.style.height = '4px';
            dot.style.border = 'none';
            dot.style.borderRadius = '999px';
            dot.style.background = i === 0 ? '#2563eb' : '#cfd9e8';
            dot.style.opacity = i === 0 ? '1' : '0.9';
            dot.style.cursor = 'pointer';
            dot.style.transition = 'all .18s ease';
            dot.onclick = function () {
                container.scrollTo({
                    left: i * metrics.visibleWidth,
                    behavior: 'smooth'
                });
            };
            track.appendChild(dot);
        }
    }

    function updateDots(containerId, trackId) {
        const container = document.getElementById(containerId);
        const track = document.getElementById(trackId);
        if (!container || !track || !track.children.length) return;

        const metrics = getSliderMetrics(container);
        const pageIndex = Math.min(
            track.children.length - 1,
            Math.round(container.scrollLeft / metrics.visibleWidth)
        );

        for (let i = 0; i < track.children.length; i++) {
            const dot = track.children[i];
            dot.style.width = i === pageIndex ? '24px' : '16px';
            dot.style.background = i === pageIndex ? '#2563eb' : '#cfd9e8';
            dot.style.opacity = i === pageIndex ? '1' : '0.9';
        }
    }

    function scrollBooks(containerId, trackId, direction) {
        const container = document.getElementById(containerId);
        if (!container) return;

        const metrics = getSliderMetrics(container);
        container.scrollBy({
            left: direction * metrics.visibleWidth,
            behavior: 'smooth'
        });

        setTimeout(function () {
            updateDots(containerId, trackId);
        }, 320);
    }

    window.addEventListener('load', function () {
        renderDots('@authorSliderId', '@authorTrackId');
        renderDots('@similarSliderId', '@similarTrackId');
        updateDots('@authorSliderId', '@authorTrackId');
        updateDots('@similarSliderId', '@similarTrackId');
    });

    window.addEventListener('resize', function () {
        renderDots('@authorSliderId', '@authorTrackId');
        renderDots('@similarSliderId', '@similarTrackId');
        updateDots('@authorSliderId', '@authorTrackId');
        updateDots('@similarSliderId', '@similarTrackId');
    });
</script>

<style>
    # @authorSliderId ::-webkit-scrollbar,
    # @similarSliderId ::-webkit-scrollbar {
        display: none;
    }

    @@media (max-width: 900px) {
        .catalog-main-grid {
            grid-template-columns: 1fr !important;
        }

        .catalog-info-row {
            grid-template-columns: 1fr !important;
        }

        .slider-arrow.left {
            left: 4px !important;
        }

        .slider-arrow.right {
            right: 4px !important;
        }
    }
</style>