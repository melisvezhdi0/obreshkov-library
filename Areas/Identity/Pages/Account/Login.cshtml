@page
@model ObreshkovLibrary.Areas.Identity.Pages.Account.LoginModel

@{
    ViewData["Title"] = "Вход";
    var selectedRole = Model?.Input?.SelectedRole == "Admin" ? "Admin" : "Student";
}

<div style="min-height:calc(100vh - 76px); display:flex; align-items:flex-start; justify-content:center; padding:42px 16px 12px 16px; box-sizing:border-box; overflow:hidden;">
    <div style="width:100%; max-width:640px;">

        <div style="text-align:center; margin-bottom:14px;">
            <h1 style="margin:0; font-size:1.75rem; font-weight:800; color:#1f2937; line-height:1.1;">
                Вход в системата
            </h1>

            <div style="width:56px; height:3px; background:#3b82f6; margin:10px auto 0 auto; border-radius:999px;"></div>
        </div>

        <div style="background:#ffffff; border:1px solid #d9e2ec; box-shadow:0 12px 28px rgba(15, 23, 42, 0.07); overflow:hidden;">
            <div style="display:grid; grid-template-columns:1fr 1fr; background:#f8fbff; border-bottom:1px solid #d9e2ec;">
                <button type="button"
                        id="studentRoleBtn"
                        style="height:58px; border:none; border-right:1px solid #d9e2ec; background:#ffffff; color:#1f2937; font-size:1rem; font-weight:800;">
                    Ученик
                </button>

                <button type="button"
                        id="adminRoleBtn"
                        style="height:58px; border:none; background:#f8fbff; color:#64748b; font-size:1rem; font-weight:700;">
                    Админ
                </button>
            </div>

            <div style="padding:24px 28px 20px 28px;">
                <form id="account" method="post" style="margin:0;">
                    <div asp-validation-summary="ModelOnly" class="text-danger" style="margin-bottom:8px;"></div>

                    <input asp-for="Input.SelectedRole" type="hidden" id="selectedRoleInput" />

                    <div id="studentFields">
                        <div style="margin-bottom:14px;">
                            <label style="display:block; margin-bottom:6px; font-weight:800; color:#334155; font-size:0.98rem;">
                                Номер на читателска карта
                            </label>

                            <input asp-for="Input.CardNumber"
                                   id="studentCardNumberInput"
                                   placeholder="Напр. 766399"
                                   autocomplete="username"
                                   style="width:100%; height:44px; border:1px solid #cbd5e1; padding:0 14px; background:#ffffff; box-sizing:border-box; outline:none;" />

                            <span asp-validation-for="Input.CardNumber" class="text-danger"></span>
                        </div>
                    </div>

                    <div id="adminFields" style="display:none;">
                        <div style="margin-bottom:14px;">
                            <label style="display:block; margin-bottom:6px; font-weight:800; color:#334155; font-size:0.98rem;">
                                Имейл
                            </label>

                            <input asp-for="Input.Email"
                                   id="adminEmailInput"
                                   placeholder="admin@obreshkov.bg"
                                   autocomplete="username"
                                   style="width:100%; height:44px; border:1px solid #cbd5e1; padding:0 14px; background:#ffffff; box-sizing:border-box; outline:none;" />

                            <span asp-validation-for="Input.Email" class="text-danger"></span>
                        </div>
                    </div>

                    <div style="margin-bottom:12px;">
                        <label style="display:block; margin-bottom:6px; font-weight:800; color:#334155; font-size:0.98rem;">
                            Парола
                        </label>

                        <input asp-for="Input.Password"
                               autocomplete="current-password"
                               placeholder="Парола"
                               style="width:100%; height:44px; border:1px solid #cbd5e1; padding:0 14px; background:#ffffff; box-sizing:border-box; outline:none;" />

                        <span asp-validation-for="Input.Password" class="text-danger"></span>
                    </div>

                    <div style="display:flex; justify-content:space-between; align-items:center; gap:12px; margin-bottom:16px; flex-wrap:wrap;">
                        <label asp-for="Input.RememberMe"
                               style="display:flex; align-items:center; gap:8px; color:#475569; font-weight:600; margin:0;">
                            <input asp-for="Input.RememberMe" style="accent-color:#2563eb;" />
                            <span>Запомни ме</span>
                        </label>

                        <a id="forgotPasswordLink"
                           asp-area="Identity"
                           asp-page="/Account/ForgotPassword"
                           style="color:#2563eb; text-decoration:none; font-weight:800;">
                            Забравена парола
                        </a>
                    </div>

                    <div style="display:flex; justify-content:flex-end;">
                        <button id="login-submit"
                                type="submit"
                                style="min-width:210px; height:46px; border:none; background:#2563eb; color:#ffffff; font-weight:800; font-size:1rem;">
                            Вход
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        const selectedRoleInput = document.getElementById('selectedRoleInput');
        const studentRoleBtn = document.getElementById('studentRoleBtn');
        const adminRoleBtn = document.getElementById('adminRoleBtn');
        const studentFields = document.getElementById('studentFields');
        const adminFields = document.getElementById('adminFields');
        const forgotPasswordLink = document.getElementById('forgotPasswordLink');

        function setRole(role) {
            selectedRoleInput.value = role;

            if (role === 'Student') {
                studentFields.style.display = 'block';
                adminFields.style.display = 'none';

                studentRoleBtn.style.background = '#ffffff';
                studentRoleBtn.style.color = '#1f2937';
                studentRoleBtn.style.fontWeight = '800';

                adminRoleBtn.style.background = '#f8fbff';
                adminRoleBtn.style.color = '#64748b';
                adminRoleBtn.style.fontWeight = '700';

                forgotPasswordLink.href = '/Identity/Account/ForgotPassword?role=Student';
            } else {
                studentFields.style.display = 'none';
                adminFields.style.display = 'block';

                adminRoleBtn.style.background = '#ffffff';
                adminRoleBtn.style.color = '#1f2937';
                adminRoleBtn.style.fontWeight = '800';

                studentRoleBtn.style.background = '#f8fbff';
                studentRoleBtn.style.color = '#64748b';
                studentRoleBtn.style.fontWeight = '700';

                forgotPasswordLink.href = '/Identity/Account/ForgotPassword?role=Admin';
            }
        }

        studentRoleBtn.addEventListener('click', () => setRole('Student'));
        adminRoleBtn.addEventListener('click', () => setRole('Admin'));

        setRole('@selectedRole');
    </script>

    <script>
        (function () {
            const html = document.documentElement;
            const body = document.body;

            const oldHtmlOverflow = html.style.overflow;
            const oldBodyOverflow = body.style.overflow;

            html.style.overflow = 'hidden';
            body.style.overflow = 'hidden';

            window.addEventListener('beforeunload', function () {
                html.style.overflow = oldHtmlOverflow;
                body.style.overflow = oldBodyOverflow;
            });
        })();
    </script>
}