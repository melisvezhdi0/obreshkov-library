@model IEnumerable<ObreshkovLibrary.Models.SchoolNews>

@{
    ViewData["Title"] = "Архив актуално в ППМГ";
    string search = (ViewBag.Search ?? "").ToString();
}

@if (TempData["Success"] != null)
{
    <div style="margin-bottom:1rem; padding:12px 14px; border:1px solid #CBD5E1; background:#F8FAFC; color:#1E293B; border-radius:12px; font-weight:600;">
        @TempData["Success"]
    </div>
}

<div style="width:100%; padding-top:6px;">

    <div style="display:flex; align-items:end; justify-content:space-between; gap:1rem; flex-wrap:wrap; margin-bottom:1rem;">
        <div>
            <h2 class="section-title mb-1">Архив — актуално в ППМГ</h2>
            <div class="accent-line"></div>
        </div>
    </div>

    <section style="background:#ffffff; border:1px solid #D9E0E7; margin-bottom:1rem;">
        <div style="display:grid; grid-template-columns:repeat(7,1fr);">
            <a asp-action="Index" style="padding:14px 8px; text-align:center; text-decoration:none; border-right:1px solid #E5EAF0; background:#F8FBFF; color:#64748B; font-weight:700;">Скоро архивирани</a>
            <a asp-action="Books" style="padding:14px 8px; text-align:center; text-decoration:none; border-right:1px solid #E5EAF0; background:#F8FBFF; color:#64748B; font-weight:700;">Книги</a>
            <a asp-action="readers" style="padding:14px 8px; text-align:center; text-decoration:none; border-right:1px solid #E5EAF0; background:#F8FBFF; color:#64748B; font-weight:700;">Читатели</a>
            <a asp-action="Categories" style="padding:14px 8px; text-align:center; text-decoration:none; border-right:1px solid #E5EAF0; background:#F8FBFF; color:#64748B; font-weight:700;">Категории</a>
            <a asp-action="Copies" style="padding:14px 8px; text-align:center; text-decoration:none; border-right:1px solid #E5EAF0; background:#F8FBFF; color:#64748B; font-weight:700;">Копия</a>
            <a asp-action="Loans" style="padding:14px 8px; text-align:center; text-decoration:none; border-right:1px solid #E5EAF0; background:#F8FBFF; color:#64748B; font-weight:700;">Заеми</a>
            <a asp-action="SchoolNews" style="padding:14px 8px; text-align:center; text-decoration:none; background:#FFFFFF; color:#1F2937; font-weight:800;">Актуално в ППМГ</a>
        </div>
    </section>

    <section class="card-soft" style="padding:1rem; margin-bottom:1rem;">
        <form method="get" asp-action="SchoolNews" style="display:flex; align-items:center; gap:12px; width:100%; flex-wrap:nowrap;">

            <div style="position:relative; flex:1 1 auto; min-width:0;">
                <span style="position:absolute; left:15px; top:50%; transform:translateY(-50%); color:#94A3B8; font-size:1rem; pointer-events:none; z-index:2;">⌕</span>

                <input type="text"
                       name="search"
                       value="@search"
                       id="archiveNewsSearch"
                       placeholder="Търси по заглавие или текст..."
                       class="form-control"
                       style="width:100%; height:50px; border-radius:16px; border:1px solid #D7DFEA; background:#fff; color:#0F172A; padding-left:40px; padding-right:42px; font-weight:600; box-shadow:none;" />

                <button type="button"
                        id="archiveNewsClearBtn"
                        aria-label="Изчисти търсенето"
                        style="position:absolute; right:12px; top:50%; transform:translateY(-50%); width:22px; height:22px; border:none; background:#E2E8F0; color:#475569; border-radius:50%; @(string.IsNullOrWhiteSpace(search) ? "display:none;" : "display:inline-flex;") align-items:center; justify-content:center; font-size:15px; line-height:1; cursor:pointer; padding:0;">
                    ×
                </button>
            </div>

            <button type="submit"
                    class="btn btn-accent"
                    style="flex:0 0 110px; width:110px; height:50px; border-radius:16px;">
                Търси
            </button>
        </form>
    </section>

    <section class="card-soft" style="padding:0; overflow:hidden;">
        @if (!Model.Any())
        {
            <div style="padding:1.15rem; color:#6B7280; font-weight:600;">Няма архивирани новини.</div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table mb-0" style="margin-bottom:0;">
                    <thead>
                        <tr>
                            <th style="padding:.95rem 1.2rem;">Заглавие</th>
                            <th style="padding:.95rem 1.2rem;">Дата</th>
                            <th style="padding:.95rem 1.2rem;">Линк</th>
                            <th style="padding:.95rem 1.2rem; text-align:right;">Действия</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td style="padding:1rem 1.2rem;">
                                    <div style="font-weight:800; color:#1F2937;">@item.Title</div>
                                    <div style="margin-top:4px; color:#6B7280; font-weight:600;">@item.Summary</div>
                                </td>
                                <td style="padding:1rem 1.2rem;">@item.PublishedOn.ToString("dd.MM.yyyy")</td>
                                <td style="padding:1rem 1.2rem;">
                                    <a href="@item.NewsUrl" target="_blank" style="font-weight:800; color:#2563EB; text-decoration:none;">
                                        Отвори
                                    </a>
                                </td>
                                <td style="padding:1rem 1.2rem; text-align:right; white-space:nowrap;">
                                    <a asp-controller="SchoolNews"
                                       asp-action="Edit"
                                       asp-route-id="@item.Id"
                                       style="color:#3B82F6; font-weight:800; text-decoration:none; margin-right:14px;">
                                        Редакция
                                    </a>

                                    <form asp-action="RestoreSchoolNews"
                                          method="post"
                                          style="display:inline;">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@item.Id" />
                                        <button type="submit"
                                                style="height:38px; padding:0 14px; border:none; background:#2563EB; color:#fff; font-weight:800; border-radius:10px;">
                                            Възстанови
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </section>
</div>

@section Scripts {
    <script>
        (() => {
            const input = document.getElementById('archiveNewsSearch');
            const clearBtn = document.getElementById('archiveNewsClearBtn');

            if (!input || !clearBtn) return;

            function toggleClearButton() {
                clearBtn.style.display = input.value.trim().length > 0 ? 'inline-flex' : 'none';
            }

            clearBtn.addEventListener('click', () => {
                input.value = '';
                toggleClearButton();
                input.focus();
            });

            input.addEventListener('input', toggleClearButton);
            toggleClearButton();
        })();
    </script>
}