@using ObreshkovLibrary.Models
@model IEnumerable<ObreshkovLibrary.Models.Category>

@{
    ViewData["Title"] = "Категории";

    var allCategories = (Model ?? Enumerable.Empty<Category>()).ToList();

    var byParent = allCategories
        .OrderBy(c => c.Name)
        .ToLookup(c => c.ParentCategoryId);

    var orderedRows = new List<(Category Category, int Level, string Path)>();

    void AddBranch(int? parentId, int level, string? parentPath = null)
    {
        var children = byParent[parentId];

        foreach (var child in children)
        {
            var path = string.IsNullOrWhiteSpace(parentPath)
                ? child.Name
                : $"{parentPath} / {child.Name}";

            orderedRows.Add((child, level, path));
            AddBranch(child.Id, level + 1, path);
        }
    }

    AddBranch(null, 0);

    var addedIds = orderedRows.Select(x => x.Category.Id).ToHashSet();
    var orphanCategories = allCategories
        .Where(c => !addedIds.Contains(c.Id))
        .OrderBy(c => c.Name)
        .ToList();

    foreach (var orphan in orphanCategories)
    {
        orderedRows.Add((orphan, 0, orphan.Name));
    }
}

<div class="categories-page">

    <div class="categories-header">
        <div>
            <h2 class="section-title mb-1">Категории</h2>
            <div class="accent-line"></div>
        </div>

        <div class="categories-header-actions">
            <a asp-action="CreatePath" class="categories-add-btn">
                Добави категории
            </a>
        </div>
    </div>

    <section class="categories-panel card-soft">
        @if (!orderedRows.Any())
        {
            <div class="categories-empty-state">
                Няма добавени категории.
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table categories-table align-middle mb-0">
                    <thead>
                        <tr>
                            <th style="width: 55%;">Категория</th>
                            <th style="width: 30%;">Път</th>
                            <th style="width: 15%;" class="text-end">Преглед</th>
                        </tr>
                    </thead>

                    <tbody>
                        @foreach (var row in orderedRows)
                        {
                            var item = row.Category;
                            var level = row.Level;
                            var indent = level * 28;

                            <tr class="category-row @(level == 0 ? "category-root-row" : "")">
                                <td>
                                    <div class="category-tree-cell" style="padding-left:@(indent)px;">
                                        @if (level > 0)
                                        {
                                            <span class="tree-branch" aria-hidden="true"></span>
                                        }

                                        <span class="category-name-cell">@item.Name</span>
                                    </div>
                                </td>

                                <td>
                                    <span class="category-path-text">@row.Path</span>
                                </td>

                                <td class="text-end">
                                    <a asp-action="Details"
                                       asp-route-id="@item.Id"
                                       class="category-view-link">
                                        Виж
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </section>

</div>

