@model ObreshkovLibrary.Models.ViewModels.ArchiveDashboardVM

@{
    ViewData["Title"] = "Архив";
    var currentAction = ViewContext.RouteData.Values["action"]?.ToString() ?? "";
    bool isRecent = currentAction == "Index";
    bool isBooks = currentAction == "Books";
    bool isClients = currentAction == "Clients";
    bool isCategories = currentAction == "Categories";
    bool isCopies = currentAction == "Copies";
    bool isLoans = currentAction == "Loans";
    bool isNews = currentAction == "SchoolNews";
    bool isPasswords = currentAction == "PasswordRequests";
}

<div style="width:100%; padding-top:6px;">

    <div style="display:flex; align-items:end; justify-content:space-between; gap:1rem; flex-wrap:wrap; margin-bottom:1rem;">
        <div>
            <h2 class="section-title mb-1">Архив</h2>
            <div class="accent-line"></div>
        </div>
    </div>

    <section style="background:#ffffff; border:1px solid #D9E0E7; margin-bottom:1rem;">
        <div style="display:grid; grid-template-columns:repeat(8,1fr);">
            <a asp-controller="Archive" asp-action="Index"
               style="padding:14px 8px; text-align:center; text-decoration:none; border-right:1px solid #E5EAF0; @(isRecent ? "background:#FFFFFF; color:#1F2937; font-weight:800;" : "background:#F8FBFF; color:#64748B; font-weight:700;")">
                Скоро архивирани
            </a>

            <a asp-controller="Archive" asp-action="Books"
               style="padding:14px 8px; text-align:center; text-decoration:none; border-right:1px solid #E5EAF0; @(isBooks ? "background:#FFFFFF; color:#1F2937; font-weight:800;" : "background:#F8FBFF; color:#64748B; font-weight:700;")">
                Книги
            </a>

            <a asp-controller="Archive" asp-action="Clients"
               style="padding:14px 8px; text-align:center; text-decoration:none; border-right:1px solid #E5EAF0; @(isClients ? "background:#FFFFFF; color:#1F2937; font-weight:800;" : "background:#F8FBFF; color:#64748B; font-weight:700;")">
                Читатели
            </a>

            <a asp-controller="Archive" asp-action="Categories"
               style="padding:14px 8px; text-align:center; text-decoration:none; border-right:1px solid #E5EAF0; @(isCategories ? "background:#FFFFFF; color:#1F2937; font-weight:800;" : "background:#F8FBFF; color:#64748B; font-weight:700;")">
                Категории
            </a>

            <a asp-controller="Archive" asp-action="Copies"
               style="padding:14px 8px; text-align:center; text-decoration:none; border-right:1px solid #E5EAF0; @(isCopies ? "background:#FFFFFF; color:#1F2937; font-weight:800;" : "background:#F8FBFF; color:#64748B; font-weight:700;")">
                Копия
            </a>

            <a asp-controller="Archive" asp-action="Loans"
               style="padding:14px 8px; text-align:center; text-decoration:none; border-right:1px solid #E5EAF0; @(isLoans ? "background:#FFFFFF; color:#1F2937; font-weight:800;" : "background:#F8FBFF; color:#64748B; font-weight:700;")">
                Заеми
            </a>

            <a asp-controller="Archive" asp-action="SchoolNews"
               style="padding:14px 8px; text-align:center; text-decoration:none; border-right:1px solid #E5EAF0; @(isNews ? "background:#FFFFFF; color:#1F2937; font-weight:800;" : "background:#F8FBFF; color:#64748B; font-weight:700;")">
                Актуално в ППМГ
            </a>

            <a asp-controller="Archive" asp-action="PasswordRequests"
               style="padding:14px 8px; text-align:center; text-decoration:none; @(isPasswords ? "background:#FFFFFF; color:#1F2937; font-weight:800;" : "background:#F8FBFF; color:#64748B; font-weight:700;")">
                Пароли
            </a>
        </div>
    </section>

    <section class="card-soft" style="padding:1rem; margin-bottom:1rem;">
        <form method="get" asp-action="Index" style="display:flex; align-items:center; gap:12px; width:100%; flex-wrap:nowrap;">

            <div style="position:relative; flex:1 1 auto; min-width:0;">
                <span style="position:absolute; left:15px; top:50%; transform:translateY(-50%); color:#94A3B8; font-size:1rem; pointer-events:none; z-index:2;">⌕</span>

                <input type="text"
                       name="search"
                       value="@Model.Search"
                       id="archiveDashboardSearch"
                       placeholder="Търси в архива..."
                       class="form-control"
                       style="width:100%; height:50px; border-radius:16px; border:1px solid #D7DFEA; background:#fff; color:#0F172A; padding-left:40px; padding-right:42px; font-weight:600; box-shadow:none;" />

                <button type="button"
                        id="archiveDashboardClearBtn"
                        aria-label="Изчисти търсенето"
                        style="position:absolute; right:12px; top:50%; transform:translateY(-50%); width:22px; height:22px; border:none; background:#E2E8F0; color:#475569; border-radius:50%; @(string.IsNullOrWhiteSpace(Model.Search) ? "display:none;" : "display:inline-flex;") align-items:center; justify-content:center; font-size:15px; line-height:1; cursor:pointer; padding:0;">
                    ×
                </button>
            </div>

            <button type="submit"
                    class="btn btn-accent"
                    style="flex:0 0 110px; width:110px; height:50px; border-radius:16px;">
                Търси
            </button>
        </form>
    </section>

    <section style="display:grid; grid-template-columns:repeat(7,1fr); gap:12px; margin-bottom:1rem;">
        <a asp-action="Books" class="card-soft" style="text-decoration:none; padding:18px 16px; color:#1F2937;">
            <div style="font-size:.84rem; text-transform:uppercase; letter-spacing:.04em; color:#6B7280; font-weight:800;">Книги</div>
            <div style="margin-top:10px; font-size:1.7rem; font-weight:900;">@Model.BooksCount</div>
        </a>

        <a asp-action="Clients" class="card-soft" style="text-decoration:none; padding:18px 16px; color:#1F2937;">
            <div style="font-size:.84rem; text-transform:uppercase; letter-spacing:.04em; color:#6B7280; font-weight:800;">Читатели</div>
            <div style="margin-top:10px; font-size:1.7rem; font-weight:900;">@Model.ClientsCount</div>
        </a>

        <a asp-action="Categories" class="card-soft" style="text-decoration:none; padding:18px 16px; color:#1F2937;">
            <div style="font-size:.84rem; text-transform:uppercase; letter-spacing:.04em; color:#6B7280; font-weight:800;">Категории</div>
            <div style="margin-top:10px; font-size:1.7rem; font-weight:900;">@Model.CategoriesCount</div>
        </a>

        <a asp-action="Copies" class="card-soft" style="text-decoration:none; padding:18px 16px; color:#1F2937;">
            <div style="font-size:.84rem; text-transform:uppercase; letter-spacing:.04em; color:#6B7280; font-weight:800;">Копия</div>
            <div style="margin-top:10px; font-size:1.7rem; font-weight:900;">@Model.CopiesCount</div>
        </a>

        <a asp-action="Loans" class="card-soft" style="text-decoration:none; padding:18px 16px; color:#1F2937;">
            <div style="font-size:.84rem; text-transform:uppercase; letter-spacing:.04em; color:#6B7280; font-weight:800;">Заеми</div>
            <div style="margin-top:10px; font-size:1.7rem; font-weight:900;">@Model.LoansCount</div>
        </a>

        <a asp-action="SchoolNews" class="card-soft" style="text-decoration:none; padding:18px 16px; color:#1F2937;">
            <div style="font-size:.84rem; text-transform:uppercase; letter-spacing:.04em; color:#6B7280; font-weight:800;">Актуално в ППМГ</div>
            <div style="margin-top:10px; font-size:1.7rem; font-weight:900;">@Model.SchoolNewsCount</div>
        </a>

        <a asp-action="PasswordRequests" class="card-soft" style="text-decoration:none; padding:18px 16px; color:#1F2937;">
            <div style="font-size:.84rem; text-transform:uppercase; letter-spacing:.04em; color:#6B7280; font-weight:800;">Пароли</div>
            <div style="margin-top:10px; font-size:1.7rem; font-weight:900;">@Model.PasswordRequestsCount</div>
        </a>
    </section>

    <section style="display:grid; grid-template-columns:1fr 1fr; gap:16px;">

        <div class="card-soft" style="padding:0; overflow:hidden;">
            <div style="padding:1rem 1.2rem; border-bottom:1px solid #D9E0E7; background:#FBFCFD;">
                <h5 class="section-title mb-0">Последно архивирани книги</h5>
            </div>

            <div style="padding:.25rem 1.2rem 1rem;">
                @if (!Model.RecentBooks.Any())
                {
                    <div style="padding-top:.9rem; color:#6B7280; font-weight:600;">Няма архивирани книги.</div>
                }
                else
                {
                    foreach (var item in Model.RecentBooks)
                    {
                        <div style="padding:.9rem 0; border-bottom:1px solid #E5EAF0;">
                            <div style="font-weight:800; color:#1F2937;">@item.Title</div>
                            <div style="margin-top:4px; color:#6B7280; font-weight:600;">@item.Author</div>
                        </div>
                    }
                }
            </div>
        </div>

        <div class="card-soft" style="padding:0; overflow:hidden;">
            <div style="padding:1rem 1.2rem; border-bottom:1px solid #D9E0E7; background:#FBFCFD;">
                <h5 class="section-title mb-0">Последно архивирани читатели</h5>
            </div>

            <div style="padding:.25rem 1.2rem 1rem;">
                @if (!Model.RecentClients.Any())
                {
                    <div style="padding-top:.9rem; color:#6B7280; font-weight:600;">Няма архивирани читатели.</div>
                }
                else
                {
                    foreach (var item in Model.RecentClients)
                    {
                        <div style="padding:.9rem 0; border-bottom:1px solid #E5EAF0;">
                            <div style="font-weight:800; color:#1F2937;">@item.FirstName @item.MiddleName @item.LastName</div>
                            <div style="margin-top:4px; color:#6B7280; font-weight:600;">№ карта: @item.CardNumber</div>
                        </div>
                    }
                }
            </div>
        </div>

        <div class="card-soft" style="padding:0; overflow:hidden;">
            <div style="padding:1rem 1.2rem; border-bottom:1px solid #D9E0E7; background:#FBFCFD;">
                <h5 class="section-title mb-0">Последно архивирани категории</h5>
            </div>

            <div style="padding:.25rem 1.2rem 1rem;">
                @if (!Model.RecentCategories.Any())
                {
                    <div style="padding-top:.9rem; color:#6B7280; font-weight:600;">Няма архивирани категории.</div>
                }
                else
                {
                    foreach (var item in Model.RecentCategories)
                    {
                        <div style="padding:.9rem 0; border-bottom:1px solid #E5EAF0;">
                            <div style="font-weight:800; color:#1F2937;">@item.Name</div>
                            <div style="margin-top:4px; color:#6B7280; font-weight:600;">
                                @(item.ParentCategory != null ? $"Родител: {item.ParentCategory.Name}" : "Основна категория")
                            </div>
                        </div>
                    }
                }
            </div>
        </div>

        <div class="card-soft" style="padding:0; overflow:hidden;">
            <div style="padding:1rem 1.2rem; border-bottom:1px solid #D9E0E7; background:#FBFCFD;">
                <h5 class="section-title mb-0">Последно архивирани копия</h5>
            </div>

            <div style="padding:.25rem 1.2rem 1rem;">
                @if (!Model.RecentCopies.Any())
                {
                    <div style="padding-top:.9rem; color:#6B7280; font-weight:600;">Няма архивирани копия.</div>
                }
                else
                {
                    foreach (var item in Model.RecentCopies)
                    {
                        <div style="padding:.9rem 0; border-bottom:1px solid #E5EAF0;">
                            <div style="font-weight:800; color:#1F2937;">Копие №@item.Id</div>
                            <div style="margin-top:4px; color:#6B7280; font-weight:600;">@item.Book?.Title</div>
                        </div>
                    }
                }
            </div>
        </div>

        <div class="card-soft" style="padding:0; overflow:hidden;">
            <div style="padding:1rem 1.2rem; border-bottom:1px solid #D9E0E7; background:#FBFCFD;">
                <h5 class="section-title mb-0">Последно архивирани заеми</h5>
            </div>

            <div style="padding:.25rem 1.2rem 1rem;">
                @if (!Model.RecentLoans.Any())
                {
                    <div style="padding-top:.9rem; color:#6B7280; font-weight:600;">Няма архивирани заеми.</div>
                }
                else
                {
                    foreach (var item in Model.RecentLoans)
                    {
                        <div style="padding:.9rem 0; border-bottom:1px solid #E5EAF0;">
                            <div style="font-weight:800; color:#1F2937;">@item.Client?.FirstName @item.Client?.LastName</div>
                            <div style="margin-top:4px; color:#6B7280; font-weight:600;">@item.BookCopy?.Book?.Title</div>
                        </div>
                    }
                }
            </div>
        </div>

        <div class="card-soft" style="padding:0; overflow:hidden;">
            <div style="padding:1rem 1.2rem; border-bottom:1px solid #D9E0E7; background:#FBFCFD;">
                <h5 class="section-title mb-0">Последно архивирани новини</h5>
            </div>

            <div style="padding:.25rem 1.2rem 1rem;">
                @if (!Model.RecentSchoolNews.Any())
                {
                    <div style="padding-top:.9rem; color:#6B7280; font-weight:600;">Няма архивирани новини.</div>
                }
                else
                {
                    foreach (var item in Model.RecentSchoolNews)
                    {
                        <div style="padding:.9rem 0; border-bottom:1px solid #E5EAF0;">
                            <div style="font-weight:800; color:#1F2937;">@item.Title</div>
                            <div style="margin-top:4px; color:#6B7280; font-weight:600;">@item.PublishedOn.ToString("dd.MM.yyyy")</div>
                        </div>
                    }
                }
            </div>
        </div>

        <div class="card-soft" style="padding:0; overflow:hidden;">
            <div style="padding:1rem 1.2rem; border-bottom:1px solid #D9E0E7; background:#FBFCFD;">
                <h5 class="section-title mb-0">Последно обработени заявки за парола</h5>
            </div>

            <div style="padding:.25rem 1.2rem 1rem;">
                @if (!Model.RecentPasswordRequests.Any())
                {
                    <div style="padding-top:.9rem; color:#6B7280; font-weight:600;">Няма архивирани заявки за парола.</div>
                }
                else
                {
                    foreach (var item in Model.RecentPasswordRequests)
                    {
                        var fullName = item.Client != null
                        ? $"{item.Client.FirstName} {item.Client.LastName}"
                        : "Неизвестен читател";

                        <div style="padding:.9rem 0; border-bottom:1px solid #E5EAF0;">
                            <div style="font-weight:800; color:#1F2937;">@fullName</div>
                            <div style="margin-top:4px; color:#6B7280; font-weight:600;">№ карта: @item.CardNumber</div>
                        </div>
                    }
                }
            </div>
        </div>

    </section>
</div>

@section Scripts {
    <script>
        (() => {
            const input = document.getElementById('archiveDashboardSearch');
            const clearBtn = document.getElementById('archiveDashboardClearBtn');

            if (!input || !clearBtn) return;

            function toggleClearButton() {
                clearBtn.style.display = input.value.trim().length > 0 ? 'inline-flex' : 'none';
            }

            clearBtn.addEventListener('click', () => {
                input.value = '';
                toggleClearButton();
                input.focus();
            });

            input.addEventListener('input', toggleClearButton);
            toggleClearButton();
        })();
    </script>
}