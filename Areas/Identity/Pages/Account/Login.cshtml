@page
@model ObreshkovLibrary.Areas.Identity.Pages.Account.LoginModel

@{
    ViewData["Title"] = "Вход";
}

<div style="min-height:100vh; background:#eef3f8; display:flex; align-items:center; justify-content:center; padding:30px 16px;">
    <div style="width:100%; max-width:540px; background:#ffffff; border:1px solid #d8e1ea; box-shadow:0 10px 24px rgba(15, 23, 42, 0.08); overflow:hidden;">

        <div style="display:grid; grid-template-columns:1fr 1fr; border-bottom:1px solid #d8e1ea;">
            <button type="button"
                    id="studentRoleBtn"
                    style="height:72px; border:none; background:#f8fbff; color:#1d4f91; font-size:1.05rem; font-weight:800; text-transform:uppercase; border-right:1px solid #d8e1ea;">
                Ученик
            </button>

            <button type="button"
                    id="adminRoleBtn"
                    style="height:72px; border:none; background:#ffffff; color:#64748b; font-size:1.05rem; font-weight:700; text-transform:uppercase;">
                Админ
            </button>
        </div>

        <div style="padding:28px;">
            <form id="account" method="post" style="margin:0;">
                <div asp-validation-summary="ModelOnly" class="text-danger" role="alert" style="margin-bottom:14px;"></div>

                <input asp-for="Input.SelectedRole" type="hidden" id="selectedRoleInput" />

                <div id="studentFields">
                    <div style="margin-bottom:14px;">
                        <label style="display:block; margin-bottom:6px; font-weight:700; color:#334155;">
                            Номер на читателска карта
                        </label>
                        <input asp-for="Input.CardNumber"
                               id="studentCardNumberInput"
                               placeholder="Напр. LIB-2026-0001"
                               style="width:100%; height:46px; border:1px solid #cbd5e1; outline:none; padding:0 14px; background:#ffffff; color:#1f2937; box-sizing:border-box;" />
                        <span asp-validation-for="Input.CardNumber" class="text-danger"></span>
                    </div>
                </div>

                <div id="adminFields" style="display:none;">
                    <div style="margin-bottom:14px;">
                        <label style="display:block; margin-bottom:6px; font-weight:700; color:#334155;">
                            Имейл
                        </label>
                        <input asp-for="Input.Email"
                               id="adminEmailInput"
                               placeholder="admin@obreshkov.bg"
                               style="width:100%; height:46px; border:1px solid #cbd5e1; outline:none; padding:0 14px; background:#ffffff; color:#1f2937; box-sizing:border-box;" />
                        <span asp-validation-for="Input.Email" class="text-danger"></span>
                    </div>
                </div>

                <div style="margin-bottom:16px;">
                    <label style="display:block; margin-bottom:6px; font-weight:700; color:#334155;">
                        Парола
                    </label>
                    <input asp-for="Input.Password"
                           autocomplete="current-password"
                           placeholder="Парола"
                           style="width:100%; height:46px; border:1px solid #cbd5e1; outline:none; padding:0 14px; background:#ffffff; color:#1f2937; box-sizing:border-box;" />
                    <span asp-validation-for="Input.Password" class="text-danger"></span>
                </div>

                <div style="margin-bottom:16px;">
                    <button id="login-submit"
                            type="submit"
                            style="width:100%; height:46px; border:none; background:#2563eb; color:#ffffff; font-size:1rem; font-weight:800; text-transform:uppercase;">
                        Вход
                    </button>
                </div>

                <div style="display:flex; justify-content:space-between; align-items:center; gap:10px; flex-wrap:wrap;">
                    <label asp-for="Input.RememberMe" style="display:flex; align-items:center; gap:8px; color:#475569; cursor:pointer; margin:0;">
                        <input asp-for="Input.RememberMe" style="margin:0;" />
                        <span>Запомни ме</span>
                    </label>

                    <a id="forgotPasswordLink"
                       asp-area="Identity"
                       asp-page="/Account/ForgotPassword"
                       style="color:#2563eb; text-decoration:none; font-weight:700;">
                        Забравена парола
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        const selectedRoleInput = document.getElementById('selectedRoleInput');
        const studentRoleBtn = document.getElementById('studentRoleBtn');
        const adminRoleBtn = document.getElementById('adminRoleBtn');
        const studentFields = document.getElementById('studentFields');
        const adminFields = document.getElementById('adminFields');
        const forgotPasswordLink = document.getElementById('forgotPasswordLink');

        function setRole(role) {
            selectedRoleInput.value = role;

            if (role === 'Student') {
                studentFields.style.display = 'block';
                adminFields.style.display = 'none';

                studentRoleBtn.style.background = '#f8fbff';
                studentRoleBtn.style.color = '#1d4f91';
                studentRoleBtn.style.fontWeight = '800';

                adminRoleBtn.style.background = '#ffffff';
                adminRoleBtn.style.color = '#64748b';
                adminRoleBtn.style.fontWeight = '700';

                forgotPasswordLink.href = '/Identity/Account/ForgotPassword?role=Student';
            } else {
                studentFields.style.display = 'none';
                adminFields.style.display = 'block';

                adminRoleBtn.style.background = '#f8fbff';
                adminRoleBtn.style.color = '#1d4f91';
                adminRoleBtn.style.fontWeight = '800';

                studentRoleBtn.style.background = '#ffffff';
                studentRoleBtn.style.color = '#64748b';
                studentRoleBtn.style.fontWeight = '700';

                forgotPasswordLink.href = '/Identity/Account/ForgotPassword?role=Admin';
            }
        }

        studentRoleBtn.addEventListener('click', () => setRole('Student'));
        adminRoleBtn.addEventListener('click', () => setRole('Admin'));

        setRole('Student');
    </script>
}